use std.testing.assert;
use std.testing.assert_eq_i32;
use src.opus.celt.mode.CELT_MODE_48000_EFF_EBANDS;
use src.opus.celt.mode.CELT_MODE_48000_MAX_LM;
use src.opus.celt.mode.CELT_MODE_48000_NB_ALLOC_VECTORS;
use src.opus.celt.mode.CELT_MODE_48000_NB_EBANDS;
use src.opus.celt.mode.CELT_MODE_48000_NB_SHORT_MDCTS;
use src.opus.celt.mode.CELT_MODE_48000_OVERLAP;
use src.opus.celt.mode.CELT_MODE_48000_SAMPLE_RATE_HZ;
use src.opus.celt.mode.CELT_MODE_48000_SHORT_MDCT_SIZE;
use src.opus.celt.mode.CeltMode;
use src.opus.celt.mode.celt_mode_eband_boundary_5ms;
use src.opus.celt.mode.celt_mode_eband_width_5ms;
use src.opus.celt.mode.celt_mode_48000;
use src.opus.celt.mode.celt_mode_for_sample_rate;

test "celt mode exposes upstream 48k static mode metadata" {
    const mode: CeltMode = celt_mode_48000();
    try assert_eq_i32(mode.sample_rate_hz as i32, 48000);
    try assert_eq_i32(mode.overlap, 120);
    try assert_eq_i32(mode.nb_ebands, 21);
    try assert_eq_i32(mode.eff_ebands, 21);
    try assert_eq_i32(mode.max_lm, 3);
    try assert_eq_i32(mode.nb_short_mdcts, 8);
    try assert_eq_i32(mode.short_mdct_size, 120);
    try assert_eq_i32(mode.nb_alloc_vectors, 11);
}

test "celt mode constants match upstream static mode fields" {
    try assert_eq_i32(CELT_MODE_48000_SAMPLE_RATE_HZ as i32, 48000);
    try assert_eq_i32(CELT_MODE_48000_OVERLAP, 120);
    try assert_eq_i32(CELT_MODE_48000_NB_EBANDS, 21);
    try assert_eq_i32(CELT_MODE_48000_EFF_EBANDS, 21);
    try assert_eq_i32(CELT_MODE_48000_MAX_LM, 3);
    try assert_eq_i32(CELT_MODE_48000_NB_SHORT_MDCTS, 8);
    try assert_eq_i32(CELT_MODE_48000_SHORT_MDCT_SIZE, 120);
    try assert_eq_i32(CELT_MODE_48000_NB_ALLOC_VECTORS, 11);
}

test "celt mode lookup accepts only the static Opus 48k mode for now" {
    const mode: CeltMode = try celt_mode_for_sample_rate(48000);
    try assert_eq_i32(mode.sample_rate_hz as i32, 48000);

    const bad: !CeltMode = celt_mode_for_sample_rate(44100);
    match bad {
        error.CeltModeError => {}
        else => { try assert(false, "unsupported CELT mode must fail"); }
    }
}

test "celt mode eband query exposes 5ms static boundaries" {
    const mode: CeltMode = celt_mode_48000();
    try assert_eq_i32((try celt_mode_eband_boundary_5ms(&mode, 0)) as i32, 0);
    try assert_eq_i32((try celt_mode_eband_boundary_5ms(&mode, 8)) as i32, 8);
    try assert_eq_i32((try celt_mode_eband_boundary_5ms(&mode, 13)) as i32, 20);
    try assert_eq_i32((try celt_mode_eband_boundary_5ms(&mode, 21)) as i32, 100);
    try assert_eq_i32((try celt_mode_eband_width_5ms(&mode, 0)) as i32, 1);
    try assert_eq_i32((try celt_mode_eband_width_5ms(&mode, 20)) as i32, 22);
}

test "celt mode eband query rejects invalid indexes" {
    const mode: CeltMode = celt_mode_48000();
    const negative_boundary: !i16 = celt_mode_eband_boundary_5ms(&mode, -1);
    match negative_boundary {
        error.CeltModeError => {}
        else => { try assert(false, "negative boundary must fail"); }
    }

    const over_boundary: !i16 = celt_mode_eband_boundary_5ms(&mode, 22);
    match over_boundary {
        error.CeltModeError => {}
        else => { try assert(false, "boundary past nb_ebands must fail"); }
    }

    const over_width: !i16 = celt_mode_eband_width_5ms(&mode, 21);
    match over_width {
        error.CeltModeError => {}
        else => { try assert(false, "band past nb_ebands must fail"); }
    }
}
