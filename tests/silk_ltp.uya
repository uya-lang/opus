use std.testing.assert;
use std.testing.assert_eq_i32;
use src.opus.entropy.range_dec.EcDec;
use src.opus.entropy.range_dec.ec_dec_init;
use src.opus.entropy.range_enc.EcEnc;
use src.opus.entropy.range_enc.ec_enc_done;
use src.opus.entropy.range_enc.ec_enc_icdf;
use src.opus.entropy.range_enc.ec_enc_init;
use src.opus.silk.decoder_control.SILK_SIGNAL_TYPE_UNVOICED;
use src.opus.silk.decoder_control.SILK_SIGNAL_TYPE_VOICED;
use src.opus.silk.decoder_control.SilkDecoderControl;
use src.opus.silk.decoder_control.silk_decoder_control_init_from_state;
use src.opus.silk.ltp.SILK_LTP_HISTORY_EXTRA_TAPS;
use src.opus.silk.ltp.SILK_LTP_ORDER;
use src.opus.silk.ltp.silk_ltp_decode_codebook_vector_q14;
use src.opus.silk.ltp.silk_ltp_decode_coefficients_q14;
use src.opus.silk.ltp.silk_ltp_gain_icdf_value;
use src.opus.silk.ltp.silk_ltp_table_hash;
use src.opus.silk.ltp.silk_ltp_table_len;
use src.opus.silk.ltp.silk_ltp_vq_q7;
use src.opus.silk.ltp.silk_ltp_history_index;
use src.opus.silk.ltp.silk_ltp_per_index_icdf_value;
use src.opus.silk.ltp.silk_ltp_scale_history_q15;
use src.opus.silk.ltp.silk_ltp_synthesis_q14;
use src.opus.silk.ltp.silk_ltp_tap_index;
use src.opus.silk.ltp.silk_ltp_validate_pitch_lag;
use src.opus.silk.state.SilkDecoderState;
use src.opus.silk.state.silk_state_init;

test "silk ltp exposes order and history constants" {
    try assert_eq_i32(SILK_LTP_ORDER as i32, 5);
    try assert_eq_i32(SILK_LTP_HISTORY_EXTRA_TAPS as i32, 2);
}

test "silk ltp codebook tables match upstream lengths and hashes" {
    try assert_eq_i32(silk_ltp_table_len(0) as i32, 3);
    try assert_eq_i32(silk_ltp_table_len(1) as i32, 8);
    try assert_eq_i32(silk_ltp_table_len(2) as i32, 16);
    try assert_eq_i32(silk_ltp_table_len(3) as i32, 32);
    try assert_eq_i32(silk_ltp_table_len(4) as i32, 40);
    try assert_eq_i32(silk_ltp_table_len(5) as i32, 80);
    try assert_eq_i32(silk_ltp_table_len(6) as i32, 160);
    try assert_eq_i32(silk_ltp_per_index_icdf_value(0) as i32, 179);
    try assert_eq_i32(silk_ltp_gain_icdf_value(2, 31) as i32, 0);
    try assert_eq_i32(silk_ltp_vq_q7(0, 0, 2) as i32, 24);
    try assert_eq_i32(silk_ltp_vq_q7(1, 11, 2) as i32, 101);
    try assert_eq_i32(silk_ltp_vq_q7(2, 29, 4) as i32, -24);
    try assert_eq_i32(silk_ltp_table_hash(0) as i32, 402142135);
    try assert_eq_i32(silk_ltp_table_hash(4) as i32, 538968179);
    try assert_eq_i32(silk_ltp_table_hash(6) as i32, 297113135);
}

test "silk ltp validates pitch lags against decoder sampling rate" {
    try silk_ltp_validate_pitch_lag(16, 32);
    try silk_ltp_validate_pitch_lag(16, 288);
    try silk_ltp_validate_pitch_lag(8, 16);
    try silk_ltp_validate_pitch_lag(12, 216);

    const too_short: !void = silk_ltp_validate_pitch_lag(16, 31);
    match too_short {
        error.SilkLtpError => {}
        else => { try assert(false, "pitch lag below 2 ms must be rejected"); }
    }

    const bad_rate: !void = silk_ltp_validate_pitch_lag(24, 48);
    match bad_rate {
        error.SilkLtpError => {}
        else => { try assert(false, "unsupported SILK fs_khz must be rejected"); }
    }
}

test "silk ltp maps channel subframe tap indices" {
    try assert_eq_i32((try silk_ltp_tap_index(0, 0, 0, 2, 4)) as i32, 0);
    try assert_eq_i32((try silk_ltp_tap_index(0, 3, 4, 2, 4)) as i32, 19);
    try assert_eq_i32((try silk_ltp_tap_index(1, 2, 3, 2, 4)) as i32, 33);

    const bad_tap: !usize = silk_ltp_tap_index(0, 0, 5, 1, 4);
    match bad_tap {
        error.SilkLtpError => {}
        else => { try assert(false, "tap past LTP_ORDER must be rejected"); }
    }
}

test "silk ltp maps pitch-relative q15 history slots" {
    try assert_eq_i32((try silk_ltp_history_index(100, 20, 0)) as i32, 82);
    try assert_eq_i32((try silk_ltp_history_index(100, 20, 4)) as i32, 78);

    const too_far: !usize = silk_ltp_history_index(20, 20, 4);
    match too_far {
        error.SilkLtpError => {}
        else => { try assert(false, "history index before buffer start must fail"); }
    }
}

test "silk ltp scales q15 history by q16 gain adjustment" {
    var history_q15: [i32: 6] = [65536, -32768, 16384, -8192, 4096, -2048];
    try silk_ltp_scale_history_q15(&history_q15[0:6], 6, 32768);

    try assert_eq_i32(history_q15[0], 32768);
    try assert_eq_i32(history_q15[1], -16384);
    try assert_eq_i32(history_q15[2], 8192);
    try assert_eq_i32(history_q15[5], -1024);
}

test "silk ltp decodes codebook vectors to q14 taps" {
    var out_q14: [i16: 5] = [0: 5];
    try silk_ltp_decode_codebook_vector_q14(&out_q14[0:5], 2, 30);

    try assert_eq_i32(out_q14[0] as i32, 10368);
    try assert_eq_i32(out_q14[1] as i32, 640);
    try assert_eq_i32(out_q14[2] as i32, 1408);
    try assert_eq_i32(out_q14[3] as i32, 384);
    try assert_eq_i32(out_q14[4] as i32, 896);

    const bad_periodicity: !void = silk_ltp_decode_codebook_vector_q14(&out_q14[0:5], 3, 0);
    match bad_periodicity {
        error.SilkLtpError => {}
        else => { try assert(false, "invalid LTP periodicity index must fail"); }
    }

    const bad_index: !void = silk_ltp_decode_codebook_vector_q14(&out_q14[0:5], 0, 8);
    match bad_index {
        error.SilkLtpError => {}
        else => { try assert(false, "codebook index past selected LTP table must fail"); }
    }
}

test "silk ltp decodes entropy-coded coefficients into decoder control" {
    var packet: [byte: 64] = [0: 64];
    var enc: EcEnc = EcEnc{};
    ec_enc_init(&enc, &packet[0:64]);
    var per_icdf: [byte: 3] = [0: 3];
    var gain_icdf: [byte: 32] = [0: 32];
    var i: usize = 0;
    while i < 3 {
        per_icdf[i] = silk_ltp_per_index_icdf_value(i);
        i = i + 1;
    }
    i = 0;
    while i < 32 {
        gain_icdf[i] = silk_ltp_gain_icdf_value(2, i);
        i = i + 1;
    }

    ec_enc_icdf(&enc, 2, &per_icdf[0:3], 8);
    ec_enc_icdf(&enc, 0, &gain_icdf[0:32], 8);
    ec_enc_icdf(&enc, 7, &gain_icdf[0:32], 8);
    ec_enc_icdf(&enc, 18, &gain_icdf[0:32], 8);
    ec_enc_icdf(&enc, 31, &gain_icdf[0:32], 8);
    _ = try ec_enc_done(&enc);

    var state: SilkDecoderState = SilkDecoderState{};
    try silk_state_init(&state, 2, 16000, 20);
    var control: SilkDecoderControl = SilkDecoderControl{};
    try silk_decoder_control_init_from_state(&control, &state);
    control.signal_type = SILK_SIGNAL_TYPE_VOICED;

    var dec: EcDec = EcDec{};
    ec_dec_init(&dec, &packet[0:64]);
    const periodicity_index: i32 = try silk_ltp_decode_coefficients_q14(&dec, &control, 1);

    try assert_eq_i32(periodicity_index, 2);
    try assert_eq_i32(control.ltp_coef_q14[20] as i32, -768);
    try assert_eq_i32(control.ltp_coef_q14[22] as i32, 7808);
    try assert_eq_i32(control.ltp_coef_q14[25] as i32, 384);
    try assert_eq_i32(control.ltp_coef_q14[27] as i32, 1664);
    try assert_eq_i32(control.ltp_coef_q14[32] as i32, 5376);
    try assert_eq_i32(control.ltp_coef_q14[39] as i32, 11264);
    try assert_eq_i32(control.ltp_coef_q14[0] as i32, 0);
}

test "silk ltp coefficient decode rejects unvoiced control" {
    var packet: [byte: 8] = [0: 8];
    var dec: EcDec = EcDec{};
    ec_dec_init(&dec, &packet[0:8]);
    var state: SilkDecoderState = SilkDecoderState{};
    try silk_state_init(&state, 1, 8000, 20);
    var control: SilkDecoderControl = SilkDecoderControl{};
    try silk_decoder_control_init_from_state(&control, &state);
    control.signal_type = SILK_SIGNAL_TYPE_UNVOICED;

    const result: !i32 = silk_ltp_decode_coefficients_q14(&dec, &control, 0);
    match result {
        error.SilkLtpError => {}
        else => { try assert(false, "LTP coefficient decode is only valid for voiced frames"); }
    }
}

test "silk ltp synthesis adds long-term prediction to q14 excitation" {
    var history_q15: [i32: 40] = [0: 40];
    var i: usize = 0;
    while i < 40 {
        history_q15[i] = ((i as i32) - 20) * 4096;
        i = i + 1;
    }
    var excitation_q14: [i32: 6] = [16000, -8000, 4800, 0, 19200, -11200];
    var coeff_q14: [i16: 5] = [4096, -2048, 1024, -512, 256];
    var out_q14: [i32: 6] = [0: 6];

    try silk_ltp_synthesis_q14(&out_q14[0:6], &history_q15[0:40], &excitation_q14[0:6], &coeff_q14[0:5], 20, 6, 6);

    try assert_eq_i32(out_q14[0], 14660);
    try assert_eq_i32(out_q14[1], -8988);
    try assert_eq_i32(out_q14[2], 4164);
    try assert_eq_i32(out_q14[3], -284);
    try assert_eq_i32(out_q14[4], 22932);
    try assert_eq_i32(out_q14[5], -15374);
    try assert_eq_i32(history_q15[20], 29320);
    try assert_eq_i32(history_q15[25], -30748);
}

test "silk ltp synthesis consumes generated history and validates bounds" {
    var history_q15: [i32: 20] = [0: 20];
    history_q15[7] = 100000;
    history_q15[6] = -50000;
    history_q15[5] = 25000;
    history_q15[4] = -12500;
    history_q15[3] = 6250;
    var excitation_q14: [i32: 3] = [0, 0, 0];
    var coeff_q14: [i16: 5] = [8192, 8192, 0, 0, 0];
    var out_q14: [i32: 3] = [0: 3];

    try silk_ltp_synthesis_q14(&out_q14[0:3], &history_q15[0:20], &excitation_q14[0:3], &coeff_q14[0:5], 10, 5, 3);

    try assert_eq_i32(out_q14[0], 12504);
    try assert_eq_i32(out_q14[1], 25004);
    try assert_eq_i32(out_q14[2], 4);
    try assert_eq_i32(history_q15[10], 25008);
    try assert_eq_i32(history_q15[11], 50008);
    try assert_eq_i32(history_q15[12], 8);

    const too_early: !void = silk_ltp_synthesis_q14(&out_q14[0:3], &history_q15[0:20], &excitation_q14[0:3], &coeff_q14[0:5], 2, 5, 3);
    match too_early {
        error.SilkLtpError => {}
        else => { try assert(false, "LTP synthesis must reject history reads before buffer start"); }
    }

    const too_short: !void = silk_ltp_synthesis_q14(&out_q14[0:3], &history_q15[0:20], &excitation_q14[0:3], &coeff_q14[0:5], 18, 5, 3);
    match too_short {
        error.SilkLtpError => {}
        else => { try assert(false, "LTP synthesis must reject history writes past buffer end"); }
    }
}
