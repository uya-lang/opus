use std.testing.assert;
use std.testing.assert_eq_i32;
use src.opus.entropy.range_dec.EcDec;
use src.opus.entropy.range_dec.ec_dec_bit_logp;
use src.opus.entropy.range_dec.ec_dec_bits;
use src.opus.entropy.range_dec.ec_dec_check;
use src.opus.entropy.range_dec.ec_dec_icdf;
use src.opus.entropy.range_dec.ec_dec_init;
use src.opus.entropy.range_dec.ec_dec_uint;
use src.opus.entropy.range_dec.ec_dec_update;
use src.opus.entropy.range_dec.ec_decode;
use src.opus.entropy.range_dec.ec_decode_bin;
use src.opus.entropy.range_dec.ec_ilog;
use src.opus.entropy.range_dec.ec_tell;
use src.opus.entropy.range_dec.ec_tell_frac;

fn assert_tell_frac_reference(rng: u32, expected: i32) !void {
    var dec: EcDec = EcDec{};
    dec.nbits_total = 77;
    dec.rng = rng;
    try assert_eq_i32(ec_tell_frac(&dec) as i32, expected);
}

test "range decoder initializes and reports fractional tell state" {
    const packet: [byte: 16] = [139, 165, 14, 64, 0, 0, 0, 0, 0, 0, 0, 0, 0, 10, 174, 168];
    var dec: EcDec = EcDec{};
    ec_dec_init(&dec, &packet[0:16]);

    try assert_eq_i32(ec_tell(&dec) as i32, 1);
    try assert_eq_i32(ec_tell_frac(&dec) as i32, 8);
    try ec_dec_check(&dec);
}

test "range decoder decodes mixed symbols from an Opus-compatible vector" {
    const packet: [byte: 16] = [139, 165, 14, 64, 0, 0, 0, 0, 0, 0, 0, 0, 0, 10, 174, 168];
    const icdf: [byte: 4] = [200, 100, 40, 0];
    var dec: EcDec = EcDec{};
    ec_dec_init(&dec, &packet[0:16]);

    const s0: u32 = ec_decode(&dec, 5);
    try assert_eq_i32(s0 as i32, 2);
    ec_dec_update(&dec, s0, s0 + 1, 5);
    try assert_eq_i32(ec_tell(&dec) as i32, 4);
    try assert_eq_i32(ec_tell_frac(&dec) as i32, 27);

    const s1: u32 = ec_decode_bin(&dec, 3);
    try assert_eq_i32(s1 as i32, 5);
    ec_dec_update(&dec, s1, s1 + 1, 8);
    try assert_eq_i32(ec_tell(&dec) as i32, 7);
    try assert_eq_i32(ec_tell_frac(&dec) as i32, 51);

    try assert_eq_i32(ec_dec_icdf(&dec, &icdf[0:4], 8), 2);
    try assert_eq_i32(ec_dec_bit_logp(&dec, 3), 1);
    try assert_eq_i32(ec_dec_uint(&dec, 100) as i32, 17);
    try assert_eq_i32(ec_dec_uint(&dec, 5000) as i32, 1000);
    try assert_eq_i32(ec_dec_bits(&dec, 5) as i32, 21);
    try assert_eq_i32(ec_dec_bits(&dec, 10) as i32, 683);
    try assert_eq_i32(ec_tell(&dec) as i32, 46);
    try assert_eq_i32(ec_tell_frac(&dec) as i32, 363);
    try ec_dec_check(&dec);
}

test "range decoder fractional tell matches upstream correction-boundary vectors" {
    try assert_tell_frac_reference(0x00800001, 424);
    try assert_tell_frac_reference(0x00ffffff, 417);
    try assert_tell_frac_reference(0x01000000, 416);
    try assert_tell_frac_reference(0x03500000, 403);
    try assert_tell_frac_reference(0x08000000, 392);
    try assert_tell_frac_reference(0x10000000, 384);
    try assert_tell_frac_reference(0x40000000, 368);
    try assert_tell_frac_reference(0x7fffffff, 361);

    try assert_tell_frac_reference(0x45ca8000, 368);
    try assert_tell_frac_reference(0x45cb0000, 367);
    try assert_tell_frac_reference(0x4c1b8000, 367);
    try assert_tell_frac_reference(0x4c1c0000, 366);
    try assert_tell_frac_reference(0x52ff8000, 366);
    try assert_tell_frac_reference(0x53000000, 365);
    try assert_tell_frac_reference(0x5a820000, 365);
    try assert_tell_frac_reference(0x5a828000, 364);
    try assert_tell_frac_reference(0x62b38000, 364);
    try assert_tell_frac_reference(0x62b40000, 363);
    try assert_tell_frac_reference(0x6ba28000, 363);
    try assert_tell_frac_reference(0x6ba30000, 362);
    try assert_tell_frac_reference(0x75608000, 362);
    try assert_tell_frac_reference(0x75610000, 361);
    try assert_tell_frac_reference(0x7fff8000, 361);
    try assert_tell_frac_reference(0x80000000, 360);
}

test "range decoder flags truncated input through ec_dec_check" {
    const truncated: [byte: 1] = [139];
    var dec: EcDec = EcDec{};
    ec_dec_init(&dec, &truncated[0:1]);

    const result: !void = ec_dec_check(&dec);
    match result {
        error.EntropyDecoderError => {}
        else => { try assert(false, "truncated entropy stream must be reported"); }
    }
}

test "range decoder validates invalid public parameters without error unions on hot APIs" {
    const packet: [byte: 16] = [139, 165, 14, 64, 0, 0, 0, 0, 0, 0, 0, 0, 0, 10, 174, 168];
    var dec: EcDec = EcDec{};
    ec_dec_init(&dec, &packet[0:16]);

    try assert_eq_i32(ec_ilog(0) as i32, 0);
    try assert_eq_i32(ec_ilog(1) as i32, 1);
    try assert_eq_i32(ec_ilog(255) as i32, 8);
    _ = ec_decode(&dec, 0);

    const result: !void = ec_dec_check(&dec);
    match result {
        error.EntropyDecoderError => {}
        else => { try assert(false, "invalid entropy parameters must set state error"); }
    }
}
