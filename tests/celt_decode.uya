    var scratch: CeltMonoDecodeScratch = CeltMonoDecodeScratch{};

    try assert_eq_i32((try celt_decode_stereo_i16(&state, &frame0[0:346], &pcm[0:1920], &scratch)) as i32, 960);
    try celt_state_configure_frame(&state, 960, 0, 21);
    try assert_eq_i32((try celt_decode_stereo_i16(&state, &frame1[0:189], &pcm[0:1920], &scratch)) as i32, 960);
    try celt_state_configure_frame(&state, 960, 0, 21);
    try assert_eq_i32((try celt_decode_stereo_i16(&state, &frame2[0:191], &pcm[0:1920], &scratch)) as i32, 960);
}

test "celt mono decode preserves overlap and energy state across calls" {
    var state: CeltDecoderState = CeltDecoderState{};
    try celt_state_init(&state, 1);
    try celt_state_configure_frame(&state, 120, 0, 3);
    var payload: [byte: 64] = [0: 64];
    var pcm: [i16: 120] = [0: 120];
    var scratch: CeltMonoDecodeScratch = CeltMonoDecodeScratch{};

    _ = try celt_decode_mono_i16(&state, &payload[0:64], &pcm[0:120], &scratch);
    const first_energy: i16 = state.old_band_e_q8[0];
    const first_overlap: i16 = state.overlap_mem_q15[0];
    _ = try celt_decode_mono_i16(&state, &payload[0:64], &pcm[0:120], &scratch);

    try assert(state.old_loge_q8[0] == state.old_ebands_q8[0], "decode must publish log energy history");
    try assert(state.old_band_e_q8[0] == state.old_ebands_q8[0], "decode must publish band energy history");
    try assert(first_energy != state.old_band_e_q8[0] || first_overlap == state.overlap_mem_q15[0] || scratch.twiddle_ready, "stateful decode path must remain reusable");
}

test "celt stereo decode writes interleaved pcm and updates both channel states" {
    var state: CeltDecoderState = CeltDecoderState{};
    try celt_state_init(&state, 2);
    try celt_state_configure_frame(&state, 120, 0, 3);
    var payload: [byte: 128] = [0: 128];
    var pcm: [i16: 240] = [321: 240];
    var scratch: CeltMonoDecodeScratch = CeltMonoDecodeScratch{};

    const decoded: usize = try celt_decode_stereo_i16(&state, &payload[0:128], &pcm[0:240], &scratch);

    try assert_eq_i32(decoded as i32, 120);
    try assert(scratch.twiddle_ready, "stereo decode must reuse cached scalar IMDCT twiddles");
    try assert(state.loss_count == 0, "successful stereo decode clears CELT loss count");
    try assert(state.freq_history_ready, "successful stereo decode must publish frequency-domain PLC history");
    try assert(state.old_loge_q8[0] == state.old_ebands_q8[0], "left channel log energy must be published");
    try assert(state.old_loge_q8[21] == state.old_ebands_q8[21], "right channel log energy must be published");
    try assert(pcm[0] != 321 || pcm[1] != 321 || pcm[238] != 321 || pcm[239] != 321, "stereo decode must write interleaved output samples");
}

test "celt stereo decode rejects mono state and short output" {
    var mono: CeltDecoderState = CeltDecoderState{};
    try celt_state_init(&mono, 1);
    try celt_state_configure_frame(&mono, 120, 0, 3);
    var payload: [byte: 16] = [0: 16];
    var pcm: [i16: 240] = [0: 240];
    var scratch: CeltMonoDecodeScratch = CeltMonoDecodeScratch{};

    const bad_channels: !usize = celt_decode_stereo_i16(&mono, &payload[0:16], &pcm[0:240], &scratch);
    match bad_channels {
        error.CeltDecodeError => {}
        else => { try assert(false, "stereo decode must reject mono state"); }
    };

    var stereo: CeltDecoderState = CeltDecoderState{};
    try celt_state_init(&stereo, 2);
    try celt_state_configure_frame(&stereo, 120, 0, 3);
    const short_output: !usize = celt_decode_stereo_i16(&stereo, &payload[0:16], &pcm[0:120], &scratch);
    match short_output {
        error.CeltDecodeError => {}
        else => { try assert(false, "stereo decode must require interleaved frame capacity"); }
    };
}

fn assert_decode_bandwidth(bandwidth: OpusBandwidth, expected_end_band: i32) !void {
    if expected_end_band <= 0 || expected_end_band > 21 {
        return error.CeltDecodeError;
    }

    var mono: CeltDecoderState = CeltDecoderState{};
    try celt_state_init(&mono, 1);
    const mono_end_band: i32 = try celt_mode_end_band_for_bandwidth(&mono.mode, bandwidth);
    try assert_eq_i32(mono_end_band, expected_end_band);
    try celt_state_configure_frame(&mono, 120, 0, mono_end_band);

    var mono_payload: [byte: 64] = [0: 64];
    var mono_pcm: [i16: 120] = [77: 120];
    var scratch: CeltMonoDecodeScratch = CeltMonoDecodeScratch{};
    const mono_decoded: usize = try celt_decode_mono_i16(&mono, &mono_payload[0:64], &mono_pcm[0:120], &scratch);
    try assert_eq_i32(mono_decoded as i32, 120);
    try assert_eq_i32(mono.end_band, expected_end_band);
    const mono_top_index: usize = (expected_end_band - 1) as usize;
    if mono_top_index >= 42 {
        return error.CeltDecodeError;
    }
    try assert(mono.old_loge_q8[mono_top_index] == mono.old_ebands_q8[mono_top_index], "mono decode must update the active top band");

    var stereo: CeltDecoderState = CeltDecoderState{};
    try celt_state_init(&stereo, 2);
    const stereo_end_band: i32 = try celt_mode_end_band_for_bandwidth(&stereo.mode, bandwidth);
    try assert_eq_i32(stereo_end_band, expected_end_band);
    try celt_state_configure_frame(&stereo, 120, 0, stereo_end_band);

    var stereo_payload: [byte: 128] = [0: 128];
    var stereo_pcm: [i16: 240] = [88: 240];
    const stereo_decoded: usize = try celt_decode_stereo_i16(&stereo, &stereo_payload[0:128], &stereo_pcm[0:240], &scratch);
    try assert_eq_i32(stereo_decoded as i32, 120);
    try assert_eq_i32(stereo.end_band, expected_end_band);
    const right_top_index: usize = (21 + expected_end_band - 1) as usize;
    if right_top_index >= 42 {
        return error.CeltDecodeError;
    }
    try assert(stereo.old_loge_q8[right_top_index] == stereo.old_ebands_q8[right_top_index], "stereo decode must update the active right top band");
}

test "celt decode supports NB active band range" {
    try assert_decode_bandwidth(OpusBandwidth.NARROWBAND, 13);
}

test "celt decode supports WB active band range" {
    try assert_decode_bandwidth(OpusBandwidth.WIDEBAND, 17);
}

test "celt decode supports SWB active band range" {
    try assert_decode_bandwidth(OpusBandwidth.SUPERWIDEBAND, 19);
}

test "celt decode supports FB active band range" {
    try assert_decode_bandwidth(OpusBandwidth.FULLBAND, 21);
}

test "celt mono decode supports 5ms frames" {
    var state: CeltDecoderState = CeltDecoderState{};
    try celt_state_init(&state, 1);
    try celt_state_configure_frame(&state, 240, 0, 21);

    var payload: [byte: 96] = [0: 96];
    var pcm: [i16: 240] = [55: 240];
    var scratch: CeltMonoDecodeScratch = CeltMonoDecodeScratch{};

    const decoded: usize = try celt_decode_mono_i16(&state, &payload[0:96], &pcm[0:240], &scratch);

    try assert_eq_i32(decoded as i32, 240);
    try assert_eq_i32(state.lm, 1);
    try assert_eq_i32(scratch.twiddle_imdct_len, 480);
    try assert(state.old_loge_q8[20] == state.old_ebands_q8[20], "5ms mono decode must update fullband energy state");
    try assert(pcm[239] != 55, "5ms mono decode must write the whole output frame");
}

test "celt stereo decode supports 5ms interleaved frames" {
    var state: CeltDecoderState = CeltDecoderState{};
    try celt_state_init(&state, 2);
    try celt_state_configure_frame(&state, 240, 0, 21);

    var payload: [byte: 192] = [0: 192];
    var pcm: [i16: 480] = [66: 480];
    var scratch: CeltMonoDecodeScratch = CeltMonoDecodeScratch{};

    const decoded: usize = try celt_decode_stereo_i16(&state, &payload[0:192], &pcm[0:480], &scratch);

    try assert_eq_i32(decoded as i32, 240);
    try assert_eq_i32(state.lm, 1);
    try assert_eq_i32(scratch.twiddle_imdct_len, 480);
    try assert(state.old_loge_q8[20] == state.old_ebands_q8[20], "5ms stereo decode must update left fullband energy state");
    try assert(state.old_loge_q8[41] == state.old_ebands_q8[41], "5ms stereo decode must update right fullband energy state");
    try assert(pcm[478] != 66 && pcm[479] != 66, "5ms stereo decode must write interleaved output");
}

test "celt mono decode supports 10ms frames" {
    var state: CeltDecoderState = CeltDecoderState{};
    try celt_state_init(&state, 1);
    try celt_state_configure_frame(&state, 480, 0, 21);

    var payload: [byte: 160] = [0: 160];
    var pcm: [i16: 480] = [44: 480];
    var scratch: CeltMonoDecodeScratch = CeltMonoDecodeScratch{};

    const decoded: usize = try celt_decode_mono_i16(&state, &payload[0:160], &pcm[0:480], &scratch);

    try assert_eq_i32(decoded as i32, 480);
    try assert_eq_i32(state.lm, 2);
    try assert_eq_i32(scratch.twiddle_imdct_len, 960);
    try assert(state.old_loge_q8[20] == state.old_ebands_q8[20], "10ms mono decode must update fullband energy state");
    try assert(pcm[479] != 44, "10ms mono decode must write the whole output frame");
}

test "celt stereo decode supports 10ms interleaved frames" {
    var state: CeltDecoderState = CeltDecoderState{};
    try celt_state_init(&state, 2);
    try celt_state_configure_frame(&state, 480, 0, 21);

    var payload: [byte: 320] = [0: 320];
    var pcm: [i16: 960] = [33: 960];
    var scratch: CeltMonoDecodeScratch = CeltMonoDecodeScratch{};

    const decoded: usize = try celt_decode_stereo_i16(&state, &payload[0:320], &pcm[0:960], &scratch);

    try assert_eq_i32(decoded as i32, 480);
    try assert_eq_i32(state.lm, 2);
    try assert_eq_i32(scratch.twiddle_imdct_len, 960);
    try assert(state.old_loge_q8[20] == state.old_ebands_q8[20], "10ms stereo decode must update left fullband energy state");
    try assert(state.old_loge_q8[41] == state.old_ebands_q8[41], "10ms stereo decode must update right fullband energy state");
    try assert(pcm[958] != 33 && pcm[959] != 33, "10ms stereo decode must write interleaved output");
}

test "celt mono decode supports 20ms frames" {
    var state: CeltDecoderState = CeltDecoderState{};
    try celt_state_init(&state, 1);
    try celt_state_configure_frame(&state, 960, 0, 21);

    var payload: [byte: 320] = [0: 320];
    var pcm: [i16: 960] = [22: 960];
    var scratch: CeltMonoDecodeScratch = CeltMonoDecodeScratch{};

    const decoded: usize = try celt_decode_mono_i16(&state, &payload[0:320], &pcm[0:960], &scratch);

    try assert_eq_i32(decoded as i32, 960);
    try assert_eq_i32(state.lm, 3);
    try assert_eq_i32(scratch.twiddle_imdct_len, 1920);
    try assert(state.old_loge_q8[20] == state.old_ebands_q8[20], "20ms mono decode must update fullband energy state");
    try assert(pcm[959] != 22, "20ms mono decode must write the whole output frame");
}

test "celt stereo decode supports 20ms interleaved frames" {
    var state: CeltDecoderState = CeltDecoderState{};
    try celt_state_init(&state, 2);
    try celt_state_configure_frame(&state, 960, 0, 21);

    var payload: [byte: 640] = [0: 640];
    var pcm: [i16: 1920] = [11: 1920];
    var scratch: CeltMonoDecodeScratch = CeltMonoDecodeScratch{};

    const decoded: usize = try celt_decode_stereo_i16(&state, &payload[0:640], &pcm[0:1920], &scratch);

    try assert_eq_i32(decoded as i32, 960);
    try assert_eq_i32(state.lm, 3);
    try assert_eq_i32(scratch.twiddle_imdct_len, 1920);
    try assert(state.old_loge_q8[20] == state.old_ebands_q8[20], "20ms stereo decode must update left fullband energy state");
    try assert(state.old_loge_q8[41] == state.old_ebands_q8[41], "20ms stereo decode must update right fullband energy state");
    try assert(pcm[1918] != 11 && pcm[1919] != 11, "20ms stereo decode must write interleaved output");
}

fn celt_decode_random_packet_once(packet: &[byte], scratch: &CeltMonoDecodeScratch) !void {
    var parsed: PacketParseResult = PacketParseResult{};
    try parse_packet(packet, &parsed);
    if parsed.info.mode != OpusMode.CELT || parsed.info.frame_count != 1 {
        return error.CeltDecodeError;
    }

    var state: CeltDecoderState = CeltDecoderState{};
    try celt_state_init(&state, parsed.info.channels as i32);
    const end_band: i32 = try celt_mode_end_band_for_bandwidth(&state.mode, parsed.info.bandwidth);
    try celt_state_configure_frame(&state, parsed.info.duration_samples_48k as i32, 0, end_band);

    var pcm: [i16: 1920] = [0: 1920];
    const frame: &[byte] = &packet[parsed.frames[0].offset:parsed.frames[0].len];
    if parsed.info.channels == 1 {
        const res_mono: !usize = celt_decode_mono_i16(&state, frame, &pcm[0:(parsed.info.duration_samples_48k as usize)], scratch);
        match res_mono {
            error.CeltDecodeError => {}
            else => {
                const decoded: usize = try res_mono;
                try assert_eq_i32(decoded as i32, parsed.info.duration_samples_48k as i32);
            }
        };
        return;
    }

    const samples: usize = (parsed.info.duration_samples_48k as usize) * 2;
    const res_stereo: !usize = celt_decode_stereo_i16(&state, frame, &pcm[0:samples], scratch);
    match res_stereo {
        error.CeltDecodeError => {}
        else => {
            const decoded: usize = try res_stereo;
            try assert_eq_i32(decoded as i32, parsed.info.duration_samples_48k as i32);
        }
    };
}

test "celt decode handles random legal CELT packets without crashing" {
    var packet: [byte: 161] = [0: 161];
    var rng: u32 = 0x12345678;
    var scratch: CeltMonoDecodeScratch = CeltMonoDecodeScratch{};
    var i: usize = 0;
    while i < 96 {
        rng = rng * 1664525 + 1013904223;
        const config_index: u32 = (16 as u32) + ((rng >> 24) % (16 as u32));
        const config: byte = ((config_index << (3 as u32)) as! byte).value;
        const stereo_bit: byte = (((rng >> 7) & (1 as u32)) as! byte).value * 4;
        packet[0] = config | stereo_bit;

        rng = rng * 1664525 + 1013904223;
        const payload_len: usize = 1 + (((rng >> 24) as usize) % (160 as usize));
        var j: usize = 0;
        while j < payload_len {
            rng = rng * 1664525 + 1013904223;
            packet[1 + j] = ((rng >> 24) as! byte).value;
            j = j + 1;
        }

        try celt_decode_random_packet_once(&packet[0:(payload_len + 1)], &scratch);
        i = i + 1;
    }
}

test "celt decode remains state-stable across a lost frame" {
    var state: CeltDecoderState = CeltDecoderState{};
    try celt_state_init(&state, 2);
    try celt_state_configure_frame(&state, 480, 0, 21);

    var payload: [byte: 320] = [0: 320];
    var pcm: [i16: 960] = [0: 960];
    var scratch: CeltMonoDecodeScratch = CeltMonoDecodeScratch{};

    _ = try celt_decode_stereo_i16(&state, &payload[0:320], &pcm[0:960], &scratch);
    state.old_ebands_q8[0] = 100;
    state.old_loge_q8[21] = -80;
    state.overlap_mem_q15[0] = 1200;
    state.preemph_mem_q15[1] = -6000;

    try celt_state_mark_lost_frame(&state);
    try assert_eq_i32(state.loss_count, 1);
    try assert_eq_i32(state.old_ebands_q8[0] as i32, 50);
    try assert_eq_i32(state.old_loge_q8[21] as i32, -40);
    try assert_eq_i32(state.overlap_mem_q15[0] as i32, 600);
    try assert_eq_i32(state.preemph_mem_q15[1], -3000);

    _ = try celt_decode_stereo_i16(&state, &payload[0:320], &pcm[0:960], &scratch);
    try assert_eq_i32(state.loss_count, 0);
    try assert(state.old_loge_q8[20] == state.old_ebands_q8[20], "normal decode after loss must republish left energy history");
    try assert(state.old_loge_q8[41] == state.old_ebands_q8[41], "normal decode after loss must republish right energy history");
}

test "celt mono decode rejects unsupported current configurations" {
    var stereo: CeltDecoderState = CeltDecoderState{};
    try celt_state_init(&stereo, 2);
    try celt_state_configure_frame(&stereo, 120, 0, 3);
    var payload: [byte: 8] = [0: 8];
    var pcm: [i16: 120] = [0: 120];
    var scratch: CeltMonoDecodeScratch = CeltMonoDecodeScratch{};

    const bad_channels: !usize = celt_decode_mono_i16(&stereo, &payload[0:8], &pcm[0:120], &scratch);
    match bad_channels {
        error.CeltDecodeError => {}
        else => { try assert(false, "mono decode must reject stereo state"); }
    };

    var mono: CeltDecoderState = CeltDecoderState{};
    try celt_state_init(&mono, 1);
    try celt_state_configure_frame(&mono, 960, 0, 3);
    const bad_duration: !usize = celt_decode_mono_i16(&mono, &payload[0:8], &pcm[0:120], &scratch);
    match bad_duration {
        error.CeltDecodeError => {}
        else => { try assert(false, "mono decode must reject output shorter than the configured frame"); }
    };
}
