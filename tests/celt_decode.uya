test "celt stereo decode accepts RFC8251 testvector01 fourth packet frames in order" {
    var state: CeltDecoderState = CeltDecoderState{};
    try celt_state_init(&state, 2);
    try celt_state_configure_frame(&state, 960, 0, 21);

    var frame0: [byte: 192] = RFC8251_TESTVECTOR01_PACKET3_FRAME0;
    var frame1: [byte: 194] = RFC8251_TESTVECTOR01_PACKET3_FRAME1;
    var frame2: [byte: 193] = RFC8251_TESTVECTOR01_PACKET3_FRAME2;
    var frame3: [byte: 195] = RFC8251_TESTVECTOR01_PACKET3_FRAME3;
    var frame4: [byte: 196] = RFC8251_TESTVECTOR01_PACKET3_FRAME4;
    var pcm: [i16: 1920] = [0: 1920];
    var scratch: CeltMonoDecodeScratch = CeltMonoDecodeScratch{};

    const decoded0: !usize = celt_decode_stereo_i16(&state, &frame0[0:192], &pcm[0:1920], &scratch);
    match decoded0 {
        count => { try assert_eq_i32(count as i32, 960); }
        error.CeltDecodeError => { try assert(false, "fourth packet frame 0 must decode"); }
    };
    try celt_state_configure_frame(&state, 960, 0, 21);
    const decoded1: !usize = celt_decode_stereo_i16(&state, &frame1[0:194], &pcm[0:1920], &scratch);
    match decoded1 {
        count => { try assert_eq_i32(count as i32, 960); }
        error.CeltDecodeError => { try assert(false, "fourth packet frame 1 must decode"); }
    };
    try celt_state_configure_frame(&state, 960, 0, 21);
    const decoded2: !usize = celt_decode_stereo_i16(&state, &frame2[0:193], &pcm[0:1920], &scratch);
    match decoded2 {
        count => { try assert_eq_i32(count as i32, 960); }
        error.CeltDecodeError => { try assert(false, "fourth packet frame 2 must decode"); }
    };
    try celt_state_configure_frame(&state, 960, 0, 21);
    const decoded3: !usize = celt_decode_stereo_i16(&state, &frame3[0:195], &pcm[0:1920], &scratch);
    match decoded3 {
        count => { try assert_eq_i32(count as i32, 960); }
        error.CeltDecodeError => { try assert(false, "fourth packet frame 3 must decode"); }
    };
    try celt_state_configure_frame(&state, 960, 0, 21);
    const decoded4: !usize = celt_decode_stereo_i16(&state, &frame4[0:196], &pcm[0:1920], &scratch);
    match decoded4 {
        count => { try assert_eq_i32(count as i32, 960); }
        error.CeltDecodeError => { try assert(false, "fourth packet frame 4 must decode"); }
    };
}

