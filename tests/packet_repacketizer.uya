use std.testing.assert;
use std.testing.assert_eq_i32;
use src.opus.core.types.PacketInfo;
use src.opus.packet.repacketizer.Repacketizer;
use src.opus.packet.repacketizer.repacketizer_add_packet;
use src.opus.packet.repacketizer.repacketizer_duration_samples_48k;
use src.opus.packet.repacketizer.repacketizer_duration_us;
use src.opus.packet.repacketizer.repacketizer_frame_count;
use src.opus.packet.repacketizer.repacketizer_init;
use src.opus.packet.repacketizer.repacketizer_is_empty;
use src.opus.packet.repacketizer.repacketizer_output_padded_packet;
use src.opus.packet.repacketizer.repacketizer_output_packet;
use src.opus.packet.repacketizer.repacketizer_payload_bytes;
use src.opus.packet.repacketizer.repacketizer_remove_padding;
use src.opus.packet.repacketizer.repacketizer_reset;
use src.opus.packet.toc.PacketParseResult;
use src.opus.packet.toc.decoder_get_packet_info;
use src.opus.packet.toc.parse_packet;

fn assert_byte_eq(actual: byte, expected: i32) !void {
    try assert_eq_i32(actual as i32, expected);
}

test "repacketizer initializes as an empty packet builder" {
    var rp: Repacketizer = Repacketizer{};
    try repacketizer_init(&rp);

    try assert(repacketizer_is_empty(&rp), "new repacketizer must start empty");
    try assert_eq_i32(repacketizer_frame_count(&rp) as i32, 0);
    try assert_eq_i32(repacketizer_payload_bytes(&rp) as i32, 0);
}

test "repacketizer reset leaves the builder empty and reusable" {
    var rp: Repacketizer = Repacketizer{};
    try repacketizer_init(&rp);
    try repacketizer_reset(&rp);

    try assert(repacketizer_is_empty(&rp), "reset repacketizer must be empty");
    try assert_eq_i32(repacketizer_frame_count(&rp) as i32, 0);
    try assert_eq_i32(repacketizer_payload_bytes(&rp) as i32, 0);
}

test "repacketizer add packet appends parsed frame payloads" {
    var rp: Repacketizer = Repacketizer{};
    try repacketizer_init(&rp);

    var one_frame: [byte: 4] = [248, 17, 18, 19];
    try repacketizer_add_packet(&rp, &one_frame[0:4]);

    try assert(!repacketizer_is_empty(&rp), "added packet must make repacketizer non-empty");
    try assert_eq_i32(repacketizer_frame_count(&rp) as i32, 1);
    try assert_eq_i32(repacketizer_payload_bytes(&rp) as i32, 3);

    var two_cbr: [byte: 5] = [249, 1, 2, 3, 4];
    try repacketizer_add_packet(&rp, &two_cbr[0:5]);

    try assert_eq_i32(repacketizer_frame_count(&rp) as i32, 3);
    try assert_eq_i32(repacketizer_payload_bytes(&rp) as i32, 7);
}

test "repacketizer stitches packets with matching config" {
    var rp: Repacketizer = Repacketizer{};
    try repacketizer_init(&rp);

    var one_frame: [byte: 4] = [248, 17, 18, 19];
    var two_cbr: [byte: 5] = [249, 20, 21, 22, 23];
    try repacketizer_add_packet(&rp, &one_frame[0:4]);
    try repacketizer_add_packet(&rp, &two_cbr[0:5]);

    try assert_eq_i32(repacketizer_frame_count(&rp) as i32, 3);
    try assert_eq_i32(repacketizer_duration_us(&rp) as i32, 60000);

    var out: [byte: 16] = [0: 16];
    const written: usize = try repacketizer_output_packet(&rp, &out[0:16], true);
    try assert_eq_i32(written as i32, 11);
    try assert_byte_eq(out[0], 251);
    try assert_byte_eq(out[1], 131);
    try assert_byte_eq(out[4], 17);
    try assert_byte_eq(out[7], 20);
    try assert_byte_eq(out[9], 22);

    var parsed: PacketParseResult = PacketParseResult{};
    try parse_packet(&out[0:written], &parsed);
    try assert_eq_i32(parsed.info.frame_count as i32, 3);
    try assert_eq_i32(parsed.frames[0].len as i32, 3);
    try assert_eq_i32(parsed.frames[1].len as i32, 2);
    try assert_eq_i32(parsed.frames[2].len as i32, 2);
}

test "repacketizer output packet exposes decoder packet info" {
    var rp: Repacketizer = Repacketizer{};
    try repacketizer_init(&rp);

    var one_frame: [byte: 4] = [248, 17, 18, 19];
    var two_cbr: [byte: 5] = [249, 20, 21, 22, 23];
    try repacketizer_add_packet(&rp, &one_frame[0:4]);
    try repacketizer_add_packet(&rp, &two_cbr[0:5]);

    var out: [byte: 16] = [0: 16];
    const written: usize = try repacketizer_output_packet(&rp, &out[0:16], true);

    var info: PacketInfo = PacketInfo{};
    try decoder_get_packet_info(&out[0:written], &info);
    try assert_eq_i32(info.frame_count as i32, 3);
    try assert_eq_i32(info.frame_duration_us as i32, 20000);
    try assert_eq_i32(info.duration_samples_48k as i32, 2880);
    try assert_eq_i32(info.channels as i32, 1);
}

test "repacketizer add packet rejects malformed packet without state changes" {
    var rp: Repacketizer = Repacketizer{};
    try repacketizer_init(&rp);

    var first: [byte: 4] = [248, 17, 18, 19];
    try repacketizer_add_packet(&rp, &first[0:4]);

    var odd_cbr: [byte: 4] = [249, 1, 2, 3];
    const add_result: !void = repacketizer_add_packet(&rp, &odd_cbr[0:4]);
    match add_result {
        error.InvalidPacket => {}
        else => { try assert(false, "malformed input must return the parser error"); }
    }

    const frames_after: usize = repacketizer_frame_count(&rp);
    const bytes_after: usize = repacketizer_payload_bytes(&rp);
    try assert_eq_i32(frames_after as i32, 1);
    try assert_eq_i32(bytes_after as i32, 3);
}

test "repacketizer rejects packets with mismatched config" {
    var rp: Repacketizer = Repacketizer{};
    try repacketizer_init(&rp);

    var first: [byte: 4] = [248, 17, 18, 19];
    try repacketizer_add_packet(&rp, &first[0:4]);

    var different_config: [byte: 4] = [240, 20, 21, 22];
    const add_mixed_result: !void = repacketizer_add_packet(&rp, &different_config[0:4]);
    match add_mixed_result {
        error.RepacketizerError => {
            try assert_eq_i32(repacketizer_frame_count(&rp) as i32, 1);
            try assert_eq_i32(repacketizer_payload_bytes(&rp) as i32, 3);
        }
        else => { try assert(false, "mixed TOC configs must be rejected"); }
    }
}

test "repacketizer add packet rejects aggregate duration over 120ms" {
    var rp: Repacketizer = Repacketizer{};
    try repacketizer_init(&rp);

    var frame: [byte: 4] = [248, 17, 18, 19];
    var i: usize = 0;
    while i < 6 {
        try repacketizer_add_packet(&rp, &frame[0:4]);
        i = i + 1;
    }

    try assert_eq_i32(repacketizer_frame_count(&rp) as i32, 6);
    try assert_eq_i32(repacketizer_payload_bytes(&rp) as i32, 18);

    const too_long: !void = repacketizer_add_packet(&rp, &frame[0:4]);
    match too_long {
        error.RepacketizerError => {}
        else => { try assert(false, "aggregate duration above 120ms must be rejected"); }
    }

    const frames_after: usize = repacketizer_frame_count(&rp);
    const bytes_after: usize = repacketizer_payload_bytes(&rp);
    try assert_eq_i32(frames_after as i32, 6);
    try assert_eq_i32(bytes_after as i32, 18);
}

test "repacketizer reports accumulated packet duration" {
    var rp: Repacketizer = Repacketizer{};
    try repacketizer_init(&rp);

    try assert_eq_i32(repacketizer_duration_us(&rp) as i32, 0);
    try assert_eq_i32(repacketizer_duration_samples_48k(&rp) as i32, 0);

    var one_frame: [byte: 4] = [248, 17, 18, 19];
    var two_cbr: [byte: 5] = [249, 1, 2, 3, 4];
    try repacketizer_add_packet(&rp, &one_frame[0:4]);
    try repacketizer_add_packet(&rp, &two_cbr[0:5]);

    try assert_eq_i32(repacketizer_frame_count(&rp) as i32, 3);
    try assert_eq_i32(repacketizer_duration_us(&rp) as i32, 60000);
    try assert_eq_i32(repacketizer_duration_samples_48k(&rp) as i32, 2880);
}

test "repacketizer outputs equal frames as CBR code 3 packet" {
    var rp: Repacketizer = Repacketizer{};
    try repacketizer_init(&rp);

    var frame: [byte: 4] = [248, 17, 18, 19];
    try repacketizer_add_packet(&rp, &frame[0:4]);
    try repacketizer_add_packet(&rp, &frame[0:4]);
    try repacketizer_add_packet(&rp, &frame[0:4]);

    var out: [byte: 16] = [0: 16];
    const written: usize = try repacketizer_output_packet(&rp, &out[0:16], false);
    try assert_eq_i32(written as i32, 11);
    try assert_byte_eq(out[0], 251);
    try assert_byte_eq(out[1], 3);
    try assert_byte_eq(out[2], 17);
    try assert_byte_eq(out[5], 17);
    try assert_byte_eq(out[8], 17);

    var parsed: PacketParseResult = PacketParseResult{};
    try parse_packet(&out[0:written], &parsed);
    try assert_eq_i32(parsed.info.frame_count as i32, 3);
    try assert_eq_i32(parsed.frames[0].len as i32, 3);
    try assert_eq_i32(parsed.frames[2].len as i32, 3);
}

test "repacketizer outputs variable frames as VBR packet" {
    var rp: Repacketizer = Repacketizer{};
    try repacketizer_init(&rp);

    var one_frame: [byte: 4] = [248, 17, 18, 19];
    var two_cbr: [byte: 5] = [249, 1, 2, 3, 4];
    try repacketizer_add_packet(&rp, &one_frame[0:4]);
    try repacketizer_add_packet(&rp, &two_cbr[0:5]);

    var out: [byte: 16] = [0: 16];
    const written: usize = try repacketizer_output_packet(&rp, &out[0:16], true);
    try assert_eq_i32(written as i32, 11);
    try assert_byte_eq(out[0], 251);
    try assert_byte_eq(out[1], 131);
    try assert_byte_eq(out[2], 3);
    try assert_byte_eq(out[3], 2);
    try assert_byte_eq(out[4], 17);
    try assert_byte_eq(out[7], 1);
    try assert_byte_eq(out[10], 4);

    var parsed: PacketParseResult = PacketParseResult{};
    try parse_packet(&out[0:written], &parsed);
    try assert_eq_i32(parsed.info.frame_count as i32, 3);
    try assert_eq_i32(parsed.frames[0].len as i32, 3);
    try assert_eq_i32(parsed.frames[1].len as i32, 2);
    try assert_eq_i32(parsed.frames[2].len as i32, 2);
}

test "repacketizer adds padding to CBR code 3 output" {
    var rp: Repacketizer = Repacketizer{};
    try repacketizer_init(&rp);

    var frame: [byte: 4] = [248, 17, 18, 19];
    try repacketizer_add_packet(&rp, &frame[0:4]);
    try repacketizer_add_packet(&rp, &frame[0:4]);
    try repacketizer_add_packet(&rp, &frame[0:4]);

    var out: [byte: 16] = [255: 16];
    const written: usize = try repacketizer_output_padded_packet(&rp, &out[0:16], false, 16);
    try assert_eq_i32(written as i32, 16);
    try assert_byte_eq(out[0], 251);
    try assert_byte_eq(out[1], 67);
    try assert_byte_eq(out[2], 4);
    try assert_byte_eq(out[15], 0);

    var parsed: PacketParseResult = PacketParseResult{};
    try parse_packet(&out[0:written], &parsed);
    try assert(parsed.info.has_padding, "padded output must set the padding bit");
    try assert_eq_i32(parsed.info.frame_count as i32, 3);
    try assert_eq_i32(parsed.frames[0].len as i32, 3);
    try assert_eq_i32(parsed.frames[2].len as i32, 3);
}

test "repacketizer removes padding from VBR code 3 packet" {
    var rp: Repacketizer = Repacketizer{};
    try repacketizer_init(&rp);

    var one_frame: [byte: 4] = [248, 17, 18, 19];
    var two_cbr: [byte: 5] = [249, 1, 2, 3, 4];
    try repacketizer_add_packet(&rp, &one_frame[0:4]);
    try repacketizer_add_packet(&rp, &two_cbr[0:5]);

    var padded: [byte: 15] = [0: 15];
    const padded_len: usize = try repacketizer_output_padded_packet(&rp, &padded[0:15], true, 15);
    try assert_eq_i32(padded_len as i32, 15);
    try assert_byte_eq(padded[1], 195);
    try assert_byte_eq(padded[2], 3);

    var compact: [byte: 15] = [0: 15];
    const compact_len: usize = try repacketizer_remove_padding(&padded[0:padded_len], &compact[0:15]);
    try assert_eq_i32(compact_len as i32, 11);
    try assert_byte_eq(compact[0], 251);
    try assert_byte_eq(compact[1], 131);

    var parsed: PacketParseResult = PacketParseResult{};
    try parse_packet(&compact[0:compact_len], &parsed);
    try assert(!parsed.info.has_padding, "compact packet must not keep padding");
    try assert_eq_i32(parsed.frames[0].len as i32, 3);
    try assert_eq_i32(parsed.frames[1].len as i32, 2);
    try assert_eq_i32(parsed.frames[2].len as i32, 2);
}
