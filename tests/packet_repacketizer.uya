use std.testing.assert;
use std.testing.assert_eq_i32;
use src.opus.packet.repacketizer.Repacketizer;
use src.opus.packet.repacketizer.repacketizer_add_packet;
use src.opus.packet.repacketizer.repacketizer_duration_samples_48k;
use src.opus.packet.repacketizer.repacketizer_duration_us;
use src.opus.packet.repacketizer.repacketizer_frame_count;
use src.opus.packet.repacketizer.repacketizer_init;
use src.opus.packet.repacketizer.repacketizer_is_empty;
use src.opus.packet.repacketizer.repacketizer_payload_bytes;
use src.opus.packet.repacketizer.repacketizer_reset;

test "repacketizer initializes as an empty packet builder" {
    var rp: Repacketizer = Repacketizer{};
    try repacketizer_init(&rp);

    try assert(repacketizer_is_empty(&rp), "new repacketizer must start empty");
    try assert_eq_i32(repacketizer_frame_count(&rp) as i32, 0);
    try assert_eq_i32(repacketizer_payload_bytes(&rp) as i32, 0);
}

test "repacketizer reset leaves the builder empty and reusable" {
    var rp: Repacketizer = Repacketizer{};
    try repacketizer_init(&rp);
    try repacketizer_reset(&rp);

    try assert(repacketizer_is_empty(&rp), "reset repacketizer must be empty");
    try assert_eq_i32(repacketizer_frame_count(&rp) as i32, 0);
    try assert_eq_i32(repacketizer_payload_bytes(&rp) as i32, 0);
}

test "repacketizer add packet appends parsed frame payloads" {
    var rp: Repacketizer = Repacketizer{};
    try repacketizer_init(&rp);

    var one_frame: [byte: 4] = [248, 17, 18, 19];
    try repacketizer_add_packet(&rp, &one_frame[0:4]);

    try assert(!repacketizer_is_empty(&rp), "added packet must make repacketizer non-empty");
    try assert_eq_i32(repacketizer_frame_count(&rp) as i32, 1);
    try assert_eq_i32(repacketizer_payload_bytes(&rp) as i32, 3);

    var two_cbr: [byte: 5] = [249, 1, 2, 3, 4];
    try repacketizer_add_packet(&rp, &two_cbr[0:5]);

    try assert_eq_i32(repacketizer_frame_count(&rp) as i32, 3);
    try assert_eq_i32(repacketizer_payload_bytes(&rp) as i32, 7);
}

test "repacketizer add packet rejects malformed packet without state changes" {
    var rp: Repacketizer = Repacketizer{};
    try repacketizer_init(&rp);

    var first: [byte: 4] = [248, 17, 18, 19];
    try repacketizer_add_packet(&rp, &first[0:4]);

    var odd_cbr: [byte: 4] = [249, 1, 2, 3];
    const add_result: !void = repacketizer_add_packet(&rp, &odd_cbr[0:4]);
    match add_result {
        error.InvalidPacket => {}
        else => { try assert(false, "malformed input must return the parser error"); }
    }

    const frames_after: usize = repacketizer_frame_count(&rp);
    const bytes_after: usize = repacketizer_payload_bytes(&rp);
    try assert_eq_i32(frames_after as i32, 1);
    try assert_eq_i32(bytes_after as i32, 3);
}

test "repacketizer add packet rejects aggregate duration over 120ms" {
    var rp: Repacketizer = Repacketizer{};
    try repacketizer_init(&rp);

    var frame: [byte: 4] = [248, 17, 18, 19];
    var i: usize = 0;
    while i < 6 {
        try repacketizer_add_packet(&rp, &frame[0:4]);
        i = i + 1;
    }

    try assert_eq_i32(repacketizer_frame_count(&rp) as i32, 6);
    try assert_eq_i32(repacketizer_payload_bytes(&rp) as i32, 18);

    const too_long: !void = repacketizer_add_packet(&rp, &frame[0:4]);
    match too_long {
        error.RepacketizerError => {}
        else => { try assert(false, "aggregate duration above 120ms must be rejected"); }
    }

    const frames_after: usize = repacketizer_frame_count(&rp);
    const bytes_after: usize = repacketizer_payload_bytes(&rp);
    try assert_eq_i32(frames_after as i32, 6);
    try assert_eq_i32(bytes_after as i32, 18);
}

test "repacketizer reports accumulated packet duration" {
    var rp: Repacketizer = Repacketizer{};
    try repacketizer_init(&rp);

    try assert_eq_i32(repacketizer_duration_us(&rp) as i32, 0);
    try assert_eq_i32(repacketizer_duration_samples_48k(&rp) as i32, 0);

    var one_frame: [byte: 4] = [248, 17, 18, 19];
    var two_cbr: [byte: 5] = [249, 1, 2, 3, 4];
    try repacketizer_add_packet(&rp, &one_frame[0:4]);
    try repacketizer_add_packet(&rp, &two_cbr[0:5]);

    try assert_eq_i32(repacketizer_frame_count(&rp) as i32, 3);
    try assert_eq_i32(repacketizer_duration_us(&rp) as i32, 60000);
    try assert_eq_i32(repacketizer_duration_samples_48k(&rp) as i32, 2880);
}
