fn fill_constant_i16(values: &[i16], sample: i16) void {
    var i: usize = 0;
    while i < values.len {
        values.ptr[i] = sample;
        i = i + 1;
    }
}

fn fill_voice_like_i16(values: &[i16]) void {
    var i: usize = 0;
    while i < values.len {
        const phase: usize = i % (80 as usize);
        var sample: i32 = 0;
        if phase < 20 {
            sample = 10000 - ((phase as i32) * 350);
        } else if phase < 40 {
            sample = 2500 - (((phase - 20) as i32) * 120);
        } else if phase < 60 {
            sample = -1800;
        } else {
            sample = 900;
        }
        values.ptr[i] = sample as i16;
        i = i + 1;
    }
}

fn fill_music_like_stereo_i16(values: &[i16]) void {
    const wave: [i16: 32] = [
        0, 1951, 3827, 5556, 7071, 8315, 9239, 9808,
        10000, 9808, 9239, 8315, 7071, 5556, 3827, 1951,
        0, -1951, -3827, -5556, -7071, -8315, -9239, -9808,
        -10000, -9808, -9239, -8315, -7071, -5556, -3827, -1951,
    ];
    var frame: usize = 0;
    while (frame * 2) + 1 < values.len {
        const bass: i32 = (wave[frame % (32 as usize)] as i32) / 2;
        const lead: i32 = (wave[(frame * 3) % (32 as usize)] as i32) / 3;
        values.ptr[frame * 2] = (bass + lead) as i16;
        values.ptr[(frame * 2) + 1] = (bass - lead) as i16;
        frame = frame + 1;
    }
}

test "encoder api exposes opaque storage backed handle" {
    var encoder: OpusEncoder = OpusEncoder{};
    _ = &encoder;

    try assert(OPUS_ENCODER_STORAGE_WORDS > 0, "encoder storage must reserve opaque state space");
    try assert(@size_of(OpusEncoder) >= OPUS_ENCODER_STORAGE_WORDS * @size_of(usize), "encoder handle must contain the advertised storage");

    const config: OpusEncoderConfig = opus_encoder_config_default();
    try assert_eq_i32(config.sample_rate_hz as i32, 48000);
    try assert_eq_i32(config.channels as i32, 1);
    try assert_eq_i32(config.application as i32, OpusApplication.AUDIO as i32);
    try assert_eq_i32(config.max_bandwidth as i32, OpusBandwidth.FULLBAND as i32);
}

test "encoder init validates config and records state" {
    var encoder: OpusEncoder = OpusEncoder{};
    try assert(!encoder_is_initialized(&encoder), "fresh encoder must not report initialized state");

    const config: OpusEncoderConfig = OpusEncoderConfig{
        sample_rate_hz: 16000,
        channels: 2,
        application: OpusApplication.VOIP,
        signal_hint: OpusSignalHint.VOICE,
        bitrate_bps: 64000,
        complexity: 10,
        max_bandwidth: OpusBandwidth.WIDEBAND,
        vbr: false,
        inband_fec: true,
        packet_loss_percent: 20,
        dtx: true,
    };
    try encoder_init(&encoder, &config);

    try assert(encoder_is_initialized(&encoder), "encoder init must record initialized state");
    try assert_eq_i32(encoder_sample_rate_hz(&encoder) as i32, 16000);
    try assert_eq_i32(encoder_channel_count(&encoder) as i32, 2);
    try assert_eq_i32(encoder_application(&encoder) as i32, OpusApplication.VOIP as i32);

    const bad_rate: OpusEncoderConfig = OpusEncoderConfig{
        sample_rate_hz: 44100,
        channels: 1,
        application: OpusApplication.AUDIO,
        signal_hint: OpusSignalHint.AUTO,
        bitrate_bps: 0,
        complexity: 5,
        max_bandwidth: OpusBandwidth.FULLBAND,
        vbr: true,
        inband_fec: false,
        packet_loss_percent: 0,
        dtx: false,
    };
    var bad_encoder: OpusEncoder = OpusEncoder{};
    const bad_rate_result: !void = encoder_init(&bad_encoder, &bad_rate);
    match bad_rate_result {
        error.EncoderApiError => {}
        else => { try assert(false, "encoder init must map invalid config to API error"); }
    };
    try assert(!encoder_is_initialized(&bad_encoder), "failed init must not mark encoder initialized");
}

test "encoder api config validation maps invalid configs to api error" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.channels = 2;
    config.complexity = 10;
    config.packet_loss_percent = 100;
    try encoder_validate_config(&config);

    config.sample_rate_hz = 44100;
    const bad_rate: !void = encoder_validate_config(&config);
    match bad_rate {
        error.EncoderApiError => {}
        else => { try assert(false, "encoder config validation must reject unsupported sample rates"); }
    };

    config = opus_encoder_config_default();
    config.channels = 3;
    const bad_channels: !void = encoder_validate_config(&config);
    match bad_channels {
        error.EncoderApiError => {}
        else => { try assert(false, "encoder config validation must reject invalid channel counts"); }
    };

    config = opus_encoder_config_default();
    config.complexity = 11;
    const bad_complexity: !void = encoder_validate_config(&config);
    match bad_complexity {
        error.EncoderApiError => {}
        else => { try assert(false, "encoder config validation must reject out-of-range complexity"); }
    };

    config = opus_encoder_config_default();
    config.packet_loss_percent = 101;
    const bad_loss: !void = encoder_validate_config(&config);
    match bad_loss {
        error.EncoderApiError => {}
        else => { try assert(false, "encoder config validation must reject out-of-range packet loss"); }
    };

    config = opus_encoder_config_default();
    config.bitrate_bps = 499;
    const bad_bitrate: !void = encoder_validate_config(&config);
    match bad_bitrate {
        error.EncoderApiError => {}
        else => { try assert(false, "encoder config validation must reject out-of-range bitrate"); }
    };
}

test "encoder encode i16 framework validates requests before unsupported modes" {
    var encoder: OpusEncoder = OpusEncoder{};
    var pcm: [i16: 960] = [0: 960];
    var packet: [byte: 1275] = [0: 1275];

    const uninitialized: !i32 = encoder_encode_i16(&encoder, &pcm[0:960], 960, &packet[0:1275]);
    match uninitialized {
        error.EncoderApiError => {}
        else => { try assert(false, "encoder encode must reject uninitialized encoders"); }
    };

    const config: OpusEncoderConfig = opus_encoder_config_default();
    try encoder_init(&encoder, &config);

    const valid_but_unsupported: !i32 = encoder_encode_i16(&encoder, &pcm[0:960], 960, &packet[0:1275]);
    match valid_but_unsupported {
        error.EncoderApiUnsupported => {}
        else => { try assert(false, "encoder encode framework must leave actual encoding to later tasks"); }
    };
    try assert(!encoder_celt_is_initialized(&encoder), "mono fullband requests are outside the Basic CELT stereo profile");

    const bad_frame: !i32 = encoder_encode_i16(&encoder, &pcm[0:960], 123, &packet[0:1275]);
    match bad_frame {
        error.EncoderApiError => {}
        else => { try assert(false, "encoder encode must reject non-Opus frame durations"); }
    };

    const short_pcm: !i32 = encoder_encode_i16(&encoder, &pcm[0:959], 960, &packet[0:1275]);
    match short_pcm {
        error.EncoderApiError => {}
        else => { try assert(false, "encoder encode must reject short PCM input"); }
    };

    const empty_packet: !i32 = encoder_encode_i16(&encoder, &pcm[0:960], 960, &packet[0:0]);
    match empty_packet {
        error.EncoderApiError => {}
        else => { try assert(false, "encoder encode must reject empty packet output buffers"); }
    };
}

test "encoder encode i16 never reports bytes beyond caller packet buffer" {
    var encoder: OpusEncoder = OpusEncoder{};
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 48000;
    config.channels = 2;
    config.max_bandwidth = OpusBandwidth.FULLBAND;
    try encoder_init(&encoder, &config);

    var stereo_pcm: [i16: 1920] = [0: 1920];
    var tiny_celt_packet: [byte: 3] = [77, 78, 99];
    const celt_encoded: i32 = try encoder_encode_i16(&encoder, &stereo_pcm[0:1920], 960, &tiny_celt_packet[0:2]);
    try assert_eq_i32(celt_encoded, 2);
    try assert(celt_encoded <= 2, "CELT API path must not report more bytes than the provided slice");
    try assert_eq_i32(tiny_celt_packet[0] as i32, 252);
    try assert_eq_i32(tiny_celt_packet[2] as i32, 99);

    config.sample_rate_hz = 16000;
    config.channels = 1;
    config.application = OpusApplication.VOIP;
    config.signal_hint = OpusSignalHint.VOICE;
    config.max_bandwidth = OpusBandwidth.WIDEBAND;
    try encoder_init(&encoder, &config);

    var mono_pcm: [i16: 320] = [0: 320];
    var short_silk_packet: [byte: 384] = [55: 384];
    short_silk_packet[383] = 99;
    const silk_encoded: !i32 = encoder_encode_i16(&encoder, &mono_pcm[0:320], 320, &short_silk_packet[0:383]);
    match silk_encoded {
        error.EncoderApiError => {}
        else => { try assert(false, "short SILK API buffers must fail before exceeding caller buffer"); }
    };
    try assert_eq_i32(short_silk_packet[383] as i32, 99);
}

test "encoder api applies CELT VBR allocation to packet length" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 48000;
    config.channels = 2;
    config.max_bandwidth = OpusBandwidth.FULLBAND;
    config.bitrate_bps = 64000;
    config.vbr = true;

    var silence_encoder: OpusEncoder = OpusEncoder{};
    try encoder_init(&silence_encoder, &config);
    var silence_pcm: [i16: 1920] = [0: 1920];
    var silence_packet: [byte: 1275] = [0: 1275];
    const silence_encoded: i32 = try encoder_encode_i16(&silence_encoder, &silence_pcm[0:1920], 960, &silence_packet[0:1275]);

    var active_encoder: OpusEncoder = OpusEncoder{};
    try encoder_init(&active_encoder, &config);
    var active_pcm: [i16: 1920] = [0: 1920];
    fill_constant_i16(&active_pcm[0:1920], 30000);
    var active_packet: [byte: 1275] = [0: 1275];
    const active_encoded: i32 = try encoder_encode_i16(&active_encoder, &active_pcm[0:1920], 960, &active_packet[0:1275]);

    try assert_eq_i32(silence_encoded, 81);
    try assert_eq_i32(active_encoded, 239);
    try assert(active_encoded > silence_encoded, "public encoder API must expose VBR allocation through packet length");

    var info: PacketInfo = PacketInfo{};
    try decoder_get_packet_info(&active_packet[0:(active_encoded as usize)], &info);
    try assert_eq_i32(info.mode as i32, OpusMode.CELT as i32);
    try assert_eq_i32(info.payload_len as i32, active_encoded - 1);
}

test "encoder api applies CELT CBR bitrate target independent of activity" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 48000;
    config.channels = 2;
    config.max_bandwidth = OpusBandwidth.FULLBAND;
    config.bitrate_bps = 64000;
    config.vbr = false;

    var silence_encoder: OpusEncoder = OpusEncoder{};
    try encoder_init(&silence_encoder, &config);
    var silence_pcm: [i16: 1920] = [0: 1920];
    var silence_packet: [byte: 1275] = [0: 1275];
    const silence_encoded: i32 = try encoder_encode_i16(&silence_encoder, &silence_pcm[0:1920], 960, &silence_packet[0:1275]);

    var active_encoder: OpusEncoder = OpusEncoder{};
    try encoder_init(&active_encoder, &config);
    var active_pcm: [i16: 1920] = [0: 1920];
    fill_constant_i16(&active_pcm[0:1920], 30000);
    var active_packet: [byte: 1275] = [0: 1275];
    const active_encoded: i32 = try encoder_encode_i16(&active_encoder, &active_pcm[0:1920], 960, &active_packet[0:1275]);

    try assert_eq_i32(silence_encoded, 160);
    try assert_eq_i32(active_encoded, 160);
    try assert_eq_i32(active_packet[0] as i32, 252);
}

test "encoder encode dispatches valid fullband frames into celt state" {
    var encoder: OpusEncoder = OpusEncoder{};
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 48000;
    config.channels = 2;
    config.max_bandwidth = OpusBandwidth.FULLBAND;
    try encoder_init(&encoder, &config);

    var pcm: [i16: 1920] = [0: 1920];
    var packet: [byte: 1275] = [0: 1275];
    try assert(!encoder_celt_is_initialized(&encoder), "freshly initialized encoder must not pre-mark CELT state");
    const encoded: i32 = try encoder_encode_i16(&encoder, &pcm[0:1920], 960, &packet[0:1275]);
    try assert(encoded > 1, "CELT range encode must produce TOC plus payload bytes");
    try assert_eq_i32(packet[0] as i32, 252);
    try assert(encoder_celt_is_initialized(&encoder), "fullband encode requests must reach CELT state dispatch");

    config.max_bandwidth = OpusBandwidth.WIDEBAND;
    try encoder_init(&encoder, &config);
    try assert(!encoder_celt_is_initialized(&encoder), "encoder init must reset CELT dispatch state");
    const unsupported_bandwidth: !i32 = encoder_encode_i16(&encoder, &pcm[0:1920], 960, &packet[0:1275]);
    match unsupported_bandwidth {
        error.EncoderApiUnsupported => {}
        else => { try assert(false, "non-fullband CELT profile should stay unsupported for now"); }
    };
    try assert(!encoder_celt_is_initialized(&encoder), "unsupported CELT profiles must not mark state initialized");
}

test "encoder range encode output is parseable as a CELT packet" {
    var encoder: OpusEncoder = OpusEncoder{};
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 48000;
    config.channels = 2;
    config.max_bandwidth = OpusBandwidth.FULLBAND;
    try encoder_init(&encoder, &config);

    var pcm: [i16: 1920] = [0: 1920];
    var packet: [byte: 1275] = [0: 1275];
    const encoded: i32 = try encoder_encode_i16(&encoder, &pcm[0:1920], 960, &packet[0:1275]);

    var info: PacketInfo = PacketInfo{};
    try decoder_get_packet_info(&packet[0:(encoded as usize)], &info);
    try assert_eq_i32(info.mode as i32, OpusMode.CELT as i32);
    try assert_eq_i32(info.bandwidth as i32, OpusBandwidth.FULLBAND as i32);
    try assert_eq_i32(info.channels as i32, 2);
    try assert_eq_i32(info.frame_count as i32, 1);
    try assert_eq_i32(info.frame_duration_us as i32, 20000);
    try assert_eq_i32(info.duration_samples_48k as i32, 960);
    try assert_eq_i32(info.payload_offset as i32, 1);
    try assert_eq_i32(info.payload_len as i32, encoded - 1);
}

test "encoder writes basic silk only wideband mono packet" {
    var encoder: OpusEncoder = OpusEncoder{};
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 16000;
    config.channels = 1;
    config.application = OpusApplication.VOIP;
    config.signal_hint = OpusSignalHint.VOICE;
    config.max_bandwidth = OpusBandwidth.WIDEBAND;
    try encoder_init(&encoder, &config);

    var pcm: [i16: 320] = [0: 320];
    var packet: [byte: 1275] = [0: 1275];
    try assert(!encoder_celt_is_initialized(&encoder), "fresh SILK profile must not pre-mark CELT state");
    try assert(!encoder_silk_is_initialized(&encoder), "fresh SILK profile must not pre-mark SILK state");

    const encoded: i32 = try encoder_encode_i16(&encoder, &pcm[0:320], 320, &packet[0:1275]);
    try assert(encoded > 1, "SILK encoder must include a decodable payload");
    try assert(!encoder_celt_is_initialized(&encoder), "SILK-only requests must not fall through into CELT state");
    try assert(encoder_silk_is_initialized(&encoder), "recognized SILK-only requests must reach the SILK state");

    var info: PacketInfo = PacketInfo{};
    try decoder_get_packet_info(&packet[0:(encoded as usize)], &info);
    try assert_eq_i32(info.mode as i32, OpusMode.SILK as i32);
    try assert_eq_i32(info.bandwidth as i32, OpusBandwidth.WIDEBAND as i32);
    try assert_eq_i32(info.channels as i32, 1);
    try assert_eq_i32(info.frame_count as i32, 1);
    try assert_eq_i32(info.frame_duration_us as i32, 20000);
    try assert_eq_i32(info.duration_samples_48k as i32, 960);
    try assert_eq_i32(info.payload_offset as i32, 1);
    try assert_eq_i32(info.payload_len as i32, encoded - 1);
}

test "encoder api returns zero bytes for dtx inactive silk voice frame" {
    var encoder: OpusEncoder = OpusEncoder{};
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 16000;
    config.channels = 1;
    config.application = OpusApplication.VOIP;
    config.signal_hint = OpusSignalHint.VOICE;
    config.max_bandwidth = OpusBandwidth.WIDEBAND;
    config.dtx = true;
    try encoder_init(&encoder, &config);

    var silence_pcm: [i16: 640] = [0: 640];
    var silence_packet: [byte: 1275] = [77: 1275];
    const silence_encoded: i32 = try encoder_encode_i16(&encoder, &silence_pcm[0:640], 640, &silence_packet[0:1275]);
    try assert_eq_i32(silence_encoded, 0);
    try assert_eq_i32(silence_packet[0] as i32, 77);

    var voice_pcm: [i16: 320] = [0: 320];
    fill_voice_like_i16(&voice_pcm[0:320]);
    var voice_packet: [byte: 1275] = [0: 1275];
    const voice_encoded: i32 = try encoder_encode_i16(&encoder, &voice_pcm[0:320], 320, &voice_packet[0:1275]);
    try assert(voice_encoded > 1, "active voice must not be suppressed by DTX");

    var info: PacketInfo = PacketInfo{};
    try decoder_get_packet_info(&voice_packet[0:(voice_encoded as usize)], &info);
    try assert_eq_i32(info.mode as i32, OpusMode.SILK as i32);
}

test "encoder bandwidth decision caps fullband request to wideband for 16k mono" {
    var encoder: OpusEncoder = OpusEncoder{};
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 16000;
    config.channels = 1;
    config.application = OpusApplication.VOIP;
    config.signal_hint = OpusSignalHint.VOICE;
    config.max_bandwidth = OpusBandwidth.FULLBAND;
    try encoder_init(&encoder, &config);

    var pcm: [i16: 320] = [0: 320];
    var packet: [byte: 1275] = [0: 1275];
    const encoded: i32 = try encoder_encode_i16(&encoder, &pcm[0:320], 320, &packet[0:1275]);

    var info: PacketInfo = PacketInfo{};
    try decoder_get_packet_info(&packet[0:(encoded as usize)], &info);
    try assert_eq_i32(info.mode as i32, OpusMode.SILK as i32);
    try assert_eq_i32(info.bandwidth as i32, OpusBandwidth.WIDEBAND as i32);
    try assert_eq_i32(info.channels as i32, 1);
    try assert(encoder_silk_is_initialized(&encoder), "bandwidth decision must route 16k mono requests into SILK");
}

test "encoder mode decision keeps restricted lowdelay on CELT path" {
    var encoder: OpusEncoder = OpusEncoder{};
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 16000;
    config.channels = 1;
    config.application = OpusApplication.RESTRICTED_LOWDELAY;
    config.signal_hint = OpusSignalHint.AUTO;
    config.max_bandwidth = OpusBandwidth.FULLBAND;
    try encoder_init(&encoder, &config);

    var pcm: [i16: 320] = [0: 320];
    var packet: [byte: 1275] = [0: 1275];
    const encoded: !i32 = encoder_encode_i16(&encoder, &pcm[0:320], 320, &packet[0:1275]);
    match encoded {
        error.EncoderApiUnsupported => {}
        else => { try assert(false, "restricted lowdelay mode decision must not fall back to SILK"); }
    };
    try assert(!encoder_silk_is_initialized(&encoder), "restricted lowdelay must leave SILK state untouched");
    try assert(!encoder_celt_is_initialized(&encoder), "unsupported CELT profile must not mark CELT state initialized");
}

test "encoder signal classifier distinguishes coarse voice and music input" {
    var voice_config: OpusEncoderConfig = opus_encoder_config_default();
    voice_config.sample_rate_hz = 16000;
    voice_config.channels = 1;
    voice_config.signal_hint = OpusSignalHint.AUTO;
    voice_config.max_bandwidth = OpusBandwidth.WIDEBAND;
    var voice_pcm: [i16: 320] = [0: 320];
    fill_voice_like_i16(&voice_pcm[0:320]);
    const voice_class: OpusSignalHint = try encoder_classify_signal_i16(&voice_config, &voice_pcm[0:320], 320);
    try assert_eq_i32(voice_class as i32, OpusSignalHint.VOICE as i32);

    var music_config: OpusEncoderConfig = opus_encoder_config_default();
    music_config.sample_rate_hz = 48000;
    music_config.channels = 2;
    music_config.signal_hint = OpusSignalHint.AUTO;
    music_config.max_bandwidth = OpusBandwidth.FULLBAND;
    var music_pcm: [i16: 1920] = [0: 1920];
    fill_music_like_stereo_i16(&music_pcm[0:1920]);
    const music_class: OpusSignalHint = try encoder_classify_signal_i16(&music_config, &music_pcm[0:1920], 960);
    try assert_eq_i32(music_class as i32, OpusSignalHint.MUSIC as i32);
}

test "encoder frame duration decision packetizes 40ms voice as two SILK frames" {
    var encoder: OpusEncoder = OpusEncoder{};
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 16000;
    config.channels = 1;
    config.application = OpusApplication.VOIP;
    config.signal_hint = OpusSignalHint.VOICE;
    config.max_bandwidth = OpusBandwidth.FULLBAND;
    try encoder_init(&encoder, &config);

    var pcm: [i16: 640] = [0: 640];
    var packet: [byte: 1275] = [0: 1275];
    const encoded: i32 = try encoder_encode_i16(&encoder, &pcm[0:640], 640, &packet[0:1275]);

    var info: PacketInfo = PacketInfo{};
    try decoder_get_packet_info(&packet[0:(encoded as usize)], &info);
    try assert_eq_i32(info.mode as i32, OpusMode.SILK as i32);
    try assert_eq_i32(info.bandwidth as i32, OpusBandwidth.WIDEBAND as i32);
    try assert_eq_i32(info.frame_count as i32, 2);
    try assert_eq_i32(info.frame_duration_us as i32, 20000);
    try assert_eq_i32(info.duration_samples_48k as i32, 1920);
    try assert(encoder_silk_is_initialized(&encoder), "40ms voice decision must still drive SILK state");
}

test "encoder frame duration decision packetizes 60ms stereo as three CELT frames" {
    var encoder: OpusEncoder = OpusEncoder{};
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 48000;
    config.channels = 2;
    config.max_bandwidth = OpusBandwidth.FULLBAND;
    try encoder_init(&encoder, &config);

    var pcm: [i16: 5760] = [0: 5760];
    var packet: [byte: 1275] = [0: 1275];
    const encoded: i32 = try encoder_encode_i16(&encoder, &pcm[0:5760], 2880, &packet[0:1275]);

    var info: PacketInfo = PacketInfo{};
    try decoder_get_packet_info(&packet[0:(encoded as usize)], &info);
    try assert_eq_i32(info.mode as i32, OpusMode.CELT as i32);
    try assert_eq_i32(info.bandwidth as i32, OpusBandwidth.FULLBAND as i32);
    try assert_eq_i32(info.channels as i32, 2);
    try assert_eq_i32(info.frame_count as i32, 3);
    try assert_eq_i32(info.frame_duration_us as i32, 20000);
    try assert_eq_i32(info.duration_samples_48k as i32, 2880);
    try assert(encoder_celt_is_initialized(&encoder), "60ms stereo decision must still drive CELT state");
}
