use std.testing.assert;
use std.testing.assert_eq_i32;
use src.opus.core.types.OpusBandwidth;
use src.opus.hybrid.merge.HybridMergeResult;
use src.opus.hybrid.merge.hybrid_merge_i16;
use src.opus.hybrid.state.HybridDecoderState;
use src.opus.hybrid.state.hybrid_state_init;

fn test_q14(value: i32) i32 {
    return value * 16384;
}

fn assert_sample_eq(actual: i16, expected: i32) !void {
    try assert_eq_i32(actual as i32, expected);
}

test "hybrid merge expands mono lowband and adds delayed highband" {
    var state: HybridDecoderState = HybridDecoderState{};
    try hybrid_state_init(&state, 1, OpusBandwidth.SUPERWIDEBAND, 480);

    var lowband_q14: [i32: 160] = [0: 160];
    var highband_q14: [i32: 480] = [0: 480];
    var pcm: [i16: 480] = [0: 480];

    var i: usize = 0;
    while i < 160 {
        lowband_q14[i] = test_q14(((i as i32) + 1) * 3);
        i = i + 1;
    }
    highband_q14[0] = test_q14(2);
    highband_q14[1] = test_q14(-1);

    const result: HybridMergeResult = try hybrid_merge_i16(&state, &lowband_q14[0:160], &highband_q14[0:480], &pcm[0:480]);
    try assert_eq_i32(result.decoded_samples_48k, 480);
    try assert_eq_i32(result.channels, 1);
    try assert_sample_eq(pcm[0], 3);
    try assert_sample_eq(pcm[1], 1);
    try assert_sample_eq(pcm[2], 3);
    try assert_sample_eq(pcm[3], 4);
    try assert_sample_eq(pcm[4], 5);
    try assert_sample_eq(pcm[5], 6);
    try assert_sample_eq(pcm[479], 480);
    try assert_eq_i32(state.merge_mem_q14[0], test_q14(480));

    i = 0;
    while i < 160 {
        lowband_q14[i] = test_q14(483 + ((i as i32) * 3));
        highband_q14[i * 3] = 0;
        highband_q14[i * 3 + 1] = 0;
        highband_q14[i * 3 + 2] = 0;
        pcm[i * 3] = 0;
        pcm[i * 3 + 1] = 0;
        pcm[i * 3 + 2] = 0;
        i = i + 1;
    }

    _ = try hybrid_merge_i16(&state, &lowband_q14[0:160], &highband_q14[0:480], &pcm[0:480]);
    try assert_sample_eq(pcm[0], 481);
    try assert_sample_eq(pcm[1], 482);
    try assert_sample_eq(pcm[2], 483);
    try assert_sample_eq(pcm[479], 960);
    try assert_eq_i32(state.merge_mem_q14[0], test_q14(960));
}

test "hybrid merge handles stereo interleaved low and high bands" {
    var state: HybridDecoderState = HybridDecoderState{};
    try hybrid_state_init(&state, 2, OpusBandwidth.FULLBAND, 960);

    var lowband_q14: [i32: 640] = [0: 640];
    var highband_q14: [i32: 1920] = [0: 1920];
    var pcm: [i16: 1920] = [0: 1920];

    var frame: usize = 0;
    while frame < 320 {
        const left: i32 = 30 + ((frame as i32) * 3);
        const right: i32 = 0 - left;
        lowband_q14[frame * 2] = test_q14(left);
        lowband_q14[frame * 2 + 1] = test_q14(right);
        frame = frame + 1;
    }
    highband_q14[1] = test_q14(2);
    highband_q14[4] = test_q14(4);

    const result: HybridMergeResult = try hybrid_merge_i16(&state, &lowband_q14[0:640], &highband_q14[0:1920], &pcm[0:1920]);
    try assert_eq_i32(result.decoded_samples_48k, 960);
    try assert_eq_i32(result.channels, 2);
    try assert_sample_eq(pcm[0], 10);
    try assert_sample_eq(pcm[1], -8);
    try assert_sample_eq(pcm[2], 20);
    try assert_sample_eq(pcm[3], -20);
    try assert_sample_eq(pcm[4], 34);
    try assert_sample_eq(pcm[5], -30);
    try assert_sample_eq(pcm[1918], 987);
    try assert_sample_eq(pcm[1919], -987);
    try assert_eq_i32(state.merge_mem_q14[0], test_q14(987));
    try assert_eq_i32(state.merge_mem_q14[1], test_q14(-987));
}

test "hybrid merge saturates mixed q14 to i16 pcm" {
    var pos_state: HybridDecoderState = HybridDecoderState{};
    try hybrid_state_init(&pos_state, 1, OpusBandwidth.SUPERWIDEBAND, 480);

    var lowband_q14: [i32: 160] = [0: 160];
    var highband_q14: [i32: 480] = [0: 480];
    var pcm: [i16: 480] = [0: 480];
    lowband_q14[0] = test_q14(32760);
    highband_q14[2] = test_q14(20);
    _ = try hybrid_merge_i16(&pos_state, &lowband_q14[0:160], &highband_q14[0:480], &pcm[0:480]);
    try assert_sample_eq(pcm[2], 32767);

    var neg_state: HybridDecoderState = HybridDecoderState{};
    try hybrid_state_init(&neg_state, 1, OpusBandwidth.SUPERWIDEBAND, 480);
    neg_state.merge_mem_q14[0] = test_q14(-32760);
    lowband_q14[0] = test_q14(-32760);
    highband_q14[0] = test_q14(-20);
    _ = try hybrid_merge_i16(&neg_state, &lowband_q14[0:160], &highband_q14[0:480], &pcm[0:480]);
    try assert_sample_eq(pcm[0], -32768);
}

test "hybrid merge validates state and buffers" {
    var state: HybridDecoderState = HybridDecoderState{};
    try hybrid_state_init(&state, 1, OpusBandwidth.SUPERWIDEBAND, 480);

    var lowband_q14: [i32: 160] = [0: 160];
    var highband_q14: [i32: 480] = [0: 480];
    var pcm: [i16: 480] = [0: 480];

    const short_low: !HybridMergeResult = hybrid_merge_i16(&state, &lowband_q14[0:159], &highband_q14[0:480], &pcm[0:480]);
    match short_low {
        error.HybridMergeError => {}
        else => { try assert(false, "merge must reject short lowband buffer"); }
    }

    const short_high: !HybridMergeResult = hybrid_merge_i16(&state, &lowband_q14[0:160], &highband_q14[0:479], &pcm[0:480]);
    match short_high {
        error.HybridMergeError => {}
        else => { try assert(false, "merge must reject short highband buffer"); }
    }

    const short_pcm: !HybridMergeResult = hybrid_merge_i16(&state, &lowband_q14[0:160], &highband_q14[0:480], &pcm[0:479]);
    match short_pcm {
        error.HybridMergeError => {}
        else => { try assert(false, "merge must reject short pcm buffer"); }
    }

    state.silk_frame_size = 159;
    const bad_layout: !HybridMergeResult = hybrid_merge_i16(&state, &lowband_q14[0:160], &highband_q14[0:480], &pcm[0:480]);
    match bad_layout {
        error.HybridMergeError => {}
        else => { try assert(false, "merge must reject inconsistent hybrid frame layout"); }
    }
}
