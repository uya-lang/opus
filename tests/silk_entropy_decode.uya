test "silk entropy decoder decodes signal type from cached VAD flags" {
    var symbols: [i32: 24] = [0: 24];
    var vad: [bool: 24] = [false: 24];
    vad[0] = true;
    symbols[0] = 3;
    symbols[1] = 1;

    var packet: [byte: 32] = [0: 32];
    try encode_type_offset_payload(&packet[0:32], &symbols[0:24], &vad[0:24], 1, 2);

    var dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&dec, &packet[0:32], 1, 2);
    dec.vad_flags[0] = true;
    dec.vad_flags[1] = false;

    try assert_eq_i32(try silk_entropy_decode_signal_type(&dec, 0, 0), SILK_SIGNAL_TYPE_VOICED);
    try assert_eq_i32(dec.signal_types[0], SILK_SIGNAL_TYPE_VOICED);
    try assert_eq_i32(dec.type_offset_symbols[0], 3);
    try assert(dec.type_offset_valid[0], "type offset symbol for frame 0 is cached");

    try assert_eq_i32(try silk_entropy_decode_signal_type(&dec, 0, 1), SILK_SIGNAL_TYPE_UNVOICED);
    try assert_eq_i32(dec.signal_types[1], SILK_SIGNAL_TYPE_UNVOICED);
    try assert_eq_i32(dec.type_offset_symbols[1], 1);
    try assert(dec.type_offset_valid[1], "type offset symbol for frame 1 is cached");
    try silk_entropy_decoder_check(&dec);

    const bad_channel: !i32 = silk_entropy_decode_signal_type(&dec, 1, 0);
    match bad_channel {
        error.SilkEntropyDecodeError => {}
        else => { try assert(false, "signal type decode must reject inactive channels"); }
    }
}

test "silk entropy decoder derives quantization offset from cached type offset" {
    var symbols: [i32: 24] = [0: 24];
    var vad: [bool: 24] = [false: 24];
    vad[0] = true;
    symbols[0] = 2;
    symbols[1] = 1;

    var packet: [byte: 32] = [0: 32];
    try encode_type_offset_payload(&packet[0:32], &symbols[0:24], &vad[0:24], 1, 2);

    var dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&dec, &packet[0:32], 1, 2);
    dec.vad_flags[0] = true;
    dec.vad_flags[1] = false;
    try assert_eq_i32(try silk_entropy_decode_signal_type(&dec, 0, 0), SILK_SIGNAL_TYPE_VOICED);
    try assert_eq_i32(try silk_entropy_decode_signal_type(&dec, 0, 1), SILK_SIGNAL_TYPE_UNVOICED);

    try assert_eq_i32(try silk_entropy_decode_quantization_offset(&dec, 0, 0), 0);
    try assert_eq_i32(dec.quant_offset_types[0], 0);
    try assert(dec.quant_offset_valid[0], "quantization offset for frame 0 is cached");

    try assert_eq_i32(try silk_entropy_decode_quantization_offset(&dec, 0, 1), 1);
    try assert_eq_i32(dec.quant_offset_types[1], 1);
    try assert(dec.quant_offset_valid[1], "quantization offset for frame 1 is cached");
    try silk_entropy_decoder_check(&dec);

    var uncached_dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&uncached_dec, &packet[0:32], 1, 2);
    const uncached: !i32 = silk_entropy_decode_quantization_offset(&uncached_dec, 0, 0);
    match uncached {
        error.SilkEntropyDecodeError => {}
        else => { try assert(false, "quantization offset decode must require a cached type offset symbol"); }
    }
}

test "silk entropy decoder decodes and dequantizes gains" {
    var delta_symbols: [i32: 3] = [4, 5, 3];
    var packet: [byte: 32] = [0: 32];
    try encode_independent_gains_payload(&packet[0:32], 2, true, 3, 5, &delta_symbols[0:3], 4);

    var dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&dec, &packet[0:32], 1, 1);
    dec.vad_flags[0] = true;
    try assert_eq_i32(try silk_entropy_decode_signal_type(&dec, 0, 0), SILK_SIGNAL_TYPE_VOICED);
    try assert_eq_i32(try silk_entropy_decode_quantization_offset(&dec, 0, 0), 0);

    var control: SilkDecoderControl = SilkDecoderControl{};
    control.channels = 1;
    control.fs_khz = 16;
    control.frame_length = 320;
    control.subframe_length = 80;
    control.nb_subframes = 4;
    control.lpc_order = 16;
    try silk_entropy_decode_gains(&dec, &control, 0, 0, false);

    try assert_eq_i32((try silk_entropy_decoder_gain_index(&dec, 0, 0, 0)) as i32, 0);
    try assert_eq_i32((try silk_entropy_decoder_gain_index(&dec, 0, 0, 3)) as i32, 3);
    try assert_eq_i32(dec.gain_indices[0], 29);
    try assert_eq_i32(dec.gain_indices[1], 4);
    try assert_eq_i32(dec.gain_indices[2], 5);
    try assert_eq_i32(dec.gain_indices[3], 3);
    try assert(dec.gain_valid[0], "gain index for subframe 0 is cached");
    try assert(dec.gain_valid[3], "gain index for subframe 3 is cached");
    try assert_eq_i32(dec.last_gain_indices[0], 29);
    try assert_eq_i32(control.gains_q16[0], 7929856);
    try assert_eq_i32(control.gains_q16[1], 7929856);
    try assert_eq_i32(control.gains_q16[2], 9240576);
    try assert_eq_i32(control.gains_q16[3], 7929856);
    try silk_entropy_decoder_check(&dec);

    var uncached_dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&uncached_dec, &packet[0:32], 1, 1);
    const uncached: !void = silk_entropy_decode_gains(&uncached_dec, &control, 0, 0, false);
    match uncached {
        error.SilkEntropyDecodeError => {}
        else => { try assert(false, "gain decode must require a cached signal type"); }
    }
}

