test "silk entropy decoder decodes LBRR frame masks" {
    var channel_flags: [bool: 2] = [false: 2];
    var frame_symbols: [i32: 2] = [0: 2];
    channel_flags[0] = true;
    frame_symbols[0] = 5;

    var packet: [byte: 32] = [0: 32];
    try encode_lbrr_payload(&packet[0:32], &channel_flags[0:2], &frame_symbols[0:2], 2, 3);

    var dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&dec, &packet[0:32], 2, 3);
    dec.lbrr_flags[1] = true;
    dec.lbrr_channel_flags[1] = true;
    try silk_entropy_decode_lbrr_flags(&dec);
    try silk_entropy_decoder_check(&dec);

    try assert(dec.lbrr_channel_flags[0], "channel 0 has LBRR");
    try assert(!dec.lbrr_channel_flags[1], "channel 1 has no LBRR");
    try assert(dec.lbrr_flags[0], "channel 0 frame 0 LBRR");
    try assert(!dec.lbrr_flags[1], "channel 0 frame 1 no LBRR");
    try assert(dec.lbrr_flags[2], "channel 0 frame 2 LBRR");
    try assert(!dec.lbrr_flags[12], "channel 1 frame 0 no LBRR");
    try assert(!dec.lbrr_flags[13], "channel 1 frame 1 no LBRR");
    try assert(!dec.lbrr_flags[14], "channel 1 frame 2 no LBRR");
}

test "silk entropy decoder handles one and two frame LBRR masks" {
    var channel_flags: [bool: 2] = [false: 2];
    var frame_symbols: [i32: 2] = [0: 2];
    channel_flags[0] = true;
    frame_symbols[0] = 2;

    var two_frame_packet: [byte: 32] = [0: 32];
    try encode_lbrr_payload(&two_frame_packet[0:32], &channel_flags[0:2], &frame_symbols[0:2], 1, 2);

    var two_frame_dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&two_frame_dec, &two_frame_packet[0:32], 1, 2);
    try silk_entropy_decode_lbrr_flags(&two_frame_dec);
    try assert(!two_frame_dec.lbrr_flags[0], "two-frame symbol clears frame 0");
    try assert(two_frame_dec.lbrr_flags[1], "two-frame symbol sets frame 1");

    var one_frame_packet: [byte: 32] = [0: 32];
    try encode_lbrr_payload(&one_frame_packet[0:32], &channel_flags[0:2], &frame_symbols[0:2], 1, 1);

    var one_frame_dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&one_frame_dec, &one_frame_packet[0:32], 1, 1);
    try silk_entropy_decode_lbrr_flags(&one_frame_dec);
    try assert(one_frame_dec.lbrr_channel_flags[0], "one-frame packet has channel LBRR");
    try assert(one_frame_dec.lbrr_flags[0], "one-frame channel LBRR implies frame LBRR");
}

test "silk entropy decoder rejects LBRR masks without a supported table" {
