test "silk entropy decoder decodes narrowband nlsf indices into q15 control" {
    var residuals: [i16: 10] = [0: 10];
    var packet: [byte: 64] = [0: 64];
    try encode_nlsf_payload(&packet[0:64], 1, false, SILK_NLSF_CODEBOOK_NB_MB, SILK_SIGNAL_TYPE_UNVOICED, 0, &residuals[0:10], 0, 2);

    var dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&dec, &packet[0:64], 1, 1);
    try assert_eq_i32(try silk_entropy_decode_signal_type(&dec, 0, 0), SILK_SIGNAL_TYPE_UNVOICED);

    var control: SilkDecoderControl = SilkDecoderControl{};
    control.channels = 1;
    control.fs_khz = 8;
    control.frame_length = 160;
    control.subframe_length = 80;
    control.nb_subframes = 2;
    control.lpc_order = 10;
    try silk_entropy_decode_nlsf_indices(&dec, &control, 0, 0);

    try assert(dec.nlsf_valid[0], "NLSF indices for frame 0 are cached");
    try assert_eq_i32((try silk_entropy_decoder_nlsf_index(&dec, 0, 0, 0)) as i32, 0);
    try assert_eq_i32((try silk_entropy_decoder_nlsf_index(&dec, 0, 0, 10)) as i32, 10);
    try assert_eq_i32(dec.nlsf_indices[0] as i32, 0);
    try assert_eq_i32(dec.nlsf_indices[10] as i32, 0);
    try assert_eq_i32(dec.nlsf_interp_q2[0], 4);
    try assert_eq_i32(control.nlsf_q15[0] as i32, 1536);
    try assert_eq_i32(control.nlsf_q15[4] as i32, 13824);
    try assert_eq_i32(control.nlsf_q15[9] as i32, 29184);
    try silk_entropy_decoder_check(&dec);
}

test "silk entropy decoder decodes wideband nlsf extensions and interpolation" {
    var residuals: [i16: 16] = [0: 16];
    residuals[0] = -5;
    residuals[1] = 5;
    residuals[2] = -4;
    residuals[3] = 4;
    var packet: [byte: 80] = [0: 80];
    try encode_nlsf_payload(&packet[0:80], 2, true, SILK_NLSF_CODEBOOK_WB, SILK_SIGNAL_TYPE_VOICED, 31, &residuals[0:16], 2, 4);

    var dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&dec, &packet[0:80], 1, 1);
    dec.vad_flags[0] = true;
    try assert_eq_i32(try silk_entropy_decode_signal_type(&dec, 0, 0), SILK_SIGNAL_TYPE_VOICED);

    var control: SilkDecoderControl = SilkDecoderControl{};
    control.channels = 1;
    control.fs_khz = 16;
    control.frame_length = 320;
    control.subframe_length = 80;
    control.nb_subframes = 4;
    control.lpc_order = 16;
    try silk_entropy_decode_nlsf_indices(&dec, &control, 0, 0);

    try assert_eq_i32(dec.nlsf_indices[0] as i32, 31);
    try assert_eq_i32(dec.nlsf_indices[1] as i32, -5);
    try assert_eq_i32(dec.nlsf_indices[2] as i32, 5);
    try assert_eq_i32(dec.nlsf_indices[3] as i32, -4);
    try assert_eq_i32(dec.nlsf_indices[4] as i32, 4);
    try assert_eq_i32(dec.nlsf_interp_q2[0], 2);
    try assert(control.nlsf_q15[0] > 0, "wideband NLSF decode writes Q15 control coefficients");
    try assert(control.nlsf_q15[15] > 0, "wideband NLSF decode writes the last coefficient");

    var uncached_dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&uncached_dec, &packet[0:80], 1, 1);
    const uncached: !void = silk_entropy_decode_nlsf_indices(&uncached_dec, &control, 0, 0);
    match uncached {
        error.SilkEntropyDecodeError => {}
        else => { try assert(false, "NLSF index decode must require a cached signal type"); }
    }
}

