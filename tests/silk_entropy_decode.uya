fn encode_test_payload(packet: &[byte]) !void {
    const icdf: [byte: 4] = [200, 100, 40, 0];
    var enc: EcEnc = EcEnc{};
    ec_enc_init(&enc, packet);
    ec_enc_icdf(&enc, 2, &icdf[0:4], 8);
    ec_enc_bit_logp(&enc, 1, 3);
    _ = try ec_enc_done(&enc);
    try ec_enc_check(&enc);
}

fn encode_vad_payload(packet: &[byte], flags: &[bool], channels: i32, frames_per_packet: i32) !void {
    var enc: EcEnc = EcEnc{};
    ec_enc_init(&enc, packet);
    var channel: i32 = 0;
    while channel < channels {
        var frame: i32 = 0;
        while frame < frames_per_packet {
            const index: usize = (channel as usize) * SILK_ENTROPY_MAX_FRAMES_PER_PACKET + (frame as usize);
            var bit: i32 = 0;
            if flags.ptr[index] {
                bit = 1;
            }
            ec_enc_bit_logp(&enc, bit, 1);
            frame = frame + 1;
        }
        channel = channel + 1;
    }
    _ = try ec_enc_done(&enc);
    try ec_enc_check(&enc);
}

fn fill_lbrr_icdf(out: &[byte], frames_per_packet: i32) !void {
    if frames_per_packet == 2 {
        var i: usize = 0;
        while i < 3 {
            out.ptr[i] = silk_lbrr_flags_2_icdf_value(i);
            i = i + 1;
        }
        return;
    }
    if frames_per_packet == 3 {
        var j: usize = 0;
        while j < 7 {
            out.ptr[j] = silk_lbrr_flags_3_icdf_value(j);
            j = j + 1;
        }
        return;
    }
    try assert(false, "test LBRR iCDF helper only supports 2 or 3 frames");
}

fn encode_lbrr_payload(packet: &[byte], channel_flags: &[bool], frame_symbols: &[i32], channels: i32, frames_per_packet: i32) !void {
    var enc: EcEnc = EcEnc{};
    ec_enc_init(&enc, packet);
    var channel: i32 = 0;
    while channel < channels {
        var bit: i32 = 0;
        if channel_flags.ptr[channel as usize] {
            bit = 1;
        }
        ec_enc_bit_logp(&enc, bit, 1);
        if bit != 0 && frames_per_packet > 1 {
            var icdf: [byte: 7] = [0: 7];
            try fill_lbrr_icdf(&icdf[0:7], frames_per_packet);
            ec_enc_icdf(&enc, frame_symbols.ptr[channel as usize] - 1, &icdf[0:(((1 << frames_per_packet) - 1) as usize)], 8);
        }
        channel = channel + 1;
    }
    _ = try ec_enc_done(&enc);
    try ec_enc_check(&enc);
}

fn fill_type_offset_icdf(out: &[byte], vad: bool) usize {
    if vad {
        var i: usize = 0;
        while i < 4 {
            out.ptr[i] = silk_type_offset_vad_icdf_value(i);
            i = i + 1;
        }
        return 4 as usize;
    }

    var j: usize = 0;
    while j < 2 {
        out.ptr[j] = silk_type_offset_no_vad_icdf_value(j);
        j = j + 1;
    }
    return 2 as usize;
}

fn encode_type_offset_payload(packet: &[byte], symbols: &[i32], vad_flags: &[bool], channels: i32, frames_per_packet: i32) !void {
    var enc: EcEnc = EcEnc{};
    ec_enc_init(&enc, packet);
    var channel: i32 = 0;
    while channel < channels {
        var frame: i32 = 0;
        while frame < frames_per_packet {
            const index: usize = (channel as usize) * SILK_ENTROPY_MAX_FRAMES_PER_PACKET + (frame as usize);
            var icdf: [byte: 4] = [0: 4];
            const icdf_len: usize = fill_type_offset_icdf(&icdf[0:4], vad_flags.ptr[index]);
            ec_enc_icdf(&enc, symbols.ptr[index], &icdf[0:icdf_len], 8);
            frame = frame + 1;
        }
        channel = channel + 1;
    }
    _ = try ec_enc_done(&enc);
    try ec_enc_check(&enc);
}

fn fill_gain_icdf(out: &[byte], signal_table: i32) !void {
    if out.len < 8 {
        try assert(false, "test gain iCDF helper needs 8 bytes");
    }
    var i: usize = 0;
    while i < 8 {
        out.ptr[i] = silk_gain_icdf_value(signal_table, i);
        i = i + 1;
    }
}

fn fill_delta_gain_icdf(out: &[byte]) !void {
    if out.len < 41 {
        try assert(false, "test delta gain iCDF helper needs 41 bytes");
    }
    var i: usize = 0;
    while i < 41 {
        out.ptr[i] = silk_delta_gain_icdf_value(i);
        i = i + 1;
    }
}

fn fill_uniform8_icdf(out: &[byte]) !void {
    if out.len < 8 {
        try assert(false, "test uniform8 iCDF helper needs 8 bytes");
    }
    var i: usize = 0;
    while i < 8 {
        out.ptr[i] = silk_uniform8_icdf_value(i);
        i = i + 1;
    }
}

fn encode_independent_gains_payload(packet: &[byte], type_offset_symbol: i32, vad: bool, first_msb: i32, first_lsb: i32, delta_symbols: &[i32], nb_subframes: i32) !void {
    var enc: EcEnc = EcEnc{};
    ec_enc_init(&enc, packet);

    var type_icdf: [byte: 4] = [0: 4];
    const type_icdf_len: usize = fill_type_offset_icdf(&type_icdf[0:4], vad);
    ec_enc_icdf(&enc, type_offset_symbol, &type_icdf[0:type_icdf_len], 8);

    var gain_signal_table: i32 = 0;
    if vad {
        gain_signal_table = (type_offset_symbol >> 1) + 1;
    }
    var gain_icdf: [byte: 8] = [0: 8];
    try fill_gain_icdf(&gain_icdf[0:8], gain_signal_table);
    ec_enc_icdf(&enc, first_msb, &gain_icdf[0:8], 8);

    var uniform8_icdf: [byte: 8] = [0: 8];
    try fill_uniform8_icdf(&uniform8_icdf[0:8]);
    ec_enc_icdf(&enc, first_lsb, &uniform8_icdf[0:8], 8);

    var delta_icdf: [byte: 41] = [0: 41];
    try fill_delta_gain_icdf(&delta_icdf[0:41]);
    var subframe: i32 = 1;
    while subframe < nb_subframes {
        ec_enc_icdf(&enc, delta_symbols.ptr[(subframe - 1) as usize], &delta_icdf[0:41], 8);
        subframe = subframe + 1;
    }

    _ = try ec_enc_done(&enc);
    try ec_enc_check(&enc);
}

fn encode_conditional_gains_payload(packet: &[byte], type_offset_symbol: i32, vad: bool, delta_symbols: &[i32], nb_subframes: i32) !void {
    var enc: EcEnc = EcEnc{};
    ec_enc_init(&enc, packet);

    var type_icdf: [byte: 4] = [0: 4];
    const type_icdf_len: usize = fill_type_offset_icdf(&type_icdf[0:4], vad);
    ec_enc_icdf(&enc, type_offset_symbol, &type_icdf[0:type_icdf_len], 8);

    var delta_icdf: [byte: 41] = [0: 41];
    try fill_delta_gain_icdf(&delta_icdf[0:41]);
    var subframe: i32 = 0;
    while subframe < nb_subframes {
        ec_enc_icdf(&enc, delta_symbols.ptr[subframe as usize], &delta_icdf[0:41], 8);
        subframe = subframe + 1;
    }

    _ = try ec_enc_done(&enc);
    try ec_enc_check(&enc);
}

fn fill_nlsf_cb1_icdf(out: &[byte], codebook: i32, signal_type: i32) !void {
    if out.len < 32 || signal_type < 0 || signal_type > 1 {
        try assert(false, "test NLSF CB1 helper needs one 32-entry signal row");
    }
    const base: usize = (signal_type as usize) * 32;
    var i: usize = 0;
    while i < 32 {
        out.ptr[i] = silk_nlsf_cb1_icdf(codebook, base + i);
        i = i + 1;
    }
}

fn fill_nlsf_cb2_icdf(out: &[byte], codebook: i32, ec_ix: i16) !void {
    if out.len < 9 || ec_ix < 0 {
        try assert(false, "test NLSF CB2 helper needs one 9-entry row");
    }
    const base: usize = ec_ix as usize;
    var i: usize = 0;
    while i < 9 {
        out.ptr[i] = silk_nlsf_cb2_icdf(codebook, base + i);
        i = i + 1;
    }
}

fn fill_nlsf_ext_icdf(out: &[byte]) !void {
    if out.len < 7 {
        try assert(false, "test NLSF extension helper needs 7 entries");
    }
    var i: usize = 0;
    while i < 7 {
        out.ptr[i] = silk_nlsf_ext_icdf_value(i);
        i = i + 1;
    }
}

fn fill_nlsf_interpolation_icdf(out: &[byte]) !void {
    if out.len < 5 {
        try assert(false, "test NLSF interpolation helper needs 5 entries");
    }
    var i: usize = 0;
    while i < 5 {
        out.ptr[i] = silk_nlsf_interpolation_factor_icdf_value(i);
        i = i + 1;
    }
}

fn encode_nlsf_residual(enc: &EcEnc, codebook: i32, ec_ix: i16, residual_index: i16) !void {
    var raw_symbol: i32 = (residual_index as i32) + SILK_NLSF_QUANT_MAX_AMPLITUDE;
    var ext_symbol: i32 = 0;
    if raw_symbol < 0 {
        ext_symbol = -raw_symbol;
        raw_symbol = 0;
    } else if raw_symbol > 2 * SILK_NLSF_QUANT_MAX_AMPLITUDE {
        ext_symbol = raw_symbol - 2 * SILK_NLSF_QUANT_MAX_AMPLITUDE;
        raw_symbol = 2 * SILK_NLSF_QUANT_MAX_AMPLITUDE;
    }
    if ext_symbol < 0 || ext_symbol > 6 {
        try assert(false, "test NLSF residual is outside upstream extension range");
    }

    var cb2_icdf: [byte: 9] = [0: 9];
    try fill_nlsf_cb2_icdf(&cb2_icdf[0:9], codebook, ec_ix);
    ec_enc_icdf(enc, raw_symbol, &cb2_icdf[0:9], 8);
    if raw_symbol == 0 || raw_symbol == 2 * SILK_NLSF_QUANT_MAX_AMPLITUDE {
        var ext_icdf: [byte: 7] = [0: 7];
        try fill_nlsf_ext_icdf(&ext_icdf[0:7]);
        ec_enc_icdf(enc, ext_symbol, &ext_icdf[0:7], 8);
    }
}

fn encode_nlsf_payload(packet: &[byte], type_offset_symbol: i32, vad: bool, codebook: i32, signal_type: i32, cb1_index: i32, residual_indices: &[i16], interpolation_symbol: i32, nb_subframes: i32) !void {
    var enc: EcEnc = EcEnc{};
    ec_enc_init(&enc, packet);

    var type_icdf: [byte: 4] = [0: 4];
    const type_icdf_len: usize = fill_type_offset_icdf(&type_icdf[0:4], vad);
    ec_enc_icdf(&enc, type_offset_symbol, &type_icdf[0:type_icdf_len], 8);

    var cb1_icdf: [byte: 32] = [0: 32];
    try fill_nlsf_cb1_icdf(&cb1_icdf[0:32], codebook, signal_type);
    ec_enc_icdf(&enc, cb1_index, &cb1_icdf[0:32], 8);

    var ec_ix: [i16: SILK_NLSF_MAX_ORDER] = [0: SILK_NLSF_MAX_ORDER];
    var pred_q8: [byte: SILK_NLSF_MAX_ORDER] = [0: SILK_NLSF_MAX_ORDER];
    try silk_nlsf_unpack_ec_tables(&ec_ix[0:SILK_NLSF_MAX_ORDER], &pred_q8[0:SILK_NLSF_MAX_ORDER], codebook, cb1_index);
    var i: usize = 0;
    while i < residual_indices.len {
        try encode_nlsf_residual(&enc, codebook, ec_ix[i], residual_indices.ptr[i]);
        i = i + 1;
    }

    if nb_subframes == (SILK_ENTROPY_MAX_NB_SUBFR as i32) {
        var interpolation_icdf: [byte: 5] = [0: 5];
        try fill_nlsf_interpolation_icdf(&interpolation_icdf[0:5]);
        ec_enc_icdf(&enc, interpolation_symbol, &interpolation_icdf[0:5], 8);
    }

    _ = try ec_enc_done(&enc);
    try ec_enc_check(&enc);
}

fn fill_pitch_lag_icdf(out: &[byte]) !void {
    if out.len < 32 {
        try assert(false, "test pitch lag helper needs 32 entries");
    }
    var i: usize = 0;
    while i < 32 {
        out.ptr[i] = silk_pitch_lag_icdf_value(i);
        i = i + 1;
    }
}

fn fill_pitch_delta_icdf(out: &[byte]) !void {
    if out.len < 21 {
        try assert(false, "test pitch delta helper needs 21 entries");
    }
    var i: usize = 0;
    while i < 21 {
        out.ptr[i] = silk_pitch_delta_icdf_value(i);
        i = i + 1;
    }
}

fn fill_pitch_low_bits_icdf(out: &[byte], fs_khz: i32) !usize {
    if fs_khz == 8 {
        if out.len < 4 {
            try assert(false, "NB pitch low bits need 4 entries");
        }
        var i: usize = 0;
        while i < 4 {
            out.ptr[i] = silk_uniform4_icdf_value(i);
            i = i + 1;
        }
        return 4 as usize;
    }
    if fs_khz == 12 {
        if out.len < 6 {
            try assert(false, "MB pitch low bits need 6 entries");
        }
        var j: usize = 0;
        while j < 6 {
            out.ptr[j] = silk_uniform6_icdf_value(j);
            j = j + 1;
        }
        return 6 as usize;
    }
    if fs_khz == 16 {
        if out.len < 8 {
            try assert(false, "WB pitch low bits need 8 entries");
        }
        var k: usize = 0;
        while k < 8 {
            out.ptr[k] = silk_uniform8_icdf_value(k);
            k = k + 1;
        }
        return 8 as usize;
    }
    try assert(false, "test pitch low bits helper only supports SILK internal rates");
    return 0 as usize;
}

fn encode_pitch_lag_absolute(enc: &EcEnc, fs_khz: i32, lag_index: i32) !void {
    const low_bits_len: i32 = fs_khz >> 1;
    const high_symbol: i32 = lag_index / low_bits_len;
    const low_symbol: i32 = lag_index - high_symbol * low_bits_len;
    var pitch_icdf: [byte: 32] = [0: 32];
    try fill_pitch_lag_icdf(&pitch_icdf[0:32]);
    ec_enc_icdf(enc, high_symbol, &pitch_icdf[0:32], 8);

    var low_icdf: [byte: 8] = [0: 8];
    const low_len: usize = try fill_pitch_low_bits_icdf(&low_icdf[0:8], fs_khz);
    ec_enc_icdf(enc, low_symbol, &low_icdf[0:low_len], 8);
}

fn encode_pitch_lag_independent_payload(packet: &[byte], type_offset_symbol: i32, vad: bool, fs_khz: i32, lag_index: i32) !void {
    var enc: EcEnc = EcEnc{};
    ec_enc_init(&enc, packet);

    var type_icdf: [byte: 4] = [0: 4];
    const type_icdf_len: usize = fill_type_offset_icdf(&type_icdf[0:4], vad);
    ec_enc_icdf(&enc, type_offset_symbol, &type_icdf[0:type_icdf_len], 8);
    try encode_pitch_lag_absolute(&enc, fs_khz, lag_index);

    _ = try ec_enc_done(&enc);
    try ec_enc_check(&enc);
}

fn encode_pitch_lag_delta_payload(packet: &[byte], first_type_offset: i32, second_type_offset: i32, fs_khz: i32, first_lag_index: i32, delta_symbol: i32) !void {
    var enc: EcEnc = EcEnc{};
    ec_enc_init(&enc, packet);

    var type_icdf: [byte: 4] = [0: 4];
    const type_icdf_len: usize = fill_type_offset_icdf(&type_icdf[0:4], true);
    ec_enc_icdf(&enc, first_type_offset, &type_icdf[0:type_icdf_len], 8);
    try encode_pitch_lag_absolute(&enc, fs_khz, first_lag_index);
    ec_enc_icdf(&enc, second_type_offset, &type_icdf[0:type_icdf_len], 8);

    var delta_icdf: [byte: 21] = [0: 21];
    try fill_pitch_delta_icdf(&delta_icdf[0:21]);
    ec_enc_icdf(&enc, delta_symbol, &delta_icdf[0:21], 8);

    _ = try ec_enc_done(&enc);
    try ec_enc_check(&enc);
}

fn fill_pitch_contour_icdf(out: &[byte], fs_khz: i32, nb_subframes: i32) !usize {
    if fs_khz == 8 && nb_subframes == 4 {
        if out.len < 11 {
            try assert(false, "NB 20ms contour helper needs 11 entries");
        }
        var i: usize = 0;
        while i < 11 {
            out.ptr[i] = silk_pitch_contour_nb_icdf_value(i);
            i = i + 1;
        }
        return 11 as usize;
    }
    if fs_khz == 8 && nb_subframes == 2 {
        if out.len < 3 {
            try assert(false, "NB 10ms contour helper needs 3 entries");
        }
        var j: usize = 0;
        while j < 3 {
            out.ptr[j] = silk_pitch_contour_10_ms_nb_icdf_value(j);
            j = j + 1;
        }
        return 3 as usize;
    }
    if nb_subframes == 4 {
        if out.len < 34 {
            try assert(false, "WB/MB 20ms contour helper needs 34 entries");
        }
        var k: usize = 0;
        while k < 34 {
            out.ptr[k] = silk_pitch_contour_icdf_value(k);
            k = k + 1;
        }
        return 34 as usize;
    }
    if nb_subframes == 2 {
        if out.len < 12 {
            try assert(false, "WB/MB 10ms contour helper needs 12 entries");
        }
        var p: usize = 0;
        while p < 12 {
            out.ptr[p] = silk_pitch_contour_10_ms_icdf_value(p);
            p = p + 1;
        }
        return 12 as usize;
    }
    try assert(false, "test pitch contour helper only supports 10ms or 20ms SILK frames");
    return 0 as usize;
}

fn encode_pitch_contour_payload(packet: &[byte], type_offset_symbol: i32, fs_khz: i32, nb_subframes: i32, lag_index: i32, contour_index: i32) !void {
    var enc: EcEnc = EcEnc{};
    ec_enc_init(&enc, packet);

    var type_icdf: [byte: 4] = [0: 4];
    const type_icdf_len: usize = fill_type_offset_icdf(&type_icdf[0:4], true);
    ec_enc_icdf(&enc, type_offset_symbol, &type_icdf[0:type_icdf_len], 8);
    try encode_pitch_lag_absolute(&enc, fs_khz, lag_index);

    var contour_icdf: [byte: 34] = [0: 34];
    const contour_len: usize = try fill_pitch_contour_icdf(&contour_icdf[0:34], fs_khz, nb_subframes);
    ec_enc_icdf(&enc, contour_index, &contour_icdf[0:contour_len], 8);

    _ = try ec_enc_done(&enc);
    try ec_enc_check(&enc);
}

fn fill_test_ltp_periodicity_icdf(out: &[byte]) !void {
    if out.len < 3 {
        try assert(false, "LTP periodicity helper needs 3 entries");
    }
    var i: usize = 0;
    while i < 3 {
        out.ptr[i] = silk_ltp_per_index_icdf_value(i);
        i = i + 1;
    }
}

fn fill_test_ltp_gain_icdf(out: &[byte], periodicity_index: i32) !usize {
    if periodicity_index == 0 {
        if out.len < 8 {
            try assert(false, "LTP gain helper needs 8 entries");
        }
        var i: usize = 0;
        while i < 8 {
            out.ptr[i] = silk_ltp_gain_icdf_value(periodicity_index, i);
            i = i + 1;
        }
        return 8 as usize;
    }
    if periodicity_index == 1 {
        if out.len < 16 {
            try assert(false, "LTP gain helper needs 16 entries");
        }
        var j: usize = 0;
        while j < 16 {
            out.ptr[j] = silk_ltp_gain_icdf_value(periodicity_index, j);
            j = j + 1;
        }
        return 16 as usize;
    }
    if periodicity_index == 2 {
        if out.len < 32 {
            try assert(false, "LTP gain helper needs 32 entries");
        }
        var k: usize = 0;
        while k < 32 {
            out.ptr[k] = silk_ltp_gain_icdf_value(periodicity_index, k);
            k = k + 1;
        }
        return 32 as usize;
    }
    try assert(false, "test LTP helper supports periodicity indexes 0..2");
    return 0 as usize;
}

fn fill_test_ltp_scale_icdf(out: &[byte]) !void {
    if out.len < 3 {
        try assert(false, "LTP scale helper needs 3 entries");
    }
    var i: usize = 0;
    while i < 3 {
        out.ptr[i] = silk_ltp_scale_icdf_value(i);
        i = i + 1;
    }
}

fn encode_ltp_coefficients_payload(packet: &[byte], type_offset_symbol: i32, fs_khz: i32, nb_subframes: i32, lag_index: i32, contour_index: i32, periodicity_index: i32, cb0: i32, cb1: i32, cb2: i32, cb3: i32) !void {
    var enc: EcEnc = EcEnc{};
    ec_enc_init(&enc, packet);

    var type_icdf: [byte: 4] = [0: 4];
    const type_icdf_len: usize = fill_type_offset_icdf(&type_icdf[0:4], true);
    ec_enc_icdf(&enc, type_offset_symbol, &type_icdf[0:type_icdf_len], 8);
    try encode_pitch_lag_absolute(&enc, fs_khz, lag_index);

    var contour_icdf: [byte: 34] = [0: 34];
    const contour_len: usize = try fill_pitch_contour_icdf(&contour_icdf[0:34], fs_khz, nb_subframes);
    ec_enc_icdf(&enc, contour_index, &contour_icdf[0:contour_len], 8);

    var per_icdf: [byte: 3] = [0: 3];
    try fill_test_ltp_periodicity_icdf(&per_icdf[0:3]);
    ec_enc_icdf(&enc, periodicity_index, &per_icdf[0:3], 8);

    var gain_icdf: [byte: 32] = [0: 32];
    const gain_len: usize = try fill_test_ltp_gain_icdf(&gain_icdf[0:32], periodicity_index);
    ec_enc_icdf(&enc, cb0, &gain_icdf[0:gain_len], 8);
    ec_enc_icdf(&enc, cb1, &gain_icdf[0:gain_len], 8);
    if nb_subframes > 2 {
        ec_enc_icdf(&enc, cb2, &gain_icdf[0:gain_len], 8);
        ec_enc_icdf(&enc, cb3, &gain_icdf[0:gain_len], 8);
    }

    _ = try ec_enc_done(&enc);
    try ec_enc_check(&enc);
}

fn encode_ltp_scaling_payload(packet: &[byte], type_offset_symbol: i32, fs_khz: i32, nb_subframes: i32, lag_index: i32, contour_index: i32, periodicity_index: i32, cb0: i32, cb1: i32, cb2: i32, cb3: i32, scale_index: i32) !void {
    var enc: EcEnc = EcEnc{};
    ec_enc_init(&enc, packet);

    var type_icdf: [byte: 4] = [0: 4];
    const type_icdf_len: usize = fill_type_offset_icdf(&type_icdf[0:4], true);
    ec_enc_icdf(&enc, type_offset_symbol, &type_icdf[0:type_icdf_len], 8);
    try encode_pitch_lag_absolute(&enc, fs_khz, lag_index);

    var contour_icdf: [byte: 34] = [0: 34];
    const contour_len: usize = try fill_pitch_contour_icdf(&contour_icdf[0:34], fs_khz, nb_subframes);
    ec_enc_icdf(&enc, contour_index, &contour_icdf[0:contour_len], 8);

    var per_icdf: [byte: 3] = [0: 3];
    try fill_test_ltp_periodicity_icdf(&per_icdf[0:3]);
    ec_enc_icdf(&enc, periodicity_index, &per_icdf[0:3], 8);

    var gain_icdf: [byte: 32] = [0: 32];
    const gain_len: usize = try fill_test_ltp_gain_icdf(&gain_icdf[0:32], periodicity_index);
    ec_enc_icdf(&enc, cb0, &gain_icdf[0:gain_len], 8);
    ec_enc_icdf(&enc, cb1, &gain_icdf[0:gain_len], 8);
    if nb_subframes > 2 {
        ec_enc_icdf(&enc, cb2, &gain_icdf[0:gain_len], 8);
        ec_enc_icdf(&enc, cb3, &gain_icdf[0:gain_len], 8);
    }

    var scale_icdf: [byte: 3] = [0: 3];
    try fill_test_ltp_scale_icdf(&scale_icdf[0:3]);
    ec_enc_icdf(&enc, scale_index, &scale_icdf[0:3], 8);

    _ = try ec_enc_done(&enc);
    try ec_enc_check(&enc);
}

test "silk entropy decoder initializes layout and reads range symbols" {
    var packet: [byte: 32] = [0: 32];
    try encode_test_payload(&packet[0:32]);

    var dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&dec, &packet[0:32], 2, 3);

    try assert_eq_i32(dec.channels, 2);
    try assert_eq_i32(dec.frames_per_packet, 3);
    try assert_eq_i32(dec.current_frame, 0);
    try assert_eq_i32(dec.ec.storage as i32, 32);
    try assert_eq_i32(SILK_ENTROPY_MAX_FRAMES_PER_PACKET as i32, 12);
    try assert_eq_i32((try silk_entropy_decoder_flag_index(&dec, 0, 0)) as i32, 0);
    try assert_eq_i32((try silk_entropy_decoder_flag_index(&dec, 1, 2)) as i32, 14);

    try silk_entropy_decoder_set_frame(&dec, 2);
    try assert_eq_i32(dec.current_frame, 2);

    const icdf: [byte: 4] = [200, 100, 40, 0];
    try assert_eq_i32(try silk_entropy_decode_icdf(&dec, &icdf[0:4], 8), 2);
    try assert_eq_i32(try silk_entropy_decode_bit_logp(&dec, 3), 1);
    try silk_entropy_decoder_check(&dec);
}

test "silk entropy decoder validates layout indexes and cdfs" {
    var packet: [byte: 8] = [0: 8];
    var dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&dec, &packet[0:8], 1, 2);

    const bad_channels: !void = silk_entropy_decoder_init(&dec, &packet[0:8], 3, 1);
    match bad_channels {
        error.SilkEntropyDecodeError => {}
        else => { try assert(false, "SILK entropy decode must reject channels above stereo"); }
    }

    const bad_frames: !void = silk_entropy_decoder_init(&dec, &packet[0:8], 1, 13);
    match bad_frames {
        error.SilkEntropyDecodeError => {}
        else => { try assert(false, "SILK entropy decode must reject packet frame counts above 120 ms / 10 ms"); }
    }

    const empty_payload: !void = silk_entropy_decoder_init(&dec, &packet[0:0], 1, 1);
    match empty_payload {
        error.SilkEntropyDecodeError => {}
        else => { try assert(false, "SILK entropy decode must reject empty range payloads"); }
    }

    const bad_index: !usize = silk_entropy_decoder_flag_index(&dec, 1, 0);
    match bad_index {
        error.SilkEntropyDecodeError => {}
        else => { try assert(false, "SILK entropy flag index must reject inactive channels"); }
    }

    const bad_frame: !void = silk_entropy_decoder_set_frame(&dec, 2);
    match bad_frame {
        error.SilkEntropyDecodeError => {}
        else => { try assert(false, "SILK entropy decoder must reject inactive frame index"); }
    }

    const bad_icdf: [byte: 3] = [200, 210, 0];
    const icdf_result: !i32 = silk_entropy_decode_icdf(&dec, &bad_icdf[0:3], 8);
    match icdf_result {
        error.SilkEntropyDecodeError => {}
        else => { try assert(false, "SILK entropy decode must reject non-monotonic iCDFs"); }
    }
}

test "silk entropy decoder decodes VAD flags in channel-major order" {
    var expected: [bool: 24] = [false: 24];
    expected[0] = true;
    expected[2] = true;
    expected[13] = true;
    expected[14] = true;

    var packet: [byte: 32] = [0: 32];
    try encode_vad_payload(&packet[0:32], &expected[0:24], 2, 3);

    var dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&dec, &packet[0:32], 2, 3);
    dec.vad_flags[0] = false;
    dec.vad_flags[1] = true;
    dec.vad_flags[13] = false;
    try silk_entropy_decode_vad_flags(&dec);
    try silk_entropy_decoder_check(&dec);

    try assert(dec.vad_flags[0], "channel 0 frame 0 VAD");
    try assert(!dec.vad_flags[1], "channel 0 frame 1 no VAD");
    try assert(dec.vad_flags[2], "channel 0 frame 2 VAD");
    try assert(!dec.vad_flags[12], "channel 1 frame 0 no VAD");
    try assert(dec.vad_flags[13], "channel 1 frame 1 VAD");
    try assert(dec.vad_flags[14], "channel 1 frame 2 VAD");
}

