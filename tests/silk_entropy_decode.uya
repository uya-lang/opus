    try assert_eq_i32(silk_uniform4_icdf_value(3) as i32, 0);
    try assert_eq_i32(silk_uniform6_icdf_value(0) as i32, 213);
    try assert_eq_i32(silk_uniform6_icdf_value(5) as i32, 0);
}

test "silk entropy decoder decodes independent pitch lag" {
    var packet: [byte: 32] = [0: 32];
    try encode_pitch_lag_independent_payload(&packet[0:32], 2, true, 16, 101);

    var dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&dec, &packet[0:32], 1, 1);
    dec.vad_flags[0] = true;
    try assert_eq_i32(try silk_entropy_decode_signal_type(&dec, 0, 0), SILK_SIGNAL_TYPE_VOICED);

    var control: SilkDecoderControl = SilkDecoderControl{};
    control.channels = 1;
    control.fs_khz = 16;
    control.frame_length = 320;
    control.subframe_length = 80;
    control.nb_subframes = 4;
    control.lpc_order = 16;
    try silk_entropy_decode_pitch_lag(&dec, &control, 0, 0, false);

    try assert(dec.pitch_lag_valid[0], "pitch lag for frame 0 is cached");
    try assert_eq_i32(dec.pitch_lag_indices[0], 101);
    try assert_eq_i32(dec.pitch_lag_values[0], 133);
    try assert_eq_i32(dec.last_pitch_lag_indices[0], 101);
    try assert(dec.last_pitch_lag_valid[0], "last voiced pitch lag is available for conditional coding");
    try assert_eq_i32(control.pitch_lags[0], 133);
    try assert_eq_i32(control.pitch_lags[1], 133);
    try assert_eq_i32(control.pitch_lags[2], 133);
    try assert_eq_i32(control.pitch_lags[3], 133);
}

test "silk entropy decoder decodes conditional pitch lag deltas" {
    var packet: [byte: 48] = [0: 48];
    try encode_pitch_lag_delta_payload(&packet[0:48], 2, 2, 16, 82, 12);

    var dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&dec, &packet[0:48], 1, 2);
    dec.vad_flags[0] = true;
    dec.vad_flags[1] = true;

    var control: SilkDecoderControl = SilkDecoderControl{};
    control.channels = 1;
    control.fs_khz = 16;
    control.frame_length = 160;
    control.subframe_length = 80;
    control.nb_subframes = 2;
    control.lpc_order = 16;

    try assert_eq_i32(try silk_entropy_decode_signal_type(&dec, 0, 0), SILK_SIGNAL_TYPE_VOICED);
    try silk_entropy_decode_pitch_lag(&dec, &control, 0, 0, false);
    try assert_eq_i32(dec.pitch_lag_indices[0], 82);
    try assert_eq_i32(control.pitch_lags[0], 114);

    try assert_eq_i32(try silk_entropy_decode_signal_type(&dec, 0, 1), SILK_SIGNAL_TYPE_VOICED);
    try silk_entropy_decode_pitch_lag(&dec, &control, 0, 1, true);
    try assert_eq_i32(dec.pitch_lag_indices[1], 85);
    try assert_eq_i32(dec.pitch_lag_values[1], 117);
    try assert_eq_i32(dec.last_pitch_lag_indices[0], 85);
    try assert_eq_i32(control.pitch_lags[0], 117);
    try assert_eq_i32(control.pitch_lags[1], 117);
}

test "silk entropy decoder rejects pitch lag for unvoiced frames" {
    var packet: [byte: 16] = [0: 16];
    var symbols: [i32: 24] = [0: 24];
    var vad: [bool: 24] = [false: 24];
    symbols[0] = 1;
    try encode_type_offset_payload(&packet[0:16], &symbols[0:24], &vad[0:24], 1, 1);

    var dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&dec, &packet[0:16], 1, 1);
    try assert_eq_i32(try silk_entropy_decode_signal_type(&dec, 0, 0), SILK_SIGNAL_TYPE_UNVOICED);
    try assert(!dec.last_pitch_lag_valid[0], "unvoiced signal clears conditional pitch history");

    var control: SilkDecoderControl = SilkDecoderControl{};
    control.channels = 1;
    control.fs_khz = 8;
    control.frame_length = 80;
    control.subframe_length = 40;
    control.nb_subframes = 2;
    control.lpc_order = 10;
    const result: !void = silk_entropy_decode_pitch_lag(&dec, &control, 0, 0, false);
    match result {
        error.SilkEntropyDecodeError => {}
        else => { try assert(false, "pitch lag decode must reject unvoiced frames"); }
    }
}

