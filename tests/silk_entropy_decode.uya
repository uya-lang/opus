    try assert_eq_i32(silk_pitch_contour_icdf_value(33) as i32, 0);
    try assert_eq_i32(silk_pitch_contour_nb_icdf_value(0) as i32, 188);
    try assert_eq_i32(silk_pitch_contour_nb_icdf_value(10) as i32, 0);
    try assert_eq_i32(silk_pitch_contour_10_ms_icdf_value(0) as i32, 165);
    try assert_eq_i32(silk_pitch_contour_10_ms_icdf_value(11) as i32, 0);
    try assert_eq_i32(silk_pitch_contour_10_ms_nb_icdf_value(0) as i32, 113);
    try assert_eq_i32(silk_pitch_contour_10_ms_nb_icdf_value(2) as i32, 0);
