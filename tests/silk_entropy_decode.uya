test "silk entropy decoder decodes LTP coefficients into control" {
    var packet: [byte: 64] = [0: 64];
    try encode_ltp_coefficients_payload(&packet[0:64], 2, 16, 4, 101, 10, 2, 0, 7, 18, 31);

    var dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&dec, &packet[0:64], 1, 1);
    dec.vad_flags[0] = true;
    try assert_eq_i32(try silk_entropy_decode_signal_type(&dec, 0, 0), SILK_SIGNAL_TYPE_VOICED);

    var control: SilkDecoderControl = SilkDecoderControl{};
    control.channels = 1;
    control.fs_khz = 16;
    control.frame_length = 320;
    control.subframe_length = 80;
    control.nb_subframes = 4;
    control.lpc_order = 16;
    try silk_entropy_decode_pitch_lag(&dec, &control, 0, 0, false);
    try silk_entropy_decode_pitch_contour(&dec, &control, 0, 0);
    try silk_entropy_decode_ltp_coefficients(&dec, &control, 0, 0);

    try assert(dec.ltp_coefficients_valid[0], "LTP coefficients for frame 0 are cached");
    try assert_eq_i32(dec.ltp_periodicity_indices[0], 2);
    try assert_eq_i32(control.signal_type, SILK_SIGNAL_TYPE_VOICED);
    try assert_eq_i32(control.ltp_coef_q14[0] as i32, -768);
    try assert_eq_i32(control.ltp_coef_q14[2] as i32, 7808);
    try assert_eq_i32(control.ltp_coef_q14[5] as i32, 384);
    try assert_eq_i32(control.ltp_coef_q14[7] as i32, 1664);
    try assert_eq_i32(control.ltp_coef_q14[12] as i32, 5376);
    try assert_eq_i32(control.ltp_coef_q14[19] as i32, 11264);
}

