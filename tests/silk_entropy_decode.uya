use std.testing.assert;
use std.testing.assert_eq_i32;
use src.opus.entropy.range_enc.EcEnc;
use src.opus.entropy.range_enc.ec_enc_bit_logp;
use src.opus.entropy.range_enc.ec_enc_check;
use src.opus.entropy.range_enc.ec_enc_done;
use src.opus.entropy.range_enc.ec_enc_icdf;
use src.opus.entropy.range_enc.ec_enc_init;
use src.opus.silk.entropy_decode.SILK_ENTROPY_MAX_FRAMES_PER_PACKET;
use src.opus.silk.entropy_decode.SilkEntropyDecoder;
use src.opus.silk.entropy_decode.silk_entropy_decode_bit_logp;
use src.opus.silk.entropy_decode.silk_entropy_decode_icdf;
use src.opus.silk.entropy_decode.silk_entropy_decode_lbrr_flags;
use src.opus.silk.entropy_decode.silk_entropy_decode_vad_flags;
use src.opus.silk.entropy_decode.silk_entropy_decoder_check;
use src.opus.silk.entropy_decode.silk_entropy_decoder_flag_index;
use src.opus.silk.entropy_decode.silk_entropy_decoder_init;
use src.opus.silk.entropy_decode.silk_entropy_decoder_set_frame;
use src.opus.silk.tables.silk_lbrr_flags_2_icdf_value;
use src.opus.silk.tables.silk_lbrr_flags_3_icdf_value;
use src.opus.silk.tables.silk_table_len;

fn encode_test_payload(packet: &[byte]) !void {
    const icdf: [byte: 4] = [200, 100, 40, 0];
    var enc: EcEnc = EcEnc{};
    ec_enc_init(&enc, packet);
    ec_enc_icdf(&enc, 2, &icdf[0:4], 8);
    ec_enc_bit_logp(&enc, 1, 3);
    _ = try ec_enc_done(&enc);
    try ec_enc_check(&enc);
}

fn encode_vad_payload(packet: &[byte], flags: &[bool], channels: i32, frames_per_packet: i32) !void {
    var enc: EcEnc = EcEnc{};
    ec_enc_init(&enc, packet);
    var channel: i32 = 0;
    while channel < channels {
        var frame: i32 = 0;
        while frame < frames_per_packet {
            const index: usize = (channel as usize) * SILK_ENTROPY_MAX_FRAMES_PER_PACKET + (frame as usize);
            var bit: i32 = 0;
            if flags.ptr[index] {
                bit = 1;
            }
            ec_enc_bit_logp(&enc, bit, 1);
            frame = frame + 1;
        }
        channel = channel + 1;
    }
    _ = try ec_enc_done(&enc);
    try ec_enc_check(&enc);
}

fn fill_lbrr_icdf(out: &[byte], frames_per_packet: i32) !void {
    if frames_per_packet == 2 {
        var i: usize = 0;
        while i < 3 {
            out.ptr[i] = silk_lbrr_flags_2_icdf_value(i);
            i = i + 1;
        }
        return;
    }
    if frames_per_packet == 3 {
        var j: usize = 0;
        while j < 7 {
            out.ptr[j] = silk_lbrr_flags_3_icdf_value(j);
            j = j + 1;
        }
        return;
    }
    try assert(false, "test LBRR iCDF helper only supports 2 or 3 frames");
}

fn encode_lbrr_payload(packet: &[byte], channel_flags: &[bool], frame_symbols: &[i32], channels: i32, frames_per_packet: i32) !void {
    var enc: EcEnc = EcEnc{};
    ec_enc_init(&enc, packet);
    var channel: i32 = 0;
    while channel < channels {
        var bit: i32 = 0;
        if channel_flags.ptr[channel as usize] {
            bit = 1;
        }
        ec_enc_bit_logp(&enc, bit, 1);
        if bit != 0 && frames_per_packet > 1 {
            var icdf: [byte: 7] = [0: 7];
            try fill_lbrr_icdf(&icdf[0:7], frames_per_packet);
            ec_enc_icdf(&enc, frame_symbols.ptr[channel as usize] - 1, &icdf[0:(((1 << frames_per_packet) - 1) as usize)], 8);
        }
        channel = channel + 1;
    }
    _ = try ec_enc_done(&enc);
    try ec_enc_check(&enc);
}

test "silk entropy decoder initializes layout and reads range symbols" {
    var packet: [byte: 32] = [0: 32];
    try encode_test_payload(&packet[0:32]);

    var dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&dec, &packet[0:32], 2, 3);

    try assert_eq_i32(dec.channels, 2);
    try assert_eq_i32(dec.frames_per_packet, 3);
    try assert_eq_i32(dec.current_frame, 0);
    try assert_eq_i32(dec.ec.storage as i32, 32);
    try assert_eq_i32(SILK_ENTROPY_MAX_FRAMES_PER_PACKET as i32, 12);
    try assert_eq_i32((try silk_entropy_decoder_flag_index(&dec, 0, 0)) as i32, 0);
    try assert_eq_i32((try silk_entropy_decoder_flag_index(&dec, 1, 2)) as i32, 14);

    try silk_entropy_decoder_set_frame(&dec, 2);
    try assert_eq_i32(dec.current_frame, 2);

    const icdf: [byte: 4] = [200, 100, 40, 0];
    try assert_eq_i32(try silk_entropy_decode_icdf(&dec, &icdf[0:4], 8), 2);
    try assert_eq_i32(try silk_entropy_decode_bit_logp(&dec, 3), 1);
    try silk_entropy_decoder_check(&dec);
}

test "silk entropy decoder validates layout indexes and cdfs" {
    var packet: [byte: 8] = [0: 8];
    var dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&dec, &packet[0:8], 1, 2);

    const bad_channels: !void = silk_entropy_decoder_init(&dec, &packet[0:8], 3, 1);
    match bad_channels {
        error.SilkEntropyDecodeError => {}
        else => { try assert(false, "SILK entropy decode must reject channels above stereo"); }
    }

    const bad_frames: !void = silk_entropy_decoder_init(&dec, &packet[0:8], 1, 13);
    match bad_frames {
        error.SilkEntropyDecodeError => {}
        else => { try assert(false, "SILK entropy decode must reject packet frame counts above 120 ms / 10 ms"); }
    }

    const empty_payload: !void = silk_entropy_decoder_init(&dec, &packet[0:0], 1, 1);
    match empty_payload {
        error.SilkEntropyDecodeError => {}
        else => { try assert(false, "SILK entropy decode must reject empty range payloads"); }
    }

    const bad_index: !usize = silk_entropy_decoder_flag_index(&dec, 1, 0);
    match bad_index {
        error.SilkEntropyDecodeError => {}
        else => { try assert(false, "SILK entropy flag index must reject inactive channels"); }
    }

    const bad_frame: !void = silk_entropy_decoder_set_frame(&dec, 2);
    match bad_frame {
        error.SilkEntropyDecodeError => {}
        else => { try assert(false, "SILK entropy decoder must reject inactive frame index"); }
    }

    const bad_icdf: [byte: 3] = [200, 210, 0];
    const icdf_result: !i32 = silk_entropy_decode_icdf(&dec, &bad_icdf[0:3], 8);
    match icdf_result {
        error.SilkEntropyDecodeError => {}
        else => { try assert(false, "SILK entropy decode must reject non-monotonic iCDFs"); }
    }
}

test "silk entropy decoder decodes VAD flags in channel-major order" {
    var expected: [bool: 24] = [false: 24];
    expected[0] = true;
    expected[2] = true;
    expected[13] = true;
    expected[14] = true;

    var packet: [byte: 32] = [0: 32];
    try encode_vad_payload(&packet[0:32], &expected[0:24], 2, 3);

    var dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&dec, &packet[0:32], 2, 3);
    dec.vad_flags[0] = false;
    dec.vad_flags[1] = true;
    dec.vad_flags[13] = false;
    try silk_entropy_decode_vad_flags(&dec);
    try silk_entropy_decoder_check(&dec);

    try assert(dec.vad_flags[0], "channel 0 frame 0 VAD");
    try assert(!dec.vad_flags[1], "channel 0 frame 1 no VAD");
    try assert(dec.vad_flags[2], "channel 0 frame 2 VAD");
    try assert(!dec.vad_flags[12], "channel 1 frame 0 no VAD");
    try assert(dec.vad_flags[13], "channel 1 frame 1 VAD");
    try assert(dec.vad_flags[14], "channel 1 frame 2 VAD");
}

test "silk entropy decoder exposes LBRR flag tables" {
    try assert_eq_i32(silk_table_len(14) as i32, 3);
    try assert_eq_i32(silk_table_len(15) as i32, 7);
    try assert_eq_i32(silk_lbrr_flags_2_icdf_value(0) as i32, 203);
    try assert_eq_i32(silk_lbrr_flags_2_icdf_value(2) as i32, 0);
    try assert_eq_i32(silk_lbrr_flags_3_icdf_value(0) as i32, 215);
    try assert_eq_i32(silk_lbrr_flags_3_icdf_value(6) as i32, 0);
}

test "silk entropy decoder decodes LBRR frame masks" {
    var channel_flags: [bool: 2] = [false: 2];
    var frame_symbols: [i32: 2] = [0: 2];
    channel_flags[0] = true;
    frame_symbols[0] = 5;

    var packet: [byte: 32] = [0: 32];
    try encode_lbrr_payload(&packet[0:32], &channel_flags[0:2], &frame_symbols[0:2], 2, 3);

    var dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&dec, &packet[0:32], 2, 3);
    dec.lbrr_flags[1] = true;
    dec.lbrr_channel_flags[1] = true;
    try silk_entropy_decode_lbrr_flags(&dec);
    try silk_entropy_decoder_check(&dec);

    try assert(dec.lbrr_channel_flags[0], "channel 0 has LBRR");
    try assert(!dec.lbrr_channel_flags[1], "channel 1 has no LBRR");
    try assert(dec.lbrr_flags[0], "channel 0 frame 0 LBRR");
    try assert(!dec.lbrr_flags[1], "channel 0 frame 1 no LBRR");
    try assert(dec.lbrr_flags[2], "channel 0 frame 2 LBRR");
    try assert(!dec.lbrr_flags[12], "channel 1 frame 0 no LBRR");
    try assert(!dec.lbrr_flags[13], "channel 1 frame 1 no LBRR");
    try assert(!dec.lbrr_flags[14], "channel 1 frame 2 no LBRR");
}

test "silk entropy decoder handles one and two frame LBRR masks" {
    var channel_flags: [bool: 2] = [false: 2];
    var frame_symbols: [i32: 2] = [0: 2];
    channel_flags[0] = true;
    frame_symbols[0] = 2;

    var two_frame_packet: [byte: 32] = [0: 32];
    try encode_lbrr_payload(&two_frame_packet[0:32], &channel_flags[0:2], &frame_symbols[0:2], 1, 2);

    var two_frame_dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&two_frame_dec, &two_frame_packet[0:32], 1, 2);
    try silk_entropy_decode_lbrr_flags(&two_frame_dec);
    try assert(!two_frame_dec.lbrr_flags[0], "two-frame symbol clears frame 0");
    try assert(two_frame_dec.lbrr_flags[1], "two-frame symbol sets frame 1");

    var one_frame_packet: [byte: 32] = [0: 32];
    try encode_lbrr_payload(&one_frame_packet[0:32], &channel_flags[0:2], &frame_symbols[0:2], 1, 1);

    var one_frame_dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&one_frame_dec, &one_frame_packet[0:32], 1, 1);
    try silk_entropy_decode_lbrr_flags(&one_frame_dec);
    try assert(one_frame_dec.lbrr_channel_flags[0], "one-frame packet has channel LBRR");
    try assert(one_frame_dec.lbrr_flags[0], "one-frame channel LBRR implies frame LBRR");
}

test "silk entropy decoder rejects LBRR masks without a supported table" {
    var packet: [byte: 8] = [0: 8];
    var enc: EcEnc = EcEnc{};
    ec_enc_init(&enc, &packet[0:8]);
    ec_enc_bit_logp(&enc, 1, 1);
    _ = try ec_enc_done(&enc);

    var dec: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&dec, &packet[0:8], 1, 4);
    const result: !void = silk_entropy_decode_lbrr_flags(&dec);
    match result {
        error.SilkEntropyDecodeError => {}
        else => { try assert(false, "LBRR masks above 3 frames need an explicit table"); }
    }
}
