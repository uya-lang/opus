use std.testing.assert;
use std.testing.assert_eq_i32;
use src.opus.silk.state.SILK_CHANNEL_HISTORY_LEN;
use src.opus.silk.state.SILK_CHANNEL_LPC_STATE_LEN;
use src.opus.silk.state.SILK_CHANNEL_NLSF_LEN;
use src.opus.silk.state.SILK_MAX_FRAME_SAMPLES;
use src.opus.silk.state.SILK_STATE_HISTORY_LEN;
use src.opus.silk.state.SILK_STATE_MAX_CHANNELS;
use src.opus.silk.state.SilkDecoderState;
use src.opus.silk.state.silk_state_fs_khz_for_rate;
use src.opus.silk.state.silk_state_history_index;
use src.opus.silk.state.silk_state_init;
use src.opus.silk.state.silk_state_lpc_index;
use src.opus.silk.state.silk_state_lpc_order_for_fs_khz;
use src.opus.silk.state.silk_state_reset;

test "silk state initializes 20ms wideband stereo decoder layout" {
    var state: SilkDecoderState = SilkDecoderState{};
    try silk_state_init(&state, 2, 16000, 20);

    try assert_eq_i32(state.channels, 2);
    try assert_eq_i32(state.sample_rate_hz, 16000);
    try assert_eq_i32(state.fs_khz, 16);
    try assert_eq_i32(state.frame_ms, 20);
    try assert_eq_i32(state.frame_length, 320);
    try assert_eq_i32(state.subframe_length, 80);
    try assert_eq_i32(state.nb_subframes, 4);
    try assert_eq_i32(state.lpc_order, 16);
    try assert_eq_i32(state.min_pitch_lag, 32);
    try assert_eq_i32(state.max_pitch_lag, 288);
    try assert(state.first_frame_after_reset, "fresh SILK state must mark the first frame after reset");
    try assert_eq_i32(SILK_STATE_MAX_CHANNELS as i32, 2);
    try assert_eq_i32(SILK_MAX_FRAME_SAMPLES as i32, 320);
    try assert_eq_i32(SILK_STATE_HISTORY_LEN as i32, 624);
    try assert_eq_i32(SILK_CHANNEL_HISTORY_LEN as i32, 1248);
    try assert_eq_i32(SILK_CHANNEL_LPC_STATE_LEN as i32, 32);
    try assert_eq_i32(SILK_CHANNEL_NLSF_LEN as i32, 32);
    try assert_eq_i32(state.prev_gain_q16[0], 0);
    try assert_eq_i32(state.lpc_state_q14[0], 0);
    try assert_eq_i32(state.history_q14[0], 0);
    try assert_eq_i32(state.old_nlsf_q15[0] as i32, 0);
}

test "silk state derives narrowband and mediumband frame parameters" {
    var nb: SilkDecoderState = SilkDecoderState{};
    try silk_state_init(&nb, 1, 8000, 10);
    try assert_eq_i32(nb.fs_khz, 8);
    try assert_eq_i32(nb.frame_length, 80);
    try assert_eq_i32(nb.subframe_length, 40);
    try assert_eq_i32(nb.nb_subframes, 2);
    try assert_eq_i32(nb.lpc_order, 10);
    try assert_eq_i32(nb.min_pitch_lag, 16);
    try assert_eq_i32(nb.max_pitch_lag, 144);

    var mb: SilkDecoderState = SilkDecoderState{};
    try silk_state_init(&mb, 1, 12000, 20);
    try assert_eq_i32(mb.fs_khz, 12);
    try assert_eq_i32(mb.frame_length, 240);
    try assert_eq_i32(mb.subframe_length, 60);
    try assert_eq_i32(mb.nb_subframes, 4);
    try assert_eq_i32(mb.lpc_order, 10);
}

test "silk state validates channels rates and frame duration" {
    var state: SilkDecoderState = SilkDecoderState{};

    const zero_channels: !void = silk_state_init(&state, 0, 16000, 20);
    match zero_channels {
        error.SilkStateError => {}
        else => { try assert(false, "zero channels must fail"); }
    }

    const too_many_channels: !void = silk_state_init(&state, 3, 16000, 20);
    match too_many_channels {
        error.SilkStateError => {}
        else => { try assert(false, "channels past Opus max must fail"); }
    }

    const bad_rate: !i32 = silk_state_fs_khz_for_rate(24000);
    match bad_rate {
        error.SilkStateError => {}
        else => { try assert(false, "SILK internal state must reject unsupported sample rates"); }
    }

    const bad_order: !i32 = silk_state_lpc_order_for_fs_khz(24);
    match bad_order {
        error.SilkStateError => {}
        else => { try assert(false, "unsupported SILK fs_khz must not pick an LPC order"); }
    }

    const bad_frame: !void = silk_state_init(&state, 1, 16000, 5);
    match bad_frame {
        error.SilkStateError => {}
        else => { try assert(false, "SILK decoder state must reject unsupported frame durations"); }
    }
}

test "silk state maps channel histories and lpc state with active lpc order" {
    var state: SilkDecoderState = SilkDecoderState{};
    try silk_state_init(&state, 2, 16000, 20);

    try assert_eq_i32((try silk_state_history_index(&state, 0, 0)) as i32, 0);
    try assert_eq_i32((try silk_state_history_index(&state, 0, 623)) as i32, 623);
    try assert_eq_i32((try silk_state_history_index(&state, 1, 0)) as i32, 624);
    try assert_eq_i32((try silk_state_lpc_index(&state, 1, 15)) as i32, 31);

    const bad_history: !usize = silk_state_history_index(&state, 1, 624);
    match bad_history {
        error.SilkStateError => {}
        else => { try assert(false, "history index past persistent buffer must fail"); }
    }

    var nb: SilkDecoderState = SilkDecoderState{};
    try silk_state_init(&nb, 1, 8000, 20);
    const inactive_lpc: !usize = silk_state_lpc_index(&nb, 0, 10);
    match inactive_lpc {
        error.SilkStateError => {}
        else => { try assert(false, "narrowband state must expose only ten LPC coefficients"); }
    }

    var mb: SilkDecoderState = SilkDecoderState{};
    try silk_state_init(&mb, 1, 12000, 20);
    const inactive_mb_lpc: !usize = silk_state_lpc_index(&mb, 0, 10);
    match inactive_mb_lpc {
        error.SilkStateError => {}
        else => { try assert(false, "mediumband state must use the ten-coefficient NB/MB LPC layout"); }
    }
}

test "silk state reset clears adaptive histories without changing configuration" {
    var state: SilkDecoderState = SilkDecoderState{};
    try silk_state_init(&state, 2, 16000, 20);
    state.first_frame_after_reset = false;
    state.loss_count = 4;
    state.prev_signal_type = 2;
    state.prev_lag = 97;
    state.rng = 33;
    state.prev_gain_q16[1] = 65536;
    state.lpc_state_q14[31] = -1200;
    state.history_q14[624] = 9000;
    state.old_nlsf_q15[16] = 123;

    silk_state_reset(&state);

    try assert_eq_i32(state.channels, 2);
    try assert_eq_i32(state.sample_rate_hz, 16000);
    try assert_eq_i32(state.frame_length, 320);
    try assert(state.first_frame_after_reset, "reset must mark the next frame as first after reset");
    try assert_eq_i32(state.loss_count, 0);
    try assert_eq_i32(state.prev_signal_type, 0);
    try assert_eq_i32(state.prev_lag, 0);
    try assert_eq_i32(state.rng as i32, 0);
    try assert_eq_i32(state.prev_gain_q16[1], 0);
    try assert_eq_i32(state.lpc_state_q14[31], 0);
    try assert_eq_i32(state.history_q14[624], 0);
    try assert_eq_i32(state.old_nlsf_q15[16] as i32, 0);
}
