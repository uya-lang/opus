}

fn test_decoder_abs_i16_to_i32(value: i16) i32 {
    if value < 0 {
        return -(value as i32);
    }
    return value as i32;
}

fn test_decoder_shifted_abs_sum(pulses: &[i16], offset: usize, shift: i32) !i32 {
    if pulses.len < offset + SILK_SHELL_CODEC_FRAME_LENGTH || shift < 0 {
        try assert(false, "pulse helper needs a full shell block");
    }
    var sum: i32 = 0;
    var i: usize = 0;
    while i < SILK_SHELL_CODEC_FRAME_LENGTH {
        sum = sum + (test_decoder_abs_i16_to_i32(pulses.ptr[offset + i]) >> shift);
        i = i + 1;
    }
    return sum;
}

fn test_decoder_write_shifted_magnitudes(out: &[i16], input: &[i16], offset: usize, shift: i32) !void {
    if out.len < offset + SILK_SHELL_CODEC_FRAME_LENGTH || input.len < offset + SILK_SHELL_CODEC_FRAME_LENGTH {
        try assert(false, "shifted magnitude helper needs a full shell block");
    }
    var i: usize = 0;
    while i < SILK_SHELL_CODEC_FRAME_LENGTH {
        out.ptr[offset + i] = (test_decoder_abs_i16_to_i32(input.ptr[offset + i]) >> shift) as i16;
        i = i + 1;
    }
}

fn test_decoder_sign_icdf_value(signal_type: i32, quant_offset_type: i32, pulse_count: i32) byte {
    var capped: i32 = pulse_count & 31;
    if capped > 6 {
        capped = 6;
    }
    return silk_sign_icdf_value((7 * (quant_offset_type + 2 * signal_type) + capped) as usize);
}

fn test_decoder_encode_pulse_signs(enc: &EcEnc, pulses: &[i16], block_totals: &[i32], signal_type: i32, quant_offset_type: i32) !void {
    if pulses.len < block_totals.len * SILK_SHELL_CODEC_FRAME_LENGTH {
        try assert(false, "pulse sign helper needs one 16-sample block per total");
    }
    var block: usize = 0;
    while block < block_totals.len {
        const total: i32 = block_totals.ptr[block];
        if total > 0 {
            var icdf: [byte: 2] = [test_decoder_sign_icdf_value(signal_type, quant_offset_type, total), 0];
            var i: usize = 0;
            while i < SILK_SHELL_CODEC_FRAME_LENGTH {
                const value: i16 = pulses.ptr[block * SILK_SHELL_CODEC_FRAME_LENGTH + i];
                if value != 0 {
                    var symbol: i32 = 1;
                    if value < 0 {
                        symbol = 0;
                    }
                    ec_enc_icdf(enc, symbol, &icdf[0:2], 8);
                }
                i = i + 1;
            }
        }
        block = block + 1;
    }
}

fn test_decoder_encode_pulse_blocks(enc: &EcEnc, signed_pulses: &[i16], frame_length: i32, rate_level: i32, quant_offset_type: i32, encoded_totals: &[i32]) !void {
    const blocks_i32: i32 = try silk_entropy_pulse_block_count(frame_length);
    const blocks: usize = blocks_i32 as usize;
    const rounded_len: usize = blocks * SILK_SHELL_CODEC_FRAME_LENGTH;
    if signed_pulses.len < rounded_len || encoded_totals.len < blocks {
        try assert(false, "pulse block helper needs rounded frame pulse storage");
    }

    var rate_icdf: [byte: 9] = [0: 9];
    try test_decoder_fill_rate_levels_icdf(&rate_icdf[0:9], SILK_SIGNAL_TYPE_UNVOICED);
    ec_enc_icdf(enc, rate_level, &rate_icdf[0:9], 8);

    var shell_totals: [i32: 20] = [0: 20];
    var lshifts: [i32: 20] = [0: 20];
    var magnitudes: [i16: SILK_CONTROL_MAX_FRAME_SAMPLES] = [0: SILK_CONTROL_MAX_FRAME_SAMPLES];

    var pulse_icdf: [byte: 18] = [0: 18];
    try test_decoder_fill_pulses_per_block_icdf(&pulse_icdf[0:18], rate_level);
    var escape_icdf: [byte: 18] = [0: 18];
    try test_decoder_fill_pulses_per_block_icdf(&escape_icdf[0:18], 9);

    var block: usize = 0;
    while block < blocks {
        const offset: usize = block * SILK_SHELL_CODEC_FRAME_LENGTH;
        var shift: i32 = 0;
        var shifted_sum: i32 = try test_decoder_shifted_abs_sum(signed_pulses, offset, shift);
        while shifted_sum > SILK_SHELL_MAX_PULSES {
            shift = shift + 1;
            if shift > 10 {
                try assert(false, "test pulse magnitudes require too many LSB shifts");
            }
            shifted_sum = try test_decoder_shifted_abs_sum(signed_pulses, offset, shift);
        }

        shell_totals[block] = shifted_sum;
        lshifts[block] = shift;
        encoded_totals.ptr[block] = shifted_sum;
        if shift > 0 {
            encoded_totals.ptr[block] = shifted_sum | (shift << 5);
            ec_enc_icdf(enc, SILK_SHELL_MAX_PULSES + 1, &pulse_icdf[0:18], 8);

            var repeat_shift: i32 = 1;
            while repeat_shift < shift {
                ec_enc_icdf(enc, SILK_SHELL_MAX_PULSES + 1, &escape_icdf[0:18], 8);
                repeat_shift = repeat_shift + 1;
            }

            if shift == 10 {
                ec_enc_icdf(enc, shifted_sum, &escape_icdf[1:17], 8);
            } else {
                ec_enc_icdf(enc, shifted_sum, &escape_icdf[0:18], 8);
            }
        } else {
            ec_enc_icdf(enc, shifted_sum, &pulse_icdf[0:18], 8);
        }

        try test_decoder_write_shifted_magnitudes(&magnitudes[0:SILK_CONTROL_MAX_FRAME_SAMPLES], signed_pulses, offset, shift);
        block = block + 1;
    }

    block = 0;
    while block < blocks {
        if shell_totals[block] > 0 {
            const offset: usize = block * SILK_SHELL_CODEC_FRAME_LENGTH;
            const total: i32 = try silk_shell_encoder(enc, &magnitudes[offset:SILK_SHELL_CODEC_FRAME_LENGTH]);
            try assert_eq_i32(total, shell_totals[block]);
        }
        block = block + 1;
    }

    var lsb_icdf: [byte: 2] = [0: 2];
    try test_decoder_fill_lsb_icdf(&lsb_icdf[0:2]);
    block = 0;
    while block < blocks {
        const shift: i32 = lshifts[block];
        if shift > 0 {
            const offset: usize = block * SILK_SHELL_CODEC_FRAME_LENGTH;
            var i: usize = 0;
            while i < SILK_SHELL_CODEC_FRAME_LENGTH {
                const abs_value: i32 = test_decoder_abs_i16_to_i32(signed_pulses.ptr[offset + i]);
                var bit_index: i32 = shift - 1;
                while bit_index >= 0 {
                    ec_enc_icdf(enc, (abs_value >> bit_index) & 1, &lsb_icdf[0:2], 8);
                    bit_index = bit_index - 1;
                }
                i = i + 1;
            }
        }
        block = block + 1;
    }

    try test_decoder_encode_pulse_signs(enc, signed_pulses, &encoded_totals[0:blocks], SILK_SIGNAL_TYPE_UNVOICED, quant_offset_type);
}

fn encode_simple_nb_10ms_unvoiced_payload(payload: &[byte]) !usize {
    var enc: EcEnc = EcEnc{};
    ec_enc_init(&enc, payload);

    ec_enc_bit_logp(&enc, 1, 1);
    ec_enc_bit_logp(&enc, 0, 1);

    var type_icdf: [byte: 4] = [0: 4];
    try test_decoder_fill_type_offset_vad_icdf(&type_icdf[0:4]);
    ec_enc_icdf(&enc, 1, &type_icdf[0:4], 8);

    var gain_icdf: [byte: 8] = [0: 8];
    try test_decoder_fill_gain_icdf(&gain_icdf[0:8], 1);
    ec_enc_icdf(&enc, 1, &gain_icdf[0:8], 8);

    var uniform8_icdf: [byte: 8] = [0: 8];
    try test_decoder_fill_uniform8_icdf(&uniform8_icdf[0:8]);
    ec_enc_icdf(&enc, 5, &uniform8_icdf[0:8], 8);

    var delta_gain_icdf: [byte: 41] = [0: 41];
    try test_decoder_fill_delta_gain_icdf(&delta_gain_icdf[0:41]);
    ec_enc_icdf(&enc, 4, &delta_gain_icdf[0:41], 8);

    var cb1_icdf: [byte: 32] = [0: 32];
    try test_decoder_fill_nlsf_cb1_icdf(&cb1_icdf[0:32], SILK_SIGNAL_TYPE_UNVOICED);
    ec_enc_icdf(&enc, 0, &cb1_icdf[0:32], 8);

    var ec_ix: [i16: SILK_NLSF_MAX_ORDER] = [0: SILK_NLSF_MAX_ORDER];
    var pred_q8: [byte: SILK_NLSF_MAX_ORDER] = [0: SILK_NLSF_MAX_ORDER];
    try silk_nlsf_unpack_ec_tables(&ec_ix[0:SILK_NLSF_MAX_ORDER], &pred_q8[0:SILK_NLSF_MAX_ORDER], SILK_NLSF_CODEBOOK_NB_MB, 0);

    var order_index: usize = 0;
    while order_index < 10 {
        try test_decoder_encode_nlsf_residual(&enc, ec_ix[order_index], 0);
        order_index = order_index + 1;
    }

    var seed_icdf: [byte: 4] = [0: 4];
    try test_decoder_fill_uniform4_icdf(&seed_icdf[0:4]);
    ec_enc_icdf(&enc, 2, &seed_icdf[0:4], 8);

    var pulses: [i16: SILK_CONTROL_MAX_FRAME_SAMPLES] = [0: SILK_CONTROL_MAX_FRAME_SAMPLES];
    pulses[0] = -3;
    pulses[2] = 1;
    pulses[5] = -2;
    pulses[8] = 4;
    pulses[11] = -1;
    pulses[15] = 5;
    pulses[32] = 2;
    pulses[33] = -1;
    pulses[47] = 4;
    var encoded_totals: [i32: 20] = [0: 20];
    try test_decoder_encode_pulse_blocks(&enc, &pulses[0:SILK_CONTROL_MAX_FRAME_SAMPLES], 80, 5, 1, &encoded_totals[0:20]);

    const used: usize = try ec_enc_done(&enc);
    try ec_enc_check(&enc);
    return used;
}

fn test_decoder_checksum_i32(values: &[i32]) i32 {
    var sum: i32 = 0;
    var i: usize = 0;
    while i < values.len {
        sum = sum + ((values.ptr[i] >> 4) * ((i as i32) + 1));
        i = i + 1;
    }
    return sum;
}

test "silk mono packet decoder decodes one narrowband 10ms packet" {
    var packet: [byte: 160] = [0: 160];
    packet[0] = 0;
    _ = try encode_simple_nb_10ms_unvoiced_payload(&packet[1:159]);
    // The current range decoder uses encoder-cleared tail bytes during final checks.
    const packet_len: usize = 160;

    var state: SilkDecoderState = SilkDecoderState{};
    var out_q14: [i32: 80] = [0: 80];
    const decoded: usize = try silk_decode_mono_packet_q14(&state, &packet[0:packet_len], &out_q14[0:80]);

    try assert_eq_i32(decoded as i32, 80);
    try assert_eq_i32(state.channels, 1);
    try assert_eq_i32(state.fs_khz, 8);
    try assert_eq_i32(state.frame_length, 80);
    try assert_eq_i32(state.prev_signal_type, SILK_SIGNAL_TYPE_UNVOICED);
    try assert(!state.first_frame_after_reset, "mono packet decode must advance SILK state");
    try assert_eq_i32(test_decoder_checksum_i32(&out_q14[0:80]), 734614);
    try assert(state.rng != 0, "mono packet decode must advance the SILK random seed");
}

test "silk mono packet decoder rejects stereo packets and short output" {
    var packet: [byte: 160] = [0: 160];
    packet[0] = 0;
    _ = try encode_simple_nb_10ms_unvoiced_payload(&packet[1:159]);
    // Keep the same full payload span as the successful decode path.
    const packet_len: usize = 160;

    var state: SilkDecoderState = SilkDecoderState{};
    var short_out: [i32: 79] = [0: 79];
    const short_res: !usize = silk_decode_mono_packet_q14(&state, &packet[0:packet_len], &short_out[0:79]);
    match short_res {
        error.SilkDecoderError => {}
        else => { try assert(false, "mono packet decode must reject undersized output"); }
    };

    packet[0] = 4;
    var out_q14: [i32: 80] = [0: 80];
    const stereo_res: !usize = silk_decode_mono_packet_q14(&state, &packet[0:packet_len], &out_q14[0:80]);
    match stereo_res {
        error.SilkDecoderError => {}
        else => { try assert(false, "mono packet decode must reject stereo packets"); }
    };
}

test "silk decoder reconstructs interleaved stereo from mid-side q14 frames" {
    var stereo: SilkStereoState = SilkStereoState{};
    stereo.s_mid[0] = 10;
    stereo.s_mid[1] = -20;
    stereo.s_side[0] = 3;
    stereo.s_side[1] = -4;
    var mid_q14: [i32: 4] = [100 << 14, 200 << 14, 300 << 14, 400 << 14];
    var side_q14: [i32: 4] = [7 << 14, -9 << 14, 11 << 14, -13 << 14];
    var pred_q13: [i32: 2] = [0: 2];
    var pcm: [i16: 8] = [0: 8];

    const decoded: usize = try silk_decoder_reconstruct_stereo_i16(&stereo, &mid_q14[0:4], &side_q14[0:4], &pred_q13[0:2], 16, 4, &pcm[0:8]);

    try assert_eq_i32(decoded as i32, 4);
    try assert_eq_i32(pcm[0] as i32, -24);
    try assert_eq_i32(pcm[1] as i32, -16);
    try assert_eq_i32(pcm[2] as i32, 107);
    try assert_eq_i32(pcm[3] as i32, 93);
    try assert_eq_i32(pcm[4] as i32, 191);
    try assert_eq_i32(pcm[5] as i32, 209);
    try assert_eq_i32(pcm[6] as i32, 311);
    try assert_eq_i32(pcm[7] as i32, 289);
    try assert_eq_i32(stereo.s_mid[0] as i32, 300);
    try assert_eq_i32(stereo.s_mid[1] as i32, 400);
    try assert_eq_i32(stereo.s_side[0] as i32, 11);
    try assert_eq_i32(stereo.s_side[1] as i32, -13);

    var short_pcm: [i16: 7] = [0: 7];
    const short_res: !usize = silk_decoder_reconstruct_stereo_i16(&stereo, &mid_q14[0:4], &side_q14[0:4], &pred_q13[0:2], 16, 4, &short_pcm[0:7]);
    match short_res {
        error.SilkDecoderError => {}
        else => { try assert(false, "stereo reconstruction must reject undersized interleaved output"); }
    };
}
