fn test_decoder_fill_nlsf_cb1_icdf(out: &[byte], signal_type: i32) !void {
    if out.len < 32 || signal_type < 0 || signal_type > 1 {
        try assert(false, "NLSF CB1 helper needs one 32-entry signal row");
    }
    const base: usize = (signal_type as usize) * 32;
    var i: usize = 0;
    while i < 32 {
        out.ptr[i] = silk_nlsf_cb1_icdf(SILK_NLSF_CODEBOOK_NB_MB, base + i);
        i = i + 1;
    }
}

fn test_decoder_fill_nlsf_cb2_icdf(out: &[byte], ec_ix: i16) !void {
    if out.len < 9 || ec_ix < 0 {
        try assert(false, "NLSF CB2 helper needs one 9-entry row");
    }
    const base: usize = ec_ix as usize;
    var i: usize = 0;
    while i < 9 {
        out.ptr[i] = silk_nlsf_cb2_icdf(SILK_NLSF_CODEBOOK_NB_MB, base + i);
        i = i + 1;
    }
}

fn test_decoder_fill_nlsf_ext_icdf(out: &[byte]) !void {
    if out.len < 7 {
        try assert(false, "NLSF extension helper needs 7 entries");
    }
    var i: usize = 0;
    while i < 7 {
        out.ptr[i] = silk_nlsf_ext_icdf_value(i);
        i = i + 1;
    }
}

fn test_decoder_encode_nlsf_residual(enc: &EcEnc, ec_ix: i16, residual_index: i16) !void {
    var raw_symbol: i32 = (residual_index as i32) + SILK_NLSF_QUANT_MAX_AMPLITUDE;
    var ext_symbol: i32 = 0;
    if raw_symbol < 0 {
        ext_symbol = -raw_symbol;
        raw_symbol = 0;
    } else if raw_symbol > 2 * SILK_NLSF_QUANT_MAX_AMPLITUDE {
        ext_symbol = raw_symbol - 2 * SILK_NLSF_QUANT_MAX_AMPLITUDE;
        raw_symbol = 2 * SILK_NLSF_QUANT_MAX_AMPLITUDE;
    }
    if ext_symbol < 0 || ext_symbol > 6 {
        try assert(false, "NLSF residual is outside test extension range");
    }

    var cb2_icdf: [byte: 9] = [0: 9];
    try test_decoder_fill_nlsf_cb2_icdf(&cb2_icdf[0:9], ec_ix);
    ec_enc_icdf(enc, raw_symbol, &cb2_icdf[0:9], 8);
    if raw_symbol == 0 || raw_symbol == 2 * SILK_NLSF_QUANT_MAX_AMPLITUDE {
        var ext_icdf: [byte: 7] = [0: 7];
        try test_decoder_fill_nlsf_ext_icdf(&ext_icdf[0:7]);
        ec_enc_icdf(enc, ext_symbol, &ext_icdf[0:7], 8);
    }
}

