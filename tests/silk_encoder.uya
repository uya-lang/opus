fn fill_silk_encoder_voice_like_i16(values: &[i16]) void {
    var i: usize = 0;
    while i < values.len {
        const phase: usize = i % (80 as usize);
        var sample: i32 = 0;
        if phase < 20 {
            sample = 9000 - ((phase as i32) * 300);
        } else if phase < 40 {
            sample = 1800 - (((phase - 20) as i32) * 80);
        } else if phase < 60 {
            sample = -1400;
        } else {
            sample = 700;
        }
        values.ptr[i] = sample as i16;
        i = i + 1;
    }
}

fn fill_silk_encoder_periodic_i16(values: &[i16], period: usize) void {
    var i: usize = 0;
    while i < values.len {
        const phase: usize = i % period;
        const phase_i32: i32 = phase as i32;
        const shaped: i32 = ((phase_i32 * 73 + ((phase_i32 * phase_i32) % 19) * 211) % 97) - 48;
        values.ptr[i] = (shaped * 220) as i16;
        i = i + 1;
    }
}

fn fill_silk_encoder_level_i16(values: &[i16], amplitude: i16) void {
    var i: usize = 0;
    while i < values.len {
        if (i % (2 as usize)) == 0 {
            values.ptr[i] = amplitude;
        } else {
            values.ptr[i] = (0 - (amplitude as i32)) as i16;
        }
        i = i + 1;
    }
}

fn fill_silk_encoder_subframe_level_i16(values: &[i16], subframe: usize, subframe_len: usize, amplitude: i16) void {
    const start: usize = subframe * subframe_len;
    var i: usize = 0;
    while i < subframe_len {
        const index: usize = start + i;
        if index < values.len {
            if (i % (2 as usize)) == 0 {
                values.ptr[index] = amplitude;
            } else {
                values.ptr[index] = (0 - (amplitude as i32)) as i16;
            }
        }
        i = i + 1;
    }
}

fn decode_silk_encoder_packet_gains(packet: &[byte], encoded: i32, entropy: &SilkEntropyDecoder, control: &SilkDecoderControl) !void {
    try silk_entropy_decoder_init(entropy, &packet[1:(encoded as usize)], 1, 1);
    try silk_entropy_decode_vad_flags(entropy);
    try silk_entropy_decode_lbrr_flags(entropy);
    _ = try silk_entropy_decode_signal_type(entropy, 0, 0);
    _ = try silk_entropy_decode_quantization_offset(entropy, 0, 0);
    control.channels = 1;
    control.fs_khz = 16;
    control.frame_length = 320;
    control.subframe_length = 80;
    control.nb_subframes = 4;
    control.lpc_order = 16;
    try silk_entropy_decode_gains(entropy, control, 0, 0, false);
}

fn decode_silk_encoder_packet_nlsf(packet: &[byte], encoded: i32, entropy: &SilkEntropyDecoder, control: &SilkDecoderControl) !void {
    try decode_silk_encoder_packet_gains(packet, encoded, entropy, control);
    try silk_entropy_decode_nlsf_indices(entropy, control, 0, 0);
}

fn decode_silk_encoder_packet_pulses(packet: &[byte], encoded: i32, entropy: &SilkEntropyDecoder, control: &SilkDecoderControl) !void {
    try decode_silk_encoder_packet_nlsf(packet, encoded, entropy, control);
    if entropy.signal_types[0] == SILK_SIGNAL_TYPE_VOICED {
        try silk_entropy_decode_pitch_lag(entropy, control, 0, 0, false);
        try silk_entropy_decode_pitch_contour(entropy, control, 0, 0);
        try silk_entropy_decode_ltp_coefficients(entropy, control, 0, 0);
        try silk_entropy_decode_ltp_scaling(entropy, control, 0, 0, false);
    }
    try silk_entropy_decode_random_seed(entropy, control, 0, 0);
    try silk_entropy_decode_pulse_blocks(entropy, control, 0, 0);
}

fn silk_encoder_nlsf_has_nonzero_residual(nlsf: &const SilkEncoderNlsfAnalysis) bool {
    var i: usize = 0;
    while i < 16 {
        if nlsf.residual_indices[i] != 0 {
            return true;
        }
        i = i + 1;
    }
    return false;
}

fn silk_encoder_control_nlsf_differs(a: &const SilkDecoderControl, b: &const SilkDecoderControl) bool {
    var i: usize = 0;
    while i < 16 {
        if a.nlsf_q15[i] != b.nlsf_q15[i] {
            return true;
        }
        i = i + 1;
    }
    return false;
}

fn silk_encoder_control_pulse_abs_sum(control: &const SilkDecoderControl) !i32 {
    const offset: usize = try silk_decoder_control_pulse_index(control, 0, 0);
    var sum: i32 = 0;
    var i: usize = 0;
    while i < 320 {
        const value: i16 = control.pulses[offset + i];
        if value < 0 {
            sum = sum - (value as i32);
        } else {
            sum = sum + (value as i32);
        }
        i = i + 1;
    }
    return sum;
}

fn silk_encoder_control_pulses_differ(a: &const SilkDecoderControl, b: &const SilkDecoderControl) !bool {
    const a_offset: usize = try silk_decoder_control_pulse_index(a, 0, 0);
    const b_offset: usize = try silk_decoder_control_pulse_index(b, 0, 0);
    var i: usize = 0;
    while i < 320 {
        if a.pulses[a_offset + i] != b.pulses[b_offset + i] {
            return true;
        }
        i = i + 1;
    }
    return false;
}

test "silk basic encoder profile records wideband mono placeholder layout" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 16000;
    config.channels = 1;
    config.max_bandwidth = OpusBandwidth.WIDEBAND;

    const profile: SilkBasicEncoderProfile = try silk_basic_encoder_profile_init(&config, 960);
    try assert_eq_i32(profile.sample_rate_hz as i32, 16000);
    try assert_eq_i32(profile.channels as i32, 1);
    try assert_eq_i32(profile.input_frame_size_samples, 320);
    try assert_eq_i32(profile.frame_size_48k, 960);
    try assert_eq_i32(profile.bandwidth as i32, OpusBandwidth.WIDEBAND as i32);
    try assert_eq_i32(profile.frame_duration_us as i32, 20000);
    try assert_eq_i32(profile.toc_config_index as i32, 9);
    try assert_eq_i32(profile.toc_byte_code0 as i32, SILK_BASIC_ENCODER_WB_20MS_MONO_TOC_BYTE_CODE0 as i32);
    try assert(!profile.inband_fec, "default SILK profile must preserve disabled FEC");
    try assert_eq_i32(profile.packet_loss_percent as i32, 0);
    try assert(!profile.dtx, "default SILK profile must preserve disabled DTX");
    try assert_eq_i32(profile.complexity as i32, 5);
}

test "silk basic encoder profile separates invalid and unsupported configs" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 16000;
    config.channels = 2;
    config.max_bandwidth = OpusBandwidth.WIDEBAND;
    const stereo: !SilkBasicEncoderProfile = silk_basic_encoder_profile_init(&config, 960);
    match stereo {
        error.SilkEncoderUnsupported => {}
        else => { try assert(false, "Basic SILK placeholder is mono only"); }
    };

    config = opus_encoder_config_default();
    config.sample_rate_hz = 16000;
    config.channels = 1;
    config.max_bandwidth = OpusBandwidth.FULLBAND;
    const fullband: !SilkBasicEncoderProfile = silk_basic_encoder_profile_init(&config, 960);
    match fullband {
        error.SilkEncoderUnsupported => {}
        else => { try assert(false, "Basic SILK placeholder is wideband only"); }
    };

    config = opus_encoder_config_default();
    config.sample_rate_hz = 44100;
    const invalid_rate: !SilkBasicEncoderProfile = silk_basic_encoder_profile_init(&config, 960);
    match invalid_rate {
        error.SilkEncoderError => {}
        else => { try assert(false, "SILK profile must reject invalid API sample rates"); }
    };
}

test "silk encoder writes wideband mono packet decodable by silk decoder" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 16000;
    config.channels = 1;
    config.max_bandwidth = OpusBandwidth.WIDEBAND;
    const profile: SilkBasicEncoderProfile = try silk_basic_encoder_profile_init(&config, 960);

    var state: SilkEncoderState = SilkEncoderState{};
    try assert(!silk_encoder_is_initialized(&state), "fresh SILK encoder state must start inactive");
    try silk_encoder_state_init(&state, &profile);
    try assert(silk_encoder_is_initialized(&state), "state init must mark the SILK placeholder active");

    var pcm: [i16: 320] = [0: 320];
    var packet: [byte: 1275] = [0: 1275];
    const encoded: i32 = try silk_encoder_encode_i16(&state, &pcm[0:320], &packet[0:1275]);
    try assert(encoded > 1, "SILK packet shell must include a decodable payload");
    try assert_eq_i32(packet[0] as i32, SILK_BASIC_ENCODER_WB_20MS_MONO_TOC_BYTE_CODE0 as i32);

    var decoder: SilkDecoderState = SilkDecoderState{};
    var out_q14: [i32: 320] = [0: 320];
    const decoded: usize = try silk_decode_mono_packet_q14(&decoder, &packet[0:(encoded as usize)], &out_q14[0:320]);
    try assert_eq_i32(decoded as i32, 320);
}

test "silk encoder VAD marks silence inactive and voice-like input active" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 16000;
    config.channels = 1;
    config.max_bandwidth = OpusBandwidth.WIDEBAND;
    const profile: SilkBasicEncoderProfile = try silk_basic_encoder_profile_init(&config, 960);

    var state: SilkEncoderState = SilkEncoderState{};
    try silk_encoder_state_init(&state, &profile);

    var silence_pcm: [i16: 320] = [0: 320];
    var silence_packet: [byte: 1275] = [0: 1275];
    const silence_encoded: i32 = try silk_encoder_encode_i16(&state, &silence_pcm[0:320], &silence_packet[0:1275]);
    var silence_entropy: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&silence_entropy, &silence_packet[1:(silence_encoded as usize)], 1, 1);
    try silk_entropy_decode_vad_flags(&silence_entropy);
    try assert(!silence_entropy.vad_flags[0], "silent SILK input must encode an inactive VAD flag");
    try silk_entropy_decode_lbrr_flags(&silence_entropy);
    try assert_eq_i32(try silk_entropy_decode_signal_type(&silence_entropy, 0, 0), SILK_SIGNAL_TYPE_UNVOICED);

    var voice_pcm: [i16: 320] = [0: 320];
    fill_silk_encoder_voice_like_i16(&voice_pcm[0:320]);
    var voice_packet: [byte: 1275] = [0: 1275];
    const voice_encoded: i32 = try silk_encoder_encode_i16(&state, &voice_pcm[0:320], &voice_packet[0:1275]);
    var voice_entropy: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&voice_entropy, &voice_packet[1:(voice_encoded as usize)], 1, 1);
    try silk_entropy_decode_vad_flags(&voice_entropy);
    try assert(voice_entropy.vad_flags[0], "voice-like SILK input must encode an active VAD flag");
    try silk_entropy_decode_lbrr_flags(&voice_entropy);
    _ = try silk_entropy_decode_signal_type(&voice_entropy, 0, 0);
}

test "silk encoder writes in-band fec lbrr for active configured voice" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 16000;
    config.channels = 1;
    config.max_bandwidth = OpusBandwidth.WIDEBAND;
    config.inband_fec = true;
    config.packet_loss_percent = 10;
    const profile: SilkBasicEncoderProfile = try silk_basic_encoder_profile_init(&config, 960);

    var state: SilkEncoderState = SilkEncoderState{};
    try silk_encoder_state_init(&state, &profile);

    var voice_pcm: [i16: 320] = [0: 320];
    fill_silk_encoder_voice_like_i16(&voice_pcm[0:320]);
    var packet: [byte: 1275] = [0: 1275];
    const encoded: i32 = try silk_encoder_encode_i16(&state, &voice_pcm[0:320], &packet[0:1275]);

    var entropy: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&entropy, &packet[1:(encoded as usize)], 1, 1);
    try silk_entropy_decode_vad_flags(&entropy);
    try silk_entropy_decode_lbrr_flags(&entropy);
    try assert(entropy.vad_flags[0], "FEC source frame must still be VAD active");
    try assert(entropy.lbrr_channel_flags[0], "enabled in-band FEC must set the mono LBRR channel flag");
    try assert(entropy.lbrr_flags[0], "single-frame LBRR must mark frame zero recoverable");

    var plan: SilkFecPlan = SilkFecPlan{};
    try silk_fec_detect_lbrr_packet(&plan, &packet[0:(encoded as usize)], 0);
    try assert(plan.can_recover, "encoded packet must be detectable as delayed FEC");

    var decoder: SilkDecoderState = SilkDecoderState{};
    var result: SilkDelayedFecResult = SilkDelayedFecResult{};
    var out_q14: [i32: 320] = [0: 320];
    try silk_fec_decode_delayed_mono_q14(&result, &decoder, &packet[0:(encoded as usize)], 0, &out_q14[0:320]);
    try assert(result.used_fec, "delayed FEC decode must use the encoded LBRR frame");
    try assert(!result.used_plc, "available LBRR must avoid PLC fallback");
    try assert_eq_i32(result.decoded_samples as i32, 320);
}

test "silk encoder leaves lbrr clear when fec is disabled or inactive" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 16000;
    config.channels = 1;
    config.max_bandwidth = OpusBandwidth.WIDEBAND;
    config.inband_fec = false;
    config.packet_loss_percent = 10;
    const disabled_profile: SilkBasicEncoderProfile = try silk_basic_encoder_profile_init(&config, 960);

    var disabled_state: SilkEncoderState = SilkEncoderState{};
    try silk_encoder_state_init(&disabled_state, &disabled_profile);
    var voice_pcm: [i16: 320] = [0: 320];
    fill_silk_encoder_voice_like_i16(&voice_pcm[0:320]);
    var disabled_packet: [byte: 1275] = [0: 1275];
    const disabled_encoded: i32 = try silk_encoder_encode_i16(&disabled_state, &voice_pcm[0:320], &disabled_packet[0:1275]);
    var disabled_entropy: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&disabled_entropy, &disabled_packet[1:(disabled_encoded as usize)], 1, 1);
    try silk_entropy_decode_vad_flags(&disabled_entropy);
    try silk_entropy_decode_lbrr_flags(&disabled_entropy);
    try assert(!disabled_entropy.lbrr_channel_flags[0], "disabled in-band FEC must not set LBRR");

    config.inband_fec = true;
    config.packet_loss_percent = 10;
    const inactive_profile: SilkBasicEncoderProfile = try silk_basic_encoder_profile_init(&config, 960);
    var inactive_state: SilkEncoderState = SilkEncoderState{};
    try silk_encoder_state_init(&inactive_state, &inactive_profile);
    var silence_pcm: [i16: 320] = [0: 320];
    var inactive_packet: [byte: 1275] = [0: 1275];
    const inactive_encoded: i32 = try silk_encoder_encode_i16(&inactive_state, &silence_pcm[0:320], &inactive_packet[0:1275]);
    var inactive_entropy: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&inactive_entropy, &inactive_packet[1:(inactive_encoded as usize)], 1, 1);
    try silk_entropy_decode_vad_flags(&inactive_entropy);
    try silk_entropy_decode_lbrr_flags(&inactive_entropy);
    try assert(!inactive_entropy.vad_flags[0], "silence must remain VAD inactive");
    try assert(!inactive_entropy.lbrr_channel_flags[0], "inactive speech must not spend LBRR bits");
}

test "silk encoder returns zero bytes for dtx inactive voice frame" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 16000;
    config.channels = 1;
    config.max_bandwidth = OpusBandwidth.WIDEBAND;
    config.dtx = true;
    const profile: SilkBasicEncoderProfile = try silk_basic_encoder_profile_init(&config, 960);

    var state: SilkEncoderState = SilkEncoderState{};
    try silk_encoder_state_init(&state, &profile);

    var silence_pcm: [i16: 320] = [0: 320];
    var silence_packet: [byte: 1275] = [77: 1275];
    const silence_encoded: i32 = try silk_encoder_encode_i16(&state, &silence_pcm[0:320], &silence_packet[0:1275]);
    try assert_eq_i32(silence_encoded, 0);
    try assert_eq_i32(silence_packet[0] as i32, 77);

    var voice_pcm: [i16: 320] = [0: 320];
    fill_silk_encoder_voice_like_i16(&voice_pcm[0:320]);
    var voice_packet: [byte: 1275] = [0: 1275];
    const voice_encoded: i32 = try silk_encoder_encode_i16(&state, &voice_pcm[0:320], &voice_packet[0:1275]);
    try assert(voice_encoded > 1, "active voice must not be suppressed by DTX");
    try assert_eq_i32(voice_packet[0] as i32, SILK_BASIC_ENCODER_WB_20MS_MONO_TOC_BYTE_CODE0 as i32);
}

test "silk encoder pitch analysis detects periodic wideband lag" {
    var periodic: [i16: 320] = [0: 320];
    fill_silk_encoder_periodic_i16(&periodic[0:320], 80);
    const periodic_analysis: SilkEncoderPitchAnalysis = try silk_encoder_pitch_analyze_i16(&periodic[0:320], 320, 1, 16);
    try assert(periodic_analysis.voiced, "periodic wideband input must be classified as voiced");
    try assert_eq_i32(periodic_analysis.lag_samples, 80);
    try assert_eq_i32(periodic_analysis.lag_index, 48);
    try assert(periodic_analysis.correlation_q15 >= 30000, "exactly repeated pitch periods must score near perfect");

    var silence: [i16: 320] = [0: 320];
    const silence_analysis: SilkEncoderPitchAnalysis = try silk_encoder_pitch_analyze_i16(&silence[0:320], 320, 1, 16);
    try assert(!silence_analysis.voiced, "silent input must not report a pitch lag");
    try assert_eq_i32(silence_analysis.lag_samples, 0);
}

test "silk encoder writes voiced pitch side info for periodic input" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 16000;
    config.channels = 1;
    config.max_bandwidth = OpusBandwidth.WIDEBAND;
    const profile: SilkBasicEncoderProfile = try silk_basic_encoder_profile_init(&config, 960);

    var state: SilkEncoderState = SilkEncoderState{};
    try silk_encoder_state_init(&state, &profile);

    var periodic: [i16: 320] = [0: 320];
    fill_silk_encoder_periodic_i16(&periodic[0:320], 80);
    var packet: [byte: 1275] = [0: 1275];
    const encoded: i32 = try silk_encoder_encode_i16(&state, &periodic[0:320], &packet[0:1275]);

    var entropy: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&entropy, &packet[1:(encoded as usize)], 1, 1);
    try silk_entropy_decode_vad_flags(&entropy);
    try assert(entropy.vad_flags[0], "periodic voiced input must be VAD active");
    try silk_entropy_decode_lbrr_flags(&entropy);
    try assert_eq_i32(try silk_entropy_decode_signal_type(&entropy, 0, 0), SILK_SIGNAL_TYPE_VOICED);

    var control: SilkDecoderControl = SilkDecoderControl{};
    control.channels = 1;
    control.fs_khz = 16;
    control.frame_length = 320;
    control.subframe_length = 80;
    control.nb_subframes = 4;
    control.lpc_order = 16;
    try silk_entropy_decode_quantization_offset(&entropy, 0, 0);
    try silk_entropy_decode_gains(&entropy, &control, 0, 0, false);
    try silk_entropy_decode_nlsf_indices(&entropy, &control, 0, 0);
    try silk_entropy_decode_pitch_lag(&entropy, &control, 0, 0, false);
    try silk_entropy_decode_pitch_contour(&entropy, &control, 0, 0);
    try silk_entropy_decode_ltp_coefficients(&entropy, &control, 0, 0);
    try silk_entropy_decode_ltp_scaling(&entropy, &control, 0, 0, false);

    try assert(entropy.pitch_lag_valid[0], "voiced encoder side info must cache a pitch lag");
    try assert_eq_i32(entropy.pitch_lag_values[0], 80);
    try assert_eq_i32(control.pitch_lags[0], 80);
    try assert_eq_i32(control.pitch_lags[1], 80);
    try assert_eq_i32(control.pitch_lags[2], 80);
    try assert_eq_i32(control.pitch_lags[3], 80);
    try assert(entropy.ltp_coefficients_valid[0], "voiced encoder side info must include LTP coefficients");

    var decoder: SilkDecoderState = SilkDecoderState{};
    var out_q14: [i32: 320] = [0: 320];
    const decoded: usize = try silk_decode_mono_packet_q14(&decoder, &packet[0:(encoded as usize)], &out_q14[0:320]);
    try assert_eq_i32(decoded as i32, 320);
}

test "silk encoder low complexity skips voiced pitch side info" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 16000;
    config.channels = 1;
    config.max_bandwidth = OpusBandwidth.WIDEBAND;
    config.complexity = 0;
    const profile: SilkBasicEncoderProfile = try silk_basic_encoder_profile_init(&config, 960);

    var state: SilkEncoderState = SilkEncoderState{};
    try silk_encoder_state_init(&state, &profile);

    var periodic: [i16: 320] = [0: 320];
    fill_silk_encoder_periodic_i16(&periodic[0:320], 80);
    var packet: [byte: 1275] = [0: 1275];
    const encoded: i32 = try silk_encoder_encode_i16(&state, &periodic[0:320], &packet[0:1275]);

    var entropy: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&entropy, &packet[1:(encoded as usize)], 1, 1);
    try silk_entropy_decode_vad_flags(&entropy);
    try assert(entropy.vad_flags[0], "low-complexity periodic input must still be VAD active");
    try silk_entropy_decode_lbrr_flags(&entropy);
    try assert_eq_i32(try silk_entropy_decode_signal_type(&entropy, 0, 0), SILK_SIGNAL_TYPE_UNVOICED);
}

test "silk encoder gain analysis tracks subframe levels" {
    var ramp: [i16: 320] = [0: 320];
    fill_silk_encoder_subframe_level_i16(&ramp[0:320], 0, 80, 128);
    fill_silk_encoder_subframe_level_i16(&ramp[0:320], 1, 80, 1024);
    fill_silk_encoder_subframe_level_i16(&ramp[0:320], 2, 80, 4096);
    fill_silk_encoder_subframe_level_i16(&ramp[0:320], 3, 80, 12000);
    const ramp_gains: SilkEncoderGainAnalysis = try silk_encoder_gain_analyze_i16(&ramp[0:320], 320, 1, 4);
    try assert_eq_i32(ramp_gains.first_msb, ramp_gains.decoded_indices[0] >> 3);
    try assert_eq_i32(ramp_gains.first_lsb, ramp_gains.decoded_indices[0] - (ramp_gains.first_msb << 3));
    try assert(ramp_gains.decoded_indices[0] < ramp_gains.decoded_indices[1], "gain analysis must raise the second subframe index");
    try assert(ramp_gains.decoded_indices[1] < ramp_gains.decoded_indices[2], "gain analysis must raise the third subframe index");
    try assert(ramp_gains.decoded_indices[2] < ramp_gains.decoded_indices[3], "gain analysis must raise the fourth subframe index");

    var silence: [i16: 320] = [0: 320];
    const silence_gains: SilkEncoderGainAnalysis = try silk_encoder_gain_analyze_i16(&silence[0:320], 320, 1, 4);
    try assert_eq_i32(silence_gains.decoded_indices[0], 0);
    try assert_eq_i32(silence_gains.decoded_indices[1], 0);
    try assert_eq_i32(silence_gains.delta_symbols[1], 4);
}

test "silk encoder writes input dependent gain side info" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 16000;
    config.channels = 1;
    config.max_bandwidth = OpusBandwidth.WIDEBAND;
    const profile: SilkBasicEncoderProfile = try silk_basic_encoder_profile_init(&config, 960);

    var state: SilkEncoderState = SilkEncoderState{};
    try silk_encoder_state_init(&state, &profile);

    var soft_pcm: [i16: 320] = [0: 320];
    fill_silk_encoder_level_i16(&soft_pcm[0:320], 512);
    var soft_packet: [byte: 1275] = [0: 1275];
    const soft_encoded: i32 = try silk_encoder_encode_i16(&state, &soft_pcm[0:320], &soft_packet[0:1275]);
    var soft_entropy: SilkEntropyDecoder = SilkEntropyDecoder{};
    var soft_control: SilkDecoderControl = SilkDecoderControl{};
    try decode_silk_encoder_packet_gains(&soft_packet[0:(soft_encoded as usize)], soft_encoded, &soft_entropy, &soft_control);

    var loud_pcm: [i16: 320] = [0: 320];
    fill_silk_encoder_level_i16(&loud_pcm[0:320], 12000);
    var loud_packet: [byte: 1275] = [0: 1275];
    const loud_encoded: i32 = try silk_encoder_encode_i16(&state, &loud_pcm[0:320], &loud_packet[0:1275]);
    var loud_entropy: SilkEntropyDecoder = SilkEntropyDecoder{};
    var loud_control: SilkDecoderControl = SilkDecoderControl{};
    try decode_silk_encoder_packet_gains(&loud_packet[0:(loud_encoded as usize)], loud_encoded, &loud_entropy, &loud_control);

    try assert(loud_entropy.gain_indices[0] > soft_entropy.gain_indices[0], "louder input must encode a higher independent gain index");
    try assert(loud_control.gains_q16[0] > soft_control.gains_q16[0], "louder input must decode to a higher first-subframe gain");

    var ramp_pcm: [i16: 320] = [0: 320];
    fill_silk_encoder_subframe_level_i16(&ramp_pcm[0:320], 0, 80, 256);
    fill_silk_encoder_subframe_level_i16(&ramp_pcm[0:320], 1, 80, 1024);
    fill_silk_encoder_subframe_level_i16(&ramp_pcm[0:320], 2, 80, 4096);
    fill_silk_encoder_subframe_level_i16(&ramp_pcm[0:320], 3, 80, 12000);
    var ramp_packet: [byte: 1275] = [0: 1275];
    const ramp_encoded: i32 = try silk_encoder_encode_i16(&state, &ramp_pcm[0:320], &ramp_packet[0:1275]);
    var ramp_entropy: SilkEntropyDecoder = SilkEntropyDecoder{};
    var ramp_control: SilkDecoderControl = SilkDecoderControl{};
    try decode_silk_encoder_packet_gains(&ramp_packet[0:(ramp_encoded as usize)], ramp_encoded, &ramp_entropy, &ramp_control);
    try assert(ramp_control.gains_q16[3] > ramp_control.gains_q16[0], "ramped input must decode to a higher last-subframe gain");
}

test "silk encoder NLSF quantization follows input spectrum" {
    var periodic: [i16: 320] = [0: 320];
    fill_silk_encoder_periodic_i16(&periodic[0:320], 80);
    const periodic_nlsf: SilkEncoderNlsfAnalysis = try silk_encoder_nlsf_quantize_i16(&periodic[0:320], 320, 1, SILK_NLSF_CODEBOOK_WB);
    try assert(periodic_nlsf.cb1_index >= 0, "NLSF quantizer must choose a first-stage vector");
    try assert(periodic_nlsf.decoded_q15[0] > 0, "decoded NLSF must stay inside Q15 range");
    try assert(periodic_nlsf.decoded_q15[15] > periodic_nlsf.decoded_q15[0], "decoded NLSF must be ordered");
    try assert(silk_encoder_nlsf_has_nonzero_residual(&periodic_nlsf), "NLSF quantizer must emit residual indices for a non-codebook target");

    var bright: [i16: 320] = [0: 320];
    fill_silk_encoder_level_i16(&bright[0:320], 12000);
    const bright_nlsf: SilkEncoderNlsfAnalysis = try silk_encoder_nlsf_quantize_i16(&bright[0:320], 320, 1, SILK_NLSF_CODEBOOK_WB);
    try assert(bright_nlsf.cb1_index != periodic_nlsf.cb1_index || bright_nlsf.decoded_q15[0] != periodic_nlsf.decoded_q15[0], "different spectral shapes must quantize to different NLSF output");
}

test "silk encoder writes input dependent NLSF side info" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 16000;
    config.channels = 1;
    config.max_bandwidth = OpusBandwidth.WIDEBAND;
    const profile: SilkBasicEncoderProfile = try silk_basic_encoder_profile_init(&config, 960);

    var state: SilkEncoderState = SilkEncoderState{};
    try silk_encoder_state_init(&state, &profile);

    var periodic: [i16: 320] = [0: 320];
    fill_silk_encoder_periodic_i16(&periodic[0:320], 80);
    var periodic_packet: [byte: 1275] = [0: 1275];
    const periodic_encoded: i32 = try silk_encoder_encode_i16(&state, &periodic[0:320], &periodic_packet[0:1275]);
    var periodic_entropy: SilkEntropyDecoder = SilkEntropyDecoder{};
    var periodic_control: SilkDecoderControl = SilkDecoderControl{};
    try decode_silk_encoder_packet_nlsf(&periodic_packet[0:(periodic_encoded as usize)], periodic_encoded, &periodic_entropy, &periodic_control);
    try assert(periodic_entropy.nlsf_valid[0], "encoded packet must carry decodable NLSF indices");

    var bright: [i16: 320] = [0: 320];
    fill_silk_encoder_level_i16(&bright[0:320], 12000);
    var bright_packet: [byte: 1275] = [0: 1275];
    const bright_encoded: i32 = try silk_encoder_encode_i16(&state, &bright[0:320], &bright_packet[0:1275]);
    var bright_entropy: SilkEntropyDecoder = SilkEntropyDecoder{};
    var bright_control: SilkDecoderControl = SilkDecoderControl{};
    try decode_silk_encoder_packet_nlsf(&bright_packet[0:(bright_encoded as usize)], bright_encoded, &bright_entropy, &bright_control);

    try assert(silk_encoder_control_nlsf_differs(&periodic_control, &bright_control), "different encoder inputs must decode to different NLSF control vectors");
    try assert(periodic_entropy.nlsf_indices[0] != 0 || periodic_entropy.nlsf_indices[1] != 0, "NLSF side info must no longer be the fixed all-zero vector");
}

test "silk encoder NSQ writes input dependent pulse blocks" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 16000;
    config.channels = 1;
    config.max_bandwidth = OpusBandwidth.WIDEBAND;
    const profile: SilkBasicEncoderProfile = try silk_basic_encoder_profile_init(&config, 960);

    var state: SilkEncoderState = SilkEncoderState{};
    try silk_encoder_state_init(&state, &profile);

    var periodic: [i16: 320] = [0: 320];
    fill_silk_encoder_periodic_i16(&periodic[0:320], 80);
    var periodic_packet: [byte: 1275] = [0: 1275];
    const periodic_encoded: i32 = try silk_encoder_encode_i16(&state, &periodic[0:320], &periodic_packet[0:1275]);
    var periodic_entropy: SilkEntropyDecoder = SilkEntropyDecoder{};
    var periodic_control: SilkDecoderControl = SilkDecoderControl{};
    try decode_silk_encoder_packet_pulses(&periodic_packet[0:(periodic_encoded as usize)], periodic_encoded, &periodic_entropy, &periodic_control);
    try assert(periodic_entropy.pulse_blocks_valid[0], "encoded SILK packet must carry decodable pulse blocks");
    try assert((try silk_encoder_control_pulse_abs_sum(&periodic_control)) > 0, "NSQ must emit non-zero pulses for active input");

    var bright: [i16: 320] = [0: 320];
    fill_silk_encoder_level_i16(&bright[0:320], 12000);
    var bright_packet: [byte: 1275] = [0: 1275];
    const bright_encoded: i32 = try silk_encoder_encode_i16(&state, &bright[0:320], &bright_packet[0:1275]);
    var bright_entropy: SilkEntropyDecoder = SilkEntropyDecoder{};
    var bright_control: SilkDecoderControl = SilkDecoderControl{};
    try decode_silk_encoder_packet_pulses(&bright_packet[0:(bright_encoded as usize)], bright_encoded, &bright_entropy, &bright_control);
    try assert((try silk_encoder_control_pulse_abs_sum(&bright_control)) > 0, "NSQ must emit non-zero pulses for high-energy input");
    try assert(try silk_encoder_control_pulses_differ(&periodic_control, &bright_control), "different inputs must produce different NSQ pulse patterns");
}

test "silk encoder rejects short packet buffers before writing past them" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 16000;
    config.channels = 1;
    config.max_bandwidth = OpusBandwidth.WIDEBAND;
    const profile: SilkBasicEncoderProfile = try silk_basic_encoder_profile_init(&config, 960);

    var state: SilkEncoderState = SilkEncoderState{};
    try silk_encoder_state_init(&state, &profile);
    var pcm: [i16: 320] = [0: 320];
    var packet: [byte: 384] = [55: 384];
    packet[383] = 99;
    const encoded: !i32 = silk_encoder_encode_i16(&state, &pcm[0:320], &packet[0:383]);
    match encoded {
        error.SilkEncoderError => {}
        else => { try assert(false, "SILK encoder must reject buffers smaller than its packet size"); }
    };
    try assert_eq_i32(packet[383] as i32, 99);
}
