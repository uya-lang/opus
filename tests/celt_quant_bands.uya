use std.testing.assert;
use std.testing.assert_eq_i32;
use src.opus.celt.quant_bands.CELT_ENERGY_DB_SHIFT;
use src.opus.celt.quant_bands.celt_decode_coarse_energy;
use src.opus.celt.state.CeltDecoderState;
use src.opus.celt.state.celt_state_configure_frame;
use src.opus.celt.state.celt_state_init;
use src.opus.celt.tables.celt_energy_prob_model_q8;
use src.opus.entropy.laplace.ec_laplace_encode;
use src.opus.entropy.range_dec.EcDec;
use src.opus.entropy.range_dec.ec_dec_check;
use src.opus.entropy.range_dec.ec_dec_init;
use src.opus.entropy.range_enc.EcEnc;
use src.opus.entropy.range_enc.ec_enc_check;
use src.opus.entropy.range_enc.ec_enc_done;
use src.opus.entropy.range_enc.ec_enc_init;

fn encode_laplace_qi(packet: &[byte], lm: usize, intra: bool, band: i32, q0: i32, q1: i32, channels: i32) !usize {
    var enc: EcEnc = EcEnc{};
    ec_enc_init(&enc, packet);

    const prob_index: usize = (2 * band) as usize;
    const fs: u32 = (celt_energy_prob_model_q8(lm, intra, prob_index) as u32) << 7;
    const decay: i32 = (celt_energy_prob_model_q8(lm, intra, prob_index + 1) as i32) << 6;

    var v0: i32 = q0;
    ec_laplace_encode(&enc, &v0, fs, decay);
    if channels == 2 {
        var v1: i32 = q1;
        ec_laplace_encode(&enc, &v1, fs, decay);
    }

    try ec_enc_check(&enc);
    const len: usize = try ec_enc_done(&enc);
    if len < 4 {
        return 4 as usize;
    }
    return len;
}

test "coarse energy decode updates mono inter band from Laplace bitstream" {
    try assert_eq_i32(CELT_ENERGY_DB_SHIFT, 10);
    var packet: [byte: 32] = [0: 32];
    const len: usize = try encode_laplace_qi(&packet[0:32], 0, false, 0, 2, 0, 1);

    var state: CeltDecoderState = CeltDecoderState{};
    try celt_state_init(&state, 1);
    try celt_state_configure_frame(&state, 120, 0, 1);

    var dec: EcDec = EcDec{};
    ec_dec_init(&dec, &packet[0:len]);
    try celt_decode_coarse_energy(&state, &dec, false);
    try ec_dec_check(&dec);

    try assert_eq_i32(state.old_ebands_q8[0] as i32, 2048);
}

test "coarse energy decode uses channel stride and intra prediction" {
    var packet: [byte: 32] = [0: 32];
    const len: usize = try encode_laplace_qi(&packet[0:32], 3, true, 0, 1, -1, 2);

    var state: CeltDecoderState = CeltDecoderState{};
    try celt_state_init(&state, 2);
    try celt_state_configure_frame(&state, 960, 0, 1);
    state.old_ebands_q8[0] = 500;
    state.old_ebands_q8[21] = 500;

    var dec: EcDec = EcDec{};
    ec_dec_init(&dec, &packet[0:len]);
    try celt_decode_coarse_energy(&state, &dec, true);
    try ec_dec_check(&dec);

    try assert_eq_i32(state.old_ebands_q8[0] as i32, 1024);
    try assert_eq_i32(state.old_ebands_q8[21] as i32, -1024);
}

test "coarse energy decode validates state band range" {
    var packet: [byte: 1] = [0];
    var dec: EcDec = EcDec{};
    ec_dec_init(&dec, &packet[0:1]);

    var state: CeltDecoderState = CeltDecoderState{};
    try celt_state_init(&state, 1);
    state.start_band = 4;
    state.end_band = 4;

    const bad_range: !void = celt_decode_coarse_energy(&state, &dec, false);
    match bad_range {
        error.CeltQuantBandsError => {}
        else => { try assert(false, "empty coarse energy band range must fail"); }
    }
}
