use std.testing.assert;
use std.testing.assert_eq_i32;
use bench.objective_quality_metrics.ObjectiveQualityResult;
use bench.objective_quality_metrics.objective_quality_energy_i16;
use bench.objective_quality_metrics.objective_quality_fill_music_48k_stereo;
use bench.objective_quality_metrics.objective_quality_fill_voice_16k_mono;
use bench.objective_quality_metrics.objective_quality_measure_i16;
use bench.objective_quality_metrics.objective_quality_mse_q8_i16;
use bench.objective_quality_metrics.objective_quality_noise_i16;
use bench.objective_quality_metrics.objective_quality_snr_q8_i16;
use src.opus.core.types.OpusApplication;
use src.opus.core.types.OpusBandwidth;
use src.opus.core.types.OpusEncoderConfig;
use src.opus.core.types.OpusSignalHint;
use src.opus.core.types.opus_encoder_config_default;

const QUALITY_TEST_PACKET_BYTES: usize = 1275;
const QUALITY_TEST_CELT_FRAME_SAMPLES: usize = 960;
const QUALITY_TEST_CELT_PCM_SAMPLES: usize = QUALITY_TEST_CELT_FRAME_SAMPLES * 2;
const QUALITY_TEST_SILK_FRAME_SAMPLES: usize = 320;

test "objective quality metrics measure mse and snr deterministically" {
    var reference: [i16: 4] = [1000, -1000, 2000, -2000];
    var decoded: [i16: 4] = [900, -900, 2100, -2100];

    const signal_energy: u64 = try objective_quality_energy_i16(&reference[0:4]);
    const noise_energy: u64 = try objective_quality_noise_i16(&reference[0:4], &decoded[0:4]);
    const mse_q8: u64 = try objective_quality_mse_q8_i16(&reference[0:4], &decoded[0:4]);
    const snr_q8: u64 = try objective_quality_snr_q8_i16(&reference[0:4], &decoded[0:4]);

    try assert_eq_i32(signal_energy as i32, 10000000);
    try assert_eq_i32(noise_energy as i32, 40000);
    try assert_eq_i32(mse_q8 as i32, 2560000);
    try assert_eq_i32(snr_q8 as i32, 64000);
}

test "objective quality bench roundtrips fullband music and records packet budget" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 48000;
    config.channels = 2;
    config.application = OpusApplication.AUDIO;
    config.signal_hint = OpusSignalHint.MUSIC;
    config.max_bandwidth = OpusBandwidth.FULLBAND;
    config.bitrate_bps = 64000;
    config.complexity = 10;
    config.vbr = true;

    var pcm: [i16: QUALITY_TEST_CELT_PCM_SAMPLES] = [0: QUALITY_TEST_CELT_PCM_SAMPLES];
    objective_quality_fill_music_48k_stereo(&pcm[0:QUALITY_TEST_CELT_PCM_SAMPLES]);
    var packet: [byte: QUALITY_TEST_PACKET_BYTES] = [0: QUALITY_TEST_PACKET_BYTES];
    var decoded: [i16: QUALITY_TEST_CELT_PCM_SAMPLES] = [0: QUALITY_TEST_CELT_PCM_SAMPLES];

    const result: ObjectiveQualityResult = try objective_quality_measure_i16(
        &config,
        &pcm[0:QUALITY_TEST_CELT_PCM_SAMPLES],
        QUALITY_TEST_CELT_FRAME_SAMPLES as i32,
        &packet[0:QUALITY_TEST_PACKET_BYTES],
        &decoded[0:QUALITY_TEST_CELT_PCM_SAMPLES],
    );

    try assert(result.encoded_bytes > 1, "objective bench must record encoded packet bytes");
    try assert_eq_i32(result.decoded_samples, QUALITY_TEST_CELT_FRAME_SAMPLES as i32);
    try assert_eq_i32(result.sample_count as i32, QUALITY_TEST_CELT_PCM_SAMPLES as i32);
    try assert(result.signal_energy > 0, "objective bench must measure non-zero signal energy");
    try assert(result.noise_energy > 0, "lossy roundtrip must report non-zero noise energy");
    try assert(result.mse_q8 > 0, "lossy roundtrip must report MSE");
}

test "objective quality bench captures speech and music cases" {
    var voice_config: OpusEncoderConfig = opus_encoder_config_default();
    voice_config.sample_rate_hz = 16000;
    voice_config.channels = 1;
    voice_config.application = OpusApplication.VOIP;
    voice_config.signal_hint = OpusSignalHint.VOICE;
    voice_config.max_bandwidth = OpusBandwidth.WIDEBAND;
    voice_config.bitrate_bps = 24000;
    voice_config.complexity = 10;

    var voice_pcm: [i16: QUALITY_TEST_SILK_FRAME_SAMPLES] = [0: QUALITY_TEST_SILK_FRAME_SAMPLES];
    objective_quality_fill_voice_16k_mono(&voice_pcm[0:QUALITY_TEST_SILK_FRAME_SAMPLES]);
    var voice_packet: [byte: QUALITY_TEST_PACKET_BYTES] = [0: QUALITY_TEST_PACKET_BYTES];
    var voice_decoded: [i16: QUALITY_TEST_SILK_FRAME_SAMPLES] = [0: QUALITY_TEST_SILK_FRAME_SAMPLES];
    const voice_result: ObjectiveQualityResult = try objective_quality_measure_i16(
        &voice_config,
        &voice_pcm[0:QUALITY_TEST_SILK_FRAME_SAMPLES],
        QUALITY_TEST_SILK_FRAME_SAMPLES as i32,
        &voice_packet[0:QUALITY_TEST_PACKET_BYTES],
        &voice_decoded[0:QUALITY_TEST_SILK_FRAME_SAMPLES],
    );
    try assert_eq_i32(voice_result.decoded_samples, QUALITY_TEST_SILK_FRAME_SAMPLES as i32);
    try assert(voice_result.encoded_bytes > 1, "speech objective case must produce a packet");

    var music_config: OpusEncoderConfig = opus_encoder_config_default();
    music_config.sample_rate_hz = 48000;
    music_config.channels = 2;
    music_config.application = OpusApplication.AUDIO;
    music_config.signal_hint = OpusSignalHint.MUSIC;
    music_config.max_bandwidth = OpusBandwidth.FULLBAND;
    music_config.bitrate_bps = 64000;
    music_config.complexity = 10;
    music_config.vbr = true;

    var music_pcm: [i16: QUALITY_TEST_CELT_PCM_SAMPLES] = [0: QUALITY_TEST_CELT_PCM_SAMPLES];
    objective_quality_fill_music_48k_stereo(&music_pcm[0:QUALITY_TEST_CELT_PCM_SAMPLES]);
    var music_packet: [byte: QUALITY_TEST_PACKET_BYTES] = [0: QUALITY_TEST_PACKET_BYTES];
    var music_decoded: [i16: QUALITY_TEST_CELT_PCM_SAMPLES] = [0: QUALITY_TEST_CELT_PCM_SAMPLES];
    const music_result: ObjectiveQualityResult = try objective_quality_measure_i16(
        &music_config,
        &music_pcm[0:QUALITY_TEST_CELT_PCM_SAMPLES],
        QUALITY_TEST_CELT_FRAME_SAMPLES as i32,
        &music_packet[0:QUALITY_TEST_PACKET_BYTES],
        &music_decoded[0:QUALITY_TEST_CELT_PCM_SAMPLES],
    );
    try assert_eq_i32(music_result.decoded_samples, QUALITY_TEST_CELT_FRAME_SAMPLES as i32);
    try assert(music_result.sample_count > voice_result.sample_count, "music objective case must record stereo 48k sample coverage");
    try assert(music_result.noise_energy > 0, "music objective case must report roundtrip noise");
}

test "practical speech encoder improves objective MSE over baseline" {
    var baseline_config: OpusEncoderConfig = opus_encoder_config_default();
    baseline_config.sample_rate_hz = 16000;
    baseline_config.channels = 1;
    baseline_config.application = OpusApplication.VOIP;
    baseline_config.signal_hint = OpusSignalHint.VOICE;
    baseline_config.max_bandwidth = OpusBandwidth.WIDEBAND;
    baseline_config.bitrate_bps = 24000;
    baseline_config.complexity = 0;

    var practical_config: OpusEncoderConfig = opus_encoder_config_default();
    practical_config.sample_rate_hz = 16000;
    practical_config.channels = 1;
    practical_config.application = OpusApplication.VOIP;
    practical_config.signal_hint = OpusSignalHint.VOICE;
    practical_config.max_bandwidth = OpusBandwidth.WIDEBAND;
    practical_config.bitrate_bps = 24000;
    practical_config.complexity = 10;

    var pcm: [i16: QUALITY_TEST_SILK_FRAME_SAMPLES] = [0: QUALITY_TEST_SILK_FRAME_SAMPLES];
    objective_quality_fill_voice_16k_mono(&pcm[0:QUALITY_TEST_SILK_FRAME_SAMPLES]);

    var baseline_packet: [byte: QUALITY_TEST_PACKET_BYTES] = [0: QUALITY_TEST_PACKET_BYTES];
    var baseline_decoded: [i16: QUALITY_TEST_SILK_FRAME_SAMPLES] = [0: QUALITY_TEST_SILK_FRAME_SAMPLES];
    const baseline: ObjectiveQualityResult = try objective_quality_measure_i16(
        &baseline_config,
        &pcm[0:QUALITY_TEST_SILK_FRAME_SAMPLES],
        QUALITY_TEST_SILK_FRAME_SAMPLES as i32,
        &baseline_packet[0:QUALITY_TEST_PACKET_BYTES],
        &baseline_decoded[0:QUALITY_TEST_SILK_FRAME_SAMPLES],
    );

    var practical_packet: [byte: QUALITY_TEST_PACKET_BYTES] = [0: QUALITY_TEST_PACKET_BYTES];
    var practical_decoded: [i16: QUALITY_TEST_SILK_FRAME_SAMPLES] = [0: QUALITY_TEST_SILK_FRAME_SAMPLES];
    const practical: ObjectiveQualityResult = try objective_quality_measure_i16(
        &practical_config,
        &pcm[0:QUALITY_TEST_SILK_FRAME_SAMPLES],
        QUALITY_TEST_SILK_FRAME_SAMPLES as i32,
        &practical_packet[0:QUALITY_TEST_PACKET_BYTES],
        &practical_decoded[0:QUALITY_TEST_SILK_FRAME_SAMPLES],
    );

    const required_mse_q8: u64 = (baseline.mse_q8 * 99) / 100;
    try assert(practical.mse_q8 <= required_mse_q8, "practical speech encoder must clear the 1% objective MSE gate");
    try assert(practical.snr_q8 >= baseline.snr_q8, "practical speech encoder must not reduce objective SNR");
}

test "practical music encoder improves objective MSE over baseline" {
    var baseline_config: OpusEncoderConfig = opus_encoder_config_default();
    baseline_config.sample_rate_hz = 48000;
    baseline_config.channels = 2;
    baseline_config.application = OpusApplication.AUDIO;
    baseline_config.signal_hint = OpusSignalHint.MUSIC;
    baseline_config.max_bandwidth = OpusBandwidth.FULLBAND;
    baseline_config.bitrate_bps = 64000;
    baseline_config.complexity = 0;
    baseline_config.vbr = true;

    var practical_config: OpusEncoderConfig = opus_encoder_config_default();
    practical_config.sample_rate_hz = 48000;
    practical_config.channels = 2;
    practical_config.application = OpusApplication.AUDIO;
    practical_config.signal_hint = OpusSignalHint.MUSIC;
    practical_config.max_bandwidth = OpusBandwidth.FULLBAND;
    practical_config.bitrate_bps = 64000;
    practical_config.complexity = 10;
    practical_config.vbr = true;

    var pcm: [i16: QUALITY_TEST_CELT_PCM_SAMPLES] = [0: QUALITY_TEST_CELT_PCM_SAMPLES];
    objective_quality_fill_music_48k_stereo(&pcm[0:QUALITY_TEST_CELT_PCM_SAMPLES]);

    var baseline_packet: [byte: QUALITY_TEST_PACKET_BYTES] = [0: QUALITY_TEST_PACKET_BYTES];
    var baseline_decoded: [i16: QUALITY_TEST_CELT_PCM_SAMPLES] = [0: QUALITY_TEST_CELT_PCM_SAMPLES];
    const baseline: ObjectiveQualityResult = try objective_quality_measure_i16(
        &baseline_config,
        &pcm[0:QUALITY_TEST_CELT_PCM_SAMPLES],
        QUALITY_TEST_CELT_FRAME_SAMPLES as i32,
        &baseline_packet[0:QUALITY_TEST_PACKET_BYTES],
        &baseline_decoded[0:QUALITY_TEST_CELT_PCM_SAMPLES],
    );

    var practical_packet: [byte: QUALITY_TEST_PACKET_BYTES] = [0: QUALITY_TEST_PACKET_BYTES];
    var practical_decoded: [i16: QUALITY_TEST_CELT_PCM_SAMPLES] = [0: QUALITY_TEST_CELT_PCM_SAMPLES];
    const practical: ObjectiveQualityResult = try objective_quality_measure_i16(
        &practical_config,
        &pcm[0:QUALITY_TEST_CELT_PCM_SAMPLES],
        QUALITY_TEST_CELT_FRAME_SAMPLES as i32,
        &practical_packet[0:QUALITY_TEST_PACKET_BYTES],
        &practical_decoded[0:QUALITY_TEST_CELT_PCM_SAMPLES],
    );

    const required_mse_q8: u64 = (baseline.mse_q8 * 99) / 100;
    try assert(practical.mse_q8 <= required_mse_q8, "practical music encoder must clear the 1% objective MSE gate");
    try assert(practical.snr_q8 >= baseline.snr_q8, "practical music encoder must not reduce objective SNR");
}
