use std.testing.assert;
use std.testing.assert_eq_i32;
use src.opus.celt.state.CeltDecoderState;
use src.opus.core.types.OpusBandwidth;
use src.opus.core.types.OpusMode;
use src.opus.core.types.PacketInfo;
use src.opus.hybrid.budget.HybridBudgetSplit;
use src.opus.hybrid.budget.hybrid_budget_init;
use src.opus.hybrid.decoder.HybridDecodeResult;
use src.opus.hybrid.decoder.HybridDecoderScratch;
use src.opus.hybrid.decoder.hybrid_decode_i16;
use src.opus.hybrid.delay.hybrid_delay_apply_highband_i16_to_q14;
use src.opus.hybrid.highband.HybridHighbandDecodeResult;
use src.opus.hybrid.highband.hybrid_highband_decode_i16;
use src.opus.hybrid.lowband.hybrid_lowband_decode_mono_q14;
use src.opus.hybrid.merge.hybrid_merge_i16;
use src.opus.hybrid.state.HYBRID_CELT_START_BAND;
use src.opus.hybrid.state.HYBRID_CELT_SWB_END_BAND;
use src.opus.hybrid.state.HybridDecoderState;
use src.opus.hybrid.state.hybrid_state_configure_from_packet_info;
use src.opus.silk.state.SilkDecoderState;
use tests.hybrid_payload.hybrid_test_encode_wb_lowband_payload;

fn hybrid_decoder_packet_info(bandwidth: OpusBandwidth, channels: u8, duration_us: u32) PacketInfo {
    var duration_samples_48k: i32 = 480;
    if duration_us == 20000 {
        duration_samples_48k = 960;
    }
    return PacketInfo{
        mode: OpusMode.HYBRID,
        bandwidth: bandwidth,
        channels: channels,
        frame_count: 1,
        frame_duration_us: duration_us,
        duration_samples_48k: duration_samples_48k,
        payload_offset: 1,
        payload_len: 0,
        self_delimited: false,
        has_padding: false,
    };
}

fn assert_i16_slice_eq(actual: &[i16], expected: &[i16]) !void {
    try assert_eq_i32(actual.len as i32, expected.len as i32);
    var i: usize = 0;
    while i < actual.len {
        try assert_eq_i32(actual.ptr[i] as i32, expected.ptr[i] as i32);
        i = i + 1;
    }
}

fn expect_hybrid_decoder_matches_manual_swb_pipeline(duration_us: u32, lowband_samples: usize, frame_samples: usize, frame_bytes: usize) !void {
    var frame: [byte: 640] = [0: 640];
    const encoded_bytes: usize = try hybrid_test_encode_wb_lowband_payload(&frame[0:640], lowband_samples as i32);
    try assert(encoded_bytes > 0, "hybrid test frame must contain encoded SILK bits");
    try assert(frame_bytes <= 640, "hybrid test frame length must fit storage");
    var info: PacketInfo = hybrid_decoder_packet_info(OpusBandwidth.SUPERWIDEBAND, 1, duration_us);

    var split: HybridBudgetSplit = HybridBudgetSplit{};
    try hybrid_budget_init(&split, &info, &frame[0:frame_bytes]);
    var manual_silk_state: SilkDecoderState = SilkDecoderState{};
    var lowband_q14: [i32: 320] = [0: 320];
    _ = try hybrid_lowband_decode_mono_q14(&manual_silk_state, &split, &lowband_q14[0:lowband_samples]);

    var manual_celt_state: CeltDecoderState = CeltDecoderState{};
    var manual_scratch: HybridDecoderScratch = HybridDecoderScratch{};
    var highband_i16: [i16: 960] = [0: 960];
    const highband_res: HybridHighbandDecodeResult = try hybrid_highband_decode_i16(
        &manual_celt_state,
        &split,
        &highband_i16[0:frame_samples],
        &manual_scratch.celt_scratch,
    );

    var manual_hybrid_state: HybridDecoderState = HybridDecoderState{};
    try hybrid_state_configure_from_packet_info(&manual_hybrid_state, &info);
    var highband_q14: [i32: 960] = [0: 960];
    _ = try hybrid_delay_apply_highband_i16_to_q14(&manual_hybrid_state, &highband_i16[0:frame_samples], &highband_q14[0:frame_samples]);
    var expected_pcm: [i16: 960] = [0: 960];
    _ = try hybrid_merge_i16(&manual_hybrid_state, &lowband_q14[0:lowband_samples], &highband_q14[0:frame_samples], &expected_pcm[0:frame_samples]);

    var hybrid_state: HybridDecoderState = HybridDecoderState{};
    var silk_state: SilkDecoderState = SilkDecoderState{};
    var celt_state: CeltDecoderState = CeltDecoderState{};
    var scratch: HybridDecoderScratch = HybridDecoderScratch{};
    var actual_pcm: [i16: 960] = [0: 960];
    const result: HybridDecodeResult = try hybrid_decode_i16(
        &hybrid_state,
        &silk_state,
        &celt_state,
        &info,
        &frame[0:frame_bytes],
        &actual_pcm[0:frame_samples],
        &scratch,
    );

    try assert_eq_i32(result.decoded_samples_48k, frame_samples as i32);
    try assert_eq_i32(result.channels, 1);
    try assert_eq_i32(result.lowband_samples_16k, lowband_samples as i32);
    try assert_eq_i32(result.highband_samples_48k, frame_samples as i32);
    try assert_eq_i32(result.celt_start_bit, highband_res.celt_start_bit);
    try assert_eq_i32(result.celt_end_bit, highband_res.celt_end_bit);
    try assert_i16_slice_eq(&actual_pcm[0:frame_samples], &expected_pcm[0:frame_samples]);
    try assert_eq_i32(hybrid_state.frame_size_48k, frame_samples as i32);
    try assert_eq_i32(hybrid_state.celt_start_band, HYBRID_CELT_START_BAND);
    try assert_eq_i32(hybrid_state.celt_end_band, HYBRID_CELT_SWB_END_BAND);
    try assert_eq_i32(celt_state.start_band, HYBRID_CELT_START_BAND);
    try assert_eq_i32(celt_state.end_band, HYBRID_CELT_SWB_END_BAND);
}

test "hybrid decoder supports mono SWB 10ms frame pipeline" {
    try expect_hybrid_decoder_matches_manual_swb_pipeline(10000, 160, 480, 255);
}

test "hybrid decoder supports mono SWB 20ms frame pipeline" {
    try expect_hybrid_decoder_matches_manual_swb_pipeline(20000, 320, 960, 511);
}

test "hybrid decoder SWB 10ms path validates active layout and buffers" {
    var frame: [byte: 320] = [0: 320];
    _ = try hybrid_test_encode_wb_lowband_payload(&frame[0:320], 160);
    const frame_bytes: usize = 255;
    var info: PacketInfo = hybrid_decoder_packet_info(OpusBandwidth.SUPERWIDEBAND, 1, 10000);

    var hybrid_state: HybridDecoderState = HybridDecoderState{};
    var silk_state: SilkDecoderState = SilkDecoderState{};
    var celt_state: CeltDecoderState = CeltDecoderState{};
    var scratch: HybridDecoderScratch = HybridDecoderScratch{};
    var short_pcm: [i16: 479] = [0: 479];
    const short_out: !HybridDecodeResult = hybrid_decode_i16(
        &hybrid_state,
        &silk_state,
        &celt_state,
        &info,
        &frame[0:frame_bytes],
        &short_pcm[0:479],
        &scratch,
    );
    match short_out {
        error.HybridDecoderError => {}
        else => { try assert(false, "hybrid SWB 10ms decoder must reject short output"); }
    }

    var pcm: [i16: 480] = [0: 480];
    info.bandwidth = OpusBandwidth.FULLBAND;
    const fb_res: !HybridDecodeResult = hybrid_decode_i16(
        &hybrid_state,
        &silk_state,
        &celt_state,
        &info,
        &frame[0:frame_bytes],
        &pcm[0:480],
        &scratch,
    );
    match fb_res {
        error.HybridDecoderUnsupported => {}
        else => { try assert(false, "SWB 10ms task must not silently accept FB frames"); }
    }

    info = hybrid_decoder_packet_info(OpusBandwidth.SUPERWIDEBAND, 2, 10000);
    const stereo_res: !HybridDecodeResult = hybrid_decode_i16(
        &hybrid_state,
        &silk_state,
        &celt_state,
        &info,
        &frame[0:frame_bytes],
        &pcm[0:480],
        &scratch,
    );
    match stereo_res {
        error.HybridDecoderUnsupported => {}
        else => { try assert(false, "hybrid decoder must reject unsupported stereo SWB frames"); }
    }
}
