test "decoder reset clears state while preserving output config" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 16000, channels: 1 };
    try decoder_init(&decoder, &config);

    var silk_packet: [byte: 384] = [0: 384];
    silk_packet[0] = (72 as! byte).value;
    _ = try hybrid_test_encode_wb_lowband_payload(&silk_packet[1:383], 320);
    var silk_pcm: [i16: 320] = [0: 320];
    const silk_decoded: i32 = try decoder_decode_i16(&decoder, &silk_packet[0:384], &silk_pcm[0:320], 320, false);
    try assert_eq_i32(silk_decoded, 320);
    try assert(decoder.history.active_mode == OpusMode.SILK, "SILK-only packet must move decoder before reset");

    var hybrid_packet: [byte: 256] = [0: 256];
    hybrid_packet[0] = (96 as! byte).value;
    _ = try hybrid_test_encode_wb_lowband_payload(&hybrid_packet[1:255], 160);
    var hybrid_pcm: [i16: 160] = [0: 160];
    const hybrid_decoded: i32 = try decoder_decode_i16(&decoder, &hybrid_packet[0:256], &hybrid_pcm[0:160], 160, false);
    try assert_eq_i32(hybrid_decoded, 160);
    try assert(decoder.history.active_mode == OpusMode.HYBRID, "Hybrid packet must move decoder before reset");

    decoder.history.celt.decode_mem[0] = 1234;
    decoder.history.celt.freq_history_ready = true;
    decoder.history.celt.loss_count = 7;
    decoder.scratch.celt_plc.used_frequency_history = true;
    decoder.history.silk.history_q14[0] = 2345;
    decoder.history.silk.loss_count = 5;
    decoder.history.hybrid.delay_q14[0] = 3456;
    decoder.history.hybrid.merge_mem_q14[0] = 4567;
    decoder.history.hybrid_silk.history_q14[0] = 5678;

    try decoder_reset(&decoder);

    try assert_eq_i32(decoder.config.sample_rate_hz as i32, 16000);
    try assert_eq_i32(decoder.config.channels as i32, 1);
    try assert_eq_i32(decoder.resampler.output_rate_hz as i32, 16000);
    try assert_eq_i32(decoder.resampler.input_rate_hz as i32, 48000);
    try assert_eq_i32(decoder.silk_resampler.input_rate_hz as i32, HYBRID_SILK_SAMPLE_RATE_HZ);
    try assert_eq_i32(decoder.silk_resampler.output_rate_hz as i32, 16000);
    try assert(decoder.history.active_mode == OpusMode.CELT, "decoder reset must return to CELT mode");
    try assert_eq_i32(decoder.history.last_frame_size_48k, decoder.history.celt.frame_size);
    try assert_eq_i32(decoder.history.celt.start_band, 0);
    try assert_eq_i32(decoder.history.celt.decode_mem[0], 0);
    try assert(!decoder.history.celt.freq_history_ready, "decoder reset must clear CELT frequency history");
    try assert_eq_i32(decoder.history.celt.loss_count, 0);
    try assert(!decoder.scratch.celt_plc.used_frequency_history, "decoder reset must clear public PLC scratch markers");
    try assert_eq_i32(decoder.history.silk.sample_rate_hz, 0);
    try assert_eq_i32(decoder.history.silk.history_q14[0], 0);
    try assert_eq_i32(decoder.history.silk.loss_count, 0);
    try assert_eq_i32(decoder.history.hybrid.frame_size_48k, 0);
    try assert_eq_i32(decoder.history.hybrid.delay_q14[0], 0);
    try assert_eq_i32(decoder.history.hybrid.merge_mem_q14[0], 0);
    try assert_eq_i32(decoder.history.hybrid_silk.history_q14[0], 0);

    var empty_packet: [byte: 1] = [0];
    var pcm_after_reset: [i16: 40] = [0: 40];
    const decoded_after_reset: i32 = try decoder_decode_i16(&decoder, &empty_packet[0:0], &pcm_after_reset[0:40], 40, false);
    try assert_eq_i32(decoded_after_reset, 40);
    try assert(decoder.history.active_mode == OpusMode.CELT, "decoder must remain usable after reset");
}

test "decoder api applies linear gain q8 to output pcm" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 1 };
    try decoder_init(&decoder, &config);

    const negative_gain: !void = decoder_set_gain_q8(&decoder, -1);
    match negative_gain {
        error.DecoderApiError => {}
        else => { try assert(false, "decoder gain must reject negative linear Q8 values"); }
    }

    const oversized_gain: !void = decoder_set_gain_q8(&decoder, 65537);
    match oversized_gain {
        error.DecoderApiError => {}
        else => { try assert(false, "decoder gain must reject oversized linear Q8 values"); }
    }

    const half_gain_q8: i32 = 128;
    try decoder_set_gain_q8(&decoder, half_gain_q8);
    const tail: usize = CELT_DECODE_MEM - 120;
    decoder.history.celt.decode_mem[tail] = 1000;

    var empty_packet: [byte: 1] = [0];
    var half_pcm: [i16: 120] = [0: 120];
    const half_decoded: i32 = try decoder_decode_i16(&decoder, &empty_packet[0:0], &half_pcm[0:120], 120, false);
    try assert_eq_i32(half_decoded, 120);
    try assert_eq_i32(half_pcm[0] as i32, 500);

    const double_gain_q8: i32 = 512;
    try decoder_set_gain_q8(&decoder, double_gain_q8);
    try decoder_reset(&decoder);
    decoder.history.celt.decode_mem[tail] = 20000;
    decoder.history.celt.decode_mem[tail + 1] = -20000;

    var saturated_pcm: [i16: 120] = [0: 120];
    const saturated_decoded: i32 = try decoder_decode_i16(&decoder, &empty_packet[0:0], &saturated_pcm[0:120], 120, false);
    try assert_eq_i32(saturated_decoded, 120);
    try assert_eq_i32(saturated_pcm[0] as i32, 32767);
    try assert_eq_i32(saturated_pcm[1] as i32, -32768);
}

test "decoder api applies gain after output resampling" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 16000, channels: 1 };
    try decoder_init(&decoder, &config);
    try decoder_set_gain_q8(&decoder, 512);

    const tail: usize = CELT_DECODE_MEM - 120;
    decoder.history.celt.decode_mem[tail] = 30000;
    decoder.history.celt.decode_mem[tail + 1] = 30000;
    decoder.history.celt.decode_mem[tail + 2] = -30000;

    var empty_packet: [byte: 1] = [0];
    var pcm: [i16: 40] = [0: 40];
    const decoded: i32 = try decoder_decode_i16(&decoder, &empty_packet[0:0], &pcm[0:40], 40, false);

    try assert_eq_i32(decoded, 40);
    try assert_eq_i32(pcm[0] as i32, 20000);
}

test "decoder api uses celt frequency history on packet loss after a decoded packet" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 1 };
    try decoder_init(&decoder, &config);

    var packet: [byte: 65] = [0: 65];
    packet[0] = (128 as! byte).value;
    var i: usize = 1;
    var rng: u32 = 0x31415926;
    while i < 65 {
        rng = rng * 1664525 + 1013904223;
        packet[i] = ((rng >> 24) as! byte).value;
        i = i + 1;
    }

    var pcm: [i16: 120] = [0: 120];
    const normal_decoded: i32 = try decoder_decode_i16(&decoder, &packet[0:65], &pcm[0:120], 120, false);
    try assert_eq_i32(normal_decoded, 120);
    try assert(decoder.history.celt.freq_history_ready, "normal decode must prepare frequency PLC history");

    var empty_packet: [byte: 1] = [0];
    var lost_pcm: [i16: 120] = [0: 120];
    const lost_decoded: i32 = try decoder_decode_i16(&decoder, &empty_packet[0:0], &lost_pcm[0:120], 120, false);

    try assert_eq_i32(lost_decoded, 120);
    try assert(decoder.scratch.celt_plc.used_frequency_history, "empty packet after CELT decode must use frequency-domain PLC");
    try assert_eq_i32(decoder.history.celt.loss_count, 1);
}

test "decoder api conceals one lost packet after a normal celt packet" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 1 };
    try decoder_init(&decoder, &config);

    var packet: [byte: 65] = [0: 65];
    packet[0] = (128 as! byte).value;
    var i: usize = 1;
    while i < 65 {
        packet[i] = ((i * 7 + 11) as! byte).value;
        i = i + 1;
    }

    var pcm: [i16: 120] = [0: 120];
    const decoded: i32 = try decoder_decode_i16(&decoder, &packet[0:65], &pcm[0:120], 120, false);
    try assert_eq_i32(decoded, 120);
    try assert_eq_i32(decoder.history.celt.loss_count, 0);

    var empty_packet: [byte: 1] = [0];
    var lost_pcm: [i16: 120] = [0: 120];
    const concealed: i32 = try decoder_decode_i16(&decoder, &empty_packet[0:0], &lost_pcm[0:120], 120, false);

    try assert_eq_i32(concealed, 120);
    try assert_eq_i32(decoder.history.celt.loss_count, 1);
    try assert(decoder.scratch.celt_plc.used_frequency_history, "single lost CELT packet must use frequency-domain PLC when history is ready");
    try assert(decoder.history.active_mode == OpusMode.CELT, "single packet loss must preserve the active CELT decoder mode");
}

test "decoder api conceals consecutive lost celt packets" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 1 };
    try decoder_init(&decoder, &config);

    var packet: [byte: 65] = [0: 65];
    packet[0] = (128 as! byte).value;
    var i: usize = 1;
    while i < 65 {
        packet[i] = ((i * 5 + 19) as! byte).value;
        i = i + 1;
    }

    var pcm: [i16: 120] = [0: 120];
    const decoded: i32 = try decoder_decode_i16(&decoder, &packet[0:65], &pcm[0:120], 120, false);
    try assert_eq_i32(decoded, 120);

    var empty_packet: [byte: 1] = [0];
    var first_loss_pcm: [i16: 120] = [0: 120];
    const first_loss: i32 = try decoder_decode_i16(&decoder, &empty_packet[0:0], &first_loss_pcm[0:120], 120, false);
    try assert_eq_i32(first_loss, 120);
    try assert_eq_i32(decoder.history.celt.loss_count, 1);

    var second_loss_pcm: [i16: 120] = [0: 120];
    const second_loss: i32 = try decoder_decode_i16(&decoder, &empty_packet[0:0], &second_loss_pcm[0:120], 120, false);
    try assert_eq_i32(second_loss, 120);
    try assert_eq_i32(decoder.history.celt.loss_count, 2);
    try assert(decoder.scratch.celt_plc.used_frequency_history, "consecutive CELT losses must keep using bounded PLC history");
}

test "decoder api decodes a normal celt packet after packet loss" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 1 };
    try decoder_init(&decoder, &config);

    var first_packet: [byte: 65] = [0: 65];
    first_packet[0] = (128 as! byte).value;
    var i: usize = 1;
    while i < 65 {
        first_packet[i] = ((i * 9 + 13) as! byte).value;
        i = i + 1;
    }

    var first_pcm: [i16: 120] = [0: 120];
    const first_decoded: i32 = try decoder_decode_i16(&decoder, &first_packet[0:65], &first_pcm[0:120], 120, false);
    try assert_eq_i32(first_decoded, 120);

    var empty_packet: [byte: 1] = [0];
    var lost_pcm: [i16: 120] = [0: 120];
    const lost_decoded: i32 = try decoder_decode_i16(&decoder, &empty_packet[0:0], &lost_pcm[0:120], 120, false);
    try assert_eq_i32(lost_decoded, 120);
    try assert_eq_i32(decoder.history.celt.loss_count, 1);

    var second_packet: [byte: 65] = [0: 65];
    second_packet[0] = (128 as! byte).value;
    i = 1;
    while i < 65 {
        second_packet[i] = ((255 - (i * 2)) as! byte).value;
        i = i + 1;
    }

    var second_pcm: [i16: 120] = [0: 120];
    const second_decoded: i32 = try decoder_decode_i16(&decoder, &second_packet[0:65], &second_pcm[0:120], 120, false);
    try assert_eq_i32(second_decoded, 120);
    try assert_eq_i32(decoder.history.celt.loss_count, 0);
    try assert(decoder.history.active_mode == OpusMode.CELT, "normal packet decode after PLC must keep CELT mode active");
    try assert(decoder.history.celt.freq_history_ready, "normal packet decode after PLC must refresh frequency PLC history");
}

test "decoder api switches into and out of hybrid mode" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 1 };
    try decoder_init(&decoder, &config);

    var celt_packet: [byte: 65] = [0: 65];
    celt_packet[0] = (128 as! byte).value;
    var i: usize = 1;
    while i < 65 {
        celt_packet[i] = ((i * 13 + 5) as! byte).value;
        i = i + 1;
    }

    var celt_pcm: [i16: 120] = [0: 120];
    const celt_decoded: i32 = try decoder_decode_i16(&decoder, &celt_packet[0:65], &celt_pcm[0:120], 120, false);
    try assert_eq_i32(celt_decoded, 120);
    try assert(decoder.history.active_mode == OpusMode.CELT, "first CELT packet must leave decoder in CELT mode");
    try assert_eq_i32(decoder.history.celt.start_band, 0);

    var hybrid_packet: [byte: 256] = [0: 256];
    hybrid_packet[0] = (96 as! byte).value;
    _ = try hybrid_test_encode_wb_lowband_payload(&hybrid_packet[1:255], 160);

    var hybrid_pcm: [i16: 480] = [0: 480];
    const hybrid_decoded: i32 = try decoder_decode_i16(&decoder, &hybrid_packet[0:256], &hybrid_pcm[0:480], 480, false);
    try assert_eq_i32(hybrid_decoded, 480);
    try assert(decoder.history.active_mode == OpusMode.HYBRID, "hybrid packet must switch the public decoder into Hybrid mode");
    try assert_eq_i32(decoder.history.hybrid.frame_size_48k, 480);
    try assert_eq_i32(decoder.history.hybrid.celt_start_band, HYBRID_CELT_START_BAND);
    try assert_eq_i32(decoder.history.hybrid.celt_end_band, HYBRID_CELT_SWB_END_BAND);
    try assert_eq_i32(decoder.history.hybrid_silk.sample_rate_hz, HYBRID_SILK_SAMPLE_RATE_HZ);
    try assert_eq_i32(decoder.history.celt.start_band, HYBRID_CELT_START_BAND);
    try assert_eq_i32(decoder.history.celt.end_band, HYBRID_CELT_SWB_END_BAND);

    decoder.history.hybrid.merge_mem_q14[0] = 123456;
    decoder.history.hybrid.delay_q14[0] = 654321;
    decoder.history.hybrid_silk.history_q14[0] = 345678;

    var after_hybrid_celt_pcm: [i16: 120] = [0: 120];
    const after_hybrid_celt: i32 = try decoder_decode_i16(&decoder, &celt_packet[0:65], &after_hybrid_celt_pcm[0:120], 120, false);
    try assert_eq_i32(after_hybrid_celt, 120);
    try assert(decoder.history.active_mode == OpusMode.CELT, "CELT packet after Hybrid must switch back to CELT mode");
    try assert_eq_i32(decoder.history.celt.start_band, 0);
    try assert_eq_i32(decoder.history.hybrid.merge_mem_q14[0], 0);
    try assert_eq_i32(decoder.history.hybrid.delay_q14[0], 0);
    try assert_eq_i32(decoder.history.hybrid_silk.history_q14[0], 0);

    var second_hybrid_pcm: [i16: 480] = [0: 480];
    const second_hybrid: i32 = try decoder_decode_i16(&decoder, &hybrid_packet[0:256], &second_hybrid_pcm[0:480], 480, false);
    try assert_eq_i32(second_hybrid, 480);
    try assert(decoder.history.active_mode == OpusMode.HYBRID, "Hybrid packet after CELT must switch back into Hybrid mode");
}

test "decoder api decode_fec falls back to plc without consuming celt packet" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 1 };
    try decoder_init(&decoder, &config);

    var first_packet: [byte: 65] = [0: 65];
    first_packet[0] = (128 as! byte).value;
    var i: usize = 1;
    while i < 65 {
        first_packet[i] = ((i * 3) as! byte).value;
        i = i + 1;
    }

    var pcm: [i16: 120] = [0: 120];
    _ = try decoder_decode_i16(&decoder, &first_packet[0:65], &pcm[0:120], 120, false);

    var next_packet: [byte: 65] = [0: 65];
    next_packet[0] = (128 as! byte).value;
    i = 1;
    while i < 65 {
        next_packet[i] = ((255 - i) as! byte).value;
        i = i + 1;
    }

    var recovered_pcm: [i16: 120] = [0: 120];
    const recovered: i32 = try decoder_decode_i16(&decoder, &next_packet[0:65], &recovered_pcm[0:120], 120, true);
    try assert_eq_i32(recovered, 120);
    try assert(decoder.scratch.celt_plc.used_frequency_history, "CELT packets do not carry FEC and must use PLC fallback");
    try assert_eq_i32(decoder.history.celt.loss_count, 1);

    var decoded_pcm: [i16: 120] = [0: 120];
    const decoded: i32 = try decoder_decode_i16(&decoder, &next_packet[0:65], &decoded_pcm[0:120], 120, false);
    try assert_eq_i32(decoded, 120);
    try assert_eq_i32(decoder.history.celt.loss_count, 0);
}

test "decoder api plc and fec fallback only write requested pcm slice" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 1 };
    try decoder_init(&decoder, &config);
    const tail: usize = CELT_DECODE_MEM - 120;
    decoder.history.celt.decode_mem[tail] = 3210;

    var empty_packet: [byte: 1] = [0];
    var plc_guarded: [i16: 128] = [0: 128];
    var i: usize = 0;
    while i < 128 {
        plc_guarded[i] = -12345;
        i = i + 1;
    }

    const plc_decoded: i32 = try decoder_decode_i16(&decoder, &empty_packet[0:0], &plc_guarded[4:120], 120, false);
    try assert_eq_i32(plc_decoded, 120);
    try assert_eq_i32(plc_guarded[0] as i32, -12345);
    try assert_eq_i32(plc_guarded[3] as i32, -12345);
    try assert_eq_i32(plc_guarded[4] as i32, 3210);
    try assert_eq_i32(plc_guarded[124] as i32, -12345);
    try assert_eq_i32(plc_guarded[127] as i32, -12345);

    var celt_packet: [byte: 65] = [0: 65];
    celt_packet[0] = (128 as! byte).value;
    i = 1;
    while i < 65 {
        celt_packet[i] = ((i * 11 + 7) as! byte).value;
        i = i + 1;
    }

    var fec_guarded: [i16: 128] = [0: 128];
    i = 0;
    while i < 128 {
        fec_guarded[i] = -23456;
        i = i + 1;
    }

    const fec_decoded: i32 = try decoder_decode_i16(&decoder, &celt_packet[0:65], &fec_guarded[4:120], 120, true);
    try assert_eq_i32(fec_decoded, 120);
    try assert_eq_i32(fec_guarded[0] as i32, -23456);
    try assert_eq_i32(fec_guarded[3] as i32, -23456);
    try assert_eq_i32(fec_guarded[124] as i32, -23456);
    try assert_eq_i32(fec_guarded[127] as i32, -23456);
}

test "decoder api empty packet validates pcm bounds" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 1 };
    try decoder_init(&decoder, &config);

    var empty_packet: [byte: 1] = [0];
    var pcm: [i16: 120] = [0: 120];
    const short_output: !i32 = decoder_decode_i16(&decoder, &empty_packet[0:0], &pcm[0:119], 120, false);
    match short_output {
        error.DecoderApiError => {}
        else => { try assert(false, "empty packet PLC must reject short PCM output"); }
    }
}
