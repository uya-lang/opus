use std.testing.assert;
use std.testing.assert_eq_i32;
use src.opus.api.decoder.DecoderApiError;
use src.opus.api.decoder.DecoderApiUnsupported;
use src.opus.api.decoder.OpusDecoder;
use src.opus.api.decoder.decoder_decode_i16;
use src.opus.api.decoder.decoder_get_packet_info;
use src.opus.api.decoder.decoder_init;
use src.opus.celt.state.CELT_DECODE_MEM;
use src.opus.core.types.OpusDecoderConfig;
use src.opus.core.types.OpusMode;
use src.opus.core.types.PacketInfo;
use src.opus.hybrid.state.HYBRID_CELT_START_BAND;
use src.opus.hybrid.state.HYBRID_CELT_SWB_END_BAND;
use src.opus.hybrid.state.HYBRID_SILK_SAMPLE_RATE_HZ;
use tests.hybrid_payload.hybrid_test_encode_wb_lowband_payload;

test "decoder init validates config and initializes 48k state" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 2 };
    try decoder_init(&decoder, &config);

    try assert_eq_i32(decoder.config.sample_rate_hz as i32, 48000);
    try assert_eq_i32(decoder.config.channels as i32, 2);
    try assert(decoder.active_mode == OpusMode.CELT, "decoder init must start in CELT mode");
    try assert_eq_i32(decoder.celt.channels, 2);
    try assert_eq_i32(decoder.last_frame_size_48k, decoder.celt.frame_size);
    try assert_eq_i32(decoder.hybrid.frame_size_48k, 0);

    const bad_channels: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 0 };
    const bad_channels_result: !void = decoder_init(&decoder, &bad_channels);
    match bad_channels_result {
        error.DecoderApiError => {}
        else => { try assert(false, "decoder init must reject invalid channel counts"); }
    }

    const output_rate: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 16000, channels: 1 };
    try decoder_init(&decoder, &output_rate);
    try assert_eq_i32(decoder.config.sample_rate_hz as i32, 16000);
    try assert_eq_i32(decoder.resampler.output_rate_hz as i32, 16000);
    try assert_eq_i32(decoder.resampler.input_rate_hz as i32, 48000);

    const unsupported_rate: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 44100, channels: 1 };
    const unsupported_rate_result: !void = decoder_init(&decoder, &unsupported_rate);
    match unsupported_rate_result {
        error.DecoderApiError => {}
        else => { try assert(false, "decoder init must reject unsupported output rates"); }
    }
}

test "decoder api packet info exposes parser metadata" {
    const packet: [byte: 3] = [252, 1, 2];
    var info: PacketInfo = PacketInfo{};
    try decoder_get_packet_info(&packet[0:3], &info);

    try assert_eq_i32(info.channels as i32, 2);
    try assert_eq_i32(info.frame_count as i32, 1);
    try assert_eq_i32(info.frame_duration_us as i32, 20000);
    try assert_eq_i32(info.duration_samples_48k as i32, 960);

    var empty_packet: [byte: 1] = [0];
    const empty_info: !void = decoder_get_packet_info(&empty_packet[0:0], &info);
    match empty_info {
        error.DecoderApiError => {}
        else => { try assert(false, "decoder api packet info must map parser errors to API errors"); }
    }
}

test "decoder api empty packet invokes celt plc" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 1 };
    try decoder_init(&decoder, &config);
    const tail: usize = CELT_DECODE_MEM - 120;
    decoder.celt.decode_mem[tail] = 5000;

    var empty_packet: [byte: 1] = [0];
    var pcm: [i16: 120] = [0: 120];
    const decoded: i32 = try decoder_decode_i16(&decoder, &empty_packet[0:0], &pcm[0:120], 120, false);

    try assert_eq_i32(decoded, 120);
    try assert_eq_i32(pcm[0] as i32, 5000);
    try assert_eq_i32(decoder.celt.loss_count, 1);
    try assert(decoder.active_mode == OpusMode.CELT, "empty-packet PLC must keep CELT mode active");
}

test "decoder api converts empty-packet plc to configured output rate" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 16000, channels: 1 };
    try decoder_init(&decoder, &config);

    const tail: usize = CELT_DECODE_MEM - 120;
    var i: usize = 0;
    while i < 120 {
        decoder.celt.decode_mem[tail + i] = (i as i32) * 3;
        i = i + 1;
    }

    var empty_packet: [byte: 1] = [0];
    var pcm: [i16: 40] = [0: 40];
    const decoded: i32 = try decoder_decode_i16(&decoder, &empty_packet[0:0], &pcm[0:40], 40, false);

    try assert_eq_i32(decoded, 40);
    try assert_eq_i32(decoder.last_frame_size_48k, 120);
    try assert_eq_i32(pcm[0] as i32, 3);
    try assert_eq_i32(pcm[1] as i32, 12);
    try assert_eq_i32(pcm[39] as i32, 354);
    try assert_eq_i32(decoder.celt.loss_count, 1);
    try assert(decoder.active_mode == OpusMode.CELT, "sample-rate conversion must preserve active CELT mode");
}

test "decoder api 48k output fast path writes directly to caller pcm" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 1 };
    try decoder_init(&decoder, &config);

    const tail: usize = CELT_DECODE_MEM - 120;
    var i: usize = 0;
    while i < 120 {
        decoder.celt.decode_mem[tail + i] = 2000 + (i as i32);
        decoder.output_scratch_i16[i] = -2222;
        i = i + 1;
    }

    var empty_packet: [byte: 1] = [0];
    var pcm: [i16: 120] = [0: 120];
    const decoded: i32 = try decoder_decode_i16(&decoder, &empty_packet[0:0], &pcm[0:120], 120, false);

    try assert_eq_i32(decoded, 120);
    try assert_eq_i32(pcm[0] as i32, 2000);
    try assert_eq_i32(pcm[119] as i32, 2119);
    try assert_eq_i32(decoder.output_scratch_i16[0] as i32, -2222);
    try assert_eq_i32(decoder.output_scratch_i16[119] as i32, -2222);
}

test "decoder api decodes silk-only through native-rate output resampler" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 8000, channels: 1 };
    try decoder_init(&decoder, &config);

    var packet: [byte: 384] = [0: 384];
    packet[0] = (72 as! byte).value;
    _ = try hybrid_test_encode_wb_lowband_payload(&packet[1:383], 320);

    var pcm: [i16: 160] = [0: 160];
    const decoded: i32 = try decoder_decode_i16(&decoder, &packet[0:384], &pcm[0:160], 160, false);

    try assert_eq_i32(decoded, 160);
    try assert(decoder.active_mode == OpusMode.SILK, "SILK-only packet must switch the public decoder into SILK mode");
    try assert_eq_i32(decoder.silk.sample_rate_hz, 16000);
    try assert_eq_i32(decoder.silk_resampler.input_rate_hz as i32, 16000);
    try assert_eq_i32(decoder.silk_resampler.output_rate_hz as i32, 8000);
    try assert_eq_i32(decoder.last_frame_size_48k, 960);
    try assert(pcm[0] != 0 || pcm[1] != 0 || pcm[159] != 0, "SILK-only decode must synthesize output samples");
}

test "decoder api uses celt frequency history on packet loss after a decoded packet" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 1 };
    try decoder_init(&decoder, &config);

    var packet: [byte: 65] = [0: 65];
    packet[0] = (128 as! byte).value;
    var i: usize = 1;
    var rng: u32 = 0x31415926;
    while i < 65 {
        rng = rng * 1664525 + 1013904223;
        packet[i] = ((rng >> 24) as! byte).value;
        i = i + 1;
    }

    var pcm: [i16: 120] = [0: 120];
    const normal_decoded: i32 = try decoder_decode_i16(&decoder, &packet[0:65], &pcm[0:120], 120, false);
    try assert_eq_i32(normal_decoded, 120);
    try assert(decoder.celt.freq_history_ready, "normal decode must prepare frequency PLC history");

    var empty_packet: [byte: 1] = [0];
    var lost_pcm: [i16: 120] = [0: 120];
    const lost_decoded: i32 = try decoder_decode_i16(&decoder, &empty_packet[0:0], &lost_pcm[0:120], 120, false);

    try assert_eq_i32(lost_decoded, 120);
    try assert(decoder.celt_plc_scratch.used_frequency_history, "empty packet after CELT decode must use frequency-domain PLC");
    try assert_eq_i32(decoder.celt.loss_count, 1);
}

test "decoder api conceals one lost packet after a normal celt packet" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 1 };
    try decoder_init(&decoder, &config);

    var packet: [byte: 65] = [0: 65];
    packet[0] = (128 as! byte).value;
    var i: usize = 1;
    while i < 65 {
        packet[i] = ((i * 7 + 11) as! byte).value;
        i = i + 1;
    }

    var pcm: [i16: 120] = [0: 120];
    const decoded: i32 = try decoder_decode_i16(&decoder, &packet[0:65], &pcm[0:120], 120, false);
    try assert_eq_i32(decoded, 120);
    try assert_eq_i32(decoder.celt.loss_count, 0);

    var empty_packet: [byte: 1] = [0];
    var lost_pcm: [i16: 120] = [0: 120];
    const concealed: i32 = try decoder_decode_i16(&decoder, &empty_packet[0:0], &lost_pcm[0:120], 120, false);

    try assert_eq_i32(concealed, 120);
    try assert_eq_i32(decoder.celt.loss_count, 1);
    try assert(decoder.celt_plc_scratch.used_frequency_history, "single lost CELT packet must use frequency-domain PLC when history is ready");
    try assert(decoder.active_mode == OpusMode.CELT, "single packet loss must preserve the active CELT decoder mode");
}

test "decoder api conceals consecutive lost celt packets" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 1 };
    try decoder_init(&decoder, &config);

    var packet: [byte: 65] = [0: 65];
    packet[0] = (128 as! byte).value;
    var i: usize = 1;
    while i < 65 {
        packet[i] = ((i * 5 + 19) as! byte).value;
        i = i + 1;
    }

    var pcm: [i16: 120] = [0: 120];
    const decoded: i32 = try decoder_decode_i16(&decoder, &packet[0:65], &pcm[0:120], 120, false);
    try assert_eq_i32(decoded, 120);

    var empty_packet: [byte: 1] = [0];
    var first_loss_pcm: [i16: 120] = [0: 120];
    const first_loss: i32 = try decoder_decode_i16(&decoder, &empty_packet[0:0], &first_loss_pcm[0:120], 120, false);
    try assert_eq_i32(first_loss, 120);
    try assert_eq_i32(decoder.celt.loss_count, 1);

    var second_loss_pcm: [i16: 120] = [0: 120];
    const second_loss: i32 = try decoder_decode_i16(&decoder, &empty_packet[0:0], &second_loss_pcm[0:120], 120, false);
    try assert_eq_i32(second_loss, 120);
    try assert_eq_i32(decoder.celt.loss_count, 2);
    try assert(decoder.celt_plc_scratch.used_frequency_history, "consecutive CELT losses must keep using bounded PLC history");
}

test "decoder api decodes a normal celt packet after packet loss" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 1 };
    try decoder_init(&decoder, &config);

    var first_packet: [byte: 65] = [0: 65];
    first_packet[0] = (128 as! byte).value;
    var i: usize = 1;
    while i < 65 {
        first_packet[i] = ((i * 9 + 13) as! byte).value;
        i = i + 1;
    }

    var first_pcm: [i16: 120] = [0: 120];
    const first_decoded: i32 = try decoder_decode_i16(&decoder, &first_packet[0:65], &first_pcm[0:120], 120, false);
    try assert_eq_i32(first_decoded, 120);

    var empty_packet: [byte: 1] = [0];
    var lost_pcm: [i16: 120] = [0: 120];
    const lost_decoded: i32 = try decoder_decode_i16(&decoder, &empty_packet[0:0], &lost_pcm[0:120], 120, false);
    try assert_eq_i32(lost_decoded, 120);
    try assert_eq_i32(decoder.celt.loss_count, 1);

    var second_packet: [byte: 65] = [0: 65];
    second_packet[0] = (128 as! byte).value;
    i = 1;
    while i < 65 {
        second_packet[i] = ((255 - (i * 2)) as! byte).value;
        i = i + 1;
    }

    var second_pcm: [i16: 120] = [0: 120];
    const second_decoded: i32 = try decoder_decode_i16(&decoder, &second_packet[0:65], &second_pcm[0:120], 120, false);
    try assert_eq_i32(second_decoded, 120);
    try assert_eq_i32(decoder.celt.loss_count, 0);
    try assert(decoder.active_mode == OpusMode.CELT, "normal packet decode after PLC must keep CELT mode active");
    try assert(decoder.celt.freq_history_ready, "normal packet decode after PLC must refresh frequency PLC history");
}

test "decoder api switches into and out of hybrid mode" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 1 };
    try decoder_init(&decoder, &config);

    var celt_packet: [byte: 65] = [0: 65];
    celt_packet[0] = (128 as! byte).value;
    var i: usize = 1;
    while i < 65 {
        celt_packet[i] = ((i * 13 + 5) as! byte).value;
        i = i + 1;
    }

    var celt_pcm: [i16: 120] = [0: 120];
    const celt_decoded: i32 = try decoder_decode_i16(&decoder, &celt_packet[0:65], &celt_pcm[0:120], 120, false);
    try assert_eq_i32(celt_decoded, 120);
    try assert(decoder.active_mode == OpusMode.CELT, "first CELT packet must leave decoder in CELT mode");
    try assert_eq_i32(decoder.celt.start_band, 0);

    var hybrid_packet: [byte: 256] = [0: 256];
    hybrid_packet[0] = (96 as! byte).value;
    _ = try hybrid_test_encode_wb_lowband_payload(&hybrid_packet[1:255], 160);

    var hybrid_pcm: [i16: 480] = [0: 480];
    const hybrid_decoded: i32 = try decoder_decode_i16(&decoder, &hybrid_packet[0:256], &hybrid_pcm[0:480], 480, false);
    try assert_eq_i32(hybrid_decoded, 480);
    try assert(decoder.active_mode == OpusMode.HYBRID, "hybrid packet must switch the public decoder into Hybrid mode");
    try assert_eq_i32(decoder.hybrid.frame_size_48k, 480);
    try assert_eq_i32(decoder.hybrid.celt_start_band, HYBRID_CELT_START_BAND);
    try assert_eq_i32(decoder.hybrid.celt_end_band, HYBRID_CELT_SWB_END_BAND);
    try assert_eq_i32(decoder.hybrid_silk.sample_rate_hz, HYBRID_SILK_SAMPLE_RATE_HZ);
    try assert_eq_i32(decoder.celt.start_band, HYBRID_CELT_START_BAND);
    try assert_eq_i32(decoder.celt.end_band, HYBRID_CELT_SWB_END_BAND);

    decoder.hybrid.merge_mem_q14[0] = 123456;
    decoder.hybrid.delay_q14[0] = 654321;
    decoder.hybrid_silk.history_q14[0] = 345678;

    var after_hybrid_celt_pcm: [i16: 120] = [0: 120];
    const after_hybrid_celt: i32 = try decoder_decode_i16(&decoder, &celt_packet[0:65], &after_hybrid_celt_pcm[0:120], 120, false);
    try assert_eq_i32(after_hybrid_celt, 120);
    try assert(decoder.active_mode == OpusMode.CELT, "CELT packet after Hybrid must switch back to CELT mode");
    try assert_eq_i32(decoder.celt.start_band, 0);
    try assert_eq_i32(decoder.hybrid.merge_mem_q14[0], 0);
    try assert_eq_i32(decoder.hybrid.delay_q14[0], 0);
    try assert_eq_i32(decoder.hybrid_silk.history_q14[0], 0);

    var second_hybrid_pcm: [i16: 480] = [0: 480];
    const second_hybrid: i32 = try decoder_decode_i16(&decoder, &hybrid_packet[0:256], &second_hybrid_pcm[0:480], 480, false);
    try assert_eq_i32(second_hybrid, 480);
    try assert(decoder.active_mode == OpusMode.HYBRID, "Hybrid packet after CELT must switch back into Hybrid mode");
}

test "decoder api decode_fec falls back to plc without consuming celt packet" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 1 };
    try decoder_init(&decoder, &config);

    var first_packet: [byte: 65] = [0: 65];
    first_packet[0] = (128 as! byte).value;
    var i: usize = 1;
    while i < 65 {
        first_packet[i] = ((i * 3) as! byte).value;
        i = i + 1;
    }

    var pcm: [i16: 120] = [0: 120];
    _ = try decoder_decode_i16(&decoder, &first_packet[0:65], &pcm[0:120], 120, false);

    var next_packet: [byte: 65] = [0: 65];
    next_packet[0] = (128 as! byte).value;
    i = 1;
    while i < 65 {
        next_packet[i] = ((255 - i) as! byte).value;
        i = i + 1;
    }

    var recovered_pcm: [i16: 120] = [0: 120];
    const recovered: i32 = try decoder_decode_i16(&decoder, &next_packet[0:65], &recovered_pcm[0:120], 120, true);
    try assert_eq_i32(recovered, 120);
    try assert(decoder.celt_plc_scratch.used_frequency_history, "CELT packets do not carry FEC and must use PLC fallback");
    try assert_eq_i32(decoder.celt.loss_count, 1);

    var decoded_pcm: [i16: 120] = [0: 120];
    const decoded: i32 = try decoder_decode_i16(&decoder, &next_packet[0:65], &decoded_pcm[0:120], 120, false);
    try assert_eq_i32(decoded, 120);
    try assert_eq_i32(decoder.celt.loss_count, 0);
}

test "decoder api plc and fec fallback only write requested pcm slice" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 1 };
    try decoder_init(&decoder, &config);
    const tail: usize = CELT_DECODE_MEM - 120;
    decoder.celt.decode_mem[tail] = 3210;

    var empty_packet: [byte: 1] = [0];
    var plc_guarded: [i16: 128] = [0: 128];
    var i: usize = 0;
    while i < 128 {
        plc_guarded[i] = -12345;
        i = i + 1;
    }

    const plc_decoded: i32 = try decoder_decode_i16(&decoder, &empty_packet[0:0], &plc_guarded[4:120], 120, false);
    try assert_eq_i32(plc_decoded, 120);
    try assert_eq_i32(plc_guarded[0] as i32, -12345);
    try assert_eq_i32(plc_guarded[3] as i32, -12345);
    try assert_eq_i32(plc_guarded[4] as i32, 3210);
    try assert_eq_i32(plc_guarded[124] as i32, -12345);
    try assert_eq_i32(plc_guarded[127] as i32, -12345);

    var celt_packet: [byte: 65] = [0: 65];
    celt_packet[0] = (128 as! byte).value;
    i = 1;
    while i < 65 {
        celt_packet[i] = ((i * 11 + 7) as! byte).value;
        i = i + 1;
    }

    var fec_guarded: [i16: 128] = [0: 128];
    i = 0;
    while i < 128 {
        fec_guarded[i] = -23456;
        i = i + 1;
    }

    const fec_decoded: i32 = try decoder_decode_i16(&decoder, &celt_packet[0:65], &fec_guarded[4:120], 120, true);
    try assert_eq_i32(fec_decoded, 120);
    try assert_eq_i32(fec_guarded[0] as i32, -23456);
    try assert_eq_i32(fec_guarded[3] as i32, -23456);
    try assert_eq_i32(fec_guarded[124] as i32, -23456);
    try assert_eq_i32(fec_guarded[127] as i32, -23456);
}

test "decoder api empty packet validates pcm bounds" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 1 };
    try decoder_init(&decoder, &config);

    var empty_packet: [byte: 1] = [0];
    var pcm: [i16: 120] = [0: 120];
    const short_output: !i32 = decoder_decode_i16(&decoder, &empty_packet[0:0], &pcm[0:119], 120, false);
    match short_output {
        error.DecoderApiError => {}
        else => { try assert(false, "empty packet PLC must reject short PCM output"); }
    }
}
