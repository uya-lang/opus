use std.testing.assert;
use std.testing.assert_eq_i32;
use src.opus.api.decoder.DecoderApiError;
use src.opus.api.decoder.DecoderApiUnsupported;
use src.opus.api.decoder.OpusDecoder;
use src.opus.api.decoder.decoder_decode_i16;
use src.opus.api.decoder.decoder_get_packet_info;
use src.opus.api.decoder.decoder_init;
use src.opus.api.decoder.decoder_reset;
use src.opus.api.decoder.decoder_set_gain_q8;
use src.opus.celt.state.CELT_DECODE_MEM;
use src.opus.core.types.OpusDecoderConfig;
use src.opus.core.types.OpusMode;
use src.opus.core.types.PacketInfo;
use src.opus.hybrid.state.HYBRID_CELT_START_BAND;
use src.opus.hybrid.state.HYBRID_CELT_SWB_END_BAND;
use src.opus.hybrid.state.HYBRID_SILK_SAMPLE_RATE_HZ;
use tests.hybrid_payload.hybrid_test_encode_wb_lowband_payload;

test "decoder init validates config and initializes 48k state" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 2 };
    try decoder_init(&decoder, &config);

    try assert_eq_i32(decoder.config.sample_rate_hz as i32, 48000);
    try assert_eq_i32(decoder.config.channels as i32, 2);
    try assert(decoder.history.active_mode == OpusMode.CELT, "decoder init must start in CELT mode");
    try assert_eq_i32(decoder.history.celt.channels, 2);
    try assert_eq_i32(decoder.history.last_frame_size_48k, decoder.history.celt.frame_size);
    try assert_eq_i32(decoder.history.hybrid.frame_size_48k, 0);

    const bad_channels: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 0 };
    const bad_channels_result: !void = decoder_init(&decoder, &bad_channels);
    match bad_channels_result {
        error.DecoderApiError => {}
        else => { try assert(false, "decoder init must reject invalid channel counts"); }
    }

    const output_rate: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 16000, channels: 1 };
    try decoder_init(&decoder, &output_rate);
    try assert_eq_i32(decoder.config.sample_rate_hz as i32, 16000);
    try assert_eq_i32(decoder.resampler.output_rate_hz as i32, 16000);
    try assert_eq_i32(decoder.resampler.input_rate_hz as i32, 48000);

    const unsupported_rate: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 44100, channels: 1 };
    const unsupported_rate_result: !void = decoder_init(&decoder, &unsupported_rate);
    match unsupported_rate_result {
        error.DecoderApiError => {}
        else => { try assert(false, "decoder init must reject unsupported output rates"); }
    }
}

test "decoder api packet info exposes parser metadata" {
    const packet: [byte: 3] = [252, 1, 2];
    var info: PacketInfo = PacketInfo{};
    try decoder_get_packet_info(&packet[0:3], &info);

    try assert_eq_i32(info.channels as i32, 2);
    try assert_eq_i32(info.frame_count as i32, 1);
    try assert_eq_i32(info.frame_duration_us as i32, 20000);
    try assert_eq_i32(info.duration_samples_48k as i32, 960);

    var empty_packet: [byte: 1] = [0];
    const empty_info: !void = decoder_get_packet_info(&empty_packet[0:0], &info);
    match empty_info {
        error.DecoderApiError => {}
        else => { try assert(false, "decoder api packet info must map parser errors to API errors"); }
    }
}

test "decoder api empty packet invokes celt plc" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 1 };
    try decoder_init(&decoder, &config);
    const tail: usize = CELT_DECODE_MEM - 120;
    decoder.history.celt.decode_mem[tail] = 5000;

    var empty_packet: [byte: 1] = [0];
    var pcm: [i16: 120] = [0: 120];
    const decoded: i32 = try decoder_decode_i16(&decoder, &empty_packet[0:0], &pcm[0:120], 120, false);

    try assert_eq_i32(decoded, 120);
    try assert_eq_i32(pcm[0] as i32, 5000);
    try assert_eq_i32(decoder.history.celt.loss_count, 1);
    try assert(decoder.history.active_mode == OpusMode.CELT, "empty-packet PLC must keep CELT mode active");
}

test "decoder api converts empty-packet plc to configured output rate" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 16000, channels: 1 };
    try decoder_init(&decoder, &config);

    const tail: usize = CELT_DECODE_MEM - 120;
    var i: usize = 0;
    while i < 120 {
        decoder.history.celt.decode_mem[tail + i] = (i as i32) * 3;
        i = i + 1;
    }

    var empty_packet: [byte: 1] = [0];
    var pcm: [i16: 40] = [0: 40];
    const decoded: i32 = try decoder_decode_i16(&decoder, &empty_packet[0:0], &pcm[0:40], 40, false);

    try assert_eq_i32(decoded, 40);
    try assert_eq_i32(decoder.history.last_frame_size_48k, 120);
    try assert_eq_i32(pcm[0] as i32, 3);
    try assert_eq_i32(pcm[1] as i32, 12);
    try assert_eq_i32(pcm[39] as i32, 354);
    try assert_eq_i32(decoder.history.celt.loss_count, 1);
    try assert(decoder.history.active_mode == OpusMode.CELT, "sample-rate conversion must preserve active CELT mode");
}

test "decoder api 48k output fast path writes directly to caller pcm" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 1 };
    try decoder_init(&decoder, &config);

    const tail: usize = CELT_DECODE_MEM - 120;
    var i: usize = 0;
    while i < 120 {
        decoder.history.celt.decode_mem[tail + i] = 2000 + (i as i32);
        decoder.scratch.output_i16[i] = -2222;
        i = i + 1;
    }

    var empty_packet: [byte: 1] = [0];
    var pcm: [i16: 120] = [0: 120];
    const decoded: i32 = try decoder_decode_i16(&decoder, &empty_packet[0:0], &pcm[0:120], 120, false);

    try assert_eq_i32(decoded, 120);
    try assert_eq_i32(pcm[0] as i32, 2000);
    try assert_eq_i32(pcm[119] as i32, 2119);
    try assert_eq_i32(decoder.scratch.output_i16[0] as i32, -2222);
    try assert_eq_i32(decoder.scratch.output_i16[119] as i32, -2222);
}

test "decoder separates persistent history from reusable scratch buffers" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 16000, channels: 1 };
    try decoder_init(&decoder, &config);

    decoder.history.active_mode = OpusMode.HYBRID;
    decoder.history.celt.decode_mem[0] = 1234;
    decoder.history.celt.freq_history_ready = true;
    decoder.history.silk.history_q14[0] = 2345;
    decoder.history.hybrid.delay_q14[0] = 3456;
    decoder.history.hybrid_silk.history_q14[0] = 4567;
    decoder.history.last_frame_size_48k = 960;
    decoder.scratch.celt_plc.used_frequency_history = true;
    decoder.scratch.output_i16[0] = -2222;
    decoder.scratch.silk_q14[0] = 7654321;

    try decoder_reset(&decoder);

    try assert(decoder.history.active_mode == OpusMode.CELT, "decoder reset must reset persistent mode history");
    try assert_eq_i32(decoder.history.celt.decode_mem[0], 0);
    try assert(!decoder.history.celt.freq_history_ready, "decoder reset must clear persistent CELT PLC history");
    try assert_eq_i32(decoder.history.silk.history_q14[0], 0);
    try assert_eq_i32(decoder.history.hybrid.delay_q14[0], 0);
    try assert_eq_i32(decoder.history.hybrid_silk.history_q14[0], 0);
    try assert_eq_i32(decoder.history.last_frame_size_48k, decoder.history.celt.frame_size);
    try assert(!decoder.scratch.celt_plc.used_frequency_history, "decoder reset must clear only live PLC scratch markers");
    try assert_eq_i32(decoder.scratch.output_i16[0] as i32, -2222);
    try assert_eq_i32(decoder.scratch.silk_q14[0], 7654321);
}

test "decoder api decodes silk-only through native-rate output resampler" {
    var decoder: OpusDecoder = OpusDecoder{};
    const config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 8000, channels: 1 };
    try decoder_init(&decoder, &config);

    var packet: [byte: 384] = [0: 384];
    packet[0] = (72 as! byte).value;
    _ = try hybrid_test_encode_wb_lowband_payload(&packet[1:383], 320);

    var pcm: [i16: 160] = [0: 160];
    const decoded: i32 = try decoder_decode_i16(&decoder, &packet[0:384], &pcm[0:160], 160, false);

    try assert_eq_i32(decoded, 160);
    try assert(decoder.history.active_mode == OpusMode.SILK, "SILK-only packet must switch the public decoder into SILK mode");
    try assert_eq_i32(decoder.history.silk.sample_rate_hz, 16000);
    try assert_eq_i32(decoder.silk_resampler.input_rate_hz as i32, 16000);
    try assert_eq_i32(decoder.silk_resampler.output_rate_hz as i32, 8000);
    try assert_eq_i32(decoder.history.last_frame_size_48k, 960);
    try assert(pcm[0] != 0 || pcm[1] != 0 || pcm[159] != 0, "SILK-only decode must synthesize output samples");
}

test "decoder api validates mono and stereo output channel layout" {
    var stereo_decoder: OpusDecoder = OpusDecoder{};
    const stereo_config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 2 };
    try decoder_init(&stereo_decoder, &stereo_config);

    var stereo_packet: [byte: 65] = [0: 65];
    stereo_packet[0] = (132 as! byte).value;
    var i: usize = 1;
    while i < 65 {
        stereo_packet[i] = ((i * 17 + 3) as! byte).value;
        i = i + 1;
    }

    var stereo_pcm: [i16: 240] = [0: 240];
    const stereo_decoded: i32 = try decoder_decode_i16(&stereo_decoder, &stereo_packet[0:65], &stereo_pcm[0:240], 120, false);
    try assert_eq_i32(stereo_decoded, 120);
    try assert_eq_i32(stereo_decoder.history.celt.channels, 2);
    try assert(stereo_decoder.history.active_mode == OpusMode.CELT, "stereo CELT packet must keep CELT mode active");

    var mono_decoder: OpusDecoder = OpusDecoder{};
    const mono_config: OpusDecoderConfig = OpusDecoderConfig{ sample_rate_hz: 48000, channels: 1 };
    try decoder_init(&mono_decoder, &mono_config);

    var mono_pcm: [i16: 120] = [0: 120];
    const stereo_to_mono: !i32 = decoder_decode_i16(&mono_decoder, &stereo_packet[0:65], &mono_pcm[0:120], 120, false);
    match stereo_to_mono {
        error.DecoderApiError => {}
        else => { try assert(false, "stereo packet must not decode into a mono-configured decoder"); }
    }

    var mono_packet: [byte: 65] = [0: 65];
    mono_packet[0] = (128 as! byte).value;
    i = 1;
    while i < 65 {
        mono_packet[i] = ((i * 7 + 29) as! byte).value;
        i = i + 1;
    }

    const mono_to_stereo: !i32 = decoder_decode_i16(&stereo_decoder, &mono_packet[0:65], &stereo_pcm[0:240], 120, false);
    match mono_to_stereo {
        error.DecoderApiError => {}
        else => { try assert(false, "mono packet must not decode into a stereo-configured decoder"); }
    }
}

