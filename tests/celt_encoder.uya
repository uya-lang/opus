use std.testing.assert;
use std.testing.assert_eq_i32;
use src.opus.celt.encoder.CeltBasicEncoderProfile;
use src.opus.celt.encoder.CeltEncoderState;
use src.opus.celt.encoder.CeltEncoderStereoDecision;
use src.opus.celt.encoder.CeltEncoderTransientAnalysis;
use src.opus.celt.encoder.celt_basic_encoder_profile_init;
use src.opus.celt.encoder.celt_encoder_decide_stereo_i16;
use src.opus.celt.encoder.celt_encoder_detect_transient_i16;
use src.opus.celt.encoder.celt_encoder_encode_i16;
use src.opus.celt.encoder.celt_encoder_is_initialized;
use src.opus.celt.encoder.celt_encoder_state_init;
use src.opus.celt.quant_bands.celt_decode_coarse_energy;
use src.opus.celt.rate.CeltRateFrameAllocation;
use src.opus.celt.rate.celt_rate_decode_allocation;
use src.opus.celt.spread.celt_decode_spread_decision;
use src.opus.celt.state.CELT_MAX_BANDS;
use src.opus.celt.state.CeltDecoderState;
use src.opus.celt.state.celt_state_configure_frame;
use src.opus.celt.state.celt_state_init;
use src.opus.celt.tf.celt_decode_tf_changes;
use src.opus.core.types.OpusBandwidth;
use src.opus.core.types.OpusEncoderConfig;
use src.opus.core.types.opus_encoder_config_default;
use src.opus.entropy.range_dec.EcDec;
use src.opus.entropy.range_dec.ec_dec_bit_logp;
use src.opus.entropy.range_dec.ec_dec_init;

fn fill_constant_stereo(pcm: &[i16], sample: i16) void {
    var i: usize = 0;
    while i < pcm.len {
        pcm.ptr[i] = sample;
        i = i + 1;
    }
}

fn fill_attack_stereo(pcm: &[i16]) void {
    var frame: usize = 0;
    while frame < (pcm.len / 2) {
        var sample: i16 = 320;
        if frame >= 480 && frame < 600 {
            if (frame % (2 as usize)) == 0 {
                sample = 28000;
            } else {
                sample = -28000;
            }
        }
        pcm.ptr[frame * 2] = sample;
        pcm.ptr[(frame * 2) + 1] = sample;
        frame = frame + 1;
    }
}

fn fill_opposed_stereo(pcm: &[i16]) void {
    var frame: usize = 0;
    while frame < (pcm.len / 2) {
        var sample: i16 = 6000;
        if (frame % (2 as usize)) != 0 {
            sample = -6000;
        }
        pcm.ptr[frame * 2] = sample;
        pcm.ptr[(frame * 2) + 1] = -sample;
        frame = frame + 1;
    }
}

fn decode_celt_encoder_packet_transient_flag(packet: &[byte], encoded: i32) !bool {
    var dec: EcDec = EcDec{};
    try assert(encoded > 2, "CELT packet must include enough payload for global flags");
    ec_dec_init(&dec, &packet[1:((encoded as usize) - 1)]);
    try assert_eq_i32(ec_dec_bit_logp(&dec, 1), 0);
    return ec_dec_bit_logp(&dec, 3) != 0;
}

fn decode_celt_encoder_packet_allocation(packet: &[byte], encoded: i32) !CeltRateFrameAllocation {
    var dec: EcDec = EcDec{};
    try assert(encoded > 2, "CELT packet must include enough payload for allocation metadata");
    const payload_len: usize = (encoded as usize) - 1;
    ec_dec_init(&dec, &packet[1:payload_len]);

    var decode_state: CeltDecoderState = CeltDecoderState{};
    try celt_state_init(&decode_state, 2);
    try celt_state_configure_frame(&decode_state, 960, 0, 21);

    try assert_eq_i32(ec_dec_bit_logp(&dec, 1), 0);
    const transient: bool = ec_dec_bit_logp(&dec, 3) != 0;
    try assert_eq_i32(ec_dec_bit_logp(&dec, 3), 0);
    try celt_decode_coarse_energy(&decode_state, &dec, false);

    var tf_res: [i32: CELT_MAX_BANDS] = [0: CELT_MAX_BANDS];
    try celt_decode_tf_changes(0, 21, transient, &tf_res[0:CELT_MAX_BANDS], 3, &dec);
    _ = try celt_decode_spread_decision(&dec, payload_len as i32 * 8);

    var pulse_bits: [i32: CELT_MAX_BANDS] = [0: CELT_MAX_BANDS];
    var fine_quant: [i32: CELT_MAX_BANDS] = [0: CELT_MAX_BANDS];
    return celt_rate_decode_allocation(
        &decode_state,
        &dec,
        payload_len as i32 * 8,
        &pulse_bits[0:CELT_MAX_BANDS],
        &fine_quant[0:CELT_MAX_BANDS],
    );
}

test "celt basic encoder profile records fullband frame layout" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 48000;
    config.channels = 2;
    config.max_bandwidth = OpusBandwidth.FULLBAND;
    config.bitrate_bps = 64000;
    config.vbr = true;

    const profile: CeltBasicEncoderProfile = try celt_basic_encoder_profile_init(&config, 960);
    try assert_eq_i32(profile.sample_rate_hz as i32, 48000);
    try assert_eq_i32(profile.channels as i32, 2);
    try assert_eq_i32(profile.frame_size_48k, 960);
    try assert_eq_i32(profile.bandwidth as i32, OpusBandwidth.FULLBAND as i32);
    try assert_eq_i32(profile.frame_duration_us as i32, 20000);
    try assert_eq_i32(profile.lm, 3);
    try assert_eq_i32(profile.end_band, 21);
    try assert_eq_i32(profile.toc_config_index as i32, 31);
    try assert_eq_i32(profile.toc_byte_code0 as i32, 252);
    try assert_eq_i32(profile.bitrate_bps as i32, 64000);
    try assert(profile.vbr == true, "profile must retain VBR mode");
}

test "celt basic encoder profile separates invalid and unsupported configs" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.max_bandwidth = OpusBandwidth.WIDEBAND;
    const unsupported_bandwidth: !CeltBasicEncoderProfile = celt_basic_encoder_profile_init(&config, 960);
    match unsupported_bandwidth {
        error.CeltEncoderUnsupported => {}
        else => { try assert(false, "non-fullband CELT basic profiles are not wired yet"); }
    };

    config = opus_encoder_config_default();
    config.channels = 3;
    const invalid_channels: !CeltBasicEncoderProfile = celt_basic_encoder_profile_init(&config, 960);
    match invalid_channels {
        error.CeltEncoderError => {}
        else => { try assert(false, "CELT encoder profile must reject invalid channel counts"); }
    };

    config = opus_encoder_config_default();
    const invalid_frame: !CeltBasicEncoderProfile = celt_basic_encoder_profile_init(&config, 123);
    match invalid_frame {
        error.CeltEncoderError => {}
        else => { try assert(false, "CELT encoder profile must reject invalid frame durations"); }
    };

    config = opus_encoder_config_default();
    config.channels = 2;
    config.max_bandwidth = OpusBandwidth.FULLBAND;
    config.bitrate_bps = 512001;
    const invalid_bitrate: !CeltBasicEncoderProfile = celt_basic_encoder_profile_init(&config, 960);
    match invalid_bitrate {
        error.CeltEncoderError => {}
        else => { try assert(false, "CELT encoder profile must reject invalid bitrate targets"); }
    };
}

test "celt basic encoder profile only supports fullband 20ms stereo shape" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.sample_rate_hz = 48000;
    config.channels = 1;
    config.max_bandwidth = OpusBandwidth.FULLBAND;
    const mono_fullband: !CeltBasicEncoderProfile = celt_basic_encoder_profile_init(&config, 960);
    match mono_fullband {
        error.CeltEncoderUnsupported => {}
        else => { try assert(false, "Basic CELT encoder should start with stereo only"); }
    };

    config.channels = 2;
    const ten_ms: !CeltBasicEncoderProfile = celt_basic_encoder_profile_init(&config, 480);
    match ten_ms {
        error.CeltEncoderUnsupported => {}
        else => { try assert(false, "Basic CELT encoder should start with 20ms frames only"); }
    };

    config.sample_rate_hz = 24000;
    const non_48k_fullband: !CeltBasicEncoderProfile = celt_basic_encoder_profile_init(&config, 960);
    match non_48k_fullband {
        error.CeltEncoderUnsupported => {}
        else => { try assert(false, "Basic CELT fullband profile requires 48k input for now"); }
    };
}

test "celt encoder state initializes from a validated profile" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.channels = 2;
    config.max_bandwidth = OpusBandwidth.FULLBAND;
    const profile: CeltBasicEncoderProfile = try celt_basic_encoder_profile_init(&config, 960);

    var state: CeltEncoderState = CeltEncoderState{};
    try assert(!celt_encoder_is_initialized(&state), "fresh CELT encoder state must start inactive");
    try celt_encoder_state_init(&state, &profile);

    try assert(celt_encoder_is_initialized(&state), "state init must mark CELT encoder active");
    try assert_eq_i32(state.profile.channels as i32, 2);
    try assert_eq_i32(state.profile.frame_size_48k, 960);
    try assert_eq_i32(state.energy.channels, 2);
    try assert_eq_i32(state.energy.start_band, 0);
    try assert_eq_i32(state.energy.end_band, 21);
    try assert_eq_i32(state.energy.lm, 3);
}

test "celt encoder writes range encoded fullband stereo packet" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.channels = 2;
    config.max_bandwidth = OpusBandwidth.FULLBAND;
    const profile: CeltBasicEncoderProfile = try celt_basic_encoder_profile_init(&config, 960);

    var state: CeltEncoderState = CeltEncoderState{};
    try celt_encoder_state_init(&state, &profile);
    var pcm: [i16: 1920] = [0: 1920];
    var packet: [byte: 1275] = [0: 1275];
    const encoded: i32 = try celt_encoder_encode_i16(&state, &pcm[0:1920], &packet[0:1275]);

    try assert(encoded > 1, "CELT encoder must return TOC plus range payload");
    try assert_eq_i32(packet[0] as i32, 252);
}

test "celt encoder never reports more bytes than caller packet buffer" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.channels = 2;
    config.max_bandwidth = OpusBandwidth.FULLBAND;
    const profile: CeltBasicEncoderProfile = try celt_basic_encoder_profile_init(&config, 960);

    var state: CeltEncoderState = CeltEncoderState{};
    try celt_encoder_state_init(&state, &profile);
    var pcm: [i16: 1920] = [0: 1920];
    var packet: [byte: 3] = [77, 78, 99];
    const encoded: i32 = try celt_encoder_encode_i16(&state, &pcm[0:1920], &packet[0:2]);
    try assert_eq_i32(encoded, 2);
    try assert(encoded <= 2, "CELT encoder must not report more bytes than the provided slice");
    try assert_eq_i32(packet[0] as i32, 252);
    try assert_eq_i32(packet[2] as i32, 99);
}

test "celt encoder vbr allocation varies packet length with input activity" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.channels = 2;
    config.max_bandwidth = OpusBandwidth.FULLBAND;
    config.bitrate_bps = 64000;
    config.vbr = true;
    const profile: CeltBasicEncoderProfile = try celt_basic_encoder_profile_init(&config, 960);

    var silence_state: CeltEncoderState = CeltEncoderState{};
    try celt_encoder_state_init(&silence_state, &profile);
    var silence_pcm: [i16: 1920] = [0: 1920];
    var silence_packet: [byte: 1275] = [0: 1275];
    const silence_encoded: i32 = try celt_encoder_encode_i16(&silence_state, &silence_pcm[0:1920], &silence_packet[0:1275]);

    var active_state: CeltEncoderState = CeltEncoderState{};
    try celt_encoder_state_init(&active_state, &profile);
    var active_pcm: [i16: 1920] = [0: 1920];
    fill_constant_stereo(&active_pcm[0:1920], 30000);
    var active_packet: [byte: 1275] = [0: 1275];
    const active_encoded: i32 = try celt_encoder_encode_i16(&active_state, &active_pcm[0:1920], &active_packet[0:1275]);

    try assert_eq_i32(silence_encoded, 81);
    try assert_eq_i32(active_encoded, 239);
    try assert(active_encoded > silence_encoded, "VBR allocation must spend more bytes on active CELT input");
    try assert_eq_i32(silence_packet[0] as i32, 252);
    try assert_eq_i32(active_packet[0] as i32, 252);
}

test "celt encoder transient detection flags sudden attacks" {
    var steady: [i16: 1920] = [0: 1920];
    fill_constant_stereo(&steady[0:1920], 4000);
    const steady_analysis: CeltEncoderTransientAnalysis = try celt_encoder_detect_transient_i16(&steady[0:1920], 960, 2);
    try assert(!steady_analysis.is_transient, "steady high-energy input must not be marked transient");

    var attack: [i16: 1920] = [0: 1920];
    fill_attack_stereo(&attack[0:1920]);
    const attack_analysis: CeltEncoderTransientAnalysis = try celt_encoder_detect_transient_i16(&attack[0:1920], 960, 2);
    try assert(attack_analysis.is_transient, "sudden high-energy attack must be marked transient");
    try assert_eq_i32(attack_analysis.peak_block, 4);
    try assert(attack_analysis.peak_energy > steady_analysis.peak_energy, "attack peak energy must exceed steady analysis peak");
}

test "celt encoder stereo decision enables intensity for linked high channels" {
    var linked: [i16: 1920] = [0: 1920];
    fill_constant_stereo(&linked[0:1920], 5000);
    const linked_decision: CeltEncoderStereoDecision = try celt_encoder_decide_stereo_i16(&linked[0:1920], 960, 2);
    try assert_eq_i32(linked_decision.intensity_band, 17);
    try assert_eq_i32(linked_decision.dual_stereo, 1);

    var opposed: [i16: 1920] = [0: 1920];
    fill_opposed_stereo(&opposed[0:1920]);
    const opposed_decision: CeltEncoderStereoDecision = try celt_encoder_decide_stereo_i16(&opposed[0:1920], 960, 2);
    try assert_eq_i32(opposed_decision.intensity_band, 0);
    try assert_eq_i32(opposed_decision.dual_stereo, 0);
}

test "celt encoder writes stereo intensity allocation decision" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.channels = 2;
    config.max_bandwidth = OpusBandwidth.FULLBAND;
    const profile: CeltBasicEncoderProfile = try celt_basic_encoder_profile_init(&config, 960);

    var linked_state: CeltEncoderState = CeltEncoderState{};
    try celt_encoder_state_init(&linked_state, &profile);
    var linked: [i16: 1920] = [0: 1920];
    fill_constant_stereo(&linked[0:1920], 5000);
    var linked_packet: [byte: 1275] = [0: 1275];
    const linked_encoded: i32 = try celt_encoder_encode_i16(&linked_state, &linked[0:1920], &linked_packet[0:1275]);
    const linked_alloc: CeltRateFrameAllocation = try decode_celt_encoder_packet_allocation(&linked_packet[0:(linked_encoded as usize)], linked_encoded);
    try assert_eq_i32(linked_alloc.intensity, 17);
    try assert_eq_i32(linked_alloc.dual_stereo, 1);

    var opposed_state: CeltEncoderState = CeltEncoderState{};
    try celt_encoder_state_init(&opposed_state, &profile);
    var opposed: [i16: 1920] = [0: 1920];
    fill_opposed_stereo(&opposed[0:1920]);
    var opposed_packet: [byte: 1275] = [0: 1275];
    const opposed_encoded: i32 = try celt_encoder_encode_i16(&opposed_state, &opposed[0:1920], &opposed_packet[0:1275]);
    const opposed_alloc: CeltRateFrameAllocation = try decode_celt_encoder_packet_allocation(&opposed_packet[0:(opposed_encoded as usize)], opposed_encoded);
    try assert_eq_i32(opposed_alloc.intensity, 0);
    try assert_eq_i32(opposed_alloc.dual_stereo, 0);
}

test "celt encoder writes detected transient global flag" {
    var config: OpusEncoderConfig = opus_encoder_config_default();
    config.channels = 2;
    config.max_bandwidth = OpusBandwidth.FULLBAND;
    const profile: CeltBasicEncoderProfile = try celt_basic_encoder_profile_init(&config, 960);

    var steady_state: CeltEncoderState = CeltEncoderState{};
    try celt_encoder_state_init(&steady_state, &profile);
    var steady: [i16: 1920] = [0: 1920];
    fill_constant_stereo(&steady[0:1920], 4000);
    var steady_packet: [byte: 1275] = [0: 1275];
    const steady_encoded: i32 = try celt_encoder_encode_i16(&steady_state, &steady[0:1920], &steady_packet[0:1275]);
    try assert(!try decode_celt_encoder_packet_transient_flag(&steady_packet[0:(steady_encoded as usize)], steady_encoded), "steady packet must clear the transient flag");

    var attack_state: CeltEncoderState = CeltEncoderState{};
    try celt_encoder_state_init(&attack_state, &profile);
    var attack: [i16: 1920] = [0: 1920];
    fill_attack_stereo(&attack[0:1920]);
    var attack_packet: [byte: 1275] = [0: 1275];
    const attack_encoded: i32 = try celt_encoder_encode_i16(&attack_state, &attack[0:1920], &attack_packet[0:1275]);
    try assert(try decode_celt_encoder_packet_transient_flag(&attack_packet[0:(attack_encoded as usize)], attack_encoded), "attack packet must set the transient flag");
}
