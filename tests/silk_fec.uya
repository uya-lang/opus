fn encode_wb20_lbrr_unvoiced_packet(packet: &[byte]) !void {
    if packet.len < 384 {
        try assert(false, "wideband delayed FEC helper needs a full TOC plus payload buffer");
    }
    packet.ptr[0] = 72;
    var enc: EcEnc = EcEnc{};
    ec_enc_init(&enc, &packet[1:383]);

    ec_enc_bit_logp(&enc, 1, 1);
    ec_enc_bit_logp(&enc, 1, 1);

    var type_icdf: [byte: 4] = [0: 4];
    try fec_test_fill_type_offset_vad_icdf(&type_icdf[0:4]);
    ec_enc_icdf(&enc, 1, &type_icdf[0:4], 8);

    var gain_icdf: [byte: 8] = [0: 8];
    try fec_test_fill_gain_icdf(&gain_icdf[0:8], 1);
    ec_enc_icdf(&enc, 1, &gain_icdf[0:8], 8);

    var uniform8_icdf: [byte: 8] = [0: 8];
    try fec_test_fill_uniform8_icdf(&uniform8_icdf[0:8]);
    ec_enc_icdf(&enc, 5, &uniform8_icdf[0:8], 8);

    var delta_gain_icdf: [byte: 41] = [0: 41];
    try fec_test_fill_delta_gain_icdf(&delta_gain_icdf[0:41]);
    var subframe: i32 = 1;
    while subframe < 4 {
        ec_enc_icdf(&enc, 4, &delta_gain_icdf[0:41], 8);
        subframe = subframe + 1;
    }

    var cb1_icdf: [byte: 32] = [0: 32];
    try fec_test_fill_nlsf_cb1_icdf(&cb1_icdf[0:32], SILK_SIGNAL_TYPE_UNVOICED);
    ec_enc_icdf(&enc, 0, &cb1_icdf[0:32], 8);

    var ec_ix: [i16: SILK_NLSF_MAX_ORDER] = [0: SILK_NLSF_MAX_ORDER];
    var pred_q8: [byte: SILK_NLSF_MAX_ORDER] = [0: SILK_NLSF_MAX_ORDER];
    try silk_nlsf_unpack_ec_tables(&ec_ix[0:SILK_NLSF_MAX_ORDER], &pred_q8[0:SILK_NLSF_MAX_ORDER], SILK_NLSF_CODEBOOK_WB, 0);

    var order_index: usize = 0;
    while order_index < 16 {
        try fec_test_encode_nlsf_residual(&enc, ec_ix[order_index], 0);
        order_index = order_index + 1;
    }

    var interpolation_icdf: [byte: 5] = [0: 5];
    try fec_test_fill_nlsf_interpolation_icdf(&interpolation_icdf[0:5]);
    ec_enc_icdf(&enc, 4, &interpolation_icdf[0:5], 8);

    var seed_icdf: [byte: 4] = [0: 4];
    try fec_test_fill_uniform4_icdf(&seed_icdf[0:4]);
    ec_enc_icdf(&enc, 2, &seed_icdf[0:4], 8);

    var rate_icdf: [byte: 9] = [0: 9];
    try fec_test_fill_rate_levels_icdf(&rate_icdf[0:9], SILK_SIGNAL_TYPE_UNVOICED);
    ec_enc_icdf(&enc, 0, &rate_icdf[0:9], 8);

    var pulse_icdf: [byte: 18] = [0: 18];
    try fec_test_fill_pulses_per_block_icdf(&pulse_icdf[0:18], 0);
    var block: i32 = 0;
    while block < 20 {
        ec_enc_icdf(&enc, 0, &pulse_icdf[0:18], 8);
        block = block + 1;
    }

    _ = try ec_enc_done(&enc);
    try ec_enc_check(&enc);
}

test "silk fec plan reports full-channel LBRR availability" {
    var payload: [byte: 1] = [0: 1];
    var decoder: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&decoder, &payload[0:1], 2, 3);

    const left_index: usize = try silk_entropy_decoder_flag_index(&decoder, 0, 2);
    const right_index: usize = try silk_entropy_decoder_flag_index(&decoder, 1, 2);
    decoder.lbrr_channel_flags[0] = true;
    decoder.lbrr_channel_flags[1] = true;
    decoder.lbrr_flags[left_index] = true;
    decoder.lbrr_flags[right_index] = true;

    try assert(try silk_fec_has_lbrr(&decoder, 0, 2), "left channel must expose frame LBRR");
    try assert(try silk_fec_has_lbrr(&decoder, 1, 2), "right channel must expose frame LBRR");

    var plan: SilkFecPlan = SilkFecPlan{};
    try silk_fec_plan_from_lbrr_flags(&plan, &decoder, 2);

    try assert(plan.can_recover, "FEC plan must recover when every active channel has LBRR");
    try assert(!plan.needs_plc, "full LBRR recovery does not need PLC fallback");
    try assert_eq_i32(plan.channels, 2);
    try assert_eq_i32(plan.frames_per_packet, 3);
    try assert_eq_i32(plan.frame_index, 2);
    try assert_eq_i32(plan.available_channels, 2);
    try assert(plan.channel_available[0], "left LBRR flag must be copied into the plan");
    try assert(plan.channel_available[1], "right LBRR flag must be copied into the plan");
}

test "silk fec plan falls back to plc for partial or absent LBRR" {
    var payload: [byte: 1] = [0: 1];
    var decoder: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&decoder, &payload[0:1], 2, 2);

    const left_index: usize = try silk_entropy_decoder_flag_index(&decoder, 0, 1);
    decoder.lbrr_channel_flags[0] = true;
    decoder.lbrr_flags[left_index] = true;

    var partial: SilkFecPlan = SilkFecPlan{};
    try silk_fec_plan_from_lbrr_flags(&partial, &decoder, 1);

    try assert(!partial.can_recover, "partial stereo LBRR must not claim full FEC recovery");
    try assert(partial.needs_plc, "partial LBRR needs PLC fallback until channel repair exists");
    try assert_eq_i32(partial.available_channels, 1);
    try assert(partial.channel_available[0], "available channel must be tracked");
    try assert(!partial.channel_available[1], "missing channel must stay unavailable");

    var absent: SilkFecPlan = SilkFecPlan{};
    try silk_fec_plan_from_lbrr_flags(&absent, &decoder, 0);
    try assert(!absent.can_recover, "absent LBRR must not be recoverable");
    try assert(absent.needs_plc, "absent LBRR must request PLC fallback");
    try assert_eq_i32(absent.available_channels, 0);
}

test "silk fec helpers validate channel and frame bounds" {
    var payload: [byte: 1] = [0: 1];
    var decoder: SilkEntropyDecoder = SilkEntropyDecoder{};
    try silk_entropy_decoder_init(&decoder, &payload[0:1], 1, 1);

    const bad_channel: !bool = silk_fec_has_lbrr(&decoder, 1, 0);
    match bad_channel {
        error.SilkFecError => {}
        else => { try assert(false, "FEC LBRR query must reject channels outside the decoder layout"); }
    }

    const bad_frame: !bool = silk_fec_has_lbrr(&decoder, 0, 1);
    match bad_frame {
        error.SilkFecError => {}
        else => { try assert(false, "FEC LBRR query must reject frames outside the packet layout"); }
    }

    var plan: SilkFecPlan = SilkFecPlan{};
    const bad_plan: !void = silk_fec_plan_from_lbrr_flags(&plan, &decoder, -1);
    match bad_plan {
        error.SilkFecError => {}
        else => { try assert(false, "FEC planning must reject negative frame indexes"); }
    }
}

test "silk fec detects LBRR flags from encoded SILK payload" {
    var payload: [byte: 32] = [0: 32];
    var channel_flags: [bool: 1] = [true];
    var frame_masks: [i32: 1] = [4];
    try encode_vad_lbrr_payload(&payload[0:32], 1, 3, &channel_flags[0:1], &frame_masks[0:1]);

    var frame_two: SilkFecPlan = SilkFecPlan{};
    try silk_fec_detect_lbrr_payload(&frame_two, &payload[0:32], 1, 3, 2);
    try assert(frame_two.can_recover, "encoded LBRR mask must make frame 2 recoverable");
    try assert(!frame_two.needs_plc, "available mono LBRR must not need PLC");
    try assert_eq_i32(frame_two.available_channels, 1);
    try assert(frame_two.channel_available[0], "payload detection must copy per-channel availability");

    var frame_one: SilkFecPlan = SilkFecPlan{};
    try silk_fec_detect_lbrr_payload(&frame_one, &payload[0:32], 1, 3, 1);
    try assert(!frame_one.can_recover, "frames absent from the LBRR mask must not be recoverable");
    try assert(frame_one.needs_plc, "missing payload LBRR must request PLC");
}

test "silk fec detects LBRR flags from complete SILK packet" {
    var packet: [byte: 33] = [0: 33];
    packet[0] = 88;
    var channel_flags: [bool: 1] = [true];
    var frame_masks: [i32: 1] = [2];
    try encode_vad_lbrr_payload(&packet[1:32], 1, 3, &channel_flags[0:1], &frame_masks[0:1]);

    var plan: SilkFecPlan = SilkFecPlan{};
    try silk_fec_detect_lbrr_packet(&plan, &packet[0:33], 1);

    try assert(plan.can_recover, "packet-level detector must derive SILK layout and find frame LBRR");
    try assert_eq_i32(plan.channels, 1);
    try assert_eq_i32(plan.frames_per_packet, 3);
    try assert_eq_i32(plan.frame_index, 1);
    try assert_eq_i32(plan.available_channels, 1);
}

test "silk fec packet detector rejects non-silk packets and bad frame indexes" {
    var celt_packet: [byte: 4] = [248, 0, 0, 0];
    var plan: SilkFecPlan = SilkFecPlan{};
    const celt_result: !void = silk_fec_detect_lbrr_packet(&plan, &celt_packet[0:4], 0);
    match celt_result {
        error.SilkFecError => {}
        else => { try assert(false, "FEC packet detection must reject non-SILK packets"); }
    }

    var silk_packet: [byte: 33] = [0: 33];
    silk_packet[0] = 88;
    var channel_flags: [bool: 1] = [false];
    var frame_masks: [i32: 1] = [0];
    try encode_vad_lbrr_payload(&silk_packet[1:32], 1, 3, &channel_flags[0:1], &frame_masks[0:1]);

    const bad_frame: !void = silk_fec_detect_lbrr_packet(&plan, &silk_packet[0:33], 3);
    match bad_frame {
        error.SilkFecError => {}
        else => { try assert(false, "FEC packet detection must reject internal frame indexes outside packet duration"); }
    }
}

test "silk delayed fec decodes recoverable mono LBRR frame" {
    var packet: [byte: 384] = [0: 384];
    try encode_wb20_lbrr_unvoiced_packet(&packet[0:384]);

    var state: SilkDecoderState = SilkDecoderState{};
    try silk_state_init(&state, 1, 16000, 20);
    state.loss_count = 1;
    var out_q14: [i32: 320] = [0: 320];
    var result: SilkDelayedFecResult = SilkDelayedFecResult{};

    try silk_fec_decode_delayed_mono_q14(&result, &state, &packet[0:384], 0, &out_q14[0:320]);

    try assert(result.used_fec, "available LBRR must use the delayed FEC decode path");
    try assert(!result.used_plc, "recoverable LBRR must not fall back to PLC");
    try assert_eq_i32(result.decoded_samples as i32, 320);
    try assert(result.plan.can_recover, "delayed FEC result must retain the successful LBRR plan");
    try assert_eq_i32(state.loss_count, 0);
    try assert(!state.first_frame_after_reset, "delayed FEC decode must advance decoder state like a decoded frame");
    try assert(state.rng != 0, "delayed FEC decode must consume encoded random seed side info");
}

test "silk delayed fec recovers previous lost frame from next packet LBRR" {
    var packet: [byte: 384] = [0: 384];
    try encode_wb20_lbrr_unvoiced_packet(&packet[0:384]);

    var state: SilkDecoderState = SilkDecoderState{};
    try silk_state_init(&state, 1, 16000, 20);
    state.loss_count = 1;
    var i: usize = 0;
    while i < 320 {
        state.history_q14[304 + i] = 20000 + (i as i32);
        i = i + 1;
    }

    var out_q14: [i32: 320] = [0: 320];
    var result: SilkDelayedFecResult = SilkDelayedFecResult{};
    try silk_fec_decode_delayed_mono_q14(&result, &state, &packet[0:384], 0, &out_q14[0:320]);

    try assert(result.used_fec, "next packet LBRR must recover the previous lost frame");
    try assert(!result.used_plc, "available LBRR must not use PLC for the previous frame");
    try assert_eq_i32(result.decoded_samples as i32, 320);
    try assert_eq_i32(result.plan.frame_index, 0);
    try assert(!result.plan.needs_plc, "recoverable previous frame must retain a non-PLC plan");
    try assert_eq_i32(state.loss_count, 0);
    try assert(out_q14[0] != 20000, "FEC output must not be a PLC copy of the previous history");
    try assert(out_q14[319] != 20319, "FEC output must not copy the end of the previous history");
}

test "silk delayed fec falls back to plc when LBRR is absent" {
    var packet: [byte: 33] = [0: 33];
    packet[0] = 72;
    var channel_flags: [bool: 1] = [false];
    var frame_masks: [i32: 1] = [0];
    try encode_vad_lbrr_payload(&packet[1:32], 1, 1, &channel_flags[0:1], &frame_masks[0:1]);

    var state: SilkDecoderState = SilkDecoderState{};
    try silk_state_init(&state, 1, 16000, 20);
    var i: usize = 0;
    while i < 320 {
        state.history_q14[304 + i] = ((i as i32) + 1) * 3;
        i = i + 1;
    }

    var out_q14: [i32: 320] = [0: 320];
    var result: SilkDelayedFecResult = SilkDelayedFecResult{};
    try silk_fec_decode_delayed_mono_q14(&result, &state, &packet[0:33], 0, &out_q14[0:320]);

    try assert(!result.used_fec, "absent LBRR must not report delayed FEC recovery");
    try assert(result.used_plc, "absent LBRR must use PLC fallback");
    try assert_eq_i32(result.decoded_samples as i32, 320);
    try assert(!result.plan.can_recover, "absent LBRR must retain a non-recoverable plan");
    try assert(result.plan.needs_plc, "fallback result must retain a PLC plan");
    try assert_eq_i32(result.plan.available_channels, 0);
    try assert(!result.plan.channel_available[0], "mono fallback must not mark a missing LBRR channel available");
    try assert_eq_i32(out_q14[0], 3);
    try assert_eq_i32(out_q14[319], 960);
    try assert_eq_i32(state.loss_count, 1);
}

test "silk delayed fec and plc fallback only write requested output slice" {
    var fec_packet: [byte: 384] = [0: 384];
    try encode_wb20_lbrr_unvoiced_packet(&fec_packet[0:384]);

    var fec_state: SilkDecoderState = SilkDecoderState{};
    try silk_state_init(&fec_state, 1, 16000, 20);
    fec_state.loss_count = 1;

    var fec_out: [i32: 326] = [0: 326];
    var i: usize = 0;
    while i < 326 {
        fec_out[i] = -77777;
        i = i + 1;
    }

    var fec_result: SilkDelayedFecResult = SilkDelayedFecResult{};
    try silk_fec_decode_delayed_mono_q14(&fec_result, &fec_state, &fec_packet[0:384], 0, &fec_out[3:320]);
    try assert(fec_result.used_fec, "recoverable LBRR must take the delayed FEC path");
    try assert_eq_i32(fec_result.decoded_samples as i32, 320);
    try assert_eq_i32(fec_out[0], -77777);
    try assert_eq_i32(fec_out[2], -77777);
    try assert_eq_i32(fec_out[323], -77777);
    try assert_eq_i32(fec_out[325], -77777);

    var plc_packet: [byte: 33] = [0: 33];
    plc_packet[0] = 72;
    var channel_flags: [bool: 1] = [false];
    var frame_masks: [i32: 1] = [0];
    try encode_vad_lbrr_payload(&plc_packet[1:32], 1, 1, &channel_flags[0:1], &frame_masks[0:1]);

    var plc_state: SilkDecoderState = SilkDecoderState{};
    try silk_state_init(&plc_state, 1, 16000, 20);
    i = 0;
    while i < 320 {
        plc_state.history_q14[304 + i] = ((i as i32) + 1) * 5;
        i = i + 1;
    }

    var plc_out: [i32: 326] = [0: 326];
    i = 0;
    while i < 326 {
        plc_out[i] = -88888;
        i = i + 1;
    }

    var plc_result: SilkDelayedFecResult = SilkDelayedFecResult{};
    try silk_fec_decode_delayed_mono_q14(&plc_result, &plc_state, &plc_packet[0:33], 0, &plc_out[3:320]);
    try assert(plc_result.used_plc, "absent LBRR must take the delayed FEC PLC fallback path");
    try assert_eq_i32(plc_result.decoded_samples as i32, 320);
    try assert_eq_i32(plc_out[0], -88888);
    try assert_eq_i32(plc_out[2], -88888);
    try assert_eq_i32(plc_out[3], 5);
    try assert_eq_i32(plc_out[322], 1600);
    try assert_eq_i32(plc_out[323], -88888);
    try assert_eq_i32(plc_out[325], -88888);
}

test "silk fec recovery marker clears pending loss state" {
    var state: SilkDecoderState = SilkDecoderState{};
    try silk_state_init(&state, 1, 16000, 20);
    state.loss_count = 2;
    state.first_frame_after_reset = true;

    try silk_fec_mark_recovered(&state);

    try assert_eq_i32(state.loss_count, 0);
    try assert(!state.first_frame_after_reset, "FEC recovery consumes the reset marker like a decoded frame");
}
