fn fec_test_fill_nlsf_cb1_icdf(out: &[byte], signal_type: i32) !void {
    if out.len < 32 || signal_type < 0 || signal_type > 1 {
        try assert(false, "NLSF CB1 helper needs one 32-entry signal row");
    }
    const base: usize = (signal_type as usize) * 32;
    var i: usize = 0;
    while i < 32 {
        out.ptr[i] = silk_nlsf_cb1_icdf(SILK_NLSF_CODEBOOK_WB, base + i);
        i = i + 1;
    }
}

fn fec_test_fill_nlsf_cb2_icdf(out: &[byte], ec_ix: i16) !void {
    if out.len < 9 || ec_ix < 0 {
