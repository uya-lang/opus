fn fill_lbrr_icdf(out: &[byte], frames_per_packet: i32) !usize {
    if frames_per_packet == 2 {
        if out.len < 3 {
            try assert(false, "two-frame LBRR helper needs 3 iCDF entries");
        }
        var i: usize = 0;
        while i < 3 {
            out.ptr[i] = silk_lbrr_flags_2_icdf_value(i);
            i = i + 1;
        }
        return 3 as usize;
    }
    if frames_per_packet == 3 {
        if out.len < 7 {
            try assert(false, "three-frame LBRR helper needs 7 iCDF entries");
        }
        var j: usize = 0;
        while j < 7 {
            out.ptr[j] = silk_lbrr_flags_3_icdf_value(j);
            j = j + 1;
        }
        return 7 as usize;
    }
    try assert(false, "test LBRR helper only supports two or three frames");
    return 0 as usize;
}

fn encode_vad_lbrr_payload(payload: &[byte], channels: i32, frames_per_packet: i32, lbrr_channel_flags: &[bool], lbrr_frame_masks: &[i32]) !void {
    var enc: EcEnc = EcEnc{};
    ec_enc_init(&enc, payload);

    var channel: i32 = 0;
    while channel < channels {
        var frame: i32 = 0;
        while frame < frames_per_packet {
            ec_enc_bit_logp(&enc, 0, 1);
            frame = frame + 1;
        }
        channel = channel + 1;
    }

    channel = 0;
    while channel < channels {
        const channel_index: usize = channel as usize;
        var has_lbrr: i32 = 0;
        if lbrr_channel_flags.ptr[channel_index] {
            has_lbrr = 1;
        }
        ec_enc_bit_logp(&enc, has_lbrr, 1);
        if has_lbrr != 0 && frames_per_packet > 1 {
            var icdf: [byte: 7] = [0: 7];
            const icdf_len: usize = try fill_lbrr_icdf(&icdf[0:7], frames_per_packet);
            const mask: i32 = lbrr_frame_masks.ptr[channel_index];
            ec_enc_icdf(&enc, mask - 1, &icdf[0:icdf_len], 8);
        }
        channel = channel + 1;
    }

    _ = try ec_enc_done(&enc);
    try ec_enc_check(&enc);
}

fn fec_test_fill_type_offset_vad_icdf(out: &[byte]) !void {
    if out.len < 4 {
        try assert(false, "type offset helper needs 4 entries");
    }
    var i: usize = 0;
    while i < 4 {
        out.ptr[i] = silk_type_offset_vad_icdf_value(i);
        i = i + 1;
    }
}

