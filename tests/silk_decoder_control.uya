use std.testing.assert;
use std.testing.assert_eq_i32;
use src.opus.silk.decoder_control.SILK_CONTROL_MAX_LPC_ORDER;
use src.opus.silk.decoder_control.SILK_CONTROL_MAX_NB_SUBFR;
use src.opus.silk.decoder_control.SILK_CONTROL_MAX_CHANNELS;
use src.opus.silk.decoder_control.SILK_SIGNAL_TYPE_VOICED;
use src.opus.silk.decoder_control.SILK_SIGNAL_TYPE_UNVOICED;
use src.opus.silk.decoder_control.SilkDecoderControl;
use src.opus.silk.decoder_control.silk_decoder_control_gain_index;
use src.opus.silk.decoder_control.silk_decoder_control_init_from_state;
use src.opus.silk.decoder_control.silk_decoder_control_lpc_index;
use src.opus.silk.decoder_control.silk_decoder_control_ltp_index;
use src.opus.silk.decoder_control.silk_decoder_control_pitch_index;
use src.opus.silk.decoder_control.silk_decoder_control_reset;
use src.opus.silk.decoder_control.silk_decoder_control_set_signal;
use src.opus.silk.state.SilkDecoderState;
use src.opus.silk.state.silk_state_init;

test "silk decoder control initializes frame layout from decoder state" {
    var state: SilkDecoderState = SilkDecoderState{};
    try silk_state_init(&state, 2, 16000, 20);

    var control: SilkDecoderControl = SilkDecoderControl{};
    try silk_decoder_control_init_from_state(&control, &state);

    try assert_eq_i32(control.channels, 2);
    try assert_eq_i32(control.fs_khz, 16);
    try assert_eq_i32(control.frame_length, 320);
    try assert_eq_i32(control.subframe_length, 80);
    try assert_eq_i32(control.nb_subframes, 4);
    try assert_eq_i32(control.lpc_order, 16);
    try assert_eq_i32(SILK_CONTROL_MAX_CHANNELS as i32, 2);
    try assert_eq_i32(SILK_CONTROL_MAX_NB_SUBFR as i32, 4);
    try assert_eq_i32(SILK_CONTROL_MAX_LPC_ORDER as i32, 16);
    try assert_eq_i32(control.signal_type, SILK_SIGNAL_TYPE_UNVOICED);
    try assert_eq_i32(control.quant_offset_type, 0);
    try assert_eq_i32(control.seed, 0);
    try assert_eq_i32(control.gains_q16[0], 0);
    try assert_eq_i32(control.nlsf_q15[31] as i32, 0);
    try assert_eq_i32(control.pred_coef_q12[31], 0);
    try assert_eq_i32(control.ltp_coef_q14[39] as i32, 0);
}

test "silk decoder control maps channel and subframe arrays" {
    var state: SilkDecoderState = SilkDecoderState{};
    try silk_state_init(&state, 2, 12000, 20);

    var control: SilkDecoderControl = SilkDecoderControl{};
    try silk_decoder_control_init_from_state(&control, &state);

    try assert_eq_i32((try silk_decoder_control_gain_index(&control, 0, 0)) as i32, 0);
    try assert_eq_i32((try silk_decoder_control_gain_index(&control, 1, 3)) as i32, 7);
    try assert_eq_i32((try silk_decoder_control_lpc_index(&control, 1, 15)) as i32, 31);
    try assert_eq_i32((try silk_decoder_control_pitch_index(&control, 3)) as i32, 3);
    try assert_eq_i32((try silk_decoder_control_ltp_index(&control, 1, 3, 4)) as i32, 39);

    const bad_gain: !usize = silk_decoder_control_gain_index(&control, 1, 4);
    match bad_gain {
        error.SilkDecoderControlError => {}
        else => { try assert(false, "gain index past active subframes must fail"); }
    }

    const bad_lpc: !usize = silk_decoder_control_lpc_index(&control, 0, 16);
    match bad_lpc {
        error.SilkDecoderControlError => {}
        else => { try assert(false, "LPC index past active order must fail"); }
    }

    const bad_ltp: !usize = silk_decoder_control_ltp_index(&control, 2, 0, 0);
    match bad_ltp {
        error.SilkDecoderControlError => {}
        else => { try assert(false, "LTP index past active channels must fail"); }
    }
}

test "silk decoder control validates signal and quantization offset fields" {
    var state: SilkDecoderState = SilkDecoderState{};
    try silk_state_init(&state, 1, 8000, 10);

    var control: SilkDecoderControl = SilkDecoderControl{};
    try silk_decoder_control_init_from_state(&control, &state);
    try silk_decoder_control_set_signal(&control, SILK_SIGNAL_TYPE_VOICED, 1);
    try assert_eq_i32(control.signal_type, SILK_SIGNAL_TYPE_VOICED);
    try assert_eq_i32(control.quant_offset_type, 1);

    const bad_signal: !void = silk_decoder_control_set_signal(&control, 3, 0);
    match bad_signal {
        error.SilkDecoderControlError => {}
        else => { try assert(false, "unknown SILK signal type must fail"); }
    }

    const bad_quant_offset: !void = silk_decoder_control_set_signal(&control, SILK_SIGNAL_TYPE_UNVOICED, 2);
    match bad_quant_offset {
        error.SilkDecoderControlError => {}
        else => { try assert(false, "quantization offset type must be 0 or 1"); }
    }
}

test "silk decoder control reset clears side information but keeps frame layout" {
    var state: SilkDecoderState = SilkDecoderState{};
    try silk_state_init(&state, 2, 16000, 20);

    var control: SilkDecoderControl = SilkDecoderControl{};
    try silk_decoder_control_init_from_state(&control, &state);
    control.signal_type = SILK_SIGNAL_TYPE_VOICED;
    control.quant_offset_type = 1;
    control.seed = 37;
    control.gains_q16[7] = 65536;
    control.pitch_lags[3] = 48;
    control.nlsf_q15[31] = 99;
    control.pred_coef_q12[31] = -12;
    control.ltp_coef_q14[39] = 3;

    silk_decoder_control_reset(&control);

    try assert_eq_i32(control.channels, 2);
    try assert_eq_i32(control.frame_length, 320);
    try assert_eq_i32(control.nb_subframes, 4);
    try assert_eq_i32(control.lpc_order, 16);
    try assert_eq_i32(control.signal_type, SILK_SIGNAL_TYPE_UNVOICED);
    try assert_eq_i32(control.quant_offset_type, 0);
    try assert_eq_i32(control.seed, 0);
    try assert_eq_i32(control.gains_q16[7], 0);
    try assert_eq_i32(control.pitch_lags[3], 0);
    try assert_eq_i32(control.nlsf_q15[31] as i32, 0);
    try assert_eq_i32(control.pred_coef_q12[31], 0);
    try assert_eq_i32(control.ltp_coef_q14[39] as i32, 0);
}
