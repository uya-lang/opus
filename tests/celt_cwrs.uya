use std.testing.assert;
use std.testing.assert_eq_i32;
use src.opus.celt.cwrs.celt_cwrs_abs_sum;
use src.opus.celt.cwrs.celt_cwrs_count;
use src.opus.celt.cwrs.celt_cwrs_validate_pulses;
use src.opus.celt.cwrs.celt_decode_pulses;
use src.opus.celt.cwrs.celt_encode_pulses;
use src.opus.celt.cwrs.celt_icwrs;

test "celt cwrs counts small pulse shell sizes" {
    try assert_eq_i32((try celt_cwrs_count(0, 0)) as i32, 1);
    try assert_eq_i32((try celt_cwrs_count(0, 1)) as i32, 0);
    try assert_eq_i32((try celt_cwrs_count(1, 0)) as i32, 1);
    try assert_eq_i32((try celt_cwrs_count(1, 3)) as i32, 2);
    try assert_eq_i32((try celt_cwrs_count(2, 1)) as i32, 4);
    try assert_eq_i32((try celt_cwrs_count(2, 2)) as i32, 8);
    try assert_eq_i32((try celt_cwrs_count(3, 2)) as i32, 18);
}

test "celt cwrs validates pulse absolute sums" {
    var pulses: [i32: 4] = [2, -1, 0, 3];
    try assert_eq_i32(try celt_cwrs_abs_sum(&pulses[0:4]), 6);
    try celt_cwrs_validate_pulses(&pulses[0:4], 6);

    const wrong_k: !void = celt_cwrs_validate_pulses(&pulses[0:4], 5);
    match wrong_k {
        error.CeltCwrsError => {}
        else => { try assert(false, "wrong pulse sum must fail"); }
    }
}

test "celt cwrs rejects unsupported dimensions and pulse counts" {
    const bad_n: !u32 = celt_cwrs_count(17, 0);
    match bad_n {
        error.CeltCwrsError => {}
        else => { try assert(false, "dimension past bound must fail"); }
    }

    const bad_k: !u32 = celt_cwrs_count(1, 33);
    match bad_k {
        error.CeltCwrsError => {}
        else => { try assert(false, "pulse count past bound must fail"); }
    }

    var too_many: [i32: 17] = [0: 17];
    const bad_len: !i32 = celt_cwrs_abs_sum(&too_many[0:17]);
    match bad_len {
        error.CeltCwrsError => {}
        else => { try assert(false, "pulse vector past bound must fail"); }
    }
}

test "celt icwrs ranks small vectors in stable pulse order" {
    var n2_k1_0: [i32: 2] = [0, 1];
    var n2_k1_1: [i32: 2] = [0, -1];
    var n2_k1_2: [i32: 2] = [1, 0];
    var n2_k1_3: [i32: 2] = [-1, 0];
    try assert_eq_i32((try celt_icwrs(&n2_k1_0[0:2])) as i32, 0);
    try assert_eq_i32((try celt_icwrs(&n2_k1_1[0:2])) as i32, 1);
    try assert_eq_i32((try celt_icwrs(&n2_k1_2[0:2])) as i32, 2);
    try assert_eq_i32((try celt_icwrs(&n2_k1_3[0:2])) as i32, 3);

    var n2_k2_0: [i32: 2] = [0, 2];
    var n2_k2_2: [i32: 2] = [1, 1];
    var n2_k2_5: [i32: 2] = [-1, -1];
    var n2_k2_7: [i32: 2] = [-2, 0];
    try assert_eq_i32((try celt_icwrs(&n2_k2_0[0:2])) as i32, 0);
    try assert_eq_i32((try celt_icwrs(&n2_k2_2[0:2])) as i32, 2);
    try assert_eq_i32((try celt_icwrs(&n2_k2_5[0:2])) as i32, 5);
    try assert_eq_i32((try celt_icwrs(&n2_k2_7[0:2])) as i32, 7);
}

test "celt icwrs rejects vectors outside supported bounds" {
    var too_many_pulses: [i32: 2] = [33, 0];
    const bad_k: !u32 = celt_icwrs(&too_many_pulses[0:2]);
    match bad_k {
        error.CeltCwrsError => {}
        else => { try assert(false, "icwrs pulse count past bound must fail"); }
    }
}

test "celt pulse decode inverts encode for representative ranks" {
    var decoded: [i32: 3] = [0: 3];
    try celt_decode_pulses(2, 2, 0, &decoded[0:3]);
    try assert_eq_i32(decoded[0], 0);
    try assert_eq_i32(decoded[1], 2);
    try assert_eq_i32((try celt_encode_pulses(&decoded[0:2])) as i32, 0);

    try celt_decode_pulses(2, 2, 5, &decoded[0:3]);
    try assert_eq_i32(decoded[0], -1);
    try assert_eq_i32(decoded[1], -1);
    try assert_eq_i32((try celt_encode_pulses(&decoded[0:2])) as i32, 5);

    try celt_decode_pulses(3, 2, 17, &decoded[0:3]);
    try assert_eq_i32(try celt_cwrs_abs_sum(&decoded[0:3]), 2);
    try assert_eq_i32((try celt_encode_pulses(&decoded[0:3])) as i32, 17);
}

test "celt pulse roundtrip covers small rank ranges" {
    var decoded: [i32: 3] = [0: 3];
    var n: i32 = 1;
    while n <= 3 {
        var k: i32 = 0;
        while k <= 2 {
            const total: i32 = (try celt_cwrs_count(n, k)) as i32;
            var rank: i32 = 0;
            while rank < total {
                try celt_decode_pulses(n, k, rank as u32, &decoded[0:3]);
                try assert_eq_i32(try celt_cwrs_abs_sum(&decoded[0:(n as usize)]), k);
                try assert_eq_i32((try celt_encode_pulses(&decoded[0:(n as usize)])) as i32, rank);
                rank = rank + 1;
            }
            k = k + 1;
        }
        n = n + 1;
    }
}

test "celt pulse decode rejects invalid ranks and output buffers" {
    var decoded: [i32: 1] = [0];
    const bad_rank: !void = celt_decode_pulses(2, 1, 4, &decoded[0:1]);
    match bad_rank {
        error.CeltCwrsError => {}
        else => { try assert(false, "rank equal to count must fail"); }
    }

    const short_out: !void = celt_decode_pulses(2, 1, 0, &decoded[0:1]);
    match short_out {
        error.CeltCwrsError => {}
        else => { try assert(false, "short decode output must fail"); }
    }
}
