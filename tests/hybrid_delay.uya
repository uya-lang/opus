use std.testing.assert;
use std.testing.assert_eq_i32;
use src.opus.core.types.OpusBandwidth;
use src.opus.hybrid.delay.hybrid_delay_apply_channel_q14;
use src.opus.hybrid.delay.hybrid_delay_apply_interleaved_q14;
use src.opus.hybrid.state.HYBRID_DELAY_BUFFER_LEN;
use src.opus.hybrid.state.HYBRID_MAX_DELAY_SAMPLES_48K;
use src.opus.hybrid.state.HybridDecoderState;
use src.opus.hybrid.state.hybrid_state_delay_index;
use src.opus.hybrid.state.hybrid_state_init;

test "hybrid delay channel emits stored delay then shifted input" {
    var state: HybridDecoderState = HybridDecoderState{};
    try hybrid_state_init(&state, 1, OpusBandwidth.SUPERWIDEBAND, 480);

    var input: [i32: 480] = [0: 480];
    var output: [i32: 480] = [0: 480];
    var i: usize = 0;
    while i < 480 {
        input[i] = (i as i32) + 1;
        i = i + 1;
    }

    const decoded: usize = try hybrid_delay_apply_channel_q14(&state, 0, &input[0:480], &output[0:480]);
    try assert_eq_i32(decoded as i32, 480);
    try assert_eq_i32(output[0], 0);
    try assert_eq_i32(output[119], 0);
    try assert_eq_i32(output[120], 1);
    try assert_eq_i32(output[479], 360);
    try assert_eq_i32(state.delay_q14[0], 361);
    try assert_eq_i32(state.delay_q14[119], 480);

    i = 0;
    while i < 480 {
        input[i] = 1001 + (i as i32);
        output[i] = 0;
        i = i + 1;
    }

    _ = try hybrid_delay_apply_channel_q14(&state, 0, &input[0:480], &output[0:480]);
    try assert_eq_i32(output[0], 361);
    try assert_eq_i32(output[119], 480);
    try assert_eq_i32(output[120], 1001);
    try assert_eq_i32(output[479], 1360);
    try assert_eq_i32(state.delay_q14[0], 1361);
    try assert_eq_i32(state.delay_q14[119], 1480);
}

test "hybrid delay interleaved path keeps channels independent" {
    var state: HybridDecoderState = HybridDecoderState{};
    try hybrid_state_init(&state, 2, OpusBandwidth.FULLBAND, 480);

    var input: [i32: 960] = [0: 960];
    var output: [i32: 960] = [0: 960];
    var frame: usize = 0;
    while frame < 480 {
        input[frame * 2] = 1000 + (frame as i32);
        input[frame * 2 + 1] = -1000 - (frame as i32);
        frame = frame + 1;
    }

    const decoded: usize = try hybrid_delay_apply_interleaved_q14(&state, &input[0:960], &output[0:960]);
    try assert_eq_i32(decoded as i32, 480);
    try assert_eq_i32(output[0], 0);
    try assert_eq_i32(output[1], 0);
    try assert_eq_i32(output[240], 1000);
    try assert_eq_i32(output[241], -1000);
    try assert_eq_i32(output[958], 1359);
    try assert_eq_i32(output[959], -1359);

    const right_base: usize = try hybrid_state_delay_index(&state, 1, 0);
    if right_base >= HYBRID_DELAY_BUFFER_LEN {
        try assert(false, "right delay index must stay inside hybrid delay buffer");
    }
    try assert_eq_i32(state.delay_q14[0], 1360);
    try assert_eq_i32(state.delay_q14[119], 1479);
    try assert_eq_i32(right_base as i32, 120);
    try assert_eq_i32(state.delay_q14[120], -1360);
    try assert_eq_i32(state.delay_q14[239], -1479);
}

test "hybrid delay works when input and output share storage" {
    var mono_state: HybridDecoderState = HybridDecoderState{};
    try hybrid_state_init(&mono_state, 1, OpusBandwidth.SUPERWIDEBAND, 480);

    var mono: [i32: 480] = [0: 480];
    var i: usize = 0;
    while i < 480 {
        mono[i] = (i as i32) + 1;
        i = i + 1;
    }

    _ = try hybrid_delay_apply_channel_q14(&mono_state, 0, &mono[0:480], &mono[0:480]);
    try assert_eq_i32(mono[0], 0);
    try assert_eq_i32(mono[119], 0);
    try assert_eq_i32(mono[120], 1);
    try assert_eq_i32(mono[479], 360);
    try assert_eq_i32(mono_state.delay_q14[0], 361);
    try assert_eq_i32(mono_state.delay_q14[119], 480);

    var stereo_state: HybridDecoderState = HybridDecoderState{};
    try hybrid_state_init(&stereo_state, 2, OpusBandwidth.FULLBAND, 480);

    var stereo: [i32: 960] = [0: 960];
    var frame: usize = 0;
    while frame < 480 {
        stereo[frame * 2] = 5000 + (frame as i32);
        stereo[frame * 2 + 1] = -5000 - (frame as i32);
        frame = frame + 1;
    }

    _ = try hybrid_delay_apply_interleaved_q14(&stereo_state, &stereo[0:960], &stereo[0:960]);
    try assert_eq_i32(stereo[0], 0);
    try assert_eq_i32(stereo[1], 0);
    try assert_eq_i32(stereo[240], 5000);
    try assert_eq_i32(stereo[241], -5000);
    try assert_eq_i32(stereo[958], 5359);
    try assert_eq_i32(stereo[959], -5359);
    try assert_eq_i32(stereo_state.delay_q14[0], 5360);
    try assert_eq_i32(stereo_state.delay_q14[119], 5479);
    try assert_eq_i32(stereo_state.delay_q14[120], -5360);
    try assert_eq_i32(stereo_state.delay_q14[239], -5479);
}

test "hybrid delay validates channels state and buffers" {
    var state: HybridDecoderState = HybridDecoderState{};
    try hybrid_state_init(&state, 1, OpusBandwidth.SUPERWIDEBAND, 480);

    var input: [i32: 480] = [0: 480];
    var output: [i32: 480] = [0: 480];

    const bad_channel: !usize = hybrid_delay_apply_channel_q14(&state, 1, &input[0:480], &output[0:480]);
    match bad_channel {
        error.HybridDelayError => {}
        else => { try assert(false, "delay channel helper must reject channels outside layout"); }
    }

    const short_input: !usize = hybrid_delay_apply_channel_q14(&state, 0, &input[0:479], &output[0:480]);
    match short_input {
        error.HybridDelayError => {}
        else => { try assert(false, "delay channel helper must reject short input"); }
    }

    const short_output: !usize = hybrid_delay_apply_channel_q14(&state, 0, &input[0:480], &output[0:479]);
    match short_output {
        error.HybridDelayError => {}
        else => { try assert(false, "delay channel helper must reject short output"); }
    }

    state.delay_samples_48k = HYBRID_MAX_DELAY_SAMPLES_48K as i32 + 1;
    const bad_delay: !usize = hybrid_delay_apply_channel_q14(&state, 0, &input[0:480], &output[0:480]);
    match bad_delay {
        error.HybridDelayError => {}
        else => { try assert(false, "delay helper must reject delay lengths outside state capacity"); }
    }

    state.delay_samples_48k = HYBRID_MAX_DELAY_SAMPLES_48K as i32;
    state.frame_size_48k = 479;
    const bad_frame: !usize = hybrid_delay_apply_channel_q14(&state, 0, &input[0:480], &output[0:480]);
    match bad_frame {
        error.HybridDelayError => {}
        else => { try assert(false, "delay helper must reject non-hybrid frame sizes"); }
    }
}
