use std.testing.assert;
use std.testing.assert_eq_i32;
use src.opus.celt.bands.celt_band_shape_normalize_q15;
use src.opus.celt.bands.celt_apply_intensity_stereo_bands_q15;
use src.opus.celt.bands.celt_apply_intensity_stereo_q15;
use src.opus.celt.bands.celt_apply_anti_collapse_q15;
use src.opus.celt.bands.celt_decode_anti_collapse_flag;
use src.opus.celt.bands.celt_decode_intensity_start_band;
use src.opus.celt.bands.celt_intensity_stereo_weights_q14;
use src.opus.celt.bands.celt_decode_band_shape;
use src.opus.celt.bands.celt_decode_band_shapes;
use src.opus.celt.cwrs.celt_encode_pulses;
use src.opus.entropy.range_dec.EcDec;
use src.opus.entropy.range_dec.ec_dec_check;
use src.opus.entropy.range_dec.ec_dec_init;
use src.opus.entropy.range_enc.EcEnc;
use src.opus.entropy.range_enc.ec_enc_check;
use src.opus.entropy.range_enc.ec_enc_done;
use src.opus.entropy.range_enc.ec_enc_bits;
use src.opus.entropy.range_enc.ec_enc_init;
use src.opus.entropy.range_enc.ec_enc_uint;

fn encode_band_rank(packet: &[byte], pulses: &[i32], combinations: u32) !usize {
    var enc: EcEnc = EcEnc{};
    ec_enc_init(&enc, packet);
    ec_enc_uint(&enc, try celt_encode_pulses(pulses), combinations);
    try ec_enc_check(&enc);
    return try ec_enc_done(&enc);
}

test "celt band shape normalizes decoded pulses to q15 unit vectors" {
    var pulses: [i32: 2] = [1, -1];
    var shape_q15: [i16: 2] = [0: 2];
    try celt_band_shape_normalize_q15(&pulses[0:2], &shape_q15[0:2]);

    try assert_eq_i32(shape_q15[0] as i32, 23171);
    try assert_eq_i32(shape_q15[1] as i32, -23171);
}

test "celt band shape decode reads cwrs rank from range coder" {
    var packet: [byte: 16] = [0: 16];
    var expected: [i32: 2] = [-1, -1];
    _ = try encode_band_rank(&packet[0:16], &expected[0:2], 8);

    var dec: EcDec = EcDec{};
    ec_dec_init(&dec, &packet[0:16]);
    var pulses: [i32: 2] = [0: 2];
    var shape_q15: [i16: 2] = [0: 2];
    const decoded: i32 = try celt_decode_band_shape(&dec, 2, 4, &pulses[0:2], &shape_q15[0:2]);
    try ec_dec_check(&dec);

    try assert_eq_i32(decoded, 2);
    try assert_eq_i32(pulses[0], -1);
    try assert_eq_i32(pulses[1], -1);
    try assert_eq_i32(shape_q15[0] as i32, -23171);
    try assert_eq_i32(shape_q15[1] as i32, -23171);
}

test "celt band shape decode clears zero budget bands" {
    var packet: [byte: 1] = [0];
    var dec: EcDec = EcDec{};
    ec_dec_init(&dec, &packet[0:1]);
    var pulses: [i32: 3] = [7: 3];
    var shape_q15: [i16: 3] = [7: 3];
    const decoded: i32 = try celt_decode_band_shape(&dec, 3, 0, &pulses[0:3], &shape_q15[0:3]);

    try assert_eq_i32(decoded, 0);
    try assert_eq_i32(pulses[0], 0);
    try assert_eq_i32(pulses[1], 0);
    try assert_eq_i32(pulses[2], 0);
    try assert_eq_i32(shape_q15[0] as i32, 0);
    try assert_eq_i32(shape_q15[1] as i32, 0);
    try assert_eq_i32(shape_q15[2] as i32, 0);
}

test "celt band shapes decode consecutive band slices" {
    var packet: [byte: 16] = [0: 16];
    var expected: [i32: 2] = [1, 0];
    _ = try encode_band_rank(&packet[0:16], &expected[0:2], 4);

    var dec: EcDec = EcDec{};
    ec_dec_init(&dec, &packet[0:16]);
    var dims: [i32: 2] = [2, 1];
    var bits: [i32: 2] = [2, 0];
    var pulses: [i32: 3] = [9: 3];
    var shape_q15: [i16: 3] = [9: 3];
    const decoded: i32 = try celt_decode_band_shapes(
        &dec,
        0,
        2,
        &dims[0:2],
        &bits[0:2],
        &pulses[0:3],
        &shape_q15[0:3],
    );
    try ec_dec_check(&dec);

    try assert_eq_i32(decoded, 1);
    try assert_eq_i32(pulses[0], 1);
    try assert_eq_i32(pulses[1], 0);
    try assert_eq_i32(pulses[2], 0);
    try assert_eq_i32(shape_q15[0] as i32, 32767);
    try assert_eq_i32(shape_q15[1] as i32, 0);
    try assert_eq_i32(shape_q15[2] as i32, 0);
}

test "celt intensity start band decodes bounded threshold" {
    var packet: [byte: 16] = [0: 16];
    var enc: EcEnc = EcEnc{};
    ec_enc_init(&enc, &packet[0:16]);
    ec_enc_uint(&enc, 2, 5);
    try ec_enc_check(&enc);
    _ = try ec_enc_done(&enc);

    var dec: EcDec = EcDec{};
    ec_dec_init(&dec, &packet[0:16]);
    const intensity: i32 = try celt_decode_intensity_start_band(&dec, 3, 7, true);
    try ec_dec_check(&dec);

    try assert_eq_i32(intensity, 5);

    var empty_dec: EcDec = EcDec{};
    ec_dec_init(&empty_dec, &packet[0:1]);
    try assert_eq_i32(try celt_decode_intensity_start_band(&empty_dec, 3, 7, false), 7);
}

test "celt intensity stereo weights follow channel energy ratio" {
    var weights: [i16: 2] = [0: 2];
    try celt_intensity_stereo_weights_q14(3, 4, &weights[0:2]);

    try assert_eq_i32(weights[0] as i32, 9830);
    try assert_eq_i32(weights[1] as i32, 13107);

    try celt_intensity_stereo_weights_q14(0, 0, &weights[0:2]);
    try assert_eq_i32(weights[0] as i32, 11585);
    try assert_eq_i32(weights[1] as i32, 11585);
}

test "celt intensity stereo applies mono shape to channel pair" {
    var mono: [i16: 3] = [32767, -16384, 8192];
    var left: [i16: 3] = [0: 3];
    var right: [i16: 3] = [0: 3];

    try celt_apply_intensity_stereo_q15(&mono[0:3], &left[0:3], &right[0:3], 3, 4);

    try assert_eq_i32(left[0] as i32, 19659);
    try assert_eq_i32(right[0] as i32, 26213);
    try assert_eq_i32(left[1] as i32, -9830);
    try assert_eq_i32(right[1] as i32, -13107);
    try assert_eq_i32(left[2] as i32, 4915);
    try assert_eq_i32(right[2] as i32, 6554);
}

test "celt intensity stereo bands only touch threshold and above" {
    var dims: [i32: 3] = [2, 1, 2];
    var left_energy: [i32: 3] = [1, 3, 0];
    var right_energy: [i32: 3] = [1, 4, 5];
    var mono: [i16: 5] = [111, 222, 32767, 8192, -8192];
    var left: [i16: 5] = [7: 5];
    var right: [i16: 5] = [9: 5];

    try celt_apply_intensity_stereo_bands_q15(
        0,
        3,
        1,
        &dims[0:3],
        &left_energy[0:3],
        &right_energy[0:3],
        &mono[0:5],
        &left[0:5],
        &right[0:5],
    );

    try assert_eq_i32(left[0] as i32, 7);
    try assert_eq_i32(right[0] as i32, 9);
    try assert_eq_i32(left[1] as i32, 7);
    try assert_eq_i32(right[1] as i32, 9);
    try assert_eq_i32(left[2] as i32, 19659);
    try assert_eq_i32(right[2] as i32, 26213);
    try assert_eq_i32(left[3] as i32, 0);
    try assert_eq_i32(right[3] as i32, 8192);
    try assert_eq_i32(left[4] as i32, 0);
    try assert_eq_i32(right[4] as i32, -8192);
}

test "celt anti collapse flag decodes only when frame can use it" {
    var packet: [byte: 8] = [0: 8];
    var enc: EcEnc = EcEnc{};
    ec_enc_init(&enc, &packet[0:8]);
    ec_enc_bits(&enc, 1, 1);
    try ec_enc_check(&enc);
    _ = try ec_enc_done(&enc);

    var dec: EcDec = EcDec{};
    ec_dec_init(&dec, &packet[0:8]);
    try assert(try celt_decode_anti_collapse_flag(&dec, true, 2, 1), "transient LM>1 frame must decode reserved flag");
    try ec_dec_check(&dec);

    var untouched: EcDec = EcDec{};
    ec_dec_init(&untouched, &packet[0:8]);
    try assert(!try celt_decode_anti_collapse_flag(&untouched, false, 2, 1), "non-transient frame must not consume anti-collapse bit");
    try assert(!try celt_decode_anti_collapse_flag(&untouched, true, 1, 1), "LM<=1 frame must not consume anti-collapse bit");
    try assert(!try celt_decode_anti_collapse_flag(&untouched, true, 2, 0), "frame without reserved bit must not decode anti-collapse");
}

test "celt anti collapse injects deterministic minimal energy into collapsed history bands" {
    var dims: [i32: 3] = [2, 3, 1];
    var masks: [u32: 3] = [0, 1, 0];
    var old_loge: [i16: 3] = [10, 10, -9000];
    var old_band_e: [i16: 3] = [0, 0, -9000];
    var shape: [i16: 6] = [0: 6];
    var rng: u32 = 12345;

    const fixed: i32 = try celt_apply_anti_collapse_q15(
        true,
        0,
        3,
        1,
        &dims[0:3],
        &masks[0:3],
        &old_loge[0:3],
        &old_band_e[0:3],
        &shape[0:6],
        &rng,
    );

    try assert_eq_i32(fixed, 1);
    try assert((shape[0] != 0 || shape[1] != 0), "collapsed active-history band must receive one minimal pulse");
    try assert_eq_i32(shape[2] as i32, 0);
    try assert_eq_i32(shape[3] as i32, 0);
    try assert_eq_i32(shape[4] as i32, 0);
    try assert_eq_i32(shape[5] as i32, 0);
}

test "celt anti collapse preserves decoded and disabled bands" {
    var dims: [i32: 2] = [2, 2];
    var masks: [u32: 2] = [0, 0];
    var old_loge: [i16: 2] = [10, 10];
    var old_band_e: [i16: 2] = [0, 0];
    var shape: [i16: 4] = [12, 0, 0, 0];
    var rng: u32 = 7;

    const disabled: i32 = try celt_apply_anti_collapse_q15(
        false,
        0,
        2,
        1,
        &dims[0:2],
        &masks[0:2],
        &old_loge[0:2],
        &old_band_e[0:2],
        &shape[0:4],
        &rng,
    );
    try assert_eq_i32(disabled, 0);
    try assert_eq_i32(shape[0] as i32, 12);
    try assert_eq_i32(shape[2] as i32, 0);

    const fixed: i32 = try celt_apply_anti_collapse_q15(
        true,
        0,
        2,
        1,
        &dims[0:2],
        &masks[0:2],
        &old_loge[0:2],
        &old_band_e[0:2],
        &shape[0:4],
        &rng,
    );
    try assert_eq_i32(fixed, 1);
    try assert_eq_i32(shape[0] as i32, 12);
    try assert((shape[2] != 0 || shape[3] != 0), "only still-collapsed band should be repaired");
}

test "celt band shape decode validates dimensions and buffers" {
    var packet: [byte: 1] = [0];
    var dec: EcDec = EcDec{};
    ec_dec_init(&dec, &packet[0:1]);
    var pulses: [i32: 1] = [0];
    var shape_q15: [i16: 1] = [0];

    const bad_dim: !i32 = celt_decode_band_shape(&dec, 17, 2, &pulses[0:1], &shape_q15[0:1]);
    match bad_dim {
        error.CeltBandsError => {}
        else => { try assert(false, "unsupported PVQ band dimension must fail"); }
    }

    const short_output: !i32 = celt_decode_band_shape(&dec, 2, 2, &pulses[0:1], &shape_q15[0:1]);
    match short_output {
        error.CeltBandsError => {}
        else => { try assert(false, "short PVQ output buffer must fail"); }
    }

    const bad_intensity: !i32 = celt_decode_intensity_start_band(&dec, 5, 4, true);
    match bad_intensity {
        error.CeltBandsError => {}
        else => { try assert(false, "invalid intensity band range must fail"); }
    }

    var weights: [i16: 1] = [0];
    const short_weights: !void = celt_intensity_stereo_weights_q14(1, 1, &weights[0:1]);
    match short_weights {
        error.CeltBandsError => {}
        else => { try assert(false, "short intensity weight output must fail"); }
    }
}
