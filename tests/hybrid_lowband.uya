        try assert(false, "NLSF CB1 helper needs 32 entries");
    }
    var i: usize = 0;
    while i < 32 {
        out.ptr[i] = silk_nlsf_cb1_icdf(SILK_NLSF_CODEBOOK_WB, i);
        i = i + 1;
    }
}

fn hybrid_lowband_test_fill_nlsf_cb2_icdf(out: &[byte], ec_ix: i16) !void {
    if out.len < 9 || ec_ix < 0 {
        try assert(false, "NLSF CB2 helper needs one 9-entry row");
    }
    const base: usize = ec_ix as usize;
    var i: usize = 0;
    while i < 9 {
        out.ptr[i] = silk_nlsf_cb2_icdf(SILK_NLSF_CODEBOOK_WB, base + i);
        i = i + 1;
    }
}

