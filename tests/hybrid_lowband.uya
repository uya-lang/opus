fn assert_i32_slice_eq(actual: &[i32], expected: &[i32]) !void {
    try assert_eq_i32(actual.len as i32, expected.len as i32);
    var i: usize = 0;
    while i < actual.len {
        try assert_eq_i32(actual.ptr[i], expected.ptr[i]);
        i = i + 1;
    }
}

fn hybrid_lowband_packet_info(bandwidth: OpusBandwidth, channels: u8, duration_us: u32) PacketInfo {
    var duration_samples_48k: i32 = 480;
    if duration_us == 20000 {
        duration_samples_48k = 960;
    }
    return PacketInfo{
        mode: OpusMode.HYBRID,
        bandwidth: bandwidth,
        channels: channels,
        frame_count: 1,
        frame_duration_us: duration_us,
        duration_samples_48k: duration_samples_48k,
        payload_offset: 1,
        payload_len: 0,
        self_delimited: false,
        has_padding: false,
    };
}

fn hybrid_lowband_test_fill_type_offset_vad_icdf(out: &[byte]) !void {
    if out.len < 4 {
        try assert(false, "type offset helper needs 4 entries");
    }
    var i: usize = 0;
    while i < 4 {
        out.ptr[i] = silk_type_offset_vad_icdf_value(i);
        i = i + 1;
    }
}

fn hybrid_lowband_test_fill_gain_icdf(out: &[byte]) !void {
    if out.len < 8 {
        try assert(false, "gain helper needs 8 entries");
    }
    var i: usize = 0;
    while i < 8 {
        out.ptr[i] = silk_gain_icdf_value(1, i);
        i = i + 1;
    }
}

