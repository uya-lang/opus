use std.testing.assert;
use std.testing.assert_eq_i32;
use src.opus.api.multistream.MultistreamDecoder;
use src.opus.api.multistream.MultistreamDecoderConfig;
use src.opus.api.multistream.MultistreamPacketSplit;
use src.opus.api.multistream.OPUS_MULTISTREAM_DECODER_STORAGE_WORDS;
use src.opus.api.multistream.OPUS_MULTISTREAM_MAPPING_SILENT;
use src.opus.api.multistream.OPUS_MULTISTREAM_MAX_CHANNELS;
use src.opus.api.multistream.multistream_split_stream_packets;
use src.opus.api.multistream.multistream_decoder_channel_count;
use src.opus.api.multistream.multistream_decoder_coupled_count;
use src.opus.api.multistream.multistream_decoder_config_family0;
use src.opus.api.multistream.multistream_decoder_config_family1;
use src.opus.api.multistream.multistream_decoder_config_family255;
use src.opus.api.multistream.multistream_decoder_init;
use src.opus.api.multistream.multistream_decoder_is_initialized;
use src.opus.api.multistream.multistream_decoder_mapping_at;
use src.opus.api.multistream.multistream_decoder_mapping_family;
use src.opus.api.multistream.multistream_decoder_stream_count;
use src.opus.api.multistream.multistream_validate_decoder_config;

fn stereo_family0_config() MultistreamDecoderConfig {
    var mapping: [u8: OPUS_MULTISTREAM_MAX_CHANNELS] = [0: OPUS_MULTISTREAM_MAX_CHANNELS];
    mapping[0] = 0;
    mapping[1] = 1;
    return MultistreamDecoderConfig{
        sample_rate_hz: 48000,
        channel_count: 2,
        stream_count: 1,
        coupled_count: 1,
        mapping_family: 0,
        mapping: mapping,
    };
}

fn assert_family1_layout(channel_count: u8, stream_count: u8, coupled_count: u8, expected_mapping: &[const u8]) !void {
    const config: MultistreamDecoderConfig = try multistream_decoder_config_family1(48000, channel_count);
    try assert_eq_i32(config.channel_count as i32, channel_count as i32);
    try assert_eq_i32(config.stream_count as i32, stream_count as i32);
    try assert_eq_i32(config.coupled_count as i32, coupled_count as i32);
    try assert_eq_i32(config.mapping_family as i32, 1);

    var i: usize = 0;
    while i < expected_mapping.len {
        try assert_eq_i32(config.mapping[i] as i32, expected_mapping.ptr[i] as i32);
        i = i + 1;
    }
}

test "multistream decoder init stores stream layout metadata" {
    var decoder: MultistreamDecoder = MultistreamDecoder{};
    var config: MultistreamDecoderConfig = stereo_family0_config();

    try multistream_decoder_init(&decoder, &config);

    try assert(multistream_decoder_is_initialized(&decoder), "multistream decoder must record initialization");
    try assert_eq_i32(multistream_decoder_channel_count(&decoder) as i32, 2);
    try assert_eq_i32(multistream_decoder_stream_count(&decoder) as i32, 1);
    try assert_eq_i32(multistream_decoder_coupled_count(&decoder) as i32, 1);
    try assert_eq_i32(multistream_decoder_mapping_family(&decoder) as i32, 0);
    try assert_eq_i32((try multistream_decoder_mapping_at(&decoder, 0)) as i32, 0);
    try assert_eq_i32((try multistream_decoder_mapping_at(&decoder, 1)) as i32, 1);
}

test "multistream decoder config validates counts and mapping bounds" {
    var config: MultistreamDecoderConfig = stereo_family0_config();
    try multistream_validate_decoder_config(&config);

    config.stream_count = 0;
    const no_streams: !void = multistream_validate_decoder_config(&config);
    match no_streams {
        error.MultistreamApiError => {}
        else => { try assert(false, "zero stream count must be rejected"); }
    }

    config = stereo_family0_config();
    config.coupled_count = 2;
    const too_many_coupled: !void = multistream_validate_decoder_config(&config);
    match too_many_coupled {
        error.MultistreamApiError => {}
        else => { try assert(false, "coupled count cannot exceed stream count"); }
    }

    config = stereo_family0_config();
    config.mapping[1] = 2;
    const bad_mapping: !void = multistream_validate_decoder_config(&config);
    match bad_mapping {
        error.MultistreamApiError => {}
        else => { try assert(false, "mapping must stay within decoded channel count"); }
    }
}

test "multistream decoder accepts silent mapped output channels" {
    var config: MultistreamDecoderConfig = stereo_family0_config();
    config.mapping[1] = OPUS_MULTISTREAM_MAPPING_SILENT;
    try multistream_validate_decoder_config(&config);

    var decoder: MultistreamDecoder = MultistreamDecoder{};
    try multistream_decoder_init(&decoder, &config);
    try assert_eq_i32((try multistream_decoder_mapping_at(&decoder, 1)) as i32, OPUS_MULTISTREAM_MAPPING_SILENT as i32);
}

test "multistream decoder metadata storage is not sized for max decoder slots" {
    try assert(OPUS_MULTISTREAM_DECODER_STORAGE_WORDS < 1024, "metadata storage must stay small until caller-provided decoder slots are implemented");
}

test "mapping family 0 config derives mono and stereo layouts" {
    const mono: MultistreamDecoderConfig = try multistream_decoder_config_family0(48000, 1);
    try assert_eq_i32(mono.channel_count as i32, 1);
    try assert_eq_i32(mono.stream_count as i32, 1);
    try assert_eq_i32(mono.coupled_count as i32, 0);
    try assert_eq_i32(mono.mapping_family as i32, 0);
    try assert_eq_i32(mono.mapping[0] as i32, 0);

    const stereo: MultistreamDecoderConfig = try multistream_decoder_config_family0(48000, 2);
    try assert_eq_i32(stereo.channel_count as i32, 2);
    try assert_eq_i32(stereo.stream_count as i32, 1);
    try assert_eq_i32(stereo.coupled_count as i32, 1);
    try assert_eq_i32(stereo.mapping_family as i32, 0);
    try assert_eq_i32(stereo.mapping[0] as i32, 0);
    try assert_eq_i32(stereo.mapping[1] as i32, 1);
}

test "mapping family 0 rejects unsupported layout inputs" {
    const zero_channels: !MultistreamDecoderConfig = multistream_decoder_config_family0(48000, 0);
    match zero_channels {
        error.MultistreamApiError => {}
        else => { try assert(false, "family 0 must reject zero channels"); }
    }

    const too_many_channels: !MultistreamDecoderConfig = multistream_decoder_config_family0(48000, 3);
    match too_many_channels {
        error.MultistreamApiError => {}
        else => { try assert(false, "family 0 only supports mono and stereo"); }
    }

    const bad_rate: !MultistreamDecoderConfig = multistream_decoder_config_family0(44100, 2);
    match bad_rate {
        error.MultistreamApiError => {}
        else => { try assert(false, "family 0 must validate Opus API sample rates"); }
    }
}

test "mapping family 1 derives Vorbis-order surround layouts" {
    const map1: [u8: 1] = [0];
    const map2: [u8: 2] = [0, 1];
    const map3: [u8: 3] = [0, 2, 1];
    const map4: [u8: 4] = [0, 1, 2, 3];
    const map5: [u8: 5] = [0, 4, 1, 2, 3];
    const map6: [u8: 6] = [0, 4, 1, 2, 3, 5];
    const map7: [u8: 7] = [0, 4, 1, 2, 3, 5, 6];
    const map8: [u8: 8] = [0, 6, 1, 2, 3, 4, 5, 7];

    try assert_family1_layout(1, 1, 0, &map1[0:1]);
    try assert_family1_layout(2, 1, 1, &map2[0:2]);
    try assert_family1_layout(3, 2, 1, &map3[0:3]);
    try assert_family1_layout(4, 2, 2, &map4[0:4]);
    try assert_family1_layout(5, 3, 2, &map5[0:5]);
    try assert_family1_layout(6, 4, 2, &map6[0:6]);
    try assert_family1_layout(7, 4, 3, &map7[0:7]);
    try assert_family1_layout(8, 5, 3, &map8[0:8]);
}

test "mapping family 1 rejects unsupported layout inputs" {
    const zero_channels: !MultistreamDecoderConfig = multistream_decoder_config_family1(48000, 0);
    match zero_channels {
        error.MultistreamApiError => {}
        else => { try assert(false, "family 1 must reject zero channels"); }
    }

    const too_many_channels: !MultistreamDecoderConfig = multistream_decoder_config_family1(48000, 9);
    match too_many_channels {
        error.MultistreamApiError => {}
        else => { try assert(false, "family 1 only supports one through eight channels"); }
    }

    const bad_rate: !MultistreamDecoderConfig = multistream_decoder_config_family1(44100, 6);
    match bad_rate {
        error.MultistreamApiError => {}
        else => { try assert(false, "family 1 must validate Opus API sample rates"); }
    }
}

test "mapping family 255 copies explicit channel mappings" {
    const identity: [u8: 3] = [0, 1, 2];
    const config: MultistreamDecoderConfig = try multistream_decoder_config_family255(48000, 3, 3, 0, &identity[0:3]);
    try assert_eq_i32(config.channel_count as i32, 3);
    try assert_eq_i32(config.stream_count as i32, 3);
    try assert_eq_i32(config.coupled_count as i32, 0);
    try assert_eq_i32(config.mapping_family as i32, 255);
    try assert_eq_i32(config.mapping[0] as i32, 0);
    try assert_eq_i32(config.mapping[1] as i32, 1);
    try assert_eq_i32(config.mapping[2] as i32, 2);
}

test "mapping family 255 accepts silent and coupled explicit layouts" {
    const explicit_map: [u8: 4] = [0, OPUS_MULTISTREAM_MAPPING_SILENT, 1, 2];
    const config: MultistreamDecoderConfig = try multistream_decoder_config_family255(48000, 4, 2, 1, &explicit_map[0:4]);
    try assert_eq_i32(config.channel_count as i32, 4);
    try assert_eq_i32(config.stream_count as i32, 2);
    try assert_eq_i32(config.coupled_count as i32, 1);
    try assert_eq_i32(config.mapping[0] as i32, 0);
    try assert_eq_i32(config.mapping[1] as i32, OPUS_MULTISTREAM_MAPPING_SILENT as i32);
    try assert_eq_i32(config.mapping[2] as i32, 1);
    try assert_eq_i32(config.mapping[3] as i32, 2);
}

test "mapping family 255 rejects malformed explicit layouts" {
    const short_map: [u8: 1] = [0];
    const too_short: !MultistreamDecoderConfig = multistream_decoder_config_family255(48000, 2, 2, 0, &short_map[0:1]);
    match too_short {
        error.MultistreamApiError => {}
        else => { try assert(false, "family 255 mapping slice must cover all output channels"); }
    }

    const bad_mapping: [u8: 2] = [0, 1];
    const out_of_range: !MultistreamDecoderConfig = multistream_decoder_config_family255(48000, 2, 1, 0, &bad_mapping[0:2]);
    match out_of_range {
        error.MultistreamApiError => {}
        else => { try assert(false, "family 255 mapping values must fit decoded channel count"); }
    }

    const good_map: [u8: 1] = [0];
    const zero_channels: !MultistreamDecoderConfig = multistream_decoder_config_family255(48000, 0, 1, 0, &good_map[0:1]);
    match zero_channels {
        error.MultistreamApiError => {}
        else => { try assert(false, "family 255 must reject zero output channels"); }
    }

    const bad_rate: !MultistreamDecoderConfig = multistream_decoder_config_family255(44100, 1, 1, 0, &good_map[0:1]);
    match bad_rate {
        error.MultistreamApiError => {}
        else => { try assert(false, "family 255 must validate Opus API sample rates"); }
    }
}

test "multistream packet split reads self-delimited code0 stream packets" {
    const packet: [byte: 8] = [128, 2, 1, 2, 128, 3, 4, 5];
    var split: MultistreamPacketSplit = MultistreamPacketSplit{};
    try multistream_split_stream_packets(&packet[0:8], 2, &split);

    try assert_eq_i32(split.stream_count as i32, 2);
    try assert_eq_i32(split.streams[0].offset as i32, 0);
    try assert_eq_i32(split.streams[0].len as i32, 4);
    try assert_eq_i32(split.streams[1].offset as i32, 4);
    try assert_eq_i32(split.streams[1].len as i32, 4);
}

test "multistream packet split reads self-delimited CBR stream packets" {
    const packet: [byte: 9] = [129, 2, 10, 11, 12, 13, 128, 1, 99];
    var split: MultistreamPacketSplit = MultistreamPacketSplit{};
    try multistream_split_stream_packets(&packet[0:9], 2, &split);

    try assert_eq_i32(split.streams[0].offset as i32, 0);
    try assert_eq_i32(split.streams[0].len as i32, 6);
    try assert_eq_i32(split.streams[1].offset as i32, 6);
    try assert_eq_i32(split.streams[1].len as i32, 3);
}

test "multistream packet split reads self-delimited VBR stream packets" {
    const code2_packet: [byte: 9] = [130, 2, 1, 10, 11, 12, 128, 1, 99];
    var split: MultistreamPacketSplit = MultistreamPacketSplit{};
    try multistream_split_stream_packets(&code2_packet[0:9], 2, &split);

    try assert_eq_i32(split.streams[0].offset as i32, 0);
    try assert_eq_i32(split.streams[0].len as i32, 6);
    try assert_eq_i32(split.streams[1].offset as i32, 6);
    try assert_eq_i32(split.streams[1].len as i32, 3);

    const code3_packet: [byte: 10] = [131, 130, 2, 1, 10, 11, 12, 128, 1, 99];
    try multistream_split_stream_packets(&code3_packet[0:10], 2, &split);

    try assert_eq_i32(split.streams[0].offset as i32, 0);
    try assert_eq_i32(split.streams[0].len as i32, 7);
    try assert_eq_i32(split.streams[1].offset as i32, 7);
    try assert_eq_i32(split.streams[1].len as i32, 3);
}

test "multistream packet split rejects malformed stream framing" {
    const packet: [byte: 4] = [128, 5, 1, 2];
    var split: MultistreamPacketSplit = MultistreamPacketSplit{};
    const truncated: !void = multistream_split_stream_packets(&packet[0:4], 2, &split);
    match truncated {
        error.MultistreamApiError => {}
        else => { try assert(false, "self-delimited stream length must fit available data"); }
    }

    const no_streams: !void = multistream_split_stream_packets(&packet[0:4], 0, &split);
    match no_streams {
        error.MultistreamApiError => {}
        else => { try assert(false, "split helper must reject zero streams"); }
    }
}
