export const OGG_OPUS_CAPTURE_PATTERN_LEN: usize = 4;
const OGG_OPUS_CAPTURE_PATTERN: [byte: 4] = [79, 103, 103, 83];

export const OGG_OPUS_STREAM_VERSION: u8 = 0;
export const OGG_OPUS_PAGE_HEADER_LEN: usize = 27;
export const OGG_OPUS_MAX_PAGE_SEGMENTS: usize = 255;
export const OGG_OPUS_MAX_LACING_VALUE: u8 = 255;
export const OGG_OPUS_CRC_OFFSET: usize = 22;
export const OGG_OPUS_CRC_LEN: usize = 4;

export const OGG_OPUS_HEADER_TYPE_CONTINUED_PACKET: u8 = 1;
export const OGG_OPUS_HEADER_TYPE_BOS: u8 = 2;
export const OGG_OPUS_HEADER_TYPE_EOS: u8 = 4;

export const OPUS_HEAD_MAGIC_LEN: usize = 8;
const OPUS_HEAD_MAGIC: [byte: 8] = [79, 112, 117, 115, 72, 101, 97, 100];
export const OPUS_HEAD_VERSION: u8 = 1;
export const OPUS_HEAD_MIN_LEN: usize = 19;
export const OPUS_HEAD_MAPPING_TABLE_OFFSET: usize = 21;
export const OPUS_HEAD_MAX_CHANNELS: usize = 255;
export const OPUS_HEAD_VERSION_OFFSET: usize = 8;
export const OPUS_HEAD_CHANNELS_OFFSET: usize = 9;
export const OPUS_HEAD_PRE_SKIP_OFFSET: usize = 10;
export const OPUS_HEAD_INPUT_SAMPLE_RATE_OFFSET: usize = 12;
export const OPUS_HEAD_OUTPUT_GAIN_OFFSET: usize = 16;
export const OPUS_HEAD_MAPPING_FAMILY_OFFSET: usize = 18;
export const OPUS_HEAD_MAPPING_FAMILY_0: u8 = 0;
export const OPUS_HEAD_MAPPING_FAMILY_1: u8 = 1;
export const OPUS_HEAD_MAPPING_SILENT: u8 = 255;

export const OPUS_TAGS_MAGIC_LEN: usize = 8;
const OPUS_TAGS_MAGIC: [byte: 8] = [79, 112, 117, 115, 84, 97, 103, 115];
export const OPUS_TAGS_MIN_LEN: usize = 16;
export const OPUS_TAGS_VENDOR_LEN_OFFSET: usize = 8;
export const OPUS_TAGS_VENDOR_OFFSET: usize = 12;
export const OPUS_TAGS_MAX_COMMENTS: usize = 128;

const OPUS_TAGS_U32_MAX_AS_USIZE: usize = 4294967295;

export error InvalidCapturePattern;
export error UnsupportedOggVersion;
export error UnsupportedOpusHeadVersion;
export error InvalidHeader;
export error InvalidTags;
export error InvalidPage;
export error InvalidCrc;
export error TruncatedHeader;
export error TruncatedTags;
export error TruncatedPage;
export error TooManySegments;
export error TooManyComments;
export error InvalidGranulePosition;
export error MissingOpusHead;
export error MissingOpusTags;
export error ChainedStreamUnsupported;

export struct OggOpusStreamState {
    serial: u32,
    next_sequence: u32,
    last_granule_position: i64,
    seen_bos: bool,
    seen_eos: bool,
    has_continued_packet: bool,
}

export struct OpusHead {
    version: u8,
    channel_count: u8,
    pre_skip: u16,
    input_sample_rate_hz: u32,
    output_gain_q8: i16,
    mapping_family: u8,
    stream_count: u8,
    coupled_count: u8,
    has_mapping_table: bool,
    channel_mapping: [u8: OPUS_HEAD_MAX_CHANNELS],
}

export struct OggOpusSpan {
    offset: usize,
    len: usize,
}

export struct OpusTags {
    vendor: OggOpusSpan,
    comment_count: u32,
    comments: [OggOpusSpan: OPUS_TAGS_MAX_COMMENTS],
    trailing: OggOpusSpan,
}

export fn ogg_opus_stream_state_default(serial: u32) OggOpusStreamState {
    return OggOpusStreamState{
        serial: serial,
        next_sequence: 0,
        last_granule_position: -1,
        seen_bos: false,
        seen_eos: false,
        has_continued_packet: false,
    };
}

export fn ogg_opus_capture_pattern_byte(index: usize) byte {
    if index < OGG_OPUS_CAPTURE_PATTERN_LEN {
        return OGG_OPUS_CAPTURE_PATTERN[index];
    }
    return 0;
}

export fn opus_head_magic_byte(index: usize) byte {
    if index < OPUS_HEAD_MAGIC_LEN {
        return OPUS_HEAD_MAGIC[index];
    }
    return 0;
}

export fn opus_tags_magic_byte(index: usize) byte {
    if index < OPUS_TAGS_MAGIC_LEN {
        return OPUS_TAGS_MAGIC[index];
    }
    return 0;
}

export fn ogg_opus_validate_page_version(version: u8) !void {
    if version == OGG_OPUS_STREAM_VERSION {
        return;
    }
    return error.UnsupportedOggVersion;
}

fn opus_head_read_le_u16(packet: &[byte], offset: usize) u16 {
    return (packet.ptr[offset] as u16) | ((packet.ptr[offset + 1] as u16) << 8);
}

fn opus_head_read_le_u32(packet: &[byte], offset: usize) u32 {
    return (packet.ptr[offset] as u32)
        | ((packet.ptr[offset + 1] as u32) << 8)
        | ((packet.ptr[offset + 2] as u32) << 16)
        | ((packet.ptr[offset + 3] as u32) << 24);
}

fn opus_head_read_le_i16(packet: &[byte], offset: usize) i16 {
    const value: u16 = opus_head_read_le_u16(packet, offset);
    if value >= 32768 {
        return ((value as i32) - 65536) as i16;
    }
    return value as i16;
}

fn opus_head_write_le_u16(out: &[byte], offset: usize, value: u16) void {
    out.ptr[offset] = (value & (255 as u16)) as byte;
    out.ptr[offset + 1] = ((value >> 8) & (255 as u16)) as byte;
}

fn opus_head_write_le_u32(out: &[byte], offset: usize, value: u32) void {
    out.ptr[offset] = (value & (255 as u32)) as byte;
    out.ptr[offset + 1] = ((value >> 8) & (255 as u32)) as byte;
    out.ptr[offset + 2] = ((value >> 16) & (255 as u32)) as byte;
    out.ptr[offset + 3] = ((value >> 24) & (255 as u32)) as byte;
}

fn opus_head_i16_to_u16(value: i16) u16 {
    const wide: i32 = value as i32;
    if wide < 0 {
        return (wide + 65536) as u16;
    }
    return wide as u16;
}

fn opus_head_write_le_i16(out: &[byte], offset: usize, value: i16) void {
    opus_head_write_le_u16(out, offset, opus_head_i16_to_u16(value));
}

fn opus_head_magic_matches(packet: &[byte]) bool {
    var i: usize = 0;
    while i < OPUS_HEAD_MAGIC_LEN {
        if packet.ptr[i] != OPUS_HEAD_MAGIC[i] {
            return false;
        }
        i = i + 1;
    }
    return true;
}

fn opus_head_clear_mapping(mapping: &[u8]) void {
    var i: usize = 0;
    while i < mapping.len {
        mapping.ptr[i] = OPUS_HEAD_MAPPING_SILENT;
        i = i + 1;
    }
}

fn opus_head_mapping_required_len(channel_count: u8) usize {
    return OPUS_HEAD_MAPPING_TABLE_OFFSET + (channel_count as usize);
}

fn opus_head_validate_version(version: u8) !void {
    if (version & (240 as u8)) == 0 {
        return;
    }
    return error.UnsupportedOpusHeadVersion;
}

fn opus_head_validate_mapped_channels(mapping_family: u8, channel_count: u8) !void {
    if channel_count == 0 {
        return error.InvalidHeader;
    }
    if mapping_family == OPUS_HEAD_MAPPING_FAMILY_0 {
        if channel_count > 2 {
            return error.InvalidHeader;
        }
        return;
    }
    if mapping_family == OPUS_HEAD_MAPPING_FAMILY_1 && channel_count > 8 {
        return error.InvalidHeader;
    }
}

fn opus_head_validate_mapping_values(head: &const OpusHead) !void {
    if head.stream_count == 0 {
        return error.InvalidHeader;
    }
    if head.coupled_count > head.stream_count {
        return error.InvalidHeader;
    }

    const decoded_channels: u16 = (head.stream_count as u16) + (head.coupled_count as u16);
    if decoded_channels == 0 || decoded_channels > OPUS_HEAD_MAX_CHANNELS as u16 {
        return error.InvalidHeader;
    }

    var i: usize = 0;
    while i < head.channel_count as usize {
        const mapped: u8 = head.channel_mapping[i];
        if mapped != OPUS_HEAD_MAPPING_SILENT && (mapped as u16) >= decoded_channels {
            return error.InvalidHeader;
        }
        i = i + 1;
    }
}

export fn ogg_opus_head_encoded_len(head: &const OpusHead) !usize {
    try opus_head_validate_version(head.version);
    try opus_head_validate_mapped_channels(head.mapping_family, head.channel_count);

    if head.mapping_family == OPUS_HEAD_MAPPING_FAMILY_0 {
        if head.has_mapping_table {
            return error.InvalidHeader;
        }
        if head.stream_count != 1 {
            return error.InvalidHeader;
        }
        if head.channel_count == 1 && head.coupled_count != 0 {
            return error.InvalidHeader;
        }
        if head.channel_count == 2 && head.coupled_count != 1 {
            return error.InvalidHeader;
        }
        return OPUS_HEAD_MIN_LEN;
    }

    if !head.has_mapping_table {
        return error.InvalidHeader;
    }
    try opus_head_validate_mapping_values(head);
    return opus_head_mapping_required_len(head.channel_count);
}

export fn ogg_opus_parse_head(packet: &[byte], head: &OpusHead) !void {
    if packet.len < OPUS_HEAD_MIN_LEN {
        return error.TruncatedHeader;
    }
    if !opus_head_magic_matches(packet) {
        return error.InvalidHeader;
    }

    const version: u8 = packet.ptr[OPUS_HEAD_VERSION_OFFSET];
    try opus_head_validate_version(version);

    const channel_count: u8 = packet.ptr[OPUS_HEAD_CHANNELS_OFFSET];
    const mapping_family: u8 = packet.ptr[OPUS_HEAD_MAPPING_FAMILY_OFFSET];
    try opus_head_validate_mapped_channels(mapping_family, channel_count);

    var mapping: [u8: OPUS_HEAD_MAX_CHANNELS] = [0: OPUS_HEAD_MAX_CHANNELS];
    opus_head_clear_mapping(&mapping[0:OPUS_HEAD_MAX_CHANNELS]);

    var stream_count: u8 = 1;
    var coupled_count: u8 = 0;
    var has_mapping_table: bool = false;

    if mapping_family == OPUS_HEAD_MAPPING_FAMILY_0 {
        if version == OPUS_HEAD_VERSION && packet.len != OPUS_HEAD_MIN_LEN {
            return error.InvalidHeader;
        }
        mapping[0] = 0;
        if channel_count == 2 {
            coupled_count = 1;
            mapping[1] = 1;
        }
    } else {
        const required_len: usize = opus_head_mapping_required_len(channel_count);
        if packet.len < required_len {
            return error.TruncatedHeader;
        }
        if version == OPUS_HEAD_VERSION && packet.len != required_len {
            return error.InvalidHeader;
        }

        stream_count = packet.ptr[19];
        coupled_count = packet.ptr[20];
        if stream_count == 0 {
            return error.InvalidHeader;
        }
        if coupled_count > stream_count {
            return error.InvalidHeader;
        }

        const decoded_channels: u16 = (stream_count as u16) + (coupled_count as u16);
        if decoded_channels == 0 || decoded_channels > OPUS_HEAD_MAX_CHANNELS as u16 {
            return error.InvalidHeader;
        }

        var i: usize = 0;
        while i < channel_count as usize {
            const mapped: u8 = packet.ptr[OPUS_HEAD_MAPPING_TABLE_OFFSET + i];
            if mapped != OPUS_HEAD_MAPPING_SILENT && (mapped as u16) >= decoded_channels {
                return error.InvalidHeader;
            }
            mapping[i] = mapped;
            i = i + 1;
        }
        has_mapping_table = true;
    }

    *head = OpusHead{
        version: version,
        channel_count: channel_count,
        pre_skip: opus_head_read_le_u16(packet, OPUS_HEAD_PRE_SKIP_OFFSET),
        input_sample_rate_hz: opus_head_read_le_u32(packet, OPUS_HEAD_INPUT_SAMPLE_RATE_OFFSET),
        output_gain_q8: opus_head_read_le_i16(packet, OPUS_HEAD_OUTPUT_GAIN_OFFSET),
        mapping_family: mapping_family,
        stream_count: stream_count,
        coupled_count: coupled_count,
        has_mapping_table: has_mapping_table,
        channel_mapping: mapping,
    };
}

export fn ogg_opus_write_head(head: &const OpusHead, out: &[byte]) !usize {
    const encoded_len: usize = try ogg_opus_head_encoded_len(head);
    if out.len < encoded_len {
        return error.TruncatedHeader;
    }

    var i: usize = 0;
    while i < OPUS_HEAD_MAGIC_LEN {
        out.ptr[i] = OPUS_HEAD_MAGIC[i];
        i = i + 1;
    }

    out.ptr[OPUS_HEAD_VERSION_OFFSET] = head.version;
    out.ptr[OPUS_HEAD_CHANNELS_OFFSET] = head.channel_count;
    opus_head_write_le_u16(out, OPUS_HEAD_PRE_SKIP_OFFSET, head.pre_skip);
    opus_head_write_le_u32(out, OPUS_HEAD_INPUT_SAMPLE_RATE_OFFSET, head.input_sample_rate_hz);
    opus_head_write_le_i16(out, OPUS_HEAD_OUTPUT_GAIN_OFFSET, head.output_gain_q8);
    out.ptr[OPUS_HEAD_MAPPING_FAMILY_OFFSET] = head.mapping_family;

    if head.mapping_family != OPUS_HEAD_MAPPING_FAMILY_0 {
        out.ptr[19] = head.stream_count;
        out.ptr[20] = head.coupled_count;
        var channel: usize = 0;
        while channel < head.channel_count as usize {
            out.ptr[OPUS_HEAD_MAPPING_TABLE_OFFSET + channel] = head.channel_mapping[channel];
            channel = channel + 1;
        }
    }

    return encoded_len;
}

fn opus_tags_magic_matches(packet: &[byte]) bool {
    var i: usize = 0;
    while i < OPUS_TAGS_MAGIC_LEN {
        if packet.ptr[i] != OPUS_TAGS_MAGIC[i] {
            return false;
        }
        i = i + 1;
    }
    return true;
}

fn opus_tags_require_range(packet_len: usize, offset: usize, len: usize) !void {
    if offset > packet_len {
        return error.TruncatedTags;
    }
    if len > packet_len - offset {
        return error.TruncatedTags;
    }
}

export fn ogg_opus_parse_tags(packet: &[byte], tags: &OpusTags) !void {
    if packet.len < OPUS_TAGS_VENDOR_OFFSET {
        return error.TruncatedTags;
    }
    if !opus_tags_magic_matches(packet) {
        return error.InvalidTags;
    }

    const vendor_len: usize = opus_head_read_le_u32(packet, OPUS_TAGS_VENDOR_LEN_OFFSET) as usize;
    try opus_tags_require_range(packet.len, OPUS_TAGS_VENDOR_OFFSET, vendor_len);

    const comment_count_offset: usize = OPUS_TAGS_VENDOR_OFFSET + vendor_len;
    try opus_tags_require_range(packet.len, comment_count_offset, 4);
    const comment_count: u32 = opus_head_read_le_u32(packet, comment_count_offset);
    if comment_count as usize > OPUS_TAGS_MAX_COMMENTS {
        return error.TooManyComments;
    }

    var parsed: OpusTags = OpusTags{};
    parsed.vendor = OggOpusSpan{ offset: OPUS_TAGS_VENDOR_OFFSET, len: vendor_len };
    parsed.comment_count = comment_count;

    var cursor: usize = comment_count_offset + 4;
    var comment_index: usize = 0;
    while comment_index < comment_count as usize {
        try opus_tags_require_range(packet.len, cursor, 4);
        const comment_len: usize = opus_head_read_le_u32(packet, cursor) as usize;
        cursor = cursor + 4;
        try opus_tags_require_range(packet.len, cursor, comment_len);
        parsed.comments[comment_index] = OggOpusSpan{ offset: cursor, len: comment_len };
        cursor = cursor + comment_len;
        comment_index = comment_index + 1;
    }

    parsed.trailing = OggOpusSpan{ offset: cursor, len: packet.len - cursor };
    *tags = parsed;
}

fn opus_tags_validate_field_len(len: usize) !void {
    if len > OPUS_TAGS_U32_MAX_AS_USIZE {
        return error.InvalidTags;
    }
}

fn opus_tags_validate_source_span(source_len: usize, span: &const OggOpusSpan) !void {
    if span.offset > source_len {
        return error.InvalidTags;
    }
    if span.len > source_len - span.offset {
        return error.InvalidTags;
    }
}

fn opus_tags_copy_span(source: &[byte], span: &const OggOpusSpan, out: &[byte], cursor: &usize) void {
    var i: usize = 0;
    while i < span.len {
        out.ptr[*cursor + i] = source.ptr[span.offset + i];
        i = i + 1;
    }
    *cursor = *cursor + span.len;
}

export fn ogg_opus_tags_encoded_len(tags: &const OpusTags) !usize {
    if tags.comment_count as usize > OPUS_TAGS_MAX_COMMENTS {
        return error.TooManyComments;
    }
    try opus_tags_validate_field_len(tags.vendor.len);

    var total: usize = OPUS_TAGS_MAGIC_LEN + 4 + tags.vendor.len + 4;
    var comment_index: usize = 0;
    while comment_index < tags.comment_count as usize {
        const len: usize = tags.comments[comment_index].len;
        try opus_tags_validate_field_len(len);
        total = total + 4 + len;
        comment_index = comment_index + 1;
    }

    return total;
}

export fn ogg_opus_write_tags(tags: &const OpusTags, source: &[byte], out: &[byte]) !usize {
    const encoded_len: usize = try ogg_opus_tags_encoded_len(tags);
    if out.len < encoded_len {
        return error.TruncatedTags;
    }

    try opus_tags_validate_source_span(source.len, &tags.vendor);
    var comment_index: usize = 0;
    while comment_index < tags.comment_count as usize {
        try opus_tags_validate_source_span(source.len, &tags.comments[comment_index]);
        comment_index = comment_index + 1;
    }

    var cursor: usize = 0;
    var magic_index: usize = 0;
    while magic_index < OPUS_TAGS_MAGIC_LEN {
        out.ptr[cursor] = OPUS_TAGS_MAGIC[magic_index];
        cursor = cursor + 1;
        magic_index = magic_index + 1;
    }

    opus_head_write_le_u32(out, cursor, tags.vendor.len as u32);
    cursor = cursor + 4;
    opus_tags_copy_span(source, &tags.vendor, out, &cursor);

    opus_head_write_le_u32(out, cursor, tags.comment_count);
    cursor = cursor + 4;
    comment_index = 0;
    while comment_index < tags.comment_count as usize {
        const comment: &const OggOpusSpan = &tags.comments[comment_index];
        opus_head_write_le_u32(out, cursor, comment.len as u32);
        cursor = cursor + 4;
        opus_tags_copy_span(source, comment, out, &cursor);
        comment_index = comment_index + 1;
    }

    return encoded_len;
}
