    81, 5, 11, 3, 7,
    2, 0, 9, 10, 88,
];

fn smulww_i32(a: i32, b: i32) i32 {
    return (((a as i64) * (b as i64)) >> 16) as i32;
}

fn smulwb_i32(a: i32, b: i16) i32 {
    return (((a as i64) * (b as i64)) >> 16) as i32;
}

fn silk_ltp_codebook_size(periodicity_index: i32) i32 {
    if periodicity_index == 0 { return 8; }
    if periodicity_index == 1 { return 16; }
    if periodicity_index == 2 { return 32; }
    return 0;
}

fn silk_ltp_hash_value(table: i32, index: usize) u64 {
    if table == 0 { return SILK_LTP_PER_INDEX_ICDF[index] as u64; }
    if table == 1 { return SILK_LTP_GAIN_ICDF_0[index] as u64; }
    if table == 2 { return SILK_LTP_GAIN_ICDF_1[index] as u64; }
    if table == 3 { return SILK_LTP_GAIN_ICDF_2[index] as u64; }
    if table == 4 { return SILK_LTP_VQ_0_Q7[index] as u64; }
    if table == 5 { return SILK_LTP_VQ_1_Q7[index] as u64; }
    if table == 6 { return SILK_LTP_VQ_2_Q7[index] as u64; }
    return 0;
}

export fn silk_ltp_table_len(table: i32) usize {
    if table == 0 { return 3; }
    if table == 1 { return 8; }
    if table == 2 { return 16; }
    if table == 3 { return 32; }
    if table == 4 { return 40; }
    if table == 5 { return 80; }
    if table == 6 { return 160; }
    return 0 as usize;
}

export fn silk_ltp_table_hash(table: i32) u32 {
    const len: usize = silk_ltp_table_len(table);
    var offset: u64 = 0;
    if table >= 4 && table <= 6 {
        offset = 32768;
    }
    const mod: u64 = 1000000007;
    var h: u64 = (2166136261 as u64) % mod;
    var i: usize = 0;
    while i < len {
        h = (h * (131 as u64) + silk_ltp_hash_value(table, i) + offset + (1 as u64)) % mod;
        i = i + 1;
    }
    return h as u32;
}

export fn silk_ltp_per_index_icdf_value(index: usize) byte {
    if index >= 3 {
        return 0;
    }
    return SILK_LTP_PER_INDEX_ICDF[index];
}

export fn silk_ltp_gain_icdf_value(periodicity_index: i32, index: usize) byte {
    if periodicity_index == 0 && index < 8 { return SILK_LTP_GAIN_ICDF_0[index]; }
    if periodicity_index == 1 && index < 16 { return SILK_LTP_GAIN_ICDF_1[index]; }
    if periodicity_index == 2 && index < 32 { return SILK_LTP_GAIN_ICDF_2[index]; }
    return 0;
}

export fn silk_ltp_vq_q7(periodicity_index: i32, codebook_index: i32, tap: i32) i16 {
    const size: i32 = silk_ltp_codebook_size(periodicity_index);
    if size == 0 || codebook_index < 0 || codebook_index >= size || tap < 0 || tap >= (SILK_LTP_ORDER as i32) {
        return 0;
    }
    const index: usize = ((codebook_index as usize) * SILK_LTP_ORDER) + (tap as usize);
    if periodicity_index == 0 { return SILK_LTP_VQ_0_Q7[index]; }
    if periodicity_index == 1 { return SILK_LTP_VQ_1_Q7[index]; }
    return SILK_LTP_VQ_2_Q7[index];
}

fn fill_ltp_gain_icdf(out: &[byte], periodicity_index: i32) !void {
    const size: i32 = silk_ltp_codebook_size(periodicity_index);
    if size == 0 || out.len < (size as usize) {
        return error.SilkLtpError;
    }
    var i: usize = 0;
    while i < (size as usize) {
        out.ptr[i] = silk_ltp_gain_icdf_value(periodicity_index, i);
        i = i + 1;
    }
}

export fn silk_ltp_decode_codebook_vector_q14(out_q14: &[i16], periodicity_index: i32, codebook_index: i32) !void {
    const size: i32 = silk_ltp_codebook_size(periodicity_index);
    if size == 0 || codebook_index < 0 || codebook_index >= size || out_q14.len < SILK_LTP_ORDER {
        return error.SilkLtpError;
    }

    var tap: usize = 0;
    while tap < SILK_LTP_ORDER {
        out_q14.ptr[tap] = ((silk_ltp_vq_q7(periodicity_index, codebook_index, tap as i32) as i32) << 7) as i16;
        tap = tap + 1;
    }
}

export fn silk_ltp_validate_fs_khz(fs_khz: i32) !void {
    if fs_khz == 8 || fs_khz == 12 || fs_khz == 16 {
        return;
    }
    return error.SilkLtpError;
}

export fn silk_ltp_validate_pitch_lag(fs_khz: i32, pitch_lag: i32) !void {
    try silk_ltp_validate_fs_khz(fs_khz);
    const min_lag: i32 = SILK_MIN_PITCH_LAG_MS * fs_khz;
    const max_lag: i32 = SILK_MAX_PITCH_LAG_MS * fs_khz;
    if pitch_lag < min_lag || pitch_lag > max_lag {
        return error.SilkLtpError;
    }
}

export fn silk_ltp_tap_index(channel: i32, subframe: i32, tap: i32, channels: i32, nb_subframes: i32) !usize {
    if channels < 1 || channels > (SILK_LTP_MAX_CHANNELS as i32) || nb_subframes < 1 || nb_subframes > (SILK_LTP_MAX_NB_SUBFR as i32) {
        return error.SilkLtpError;
    }
    if channel < 0 || channel >= channels || subframe < 0 || subframe >= nb_subframes || tap < 0 || tap >= (SILK_LTP_ORDER as i32) {
        return error.SilkLtpError;
    }

    return (channel as usize) * SILK_LTP_MAX_NB_SUBFR * SILK_LTP_ORDER
        + (subframe as usize) * SILK_LTP_ORDER
        + (tap as usize);
}

export fn silk_ltp_history_index(write_index: i32, pitch_lag: i32, tap: i32) !usize {
    if pitch_lag <= 0 || tap < 0 || tap >= (SILK_LTP_ORDER as i32) {
        return error.SilkLtpError;
    }
    const index: i32 = write_index - pitch_lag + (SILK_LTP_HISTORY_EXTRA_TAPS as i32) - tap;
    if index < 0 {
        return error.SilkLtpError;
    }
    return index as usize;
}

export fn silk_ltp_scale_history_q15(history_q15: &[i32], len: i32, gain_adj_q16: i32) !void {
    if len < 0 || history_q15.len < (len as usize) || gain_adj_q16 < 0 {
        return error.SilkLtpError;
    }

    var i: usize = 0;
    while i < (len as usize) {
        history_q15.ptr[i] = smulww_i32(gain_adj_q16, history_q15.ptr[i]);
        i = i + 1;
    }
}

export fn silk_ltp_synthesis_q14(out_q14: &[i32], history_q15: &[i32], excitation_q14: &[i32], coeff_q14: &[i16], write_index: i32, pitch_lag: i32, len: i32) !void {
    if write_index < 0 || len < 0 || pitch_lag <= 0 || out_q14.len < (len as usize) || excitation_q14.len < (len as usize) || coeff_q14.len < SILK_LTP_ORDER {
        return error.SilkLtpError;
    }
    if history_q15.len < ((write_index + len) as usize) {
        return error.SilkLtpError;
    }

    var i: usize = 0;
    while i < (len as usize) {
        const history_write_index: i32 = write_index + (i as i32);
        var pred_q13: i32 = 2;
        var tap: usize = 0;
        while tap < SILK_LTP_ORDER {
            const history_index: usize = try silk_ltp_history_index(history_write_index, pitch_lag, tap as i32);
            if history_index >= history_q15.len {
                return error.SilkLtpError;
            }
            pred_q13 = pred_q13 + smulwb_i32(history_q15.ptr[history_index], coeff_q14.ptr[tap]);
            tap = tap + 1;
        }

        const residual_q14: i32 = sat32((excitation_q14.ptr[i] as i64) + ((pred_q13 as i64) << 1));
        out_q14.ptr[i] = residual_q14;
        history_q15.ptr[history_write_index as usize] = sat32((residual_q14 as i64) << 1);
        i = i + 1;
    }
}

export fn silk_ltp_decode_coefficients_q14(dec: &EcDec, control: &SilkDecoderControl, channel: i32) !i32 {
    if control.signal_type != SILK_SIGNAL_TYPE_VOICED || channel < 0 || channel >= control.channels {
        return error.SilkLtpError;
    }

    var per_icdf: [byte: 3] = [0: 3];
    var per_i: usize = 0;
    while per_i < 3 {
        per_icdf[per_i] = SILK_LTP_PER_INDEX_ICDF[per_i];
        per_i = per_i + 1;
    }
    const periodicity_index: i32 = ec_dec_icdf(dec, &per_icdf[0:3], 8);
    if periodicity_index < 0 || periodicity_index >= (SILK_LTP_NB_CODEBOOKS as i32) {
        return error.SilkLtpError;
    }

    var gain_icdf: [byte: 32] = [0: 32];
    try fill_ltp_gain_icdf(&gain_icdf[0:32], periodicity_index);
    const cb_size: i32 = silk_ltp_codebook_size(periodicity_index);
    var subframe: i32 = 0;
    while subframe < control.nb_subframes {
        const codebook_index: i32 = ec_dec_icdf(dec, &gain_icdf[0:(cb_size as usize)], 8);
        if codebook_index < 0 || codebook_index >= cb_size {
            return error.SilkLtpError;
        }
        var tap: i32 = 0;
        while tap < (SILK_LTP_ORDER as i32) {
            const out_index: usize = try silk_decoder_control_ltp_index(control, channel, subframe, tap);
            control.ltp_coef_q14[out_index] = ((silk_ltp_vq_q7(periodicity_index, codebook_index, tap) as i32) << 7) as i16;
            tap = tap + 1;
        }
        subframe = subframe + 1;
    }

    return periodicity_index;
}
