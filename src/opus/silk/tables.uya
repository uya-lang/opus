export fn silk_shell_code_table_value(table: i32, index: usize) byte {
    if index >= 152 {
        return 0;
    }
    if table == 0 { return SILK_SHELL_CODE_TABLE0[index]; }
    if table == 1 { return SILK_SHELL_CODE_TABLE1[index]; }
    if table == 2 { return SILK_SHELL_CODE_TABLE2[index]; }
    if table == 3 { return SILK_SHELL_CODE_TABLE3[index]; }
    return 0;
}

export fn silk_shell_code_table_offset(pulses: i32) usize {
    if pulses < 0 || pulses > 16 {
        return 0 as usize;
    }
    const index: usize = pulses as usize;
    if index >= 17 {
        return 0 as usize;
    }
    return SILK_SHELL_CODE_TABLE_OFFSETS[index];
}

export fn silk_table_len(table: i32) usize {
    if table == 0 { return 16; }
    if table == 1 { return 25; }
    if table == 2 { return 32; }
    if table == 3 { return 21; }
    if table == 4 { return 34; }
    if table == 5 { return 15; }
    if table == 6 { return 10; }
    if table == 7 { return 152; }
    if table == 8 { return 152; }
    if table == 9 { return 152; }
    if table == 10 { return 152; }
    if table == 11 { return 17; }
    if table == 12 { return 42; }
    if table == 13 { return 129; }
    if table == 14 { return 3; }
    if table == 15 { return 7; }
    if table == 16 { return 4; }
    if table == 17 { return 2; }
    if table == 18 { return 24; }
    if table == 19 { return 41; }
    if table == 20 { return 5; }
    if table == 21 { return 7; }
    if table == 22 { return 11; }
    if table == 23 { return 12; }
    if table == 24 { return 3; }
    return 0 as usize;
}
