fn silk_shell_hash_value(table: i32, index: usize) u64 {
    if table == 0 { return SILK_SHELL_CODE_TABLE0[index] as u64; }
    if table == 1 { return SILK_SHELL_CODE_TABLE1[index] as u64; }
    if table == 2 { return SILK_SHELL_CODE_TABLE2[index] as u64; }
    if table == 3 { return SILK_SHELL_CODE_TABLE3[index] as u64; }
    if table == 4 { return SILK_SHELL_CODE_TABLE_OFFSETS[index] as u64; }
    return 0;
}

fn silk_lsf_cos_hash_value(index: usize) u64 {
    return SILK_LSF_COS_TAB_Q12[index] as u64;
}

fn hash_shell_table(table: i32, len: usize) u32 {
    const mod: u64 = 1000000007;
    var h: u64 = (2166136261 as u64) % mod;
    var i: usize = 0;
    while i < len {
        h = (h * (131 as u64) + silk_shell_hash_value(table, i) + (1 as u64)) % mod;
        i = i + 1;
    }
    return h as u32;
}

export fn silk_shell_table_hash(table: i32) u32 {
    if table == 0 { return hash_shell_table(0, 152); }
    if table == 1 { return hash_shell_table(1, 152); }
    if table == 2 { return hash_shell_table(2, 152); }
    if table == 3 { return hash_shell_table(3, 152); }
    if table == 4 { return hash_shell_table(4, 17); }
    return 0;
}

export fn silk_sign_icdf_hash() u32 {
    const mod: u64 = 1000000007;
    var h: u64 = (2166136261 as u64) % mod;
    var i: usize = 0;
    while i < 42 {
        h = (h * (131 as u64) + (SILK_SIGN_ICDF[i] as u64) + (1 as u64)) % mod;
        i = i + 1;
    }
    return h as u32;
}

export fn silk_lsf_cos_table_hash() u32 {
    const mod: u64 = 1000000007;
    var h: u64 = (2166136261 as u64) % mod;
    var i: usize = 0;
    while i < 129 {
        h = (h * (131 as u64) + silk_lsf_cos_hash_value(i) + (32768 as u64) + (1 as u64)) % mod;
        i = i + 1;
    }
    return h as u32;
}

export fn silk_lsf_cos_q12(index: usize) i16 {
    if index >= 129 {
        return 0;
    }
    return SILK_LSF_COS_TAB_Q12[index];
}

export fn silk_sign_icdf_value(index: usize) byte {
    if index >= 42 {
        return 0;
    }
    return SILK_SIGN_ICDF[index];
}

