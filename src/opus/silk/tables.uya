export fn silk_pitch_contour_offset(fs_khz: i32, nb_subframes: i32, subframe: i32, contour_index: i32) i16 {
    if subframe < 0 || contour_index < 0 {
        return 0;
    }
    if fs_khz == 8 && nb_subframes == 4 && subframe < 4 && contour_index < 11 {
        return SILK_PITCH_CONTOUR_NB_OFFSETS[(subframe as usize) * 11 + (contour_index as usize)];
    }
    if fs_khz == 8 && nb_subframes == 2 && subframe < 2 && contour_index < 3 {
        return SILK_PITCH_CONTOUR_10_MS_NB_OFFSETS[(subframe as usize) * 3 + (contour_index as usize)];
    }
    if nb_subframes == 4 && subframe < 4 && contour_index < 34 {
        return SILK_PITCH_CONTOUR_OFFSETS[(subframe as usize) * 34 + (contour_index as usize)];
    }
    if nb_subframes == 2 && subframe < 2 && contour_index < 12 {
        return SILK_PITCH_CONTOUR_10_MS_OFFSETS[(subframe as usize) * 12 + (contour_index as usize)];
    }
    return 0;
}

