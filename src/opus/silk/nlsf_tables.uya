fn nlsf_table_hash_value(table: i32, index: usize) u64 {
    if table == 0 { return SILK_NLSF_CB1_NB_MB_Q8[index] as u64; }
    if table == 1 { return SILK_NLSF_CB1_NB_MB_WGHT_Q9[index] as u64; }
    if table == 2 { return SILK_NLSF_CB1_ICDF_NB_MB[index] as u64; }
    if table == 3 { return SILK_NLSF_CB2_SELECT_NB_MB[index] as u64; }
    if table == 4 { return SILK_NLSF_CB2_ICDF_NB_MB[index] as u64; }
    if table == 5 { return SILK_NLSF_PRED_NB_MB_Q8[index] as u64; }
    if table == 6 { return SILK_NLSF_DELTA_MIN_NB_MB_Q15[index] as u64; }
    if table == 7 { return SILK_NLSF_CB1_WB_Q8[index] as u64; }
    if table == 8 { return SILK_NLSF_CB1_WB_WGHT_Q9[index] as u64; }
    if table == 9 { return SILK_NLSF_CB1_ICDF_WB[index] as u64; }
    if table == 10 { return SILK_NLSF_CB2_SELECT_WB[index] as u64; }
    if table == 11 { return SILK_NLSF_CB2_ICDF_WB[index] as u64; }
    if table == 12 { return SILK_NLSF_PRED_WB_Q8[index] as u64; }
    if table == 13 { return SILK_NLSF_DELTA_MIN_WB_Q15[index] as u64; }
    return 0;
}

fn nlsf_table_hash_offset(table: i32) u64 {
    if table == 1 { return 32768 as u64; }
    if table == 6 { return 32768 as u64; }
    if table == 8 { return 32768 as u64; }
    if table == 13 { return 32768 as u64; }
    return 0;
}

export fn silk_nlsf_table_len(table: i32) usize {
    if table == 0 { return 320; }
    if table == 1 { return 320; }
    if table == 2 { return 64; }
    if table == 3 { return 160; }
    if table == 4 { return 72; }
    if table == 5 { return 18; }
    if table == 6 { return 11; }
    if table == 7 { return 512; }
    if table == 8 { return 512; }
    if table == 9 { return 64; }
    if table == 10 { return 256; }
    if table == 11 { return 72; }
    if table == 12 { return 30; }
    if table == 13 { return 17; }
    return 0 as usize;
}

export fn silk_nlsf_table_hash(table: i32) u32 {
    const len: usize = silk_nlsf_table_len(table);
    if len == 0 { return 0; }
    const mod: u64 = 1000000007;
    const offset: u64 = nlsf_table_hash_offset(table);
    var h: u64 = (2166136261 as u64) % mod;
    var i: usize = 0;
    while i < len {
        h = (h * (131 as u64) + nlsf_table_hash_value(table, i) + offset + (1 as u64)) % mod;
        i = i + 1;
    }
    return h as u32;
}

export fn silk_nlsf_codebook_order(codebook: i32) i32 {
    if codebook == SILK_NLSF_CODEBOOK_NB_MB { return 10; }
    if codebook == SILK_NLSF_CODEBOOK_WB { return 16; }
    return 0;
}

export fn silk_nlsf_codebook_quant_step_q16(codebook: i32) i32 {
    if codebook == SILK_NLSF_CODEBOOK_NB_MB { return 11796; }
    if codebook == SILK_NLSF_CODEBOOK_WB { return 9830; }
    return 0;
}

export fn silk_nlsf_cb1_nlsf_q8(codebook: i32, index: usize) byte {
    if codebook == SILK_NLSF_CODEBOOK_NB_MB && index < 320 { return SILK_NLSF_CB1_NB_MB_Q8[index]; }
    if codebook == SILK_NLSF_CODEBOOK_WB && index < 512 { return SILK_NLSF_CB1_WB_Q8[index]; }
    return 0;
}

